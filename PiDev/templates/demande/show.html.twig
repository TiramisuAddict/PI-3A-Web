{% extends 'base.html.twig' %}

{% block title %}Demande #{{ demande.id }}{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <div class="page-pretitle">Demande #{{ demande.id }}</div>
        <h2 class="page-title">{{ demande.titre }}</h2>
    </div>
    <div class="col-auto">
        <div class="btn-list">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#statusModal">
                <i class="ti ti-refresh me-1"></i>Changer statut
            </button>
            <a href="{{ path('demande_edit', {id: demande.id}) }}" class="btn btn-warning">
                <i class="ti ti-edit me-1"></i>Modifier
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="app-hero p-4 mb-4 position-relative">
            <div class="row">
                <div class="col">
                    <h3 class="mb-3">{{ demande.titre }}</h3>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="soft-pill">
                            <i class="ti ti-folder"></i>{{ demande.categorie }}
                        </span>
                        <span class="soft-pill">
                            <i class="ti ti-tag"></i>{{ demande.typeDemande }}
                        </span>
                        {% if demande.priorite == 'HAUTE' %}
                            <span class="badge bg-red">{{ demande.priorite }}</span>
                        {% elseif demande.priorite == 'NORMALE' %}
                            <span class="badge bg-blue">{{ demande.priorite }}</span>
                        {% else %}
                            <span class="badge bg-green">{{ demande.priorite }}</span>
                        {% endif %}
                        {% if demande.status == 'Nouvelle' %}
                            <span class="badge bg-blue">{{ demande.status }}</span>
                        {% elseif demande.status == 'En cours' %}
                            <span class="badge bg-yellow">{{ demande.status }}</span>
                        {% elseif demande.status == 'En attente' %}
                            <span class="badge bg-orange">{{ demande.status }}</span>
                        {% elseif demande.status == 'Résolue' %}
                            <span class="badge bg-green">{{ demande.status }}</span>
                        {% elseif demande.status == 'Annulée' %}
                            <span class="badge bg-red">{{ demande.status }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ demande.status }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="col-auto text-end">
                    <div class="mini-muted">Créée le</div>
                    <div class="fw-bold">{{ demande.dateCreation|date('d/m/Y à H:i') }}</div>
                </div>
            </div>
        </div>

        <div class="surface-card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-info-circle me-2"></i>Description
                </h3>
            </div>
            <div class="card-body">
                {% if demande.description %}
                    <p class="mb-0">{{ demande.description|nl2br }}</p>
                {% else %}
                    <p class="text-muted mb-0">
                        <i class="ti ti-info-circle me-1"></i>Aucune description fournie
                    </p>
                {% endif %}
            </div>
        </div>

        {% if demande.details and demande.details.details|length > 0 %}
        <div class="surface-card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-forms me-2"></i>Détails spécifiques
                </h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for key, value in demande.details.details %}
                        {% if not key ends with 'Lat' and not key ends with 'Lon' and value %}
                        <div class="col-md-6">
                            <div class="stat-card p-3">
                                <div class="mini-muted mb-1">{{ fieldLabels[key] | default(key) }}</div>
                                <div class="fw-semibold">{{ value }}</div>
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-lg-4">
        <div class="surface-card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-history me-2"></i>Historique
                </h3>
            </div>
            <div class="card-body">
                {% if demande.historiques|length > 0 %}
                    <ul class="timeline">
                        {% for historique in demande.historiques %}
                        <li class="timeline-event">
                            <div class="timeline-event-icon bg-primary-lt">
                                <i class="ti ti-refresh"></i>
                            </div>
                            <div class="card timeline-event-card">
                                <div class="card-body p-3">
                                    <div class="mini-muted mb-1">{{ historique.dateAction|date('d/m/Y H:i') }}</div>
                                    <div class="mb-2">
                                        {% if historique.ancienStatut %}
                                            <span class="badge bg-secondary">{{ historique.ancienStatut }}</span>
                                            <i class="ti ti-arrow-right mx-1"></i>
                                        {% endif %}
                                        <span class="badge bg-primary">{{ historique.nouveauStatut }}</span>
                                    </div>
                                    <div class="mini-muted">
                                        <i class="ti ti-user me-1"></i>{{ historique.acteur }}
                                    </div>
                                    {% if historique.commentaire %}
                                        <div class="mt-2 small">{{ historique.commentaire }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted mb-0">
                        <i class="ti ti-info-circle me-1"></i>Aucun historique
                    </p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="modal modal-blur fade" id="statusModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="ti ti-refresh me-2"></i>Changer le statut
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Nouveau statut</label>
                    <select class="form-select" id="newStatus">
                        {% for status in statuses %}
                            <option value="{{ status }}" {{ status == demande.status ? 'selected' : '' }}>{{ status }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Commentaire</label>
                    <textarea class="form-control" id="statusComment" rows="3" placeholder="Commentaire (optionnel)"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="saveStatus">
                    <i class="ti ti-check me-1"></i>Enregistrer
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.getElementById('saveStatus').addEventListener('click', async function() {
    const newStatus = document.getElementById('newStatus').value;
    const comment = document.getElementById('statusComment').value;
    
    try {
        const response = await fetch('/demande/api/{{ demande.id }}/status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus, commentaire: comment })
        });
        const result = await response.json();
        
        if (result.success) {
            window.location.reload();
        } else {
            alert('Erreur: ' + result.message);
        }
    } catch (error) {
        alert('Erreur de connexion');
    }
});
</script>
{% endblock %}