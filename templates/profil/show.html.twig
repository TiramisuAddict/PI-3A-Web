{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
  {{ include('components/navbar.html.twig')}}
  <div class="d-flex overflow-hidden" style="height:calc(100vh - 56px);">
    {{ include('components/sidebar.html.twig',{'sidebar_role': role}) }}

  <div class="flex-fill overflow-y-auto p-4" style="min-width:0;">
    

    <div class="flex-fill overflow-y-auto p-4" style="min-width:0;">
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <h1 class="mb-1">Mon profil</h1>
          <div class="text-muted">Consultez vos informations personnelles et professionnelles</div>
        </div>
      </div>

      {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
          <div class="alert-description">{{ message }}</div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}
      {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
          <div class="alert-description">{{ message }}</div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}

      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card shadow-sm h-100">
            <div class="card-body text-center p-4">
              <div class="position-relative d-inline-block mb-3 avatar-container" style="cursor: pointer;">
                {% if profile_type == 'employee' and employe.getImage_profil() %}
                  <img src="{{ employe.getImage_profil() }}" alt="Avatar" class="avatar avatar-xl text-white fw-bold" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;">
                {% else %}
                  <div class="avatar avatar-xl text-white fw-bold" style="background:#4254D6; font-size:1.3rem;">
                    {% if profile_type == 'employee' %}
                      {{ employe.getPrenom()|first }}{{ employe.getNom()|first }}
                    {% else %}
                      AD
                    {% endif %}
                  </div>
                {% endif %}
                <div class="avatar-overlay d-flex align-items-center justify-content-center" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); border-radius: 50%; opacity: 0; transition: opacity 0.3s ease; display: none;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                </div>
                <input type="file" id="avatarInput" accept="image/*" style="display: none;" />
              </div>
              <h3 class="mb-1">
                {% if profile_type == 'employee' %}
                  {{ employe.getPrenom() }} {{ employe.getNom() }}
                {% else %}
                  Administrateur système
                {% endif %}
              </h3>
              <div class="text-muted mb-3">{{ role }}</div>
              <div class="badge bg-blue-lt text-blue">{{ email }}</div>
            </div>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-header">
              <h3 class="card-title mb-0">Informations du compte</h3>
            </div>
            <div class="card-body">
              {% if profile_type == 'employee' %}
                {{ form_start(profile_form, {'attr': {'class': 'row g-3', 'novalidate': 'novalidate'}}) }}
                  {{ include('components/controleSaisieAlert.html.twig', {'form': profile_form}) }}
                  <div class="col-md-6">
                    <div class="text-muted small mb-1">Nom</div>
                    {{ form_widget(profile_form.nom, {'attr': {'class': 'form-control'}}) }}
                  </div>
                  <div class="col-md-6">
                    <div class="text-muted small mb-1">Prénom</div>
                    {{ form_widget(profile_form.prenom, {'attr': {'class': 'form-control'}}) }}
                  </div>
                  <div class="col-md-6">
                    <div class="text-muted small mb-1">Email</div>
                    {{ form_widget(profile_form.e_mail, {'attr': {'class': 'form-control'}}) }}
                  </div>
                  <div class="col-md-6">
                    <div class="text-muted small mb-1">Téléphone</div>
                    {{ form_widget(profile_form.telephone, {'attr': {'class': 'form-control'}}) }}
                  </div>
                  <div class="col-md-6"><div class="text-muted small mb-1">Poste</div><div class="form-control bg-light">{{ employe.getPoste() }}</div></div>
                  <div class="col-md-6"><div class="text-muted small mb-1">Rôle</div><div class="form-control bg-light">{{ employe.getRole() }}</div></div>
                  <div class="col-md-6"><div class="text-muted small mb-1">Date d'embauche</div><div class="form-control bg-light">{{ employe.getDateEmbauche() ? employe.getDateEmbauche()|date('d/m/Y') : 'Non renseignée' }}</div></div>
                  <div class="col-md-6">
                    <div class="text-muted small mb-1">CV (PDF)</div>
                    {{ form_widget(profile_form.cv_data, {'attr': {'class': 'form-control', 'accept': '.pdf,application/pdf'}}) }}
                    <div class="form-text">
                      {% if employe.getCv_nom() %}
                        CV actuel: {{ employe.getCv_nom() }}
                      {% else %}
                        Aucun CV importe.
                      {% endif %}
                    </div>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn text-white" style="background:#4254D6;">Enregistrer les modifications</button>
                  </div>
                {{ form_end(profile_form) }}
              {% else %}
                <div class="row g-3">
                  <div class="col-md-6"><div class="text-muted small mb-1">Email</div><div class="form-control bg-light">{{ email }}</div></div>
                  <div class="col-md-6"><div class="text-muted small mb-1">Type de compte</div><div class="form-control bg-light">Administrateur système</div></div>
                </div>
              {% endif %}
            </div>
          </div>

          {% if profile_type == 'employee' %}
            <div class="card shadow-sm mb-4">
              <div class="card-header">
                <h3 class="card-title mb-0">Compétences</h3>
              </div>
              <div class="card-body">
                <form method="post" action="{{ path('profil_competence_add') }}" class="d-flex gap-2 mb-3" novalidate>
                  <input type="hidden" name="_token" value="{{ csrf_token('profil_competence_add') }}">
                  <input type="text" name="skill" class="form-control" placeholder="Ajouter une compétence (ex: Symfony)">
                  <button type="submit" class="btn btn-primary">Ajouter</button>
                </form>

                <div class="d-flex flex-wrap gap-2">
                  {% if skills|default([])|length > 0 %}
                    {% for skill in skills %}
                      <form method="post" action="{{ path('profil_competence_remove') }}" class="d-inline-flex" novalidate>
                        <input type="hidden" name="_token" value="{{ csrf_token('profil_competence_remove') }}">
                        <input type="hidden" name="skill" value="{{ skill }}">
                        <button type="submit" class="badge bg-blue-lt text-blue border-0 px-3 py-2" title="Supprimer {{ skill }}">
                          {{ skill }}
                          <span class="ms-1">x</span>
                        </button>
                      </form>
                    {% endfor %}
                  {% else %}
                    <div class="text-muted">Aucune compétence enregistrée.</div>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="card shadow-sm mb-4">
              <div class="card-header d-flex align-items-center justify-content-between">
                <h3 class="card-title mb-0">Identification Face ID</h3>
                {% set face_enabled = employe.getFaceEmbedding() is not null and employe.getFaceConsent() %}
                <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
                  <input class="form-check-input ms-0" type="checkbox" role="switch" id="faceToggleSwitch" {% if face_enabled %}checked{% endif %}>
                  <label class="form-check-label fw-semibold mb-0" for="faceToggleSwitch" id="faceToggleLabel">
                    {% if face_enabled %}
                      Activé
                    {% else %}
                      Désactivé
                    {% endif %}
                  </label>
                </div>
              </div>
              <div class="card-body">
                <p class="text-muted mb-3">
                  Activez Face ID pour enregistrer votre empreinte faciale. Ces données seront utilisées lors de la connexion via Face ID.
                </p>
                {% if employe.getFaceRegisteredAt() %}
                  <div class="small text-muted mb-3">
                    Dernier enregistrement: {{ employe.getFaceRegisteredAt()|date('d/m/Y H:i') }}
                  </div>
                {% endif %}
                <div id="faceEnrollResult" class="mt-3"></div>
              </div>
            </div>
          {% endif %}

          
        </div>
      </div>
    </div>
  </div>
  </div>

  <style>
    .avatar-container:hover .avatar-overlay {
      opacity: 1 !important;
      display: flex !important;
    }

    #faceEnrollVideo {
      width: 100%;
      max-height: 320px;
      border-radius: 12px;
      background: #111;
    }
  </style>

  <div class="modal fade" id="faceEnrollModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Activer Face ID</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Regardez la caméra et bougez légèrement la tête pour la détection de vivacité.</p>
          <video id="faceEnrollVideo" autoplay playsinline muted></video>
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" id="faceConsentCheckbox">
            <label class="form-check-label" for="faceConsentCheckbox">
              J'accepte l'utilisation de mon empreinte faciale pour l'authentification.
            </label>
          </div>
          <div id="faceEnrollStatus" class="small text-muted mt-2">Initialisation...</div>
          <div id="faceEnrollModalResult" class="mt-2"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
          <button type="button" class="btn btn-primary" id="saveFaceIdBtn" disabled>Enregistrer</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const avatarContainer = document.querySelector('.avatar-container');
      const avatarInput = document.getElementById('avatarInput');
      const avatarOverlay = document.querySelector('.avatar-overlay');
      const faceToggleSwitch = document.getElementById('faceToggleSwitch');
      const faceToggleLabel = document.getElementById('faceToggleLabel');
      const faceEnrollModalEl = document.getElementById('faceEnrollModal');
      const faceEnrollVideo = document.getElementById('faceEnrollVideo');
      const faceEnrollStatus = document.getElementById('faceEnrollStatus');
      const faceEnrollResult = document.getElementById('faceEnrollResult');
      const faceEnrollModalResult = document.getElementById('faceEnrollModalResult');
      const faceConsentCheckbox = document.getElementById('faceConsentCheckbox');
      const saveFaceIdBtn = document.getElementById('saveFaceIdBtn');

      let faceStream = null;
      let faceDescriptor = null;
      let faceIsLive = false;
      let faceBaseX = null;
      let faceTimer = null;
      let faceModal = null;
      let faceEnrollmentSuccess = false;
      const faceDeactivateUrl = '{{ path('face_deactivate') }}';

      if (avatarContainer && avatarInput) {
        avatarContainer.addEventListener('click', function() {
          avatarInput.click();
        });

        avatarInput.addEventListener('change', function(e) {
          const file = e.target.files[0];
          if (file) {
            const formData = new FormData();
            formData.append('image', file);

            fetch('{{ path("profil_upload_image") }}', {
              method: 'POST',
              body: formData,
              headers: {
                'X-Requested-With': 'XMLHttpRequest'
              }
            })
            .then(response => response.json())
            .then(data => {
              if (data.success) {
                // Rechargs la page pour voir la nouvelle image
                location.reload();
              } else {
                alert('Erreur: ' + (data.error || 'Impossible d\'uploader l\'image'));
              }
            })
            .catch(error => {
              console.error('Erreur:', error);
              alert('Une erreur est survenue lors de l\'upload');
            });
          }
        });
      }

      function setFaceEnrollResult(message, success) {
        const alertHtml = `<div class="alert ${success ? 'alert-success' : 'alert-danger'} mb-0" role="alert">${message}</div>`;

        if (faceEnrollResult) {
          faceEnrollResult.innerHTML = alertHtml;
        }

        if (faceEnrollModalResult) {
          faceEnrollModalResult.innerHTML = alertHtml;
        }
      }

      function setFaceToggleState(checked) {
        if (!faceToggleSwitch) {
          return;
        }

        faceToggleSwitch.checked = checked;
        if (faceToggleLabel) {
          faceToggleLabel.textContent = checked ? 'Face ID activé' : 'Face ID désactivé';
        }
      }

      async function parseJsonSafe(response) {
        const text = await response.text();

        if (!text) {
          return {};
        }

        try {
          return JSON.parse(text);
        } catch (e) {
          return {
            success: false,
            message: `Reponse serveur non JSON (HTTP ${response.status}).`
          };
        }
      }

      async function loadFaceApiModels() {
        if (window.faceapi) {
          return;
        }

        await new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js';
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }

      async function startFaceEnrollment() {
        await loadFaceApiModels();

        await Promise.all([
          faceapi.nets.tinyFaceDetector.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models'),
          faceapi.nets.faceLandmark68Net.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models'),
          faceapi.nets.faceRecognitionNet.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models')
        ]);

        faceStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
        faceEnrollVideo.srcObject = faceStream;
        faceEnrollStatus.textContent = 'Regardez la caméra et bougez légèrement la tête.';

        faceDescriptor = null;
        faceIsLive = false;
        faceBaseX = null;
        saveFaceIdBtn.disabled = true;

        faceTimer = window.setInterval(async () => {
          if (!faceEnrollVideo || faceEnrollVideo.readyState < 2) {
            return;
          }

          const detection = await faceapi
            .detectSingleFace(faceEnrollVideo, new faceapi.TinyFaceDetectorOptions())
            .withFaceLandmarks()
            .withFaceDescriptor();

          if (!detection) {
            faceEnrollStatus.textContent = 'Aucun visage détecté...';
            saveFaceIdBtn.disabled = true;
            return;
          }

          faceDescriptor = Array.from(detection.descriptor);
          const currentX = detection.detection.box.x;
          if (faceBaseX === null) {
            faceBaseX = currentX;
          }

          if (Math.abs(currentX - faceBaseX) > 12) {
            faceIsLive = true;
          }

          saveFaceIdBtn.disabled = !(faceDescriptor && faceConsentCheckbox.checked);
          faceEnrollStatus.textContent = faceIsLive
            ? 'Vivacité validée. Vous pouvez enregistrer.'
            : 'Bougez légèrement la tête (gauche/droite) pour valider la vivacité.';
        }, 700);
      }

      function stopFaceEnrollment() {
        if (faceTimer) {
          window.clearInterval(faceTimer);
          faceTimer = null;
        }

        if (faceStream) {
          faceStream.getTracks().forEach(track => track.stop());
          faceStream = null;
        }

        if (faceEnrollVideo) {
          faceEnrollVideo.srcObject = null;
        }
      }

      if (faceToggleSwitch && faceEnrollModalEl && window.bootstrap) {
        faceModal = new window.bootstrap.Modal(faceEnrollModalEl);

        faceToggleSwitch.addEventListener('change', async function() {
          if (faceToggleSwitch.checked) {
            faceEnrollmentSuccess = false;
            if (faceEnrollResult) {
              faceEnrollResult.innerHTML = '';
            }
            if (faceEnrollModalResult) {
              faceEnrollModalResult.innerHTML = '';
            }
            faceConsentCheckbox.checked = false;
            faceModal.show();

            try {
              await startFaceEnrollment();
            } catch (e) {
              faceEnrollmentSuccess = false;
              setFaceToggleState(false);
              faceEnrollStatus.textContent = 'Impossible de démarrer la caméra.';
              setFaceEnrollResult(e.message || 'Erreur de chargement Face ID.', false);
            }
            return;
          }

          try {
            const response = await fetch(faceDeactivateUrl, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            const data = await parseJsonSafe(response);

            if (!response.ok) {
              setFaceEnrollResult(data.message || `Echec serveur (HTTP ${response.status}).`, false);
              setFaceToggleState(true);
              return;
            }

            setFaceEnrollResult(data.message || 'Face ID desactive.', true);
            faceEnrollmentSuccess = true;
            window.setTimeout(function() {
              window.location.reload();
            }, 900);
          } catch (error) {
            setFaceEnrollResult(`Erreur reseau pendant la désactivation Face ID: ${error.message || 'inconnue'}.`, false);
            setFaceToggleState(true);
          }
        });

        faceEnrollModalEl.addEventListener('hidden.bs.modal', function() {
          if (!faceEnrollmentSuccess) {
            setFaceToggleState(false);
          }
          stopFaceEnrollment();
        });

        faceConsentCheckbox.addEventListener('change', function() {
          saveFaceIdBtn.disabled = !(faceDescriptor && faceConsentCheckbox.checked);
        });

        saveFaceIdBtn.addEventListener('click', async function() {
          if (!faceDescriptor) {
            setFaceEnrollResult('Empreinte faciale indisponible.', false);
            return;
          }

          if (!faceConsentCheckbox.checked) {
            setFaceEnrollResult('Vous devez accepter le consentement.', false);
            return;
          }

          if (!faceIsLive) {
            setFaceEnrollResult('Vivacite non validee. Bougez legerement la tete puis reessayez.', false);
            return;
          }

          try {
            const response = await fetch('{{ path('face_register') }}', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              },
              body: JSON.stringify({
                embedding: faceDescriptor,
                consent: true,
                isLive: faceIsLive
              })
            });

            const data = await parseJsonSafe(response);

            if (!response.ok) {
              const defaultMessage = `Echec serveur (HTTP ${response.status}).`;
              setFaceEnrollResult(data.message || defaultMessage, false);
              return;
            }

            if (data.success) {
              setFaceEnrollResult('Face ID activé avec succès.', true);
              faceEnrollStatus.textContent = 'Enregistrement termine avec succes.';
              faceEnrollmentSuccess = true;
              saveFaceIdBtn.disabled = true;
              window.setTimeout(function() {
                faceModal.hide();
                window.location.reload();
              }, 1200);
              return;
            }

            setFaceEnrollResult(data.message || 'Erreur lors de l\'enregistrement Face ID.', false);
          } catch (error) {
            setFaceEnrollResult(`Erreur reseau pendant l'enregistrement Face ID: ${error.message || 'inconnue'}.`, false);
          }
        });
      }

      if (deactivateFaceIdBtn) {
        deactivateFaceIdBtn.addEventListener('click', async function() {
          deactivateFaceIdBtn.disabled = true;

          try {
            const response = await fetch(faceDeactivateUrl, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
              }
            });

            const data = await parseJsonSafe(response);

            if (!response.ok) {
              setFaceEnrollResult(data.message || `Echec serveur (HTTP ${response.status}).`, false);
              deactivateFaceIdBtn.disabled = false;
              return;
            }

            setFaceEnrollResult(data.message || 'Face ID desactive.', true);
            window.setTimeout(function() {
              window.location.reload();
            }, 900);
          } catch (error) {
            setFaceEnrollResult(`Erreur reseau pendant la désactivation Face ID: ${error.message || 'inconnue'}.`, false);
            deactivateFaceIdBtn.disabled = false;
          }
        });
      }
    });
  </script>
{% endblock %}
