{{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

{{ form_errors(form) }}

<div class="row g-3">
	<div class="col-12 col-md-6">
		<label class="form-label" for="{{ form.cv_data.vars.id }}">{{ form.cv_data.vars.label }}</label>
		<div class="dropzone dz-clickable">
			<div class="dz-message">
				<h3 class="dropzone-msg-title mb-1">Déposez votre CV ici</h3>
				<span class="dropzone-msg-desc text-secondary">PDF uniquement, taille max 8 MB</span>
			</div>
			<div class="fallback mt-2">
				{{ form_widget(form.cv_data, { attr: { class: 'form-control', accept: 'application/pdf,.pdf' } }) }}
			</div>
		</div>
		{{ form_errors(form.cv_data) }}
	</div>

	<div class="col-12 col-md-6">
		<label class="form-label" for="{{ form.lettre_motivation_data.vars.id }}">{{ form.lettre_motivation_data.vars.label }}</label>
		<div class="dropzone dz-clickable">
			<div class="dz-message">
				<h3 class="dropzone-msg-title mb-1">Déposez votre lettre ici</h3>
				<span class="dropzone-msg-desc text-secondary">PDF uniquement, taille max 8 MB</span>
			</div>
			<div class="fallback mt-2">
				{{ form_widget(form.lettre_motivation_data, { attr: { class: 'form-control', accept: 'application/pdf,.pdf' } }) }}
			</div>
		</div>
		{{ form_errors(form.lettre_motivation_data) }}
	</div>
</div>

<div class="mt-3 d-grid">
	{{ form_widget(form.Submit, { attr: { class: 'btn btn-primary' } }) }}
</div>

{{ form_rest(form) }}
{{ form_end(form, { render_rest: false }) }}