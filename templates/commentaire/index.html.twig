{% extends 'base.html.twig' %}

{% block title %}
    {% if current_post %}
        Commentaires - {{ current_post.titre|length > 50 ? current_post.titre|slice(0, 50) ~ '...' : current_post.titre }}
    {% else %}
        Commentaires - Momentum
    {% endif %}
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center g-3">
                <div class="col">
                    <h2 class="page-title">Commentaires</h2>
                    {% if current_post %}
                        <div class="text-secondary mt-1">
                            {{ current_post.typePost == 2 ? 'Evenement' : 'Publication' }} :
                            <span class="fw-semibold text-body">{{ current_post.titre }}</span>
                        </div>
                    {% else %}
                        <div class="text-secondary mt-1">Tous les commentaires enregistres.</div>
                    {% endif %}
                </div>
                <div class="col-auto">
                    {% if current_post %}
                        <a class="btn btn-primary" href="{{ path('app_post_show', { id_post: current_post.idPost }) }}">
                            <i class="ti ti-arrow-left me-1"></i>Retour a la publication
                        </a>
                    {% else %}
                        <a class="btn btn-primary" href="{{ path('app_post_index') }}">
                            <i class="ti ti-arrow-left me-1"></i>Retour aux publications
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            {% if current_post %}
                <div class="card mb-3">
                    <div class="card-body py-3">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <span class="badge {{ current_post.typePost == 2 ? 'bg-yellow-lt text-yellow' : 'bg-azure-lt text-azure' }}">
                                {{ current_post.typePost == 2 ? 'Evenement' : 'Annonce' }}
                            </span>
                            <span class="text-secondary small">{{ commentaires.getTotalItemCount }} commentaire{{ commentaires.getTotalItemCount > 1 ? 's' : '' }}</span>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="card">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th>Contenu</th>
                                <th>Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for commentaire in commentaires %}
                            <tr>
                                <td>
                                    <div class="fw-medium">{{ commentaire.contenu|length > 95 ? commentaire.contenu|slice(0, 95) ~ '...' : commentaire.contenu }}</div>
                                </td>
                                <td class="text-secondary small">{{ commentaire.dateCommentaire ? commentaire.dateCommentaire|date('d/m/Y H:i') : '-' }}</td>
                                <td class="text-end text-nowrap">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <form class="d-inline" method="post" action="{{ path('app_commentaire_delete', { id_commentaire: commentaire.idCommentaire, id_post: current_post ? current_post.idPost : null, page: commentaires.getCurrentPageNumber }) }}" onsubmit="return confirm('Supprimer ce commentaire ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.idCommentaire) }}">
                                            <button type="submit" class="btn btn-icon btn-ghost-danger" title="Supprimer">
                                                <i class="ti ti-trash" style="font-size: 1.25rem;"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <div class="text-secondary small">
                                        {% if current_post %}
                                            Aucun commentaire pour cette publication.
                                        {% else %}
                                            Aucun commentaire trouve.
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if commentaires.getTotalItemCount > 0 %}
                    {% set page_start = ((commentaires.getCurrentPageNumber - 1) * commentaires.getItemNumberPerPage) + 1 %}
                    {% set page_end_candidate = commentaires.getCurrentPageNumber * commentaires.getItemNumberPerPage %}
                    {% set page_end = page_end_candidate < commentaires.getTotalItemCount ? page_end_candidate : commentaires.getTotalItemCount %}
                    <div class="card-footer d-flex flex-column flex-md-row align-items-md-center gap-3">
                        <div class="text-secondary small">
                            Affichage de {{ page_start }} a {{ page_end }} sur {{ commentaires.getTotalItemCount }} commentaire{{ commentaires.getTotalItemCount > 1 ? 's' : '' }}
                        </div>
                        <div class="ms-md-auto">
                            {{ knp_pagination_render(commentaires) }}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
