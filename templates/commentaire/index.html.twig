{% extends 'base.html.twig' %}

{% block title %}Commentaires{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Commentaires</h1>
        <a class="btn btn-primary" href="{{ path('app_commentaire_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>id_commentaire</th>
                    <th>contenu</th>
                    <th>date_commentaire</th>
                    <th>utilisateur_id</th>
                    <th>post</th>
                    <th class="text-nowrap">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for commentaire in commentaires %}
                <tr>
                    <td>{{ commentaire.id_commentaire }}</td>
                    <td>{{ commentaire.contenu|length > 60 ? commentaire.contenu|slice(0, 60) ~ '…' : commentaire.contenu }}</td>
                    <td>{{ commentaire.date_commentaire ? commentaire.date_commentaire|date('Y-m-d H:i') : '' }}</td>
                    <td>{{ commentaire.utilisateur_id }}</td>
                    <td>{% if commentaire.post %}#{{ commentaire.post.id_post }}{% endif %}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-primary" href="{{ path('app_commentaire_show', { id_commentaire: commentaire.id_commentaire }) }}"><i class="ti ti-eye"></i></a>
                        <a class="btn btn-sm btn-warning" href="{{ path('app_commentaire_edit', { id_commentaire: commentaire.id_commentaire }) }}"><i class="ti ti-edit"></i></a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
