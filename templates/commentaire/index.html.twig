{% extends 'base.html.twig' %}

{% block title %}Commentaires{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Commentaires</h1>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle table-vcenter">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Contenu</th>
                    <th>Date</th>
                    <th>Utilisateur</th>
                    <th>Post</th>
                    <th class="text-end text-nowrap" style="width: 1%;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for commentaire in commentaires %}
                <tr>
                    <td>{{ commentaire.idCommentaire }}</td>
                    <td>{{ commentaire.contenu|length > 60 ? commentaire.contenu|slice(0, 60) ~ '…' : commentaire.contenu }}</td>
                    <td>{{ commentaire.dateCommentaire ? commentaire.dateCommentaire|date('Y-m-d H:i') : '' }}</td>
                    <td>{{ commentaire.utilisateurId }}</td>
                    <td>{% if commentaire.post %}#{{ commentaire.post.idPost }}{% endif %}</td>
                    <td class="text-end text-nowrap">
                        <form class="d-inline" method="post" action="{{ path('app_commentaire_delete', { id_commentaire: commentaire.idCommentaire }) }}" onsubmit="return confirm('Supprimer ce commentaire ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.idCommentaire) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Supprimer"><i class="ti ti-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
