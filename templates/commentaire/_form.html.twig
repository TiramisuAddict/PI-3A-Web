{{ form_start(form, { attr: { class: 'form-group', novalidate: 'novalidate' } }) }}
{% if form.vars.submitted and not form.vars.valid %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex">
            <div><i class="ti ti-alert-circle me-3"></i></div>
            <div class="flex-grow-1">
                <strong>Formulaire invalide</strong>
                <div class="small mt-2">Veuillez corriger les erreurs ci-dessous :</div>
            </div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></a>
    </div>
{% endif %}

<div class="row g-3 mb-4">
    {% for field in form %}
        <div class="col-12">
            {{ form_row(field, { 
                attr: { class: 'form-control' },
                label_attr: { class: 'form-label' }
            }) }}
        </div>
    {% endfor %}
</div>

<div class="form-footer">
    <div class="d-flex align-items-center justify-content-end gap-2">
        <a href="{{ cancel_path }}" class="btn btn-link">Annuler</a>
        <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i>{{ submit_label|default('Enregistrer') }}</button>
    </div>
</div>
{{ form_end(form) }}
