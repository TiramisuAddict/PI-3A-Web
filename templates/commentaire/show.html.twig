{% extends 'base.html.twig' %}

{% block title %}Commentaire #{{ commentaire.idCommentaire }} — Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Commentaire #{{ commentaire.idCommentaire }}</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label text-secondary small">Contenu</label>
                            <p class="mb-0 text-break">{{ commentaire.contenu }}</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Date</label>
                            <p class="mb-0">{{ commentaire.dateCommentaire ? commentaire.dateCommentaire|date('d/m/Y H:i') : '—' }}</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Publication</label>
                            <p class="mb-0">{% if commentaire.post %}<a href="{{ path('app_post_show', {id_post: commentaire.post.idPost}) }}" class="btn btn-ghost-primary">{{ commentaire.post.titre }}</a>{% else %}—{% endif %}</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-primary" href="{{ path('app_commentaire_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
                <a class="btn btn-warning" href="{{ path('app_commentaire_edit', { id_commentaire: commentaire.idCommentaire }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
                {{ include('commentaire/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
