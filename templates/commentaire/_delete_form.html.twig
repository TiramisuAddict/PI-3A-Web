<form class="d-inline" method="post" action="{{ path('app_commentaire_delete', {'id_commentaire': commentaire.id_commentaire}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.id_commentaire) }}">
    <button type="submit" class="btn btn-danger"><i class="ti ti-trash me-1"></i>Supprimer</button>
</form>
