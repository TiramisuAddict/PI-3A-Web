<header class="navbar navbar-expand-md navbar-light border-bottom bg-white" style="height:56px;">
  <div class="container-fluid">
    <a href="#" class="navbar-brand py-0">
      <img src="/images/WKlogo.svg" height="150"  width="150" alt="Logo">
    </a>
    {% set avatarEmploye = employe is defined and employe ? employe : current_employe() %}
    {% set google_session_linked = app.session.get('google_linked') == true and app.session.get('google_access_token') is not empty %}
    {% set google_email = app.session.get('google_email') %}
    <div class="navbar-nav flex-row order-md-last ms-auto">
      <div class="nav-item d-flex align-items-center me-2">
        {% if google_session_linked %}
          <span class="badge bg-green-lt text-green">Google: session liee</span>
        {% else %}
          <span class="badge bg-red-lt text-red">Google: non liee</span>
        {% endif %}
      </div>
      <div class="nav-item dropdown">
        <a href="#" class="nav-link d-flex lh-1 text-reset align-items-center gap-2"
          data-bs-toggle="dropdown">
          {% if avatarEmploye and avatarEmploye.getImage_profil() %}
            <img src="{{ avatarEmploye.getImage_profil() }}" alt="Avatar" class="avatar avatar-sm" style="width:40px; height:40px; border-radius:50%; object-fit: cover;">
          {% else %}
            <span class="avatar avatar-sm" style="background-color: #4254D6; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.75rem; width:40px; height:40px; border-radius:50%;">
              {% if avatarEmploye %}
                {{ avatarEmploye.getPrenom()|first }}{{ avatarEmploye.getNom()|first }}
              {% else %}
                U
              {% endif %}
            </span>
          {% endif %}
          <div class="d-none d-xl-block">
            <div style="font-size:0.875rem;">{{ email|default('') }}</div>
            <div class="small text-secondary">{{ role|default('') }}</div>
          </div>
        </a>
        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
          <span class="dropdown-item-text text-secondary small">
            {% if google_session_linked %}
              Session Google active{% if google_email %} ({{ google_email }}){% endif %}
            {% else %}
              Session Google inactive
            {% endif %}
          </span>
          <div class="dropdown-divider"></div>
          <a href="{{ path('profil') }}" class="dropdown-item">Profil</a>
          <a href="#" class="dropdown-item">Paramètres</a>

          <a href="{{ path('app_google_link_start') }}" class="dropdown-item" id="linkGoogleAccountBtn">
            Lier mon compte Google
            <span class="badge bg-azure-lt text-azure ms-2">Temp</span>
          </a>

          <form method="post" action="{{ path('app_google_unlink') }}" class="m-0 p-0">
            <input type="hidden" name="_token" value="{{ csrf_token('google_unlink') }}">
            <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start" id="unlinkGoogleAccountBtn">
              Délier mon compte Google
            </button>
          </form>
          
          <div class="dropdown-divider"></div>
          <a href="{{ path('logout') }}" class="dropdown-item text-danger"
            data-bs-toggle="modal" data-bs-target="#logoutModal">
            Se déconnecter
          </a>
        </div>
      </div>
    </div>
  </div>

</header>

<div class="modal" id="logoutModal" tabindex="-1">
  <div class="modal-dialog modal-sm" role="document">
    <div class="modal-content">
      <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      <div class="modal-status bg-danger"></div>
      <div class="modal-body text-center py-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon mb-2 text-danger icon-lg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v2m0 4v.01"/><path d="M5 19h14a2 2 0 0 0 1.84-2.75l-7.1-12.25a2 2 0 0 0-3.5 0l-7.1 12.25a2 2 0 0 0 1.75 2.75"/></svg>
        <h3>Déconnexion</h3>
        <div class="text-secondary">Êtes-vous sûr de vouloir vous déconnecter ?</div>
      </div>
      <div class="modal-footer">
        <div class="w-100">
          <div class="row">
            <div class="col"><button class="btn w-100" data-bs-dismiss="modal">Annuler</button></div>
            <div class="col"><a href="{{ path('logout') }}" class="btn btn-danger w-100">Se déconnecter</a></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
