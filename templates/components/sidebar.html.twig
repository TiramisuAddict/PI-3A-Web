<aside class="d-flex flex-column border-end bg-white px-2 py-3"
  style="width:280px; min-width:280px; overflow-y:auto;">

  {# ── Navigation links ── #}
  <ul class="list-unstyled d-flex flex-column gap-1 mb-0 mt-2">

    <li>
      <a href="{{ (sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise']) ? path('app_admin_dashboard') : path('app_employe_feed') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'accueil' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-home" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Accueil</span>
      </a>
    </li>

    <li>
      <a href="{{ path('demande_index') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'demandes' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-file-text" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Les demandes</span>
      </a>
    </li>

    <li>
      <a href="{{ path('app_projet_index') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'projets' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-layout-kanban" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Les projets</span>
      </a>
    </li>

    <li>
      <a href="{{ (sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise']) ? path('app_formation_rh') : path('app_inscription_employe') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'formations' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-school" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Les formations</span>
      </a>
    </li>

    {# Gestion employés — visible uniquement pour RH et administrateur entreprise #}
    {% if sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise'] %}
    <li>
      <a href="{{ path('RH_Home') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'employes' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-users" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Gestion d'employés</span>
      </a>
    </li>
    {% endif %}

    {# Offres — visible uniquement pour RH et administrateur entreprise #}
    {% if sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise'] %}
    <li>
      <a href="{{ path('app_candidat_dashboard') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'offres' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <i class="ti ti-circle-check" style="font-size:18px;"></i>
        <span style="font-size:0.875rem;">Les offres</span>
      </a>
    </li>
    {% endif %}

  </ul>

  {# ── Project list section (shown on projet pages) ── #}
  {% if active_page is defined and active_page == 'projets' %}
  <hr class="my-3">

  <div class="d-flex justify-content-between align-items-center mb-2 px-2">
    <h6 class="mb-0 fw-bold text-uppercase small" style="letter-spacing:0.05em;">Projets</h6>
    {% if canManageProjects|default(false) %}
      <a href="{{ path('app_projet_new') }}" class="btn btn-sm btn-primary btn-icon" title="Nouveau projet" style="width:24px;height:24px;min-width:24px;">
        <i class="ti ti-plus" style="font-size:14px;"></i>
      </a>
    {% endif %}
  </div>

  {# ── Filters (only on index page) ── #}
  {% if filters is defined %}
  <form id="sidebar-project-filter-form" method="get" action="{{ path('app_projet_index') }}" class="px-1 mb-2">
    {% if sidebarSelectedProjetId is defined and sidebarSelectedProjetId %}
      <input type="hidden" name="projet" value="{{ sidebarSelectedProjetId }}">
    {% endif %}
    <div class="d-flex gap-2 mb-2">
      <div class="input-icon flex-grow-1">
        <span class="input-icon-addon"><i class="ti ti-search" style="font-size:14px;"></i></span>
        <input type="text" name="search" value="{{ filters.search|default('') }}" class="form-control form-control-sm" placeholder="Rechercher..." style="font-size:13px;">
      </div>
      {% set hasAdvancedFilters = filters.statut|default('') != '' or filters.priorite|default('') != '' or filters.chef_projet|default(filters.responsable|default('')) != '' %}
      <button type="button" class="btn btn-sm btn-icon {{ hasAdvancedFilters ? 'btn-primary' : 'btn-ghost-secondary' }}" data-bs-toggle="collapse" data-bs-target="#sidebar-filters-panel" aria-expanded="{{ hasAdvancedFilters ? 'true' : 'false' }}" title="Filtres avancés">
        <i class="ti ti-adjustments-horizontal"></i>
      </button>
    </div>
    <div id="sidebar-filters-panel" class="collapse {{ hasAdvancedFilters ? 'show' : '' }}">
      <div class="d-flex flex-column gap-2 mb-2">
        <select name="statut" class="form-select form-select-sm" style="font-size:13px;">
          <option value="">Tous les statuts</option>
          <option value="PLANIFIE" {{ filters.statut|default('') == 'PLANIFIE' ? 'selected' : '' }}>Planifié</option>
          <option value="EN_COURS" {{ filters.statut|default('') == 'EN_COURS' ? 'selected' : '' }}>En cours</option>
          <option value="EN_ATTENTE" {{ filters.statut|default('') == 'EN_ATTENTE' ? 'selected' : '' }}>En attente</option>
          <option value="TERMINE" {{ filters.statut|default('') == 'TERMINE' ? 'selected' : '' }}>Terminé</option>
        </select>
        <select name="priorite" class="form-select form-select-sm" style="font-size:13px;">
          <option value="">Toutes priorités</option>
          <option value="BASSE" {{ filters.priorite|default('') == 'BASSE' ? 'selected' : '' }}>Basse</option>
          <option value="MOYENNE" {{ filters.priorite|default('') == 'MOYENNE' ? 'selected' : '' }}>Moyenne</option>
          <option value="HAUTE" {{ filters.priorite|default('') == 'HAUTE' ? 'selected' : '' }}>Haute</option>
        </select>
        <select name="chef_projet" class="form-select form-select-sm" style="font-size:13px;">
          <option value="">Tous les chefs</option>
          {% for chefProjet in chefProjets|default([]) %}
            <option value="{{ chefProjet.idEmploye|default('') }}" {{ filters.chef_projet|default(filters.responsable|default('')) == chefProjet.idEmploye|default('') ? 'selected' : '' }}>
              {{ chefProjet.nom }} {{ chefProjet.prenom }}
            </option>
          {% endfor %}
        </select>
        <a href="{{ path('app_projet_index') }}" class="btn btn-sm btn-ghost-secondary w-100" style="font-size:12px;">
          <i class="ti ti-rotate me-1"></i>Réinitialiser
        </a>
      </div>
    </div>
  </form>
  {% endif %}

  {# ── Collapsible project list ── #}
  <a href="#sidebar-projets-list" class="d-flex align-items-center justify-content-between px-3 py-2 rounded text-decoration-none text-secondary fw-bold small text-uppercase" style="letter-spacing:0.05em;font-size:12px;" data-bs-toggle="collapse" aria-expanded="true" aria-controls="sidebar-projets-list">
    <span><i class="ti ti-list-details me-2"></i>Tous les projets</span>
    <i class="ti ti-chevron-down" style="font-size:14px;"></i>
  </a>

  <div id="sidebar-projets-list" class="collapse show">
    {% for p in sidebarProjets|default([]) %}
      {% set isSelected = sidebarSelectedProjetId|default(0) == p.idProjet %}
      {% set delayed = p.statut != 'TERMINE' and p.dateFinPrevue and p.dateFinPrevue|date('Y-m-d') < 'now'|date('Y-m-d') %}
      {% set initialNom = p.responsable and p.responsable.nom ? p.responsable.nom|slice(0,1) : '?' %}
      {% set initialPrenom = p.responsable and p.responsable.prenom ? p.responsable.prenom|slice(0,1) : '' %}
      {% set statusColor = 'azure' %}
      {% if p.statut == 'EN_COURS' %}{% set statusColor = 'green' %}
      {% elseif p.statut == 'TERMINE' %}{% set statusColor = 'teal' %}
      {% elseif p.statut == 'EN_ATTENTE' %}{% set statusColor = 'yellow' %}
      {% elseif p.statut == 'PLANIFIE' %}{% set statusColor = 'blue' %}{% endif %}

      <div class="sidebar-projet-item d-flex align-items-center gap-2 px-2 py-1 rounded mb-1 {{ isSelected ? 'bg-' ~ statusColor ~ '-lt' : '' }}" data-status-color="{{ statusColor }}" style="min-height:36px;transition:background .15s ease;">
        <a href="{{ path('app_projet_index', {
              projet: p.idProjet,
              search: filters is defined ? filters.search|default('') : '',
              statut: filters is defined ? filters.statut|default('') : '',
              priorite: filters is defined ? filters.priorite|default('') : '',
              chef_projet: filters is defined ? filters.chef_projet|default(filters.responsable|default('')) : ''
            }) }}"
          class="text-decoration-none text-reset d-flex align-items-center gap-2 flex-grow-1 min-w-0">
          <span class="avatar avatar-xs bg-{{ statusColor }}-lt text-{{ statusColor }}" style="width:28px;height:28px;font-size:11px;font-weight:700;">{{ (initialNom ~ initialPrenom)|upper }}</span>
          <span class="text-truncate {{ isSelected ? 'fw-medium text-' ~ statusColor : '' }}" style="font-size:0.8125rem;">{{ p.nom }}</span>
          {% if delayed %}
            <i class="ti ti-alert-triangle-filled text-danger" style="font-size:14px;" title="Projet en retard"></i>
          {% endif %}
        </a>

        <div class="dropdown ms-auto flex-shrink-0">
          <button class="btn btn-sm btn-ghost-secondary btn-icon" style="width:24px;height:24px;min-width:24px;" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="ti ti-dots" style="font-size:14px;"></i>
          </button>
          <div class="dropdown-menu dropdown-menu-end">
            <a class="dropdown-item" href="{{ path('app_projet_show', {'id_projet': p.idProjet}) }}">
              <i class="ti ti-eye me-2"></i>Détails
            </a>
            {% if canManageProjects|default(false) %}
              <a class="dropdown-item" href="{{ path('app_projet_edit', {'id_projet': p.idProjet}) }}">
                <i class="ti ti-pencil me-2"></i>Modifier
              </a>
              <div class="dropdown-divider"></div>
              <button type="button" class="dropdown-item text-danger js-sidebar-delete-trigger"
                      data-delete-url="{{ path('app_projet_delete', {'id_projet': p.idProjet}) }}"
                      data-delete-token="{{ csrf_token('delete' ~ p.idProjet) }}"
                      data-delete-message="Voulez-vous vraiment supprimer le projet « {{ p.nom }} » ?">
                <i class="ti ti-trash me-2"></i>Supprimer
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    {% else %}
      <div class="px-3 py-2 small text-muted">Aucun projet.</div>
    {% endfor %}
  </div>

  {# ── Delete confirmation modal ── #}
  <div class="modal modal-blur fade" id="sidebar-modal-delete" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered" role="document">
      <div class="modal-content">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        <div class="modal-status bg-danger"></div>
        <div class="modal-body text-center py-4">
          <i class="ti ti-alert-triangle mb-2 text-danger" style="font-size:40px;"></i>
          <h3>Confirmer la suppression</h3>
          <div class="text-muted" id="sidebar-modal-delete-message">Voulez-vous vraiment supprimer cet élément ?</div>
        </div>
        <div class="modal-footer">
          <div class="w-100">
            <div class="row">
              <div class="col">
                <button type="button" class="btn w-100" data-bs-dismiss="modal">Annuler</button>
              </div>
              <div class="col">
                <form id="sidebar-modal-delete-form" method="post" action="">
                  <input type="hidden" name="_token" id="sidebar-modal-delete-token" value="">
                  <button type="submit" class="btn btn-danger w-100">Supprimer</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Auto-submit filter form
      var filterForm = document.getElementById('sidebar-project-filter-form');
      if (filterForm) {
        var controls = filterForm.querySelectorAll('input[type="text"], select');
        var timeoutId = null;
        controls.forEach(function (control) {
          if (control.tagName === 'SELECT') {
            control.addEventListener('change', function () { filterForm.submit(); });
          } else {
            control.addEventListener('input', function () {
              if (timeoutId !== null) clearTimeout(timeoutId);
              timeoutId = setTimeout(function () { filterForm.submit(); }, 400);
            });
          }
        });
      }

      // Hover effect for project items (status-based color)
      document.querySelectorAll('.sidebar-projet-item').forEach(function (item) {
        var color = item.getAttribute('data-status-color') || 'azure';
        var isSelected = item.classList.contains('bg-' + color + '-lt');
        item.addEventListener('mouseenter', function () {
          if (!isSelected) item.classList.add('bg-' + color + '-lt');
        });
        item.addEventListener('mouseleave', function () {
          if (!isSelected) item.classList.remove('bg-' + color + '-lt');
        });
      });

      // Delete trigger for sidebar projects
      document.querySelectorAll('.js-sidebar-delete-trigger').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var form = document.getElementById('sidebar-modal-delete-form');
          var token = document.getElementById('sidebar-modal-delete-token');
          var msg = document.getElementById('sidebar-modal-delete-message');
          if (form) form.action = btn.getAttribute('data-delete-url') || '';
          if (token) token.value = btn.getAttribute('data-delete-token') || '';
          if (msg) msg.textContent = btn.getAttribute('data-delete-message') || 'Voulez-vous vraiment supprimer cet élément ?';
          var modal = new bootstrap.Modal(document.getElementById('sidebar-modal-delete'));
          modal.show();
        });
      });
    });
  </script>
  {% endif %}

  {# ── Google Calendar sync ── #}
  {% if active_page is defined and active_page == 'projets' %}
  <div class="mt-auto pt-3 border-top">
    {% if app.session.get('google_linked') %}
      <button type="button"
        id="btn-calendar-sync"
        class="d-flex align-items-center gap-2 w-100 px-3 py-2 btn btn-sm btn-outline-success rounded">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span style="font-size:0.8rem;">Sync Google Calendar</span>
      </button>
    {% else %}
      <a href="{{ path('app_google_link_start') }}"
        class="d-flex align-items-center gap-2 px-3 py-2 btn btn-sm btn-outline-secondary rounded text-decoration-none w-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <span style="font-size:0.8rem;">Lier Google Calendar</span>
      </a>
    {% endif %}
  </div>

  {# ── Calendar sync modal ── #}
  <div class="modal fade" id="calendarSyncModal" tabindex="-1" aria-labelledby="calendarSyncModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="calendarSyncModalLabel">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Synchroniser vers Google Calendar
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
        </div>

        <div class="modal-body">
          {# Step 1 – project picker #}
          <div id="cal-step-pick">
            <p class="text-muted mb-3" style="font-size:0.875rem;">
              Choisissez un projet pour synchroniser vos tâches dans Google Calendar.
            </p>
            <div id="cal-projects-loading" class="text-center py-3">
              <div class="spinner-border spinner-border-sm text-success" role="status"></div>
              <span class="ms-2 text-muted">Chargement…</span>
            </div>
            <div id="cal-projects-list" class="d-none list-group list-group-flush"></div>
            <div id="cal-projects-empty" class="d-none text-muted" style="font-size:0.875rem;">
              Vous n'êtes membre d'aucun projet.
            </div>
          </div>

          {# Step 2 – syncing spinner #}
          <div id="cal-step-syncing" class="d-none text-center py-4">
            <div class="spinner-border text-success mb-2" role="status"></div>
            <p class="text-muted mb-0">Synchronisation en cours…</p>
          </div>

          {# Step 3 – results #}
          <div id="cal-step-result" class="d-none">
            <div id="cal-result-success" class="d-none">
              <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
                <i class="ti ti-circle-check"></i>
                <span id="cal-synced-count"></span>
              </div>
              <ul id="cal-synced-links" class="list-group list-group-flush mb-0"></ul>
            </div>
            <div id="cal-result-skipped" class="d-none alert alert-warning mb-0">
              <strong>Tâches ignorées (dates manquantes) :</strong>
              <ul id="cal-skipped-list" class="mb-0 mt-1 ps-3"></ul>
            </div>
          </div>

          {# Error #}
          <div id="cal-error" class="d-none alert alert-danger mb-0"></div>
        </div>

        <div class="modal-footer justify-content-between">
          <button type="button" id="cal-btn-back" class="btn btn-sm btn-link text-muted d-none px-0">
            ← Choisir un autre projet
          </button>
          <button type="button" class="btn btn-sm btn-secondary ms-auto" data-bs-dismiss="modal">Fermer</button>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function () {
    var syncBtn = document.getElementById('btn-calendar-sync');
    if (!syncBtn) return;

    var syncModal;
    var projectsUrl  = '{{ path('app_calendar_projects') }}';
    var syncBaseUrl  = '{{ path('app_calendar_sync', {'id_projet': 0}) }}'.replace('/0', '/');

    function showStep(name) {
      ['cal-step-pick', 'cal-step-syncing', 'cal-step-result'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.classList.add('d-none');
      });
      var target = document.getElementById('cal-step-' + name);
      if (target) target.classList.remove('d-none');
      var backBtn = document.getElementById('cal-btn-back');
      if (backBtn) backBtn.classList.toggle('d-none', name !== 'result');
      document.getElementById('cal-error').classList.add('d-none');
    }

    function loadProjects() {
      showStep('pick');
      var loading = document.getElementById('cal-projects-loading');
      var list    = document.getElementById('cal-projects-list');
      var empty   = document.getElementById('cal-projects-empty');
      loading.classList.remove('d-none');
      list.classList.add('d-none');
      empty.classList.add('d-none');
      list.innerHTML = '';

      fetch(projectsUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          loading.classList.add('d-none');
          if (!data.ok || !data.projects.length) {
            empty.classList.remove('d-none');
            return;
          }
          data.projects.forEach(function (p) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'list-group-item list-group-item-action d-flex align-items-center gap-2';
            btn.innerHTML = '<i class="ti ti-layout-kanban text-muted"></i> ' +
              '<span style="font-size:0.875rem;">' + p.nom + '</span>';
            btn.addEventListener('click', function () { syncProject(p.id, p.nom); });
            list.appendChild(btn);
          });
          list.classList.remove('d-none');
        })
        .catch(function () {
          loading.classList.add('d-none');
          show_error('Impossible de charger les projets.');
        });
    }

    function syncProject(id, nom) {
      showStep('syncing');
      fetch(syncBaseUrl + id, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Bypass': '1' }
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) { show_error(data.message || 'Erreur lors de la synchronisation.'); return; }
          showStep('result');

          var successBox  = document.getElementById('cal-result-success');
          var skippedBox  = document.getElementById('cal-result-skipped');
          var countEl     = document.getElementById('cal-synced-count');
          var linksList   = document.getElementById('cal-synced-links');
          var skippedList = document.getElementById('cal-skipped-list');

          linksList.innerHTML   = '';
          skippedList.innerHTML = '';

          if (data.synced && data.synced.length) {
            successBox.classList.remove('d-none');
            countEl.textContent = data.synced.length + ' tâche(s) ajoutée(s) au calendrier depuis «\u00a0' + nom + '\u00a0».';
            data.synced.forEach(function (ev) {
              var li = document.createElement('li');
              li.className = 'list-group-item px-0 py-1 border-0';
              li.innerHTML = '<a href="' + ev.link + '" target="_blank" rel="noopener noreferrer" class="text-success" style="font-size:0.8rem;">' +
                '<i class="ti ti-external-link me-1"></i>' + ev.titre + '</a>';
              linksList.appendChild(li);
            });
          } else {
            successBox.classList.remove('d-none');
            countEl.textContent = 'Aucune tâche à synchroniser dans «\u00a0' + nom + '\u00a0».';
          }

          if (data.skipped && data.skipped.length) {
            skippedBox.classList.remove('d-none');
            data.skipped.forEach(function (t) {
              var li = document.createElement('li');
              li.textContent = t;
              li.style.fontSize = '0.8rem';
              skippedList.appendChild(li);
            });
          }
        })
        .catch(function () { show_error('Erreur réseau. Réessayez.'); });
    }

    function show_error(msg) {
      var err = document.getElementById('cal-error');
      err.textContent = msg;
      err.classList.remove('d-none');
      showStep('pick');
    }

    syncBtn.addEventListener('click', function () {
      if (!syncModal) {
        syncModal = new bootstrap.Modal(document.getElementById('calendarSyncModal'));
      }
      loadProjects();
      syncModal.show();
    });

    document.getElementById('cal-btn-back').addEventListener('click', function () {
      loadProjects();
    });
  })();
  </script>
  {% endif %}
</aside>