<aside class="d-flex flex-column border-end bg-white px-2 py-3"
  style="width:220px; min-width:280px; overflow-y:auto;">

  <ul class="list-unstyled d-flex flex-column gap-1 mb-0 mt-2">

    <li>
      <a href="#"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'accueil' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><polyline points="5 12 3 12 12 3 21 12 19 12"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/></svg>
        <span style="font-size:0.875rem;">Accueil</span>
      </a>
    </li>

    <li>
      <a href="{{ path('demande_index') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'demandes' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21h-10a2 2 0 0 1-2-2v-14a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/></svg>
        <span style="font-size:0.875rem;">Les demandes</span>
      </a>
    </li>

    <li>
      <a href="#"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'projets' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/></svg>
        <span style="font-size:0.875rem;">Les projets</span>
      </a>
    </li>

    <li>
      <a href="#"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'formations' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 6m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"/><path d="M6 21v-1a6 6 0 0 1 6-6h0a6 6 0 0 1 6 6v1"/></svg>
        <span style="font-size:0.875rem;">Les formations</span>
      </a>
    </li>

    {# Gestion employés — visible uniquement pour RH et administrateur entreprise #}
    {% if sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise'] %}
    <li>
      <a href="{{ path('RH_Home') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'employes' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.85"/></svg>
        <span style="font-size:0.875rem;">Gestion d'employés</span>
      </a>
    </li>
    {% endif %}

    {# Offres — visible uniquement pour RH et administrateur entreprise #}
    {% if sidebar_role is defined and sidebar_role in ['RH', 'administrateur entreprise'] %}
    <li>
      <a href="{{ path('app_candidat_dashboard') }}"
        class="d-flex align-items-center gap-3 px-3 py-2 rounded text-decoration-none
        {{ active_page is defined and active_page == 'offres' ? 'bg-blue-lt text-blue fw-medium' : 'text-secondary' }}">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2l4-4"/></svg>
        <span style="font-size:0.875rem;">Les offres</span>
      </a>
    </li>
    {% endif %}

  </ul>
</aside>