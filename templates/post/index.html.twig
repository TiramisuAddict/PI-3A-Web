{% extends 'base.html.twig' %}

{% block title %}Posts{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
        <h1 class="mb-0">Publications</h1>
        <a class="btn btn-primary" href="{{ path('app_post_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>

    <form id="post-search-form" method="get" action="{{ path('app_post_index') }}" class="mb-4" data-rows-url="{{ path('app_post_rows') }}">
        <div class="row g-2 align-items-end">
            <div class="col-md-8 col-lg-6">
                <label class="form-label visually-hidden" for="post-search-input">Rechercher</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="ti ti-search text-muted"></i></span>
                    <input type="search" id="post-search-input" name="search" value="{{ search|default('') }}" class="form-control" placeholder="Rechercher un post…" autocomplete="off" aria-busy="false">
                </div>
            </div>
            <div class="col-auto d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="ti ti-search me-1"></i>Rechercher</button>
                <a href="{{ path('app_post_index') }}" id="post-search-reset" class="btn btn-outline-secondary {{ search|default('') == '' ? 'd-none' : '' }}">Réinitialiser</a>
            </div>
        </div>
        <p id="post-search-meta" class="text-secondary small mt-2 mb-0 {{ search|default('') == '' ? 'd-none' : '' }}">{% if search|default('') != '' %}{{ posts|length }} résultat{{ posts|length > 1 ? 's' : '' }} trouvé{{ posts|length > 1 ? 's' : '' }}{% endif %}</p>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle table-vcenter">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Contenu</th>
                    <th>Type</th>
                    <th>Création</th>
                    <th>Utilisateur</th>
                    <th>Actif</th>
                    <th>Début évén.</th>
                    <th>Fin évén.</th>
                    <th>Lieu</th>
                    <th>Capacité</th>
                    <th>Lat.</th>
                    <th>Long.</th>
                    <th class="text-end text-nowrap" style="width: 1%;">Actions</th>
                </tr>
            </thead>
            <tbody id="posts-table-body">
                {% include 'post/_rows.html.twig' %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const form = document.getElementById('post-search-form');
            const input = document.getElementById('post-search-input');
            const tbody = document.getElementById('posts-table-body');
            const meta = document.getElementById('post-search-meta');
            const resetBtn = document.getElementById('post-search-reset');
            const rowsUrl = form?.dataset?.rowsUrl;
            if (!form || !input || !tbody || !rowsUrl) {
                return;
            }

            let debounceTimer = null;
            let abortController = null;

            function countResultRows() {
                const emptyCell = tbody.querySelector('td[colspan="14"]');
                if (emptyCell) {
                    return 0;
                }
                return tbody.querySelectorAll('tr').length;
            }

            function updateMeta(query) {
                if (!meta) {
                    return;
                }
                const q = query.trim();
                if (q === '') {
                    meta.classList.add('d-none');
                    meta.textContent = '';
                    return;
                }
                const n = countResultRows();
                meta.classList.remove('d-none');
                if (n === 0) {
                    meta.textContent = 'Aucun résultat';
                } else {
                    meta.textContent = n + ' résultat' + (n > 1 ? 's' : '') + ' trouvé' + (n > 1 ? 's' : '');
                }
            }

            function toggleReset(query) {
                if (!resetBtn) {
                    return;
                }
                if (query.trim() === '') {
                    resetBtn.classList.add('d-none');
                } else {
                    resetBtn.classList.remove('d-none');
                }
            }

            async function fetchRows(query) {
                if (abortController) {
                    abortController.abort();
                }
                abortController = new AbortController();
                const url = new URL(rowsUrl, window.location.origin);
                url.searchParams.set('search', query);
                input.setAttribute('aria-busy', 'true');
                try {
                    const res = await fetch(url.toString(), {
                        method: 'GET',
                        signal: abortController.signal,
                        headers: { 'X-Requested-With': 'XMLHttpRequest', Accept: 'text/html' },
                        credentials: 'same-origin',
                    });
                    if (!res.ok) {
                        throw new Error('HTTP ' + res.status);
                    }
                    tbody.innerHTML = await res.text();
                    updateMeta(query);
                    toggleReset(query);
                    const u = new URL(window.location.href);
                    if (query.trim() === '') {
                        u.searchParams.delete('search');
                    } else {
                        u.searchParams.set('search', query);
                    }
                    window.history.replaceState({}, '', u.pathname + (u.search ? u.search : ''));
                } catch (e) {
                    if (e.name === 'AbortError') {
                        return;
                    }
                    console.error(e);
                } finally {
                    input.setAttribute('aria-busy', 'false');
                }
            }

            function scheduleFetch() {
                clearTimeout(debounceTimer);
                debounceTimer = window.setTimeout(function () {
                    fetchRows(input.value);
                }, 280);
            }

            input.addEventListener('input', scheduleFetch);

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                clearTimeout(debounceTimer);
                fetchRows(input.value);
            });

            resetBtn?.addEventListener('click', function (e) {
                e.preventDefault();
                input.value = '';
                clearTimeout(debounceTimer);
                fetchRows('');
            });
        })();
    </script>
{% endblock %}
