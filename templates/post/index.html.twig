{% extends 'base.html.twig' %}

{% block title %}Posts{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Publications</h1>
        <a class="btn btn-primary" href="{{ path('app_post_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>id_post</th>
                    <th>titre</th>
                    <th>contenu</th>
                    <th>type_post</th>
                    <th>date_creation</th>
                    <th>utilisateur_id</th>
                    <th>active</th>
                    <th>date_evenement</th>
                    <th>date_fin_evenement</th>
                    <th>lieu</th>
                    <th>capacite_max</th>
                    <th>latitude</th>
                    <th>longitude</th>
                    <th class="text-nowrap">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for post in posts %}
                <tr>
                    <td>{{ post.id_post }}</td>
                    <td>{{ post.titre }}</td>
                    <td>{{ post.contenu|length > 80 ? post.contenu|slice(0, 80) ~ '…' : post.contenu }}</td>
                    <td>{{ post.type_post }}</td>
                    <td>{{ post.date_creation ? post.date_creation|date('Y-m-d H:i') : '' }}</td>
                    <td>{{ post.utilisateur_id }}</td>
                    <td>{{ post.active ? 'Oui' : 'Non' }}</td>
                    <td>{{ post.date_evenement ? post.date_evenement|date('Y-m-d') : '' }}</td>
                    <td>{{ post.date_fin_evenement ? post.date_fin_evenement|date('Y-m-d') : '' }}</td>
                    <td>{{ post.lieu }}</td>
                    <td>{{ post.capacite_max }}</td>
                    <td>{{ post.latitude }}</td>
                    <td>{{ post.longitude }}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-primary" href="{{ path('app_post_show', { id_post: post.id_post }) }}" title="Voir"><i class="ti ti-eye"></i></a>
                        <a class="btn btn-sm btn-warning" href="{{ path('app_post_edit', { id_post: post.id_post }) }}" title="Modifier"><i class="ti ti-edit"></i></a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="14" class="text-center text-secondary py-4">Aucun enregistrement</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
