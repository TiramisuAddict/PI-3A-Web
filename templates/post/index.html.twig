{% extends 'base.html.twig' %}

{% block title %}Publications - Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Publications</h2>
                </div>
                <div class="col-auto">
                    <a class="btn btn-primary" href="{{ path('app_post_new') }}"><i class="ti ti-plus me-1"></i>Creer une publication</a>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <form id="post-search-form" method="get" action="{{ path('app_post_index') }}" class="mb-0">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-8 col-lg-6">
                                <label class="form-label" for="post-search-input">Rechercher</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="ti ti-search"></i></span>
                                    <input type="search" id="post-search-input" name="search" value="{{ search|default('') }}" class="form-control" placeholder="Rechercher par titre ou contenu..." autocomplete="off">
                                    <button type="submit" class="btn btn-primary">Rechercher</button>
                                </div>
                                <p id="post-search-meta" class="text-secondary small mt-2 mb-0 {{ search|default('') == '' ? 'd-none' : '' }}">
                                    {% if search|default('') != '' %}
                                        {{ posts.getTotalItemCount }} resultat{{ posts.getTotalItemCount > 1 ? 's' : '' }} trouve{{ posts.getTotalItemCount > 1 ? 's' : '' }}
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-auto">
                                {% if search|default('') != '' %}
                                    <a class="btn btn-outline-secondary" href="{{ path('app_post_index') }}">
                                        <i class="ti ti-x me-1"></i>Reinitialiser
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="table-responsive {{ posts.getTotalItemCount == 0 ? 'd-none' : '' }}" id="posts-table-wrapper">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th>Type</th>
                                <th>Etat</th>
                                <th>Creation</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="posts-table-body">
                            {% include 'post/_rows.html.twig' %}
                        </tbody>
                    </table>
                </div>
                <div class="card-body {{ posts.getTotalItemCount > 0 ? 'd-none' : '' }}" id="empty-state">
                    <div class="empty">
                        <div class="empty-header">404</div>
                        <div class="empty-title">Aucune publication trouvee</div>
                        <div class="empty-subtitle text-secondary">Creez une nouvelle publication pour commencer.</div>
                        <div class="empty-action">
                            <a href="{{ path('app_post_new') }}" class="btn btn-primary"><i class="ti ti-plus me-1"></i>Creer une publication</a>
                        </div>
                    </div>
                </div>
                {% if posts.getTotalItemCount > 0 %}
                    {% set page_start = ((posts.getCurrentPageNumber - 1) * posts.getItemNumberPerPage) + 1 %}
                    {% set page_end_candidate = posts.getCurrentPageNumber * posts.getItemNumberPerPage %}
                    {% set page_end = page_end_candidate < posts.getTotalItemCount ? page_end_candidate : posts.getTotalItemCount %}
                    <div class="card-footer d-flex flex-column flex-md-row align-items-md-center gap-3">
                        <div class="text-secondary small">
                            Affichage de {{ page_start }} a {{ page_end }} sur {{ posts.getTotalItemCount }} publication{{ posts.getTotalItemCount > 1 ? 's' : '' }}
                        </div>
                        <div class="ms-md-auto">
                            {{ knp_pagination_render(posts) }}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
