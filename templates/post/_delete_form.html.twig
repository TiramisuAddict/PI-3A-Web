<form class="d-inline" method="post" action="{{ path('app_post_delete', {'id_post': post.idPost}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette publication ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.idPost) }}">
    <button type="submit" class="btn btn-danger"><i class="ti ti-trash me-1"></i>Supprimer</button>
</form>
