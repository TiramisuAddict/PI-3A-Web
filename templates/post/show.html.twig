{% extends 'base.html.twig' %}

{% block title %}{{ post.titre }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">{{ post.titre }}</h1>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">id_post</th><td>{{ post.id_post }}</td></tr>
                        <tr><th>titre</th><td>{{ post.titre }}</td></tr>
                        <tr><th>contenu</th><td class="text-break">{{ post.contenu }}</td></tr>
                        <tr><th>type_post</th><td>{{ post.type_post }}</td></tr>
                        <tr><th>date_creation</th><td>{{ post.date_creation ? post.date_creation|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>utilisateur_id</th><td>{{ post.utilisateur_id }}</td></tr>
                        <tr><th>active</th><td>{{ post.active ? 'Oui' : 'Non' }}</td></tr>
                        <tr><th>date_evenement</th><td>{{ post.date_evenement ? post.date_evenement|date('Y-m-d') : '' }}</td></tr>
                        <tr><th>date_fin_evenement</th><td>{{ post.date_fin_evenement ? post.date_fin_evenement|date('Y-m-d') : '' }}</td></tr>
                        <tr><th>lieu</th><td>{{ post.lieu }}</td></tr>
                        <tr><th>capacite_max</th><td>{{ post.capacite_max }}</td></tr>
                        <tr><th>latitude</th><td>{{ post.latitude }}</td></tr>
                        <tr><th>longitude</th><td>{{ post.longitude }}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_post_index') }}"><i class="ti ti-list me-1"></i>Retour à la liste</a>
        <a class="btn btn-warning" href="{{ path('app_post_edit', { id_post: post.id_post }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('post/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
