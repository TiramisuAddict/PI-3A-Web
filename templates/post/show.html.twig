{% extends 'base.html.twig' %}

{% block title %}{{ post.titre|length > 50 ? post.titre|slice(0, 50) ~ '…' : post.titre }} — Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">{{ post.titre }}</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <div class="row g-4">
                        {% if post.typePost == 2 %}
                            <div class="col-12">
                                <span class="badge bg-yellow-lt text-yellow">Événement</span>
                            </div>
                        {% endif %}
                        
                        <div class="col-12">
                            <div>
                                <label class="form-label text-secondary small">Contenu</label>
                                <p class="text-break">{{ post.contenu }}</p>
                            </div>
                        </div>

                        {% if post.typePost == 2 %}
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Date de début</label>
                                <p class="mb-0">{{ post.dateEvenement ? post.dateEvenement|date('d/m/Y') : '—' }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Date de fin</label>
                                <p class="mb-0">{{ post.dateFinEvenement ? post.dateFinEvenement|date('d/m/Y') : '—' }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Lieu</label>
                                <p class="mb-0">{{ post.lieu|default('—') }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary small">Capacité</label>
                                <p class="mb-0">{{ post.capaciteMax|default('—') }}</p>
                            </div>
                        {% endif %}

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Créé le</label>
                            <p class="mb-0">{{ post.dateCreation ? post.dateCreation|date('d/m/Y H:i') : '—' }}</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">État</label>
                            <p class="mb-0"><span class="badge {% if post.active %}bg-green-lt text-green{% else %}bg-secondary-lt text-secondary{% endif %}">{{ post.active ? 'Actif' : 'Inactif' }}</span></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-primary" href="{{ path('app_post_index') }}"><i class="ti ti-list me-1"></i>Retour à la liste</a>
                <a class="btn btn-warning" href="{{ path('app_post_edit', { id_post: post.idPost }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
                {{ include('post/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}