{% extends 'base.html.twig' %}

{% block title %}Gestion des employés{% endblock %}

{% block body %}
  {{ include('components/navbar.html.twig') }}
  <div class="d-flex overflow-hidden" style="height:calc(100vh - 56px);">
    {{ include('components/sidebar.html.twig', {'active_page': 'employes','sidebar_role': role}) }}
    <div class="flex-fill overflow-y-auto p-4" style= min-width:0;">

      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="mb-0">Gestion des employés</h1>
          <div class="text-muted small mt-1">Consultez et modifiez les informations des employés</div>
        </div>
      </div>
      {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
          <div class="d-flex align-items-center">
            <div class="alert-icon me-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-2"><path d="M5 12l5 5l10 -10"/></svg>
            </div>
            <div>
              <h4 class="alert-heading mb-1">Succès !</h4>
              <div class="alert-description">{{ message }}</div>
            </div>
          </div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}
      {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible mb-3" role="alert">
          <div class="alert-description">{{ message }}</div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}
      {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
          <div class="alert-description">{{ message }}</div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}

      <div class="d-flex justify-content-between mb-3 align-items-center">
  
  {# Filtre automatique sans bouton #}
  <form method="GET" class="d-flex gap-2 flex-fill">
    <input type="text" name="search" class="form-control"
           placeholder="Rechercher par nom..."
           value="{{ search }}">
           
    <select name="role" class="form-select" onchange="this.form.submit()">
      <option value="">Tous les rôles</option>
      <option value="rh" {{ selected_role == 'rh' ? 'selected' }}>RH</option>
      <option value="employé" {{ selected_role == 'employé' ? 'selected' }}>Employé</option>
      <option value="chef projet" {{ selected_role == 'chef projet' ? 'selected' }}>Chef de projet</option>
      <option value="administrateur entreprise" {{ selected_role == 'administrateur entreprise' ? 'selected' }}>Administrateur entreprise</option>
    </select>
  </form>

  {# Bouton ajouter employé #}
  <div class="ms-2">
    <a href="{{ path('employe_ajouter', {search: search, role: selected_role}) }}" class="btn text-white" style="background:#4254D6;">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Ajouter un employé
    </a>
  </div>

</div>
      {# Liste employés #}
      <div class="d-flex gap-3 align-items-start">

        {# Liste employés #}
        <div class="flex-fill" style="min-width:0;">
          {% for emp in employes %}
          {% set role_lower = emp.getRole()|lower %}
          {% set is_admin_systeme = role_lower in ['administrateur entreprise'] %}
          <div
            class="employee-card bg-white rounded border mb-2 d-flex align-items-center gap-3 px-4 py-3"
            data-id="{{ emp.getId_employe() }}"
            data-nom="{{ emp.getNom()|lower }}"
            data-prenom="{{ emp.getPrenom()|lower }}"
            data-role="{{ emp.getRole()|lower }}"
            onclick="toggleDetail({{ emp.getId_employe() }})"
            onmouseover="this.style.borderColor='#4254D6'; this.style.cursor='pointer';"
            onmouseout="this.style.borderColor='{% if employe_select is defined and employe_select.getId_employe() == emp.getId_employe() %}#4254D6{% else %}#dee2e6{% endif %}'">
            {% if emp.getImage_profil() %}
              <img src="{{ emp.getImage_profil() }}" alt="Avatar" class="avatar avatar-sm" style="flex-shrink:0; width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
            {% else %}
              <span class="avatar avatar-sm bg-blue-lt text-blue fw-bold" style="flex-shrink:0;">
                {{ emp.getPrenom()|first }}{{ emp.getNom()|first }}
              </span>
            {% endif %}
            <div class="flex-fill" style="min-width:0;">
              <div class="fw-semibold" style="font-size:0.875rem;">{{ emp.getPrenom() }} {{ emp.getNom() }}</div>
              <div class="text-muted" style="font-size:0.78rem;">{{ emp.getPoste() }}</div>
            </div>
            <span class="badge bg-blue-lt">{{ emp.getRole() }}</span>
            {% if not is_admin_systeme %}
              <div class="d-flex gap-2" onclick="event.stopPropagation();">
                <a href="{{ path('employe_details', {id: emp.getId_employe(), search: search, role: selected_role}) }}" class="btn btn-sm btn-outline-primary p-2" title="Modifier" aria-label="Modifier">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M12 20h9"/>
                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3l-11 11l-4 1l1 -4z"/>
                  </svg>
                </a>
                <form method="POST" action="{{ path('employe_supprimer', {id: emp.getId_employe()}) }}" onsubmit="event.stopPropagation(); return confirm('Supprimer cet employe ?');" class="m-0">
                  <button type="submit" class="btn btn-sm btn-outline-danger p-2" title="Supprimer" aria-label="Supprimer">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M4 7l16 0"/>
                      <path d="M10 11l0 6"/>
                      <path d="M14 11l0 6"/>
                      <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                      <path d="M9 7l1 -3h4l1 3"/>
                    </svg>
                  </button>
                </form>
              </div>
            {% endif %}
          </div>
          {% else %}
          <div class="empty bg-white rounded py-5">
            <p class="empty-title">Aucun employé trouvé</p>
          </div>
          {% endfor %}
        </div>

      </div>
    </div>
  </div>

  {{ include('rh/ajoutEmploye.html.twig', {'form': form_ajout, 'show_ajout': show_ajout is defined ? show_ajout : false}) }}
  {{ include('rh/modifierEmploye.html.twig', {
    'employe_select': employe_select is defined ? employe_select : null,
    'form': form is defined ? form : null,
    'show_modifier': employe_select is defined
  }) }}

{% endblock %}