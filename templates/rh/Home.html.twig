{% extends 'base.html.twig' %}

{% block title %}Gestion des employés{% endblock %}

{% block body %}
<div class="wrapper">

  <!-- Sidebar -->
  <aside class="navbar navbar-vertical navbar-expand-lg navbar-dark">
    <div class="container-fluid">
      <h1 class="navbar-brand navbar-brand-autodark">
        <a href="#"><img src="/images/WKlogo.svg" height="32" alt="Logo"></a>
      </h1>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav pt-lg-3">
          <li class="nav-item active">
            <a class="nav-link" href="{{ path('RH_Home') }}">
              <span class="nav-link-icon d-md-none d-lg-inline-block">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.85"/>
                </svg>
              </span>
              <span class="nav-link-title">Employés</span>
            </a>
          </li>
        </ul>
        <div class="mt-auto pb-3 px-3">
          <a href="{{ path('logout') }}" class="btn btn-danger w-100">
            Se déconnecter
          </a>
        </div>
      </div>
    </div>
  </aside>

  <!-- Page wrapper -->
  <div class="page-wrapper">

    <!-- Navbar top -->
    <header class="navbar navbar-expand-md navbar-light d-print-none">
      <div class="container-fluid">
        <div class="ms-auto navbar-nav flex-row">
          <div class="nav-item">
            <span class="nav-link text-muted">
              {{ email }} — <strong>{{ role }}</strong>
            </span>
          </div>
        </div>
      </div>
    </header>

    <div class="page-body">
      <div class="container-xl">

        <!-- Flashes -->
        {% for message in app.flashes('success') %}
          <div class="alert alert-success alert-dismissible mb-3">
            {{ message }}
            <a class="btn-close" data-bs-dismiss="alert"></a>
          </div>
        {% endfor %}

        <!-- En-tête -->
        <div class="page-header mb-3">
          <div class="row align-items-center">
            <div class="col">
              <h2 class="page-title">Gestion des employés</h2>
            </div>
            <div class="col-auto">
              <a href="{{ path('employe_ajouter') }}" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Ajouter un employé
              </a>
            </div>
          </div>
        </div>

        <div class="row g-3">

          <!-- Liste employés -->
          <div class="col-md-{{ (employe_select is defined or show_ajout is defined) ? '4' : '12' }}">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Liste des employés</h3>
              </div>
              <div class="list-group list-group-flush">
                {% for emp in employes %}
                  <a href="{{ path('employe_details', {id: emp.getId_employe()}) }}"
                     class="list-group-item list-group-item-action {{ employe_select is defined and employe_select.getId_employe() == emp.getId_employe() ? 'active' : '' }}">
                    <div class="row align-items-center">
                      <div class="col-auto">
                        <span class="avatar">{{ emp.getPrenom()|first }}{{ emp.getNom()|first }}</span>
                      </div>
                      <div class="col">
                        <div class="fw-semibold">{{ emp.getPrenom() }} {{ emp.getNom() }}</div>
                        <div class="text-muted small">{{ emp.getPoste() }}</div>
                      </div>
                      <div class="col-auto">
                        <span class="badge bg-blue-lt">{{ emp.getRole() }}</span>
                      </div>
                    </div>
                  </a>
                {% else %}
                  <div class="list-group-item text-muted text-center py-4">
                    Aucun employé trouvé.
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>

          <!-- Formulaire détails / modification -->
          {% if employe_select is defined %}
          <div class="col-md-8">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">
                  Modifier — {{ employe_select.getPrenom() }} {{ employe_select.getNom() }}
                </h3>
              </div>
              <div class="card-body">
                {{ form_start(form, {action: path('employe_details', {id: employe_select.getId_employe()}), method: 'POST'}) }}
                <div class="row g-3">
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.nom) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.prenom) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.e_mail, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.e_mail, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.e_mail) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.telephone, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.telephone) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.poste, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.poste, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.poste) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.role, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.role, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.role) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form.date_embauche, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form.date_embauche, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form.date_embauche) }}
                    </div>
                  </div>
                </div>
                <div class="mt-3">
                  <button type="submit" class="btn btn-primary">Enregistrer</button>
                  <a href="{{ path('RH_Home') }}" class="btn btn-secondary ms-2">Annuler</a>
                </div>
                {{ form_end(form) }}
              </div>
            </div>
          </div>
          {% endif %}

          <!-- Formulaire ajout -->
          {% if show_ajout is defined and show_ajout %}
          <div class="col-md-8">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Ajouter un employé</h3>
              </div>
              <div class="card-body">
                {{ form_start(form_ajout, {action: path('employe_ajouter'), method: 'POST'}) }}
                <div class="row g-3">
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.nom, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.nom) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.prenom, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.prenom, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.prenom) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.e_mail, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.e_mail, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.e_mail) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.telephone, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.telephone, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.telephone) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.poste, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.poste, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.poste) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.role, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.role, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.role) }}
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="mb-3">
                      {{ form_label(form_ajout.date_embauche, null, {'label_attr': {'class': 'form-label'}}) }}
                      {{ form_widget(form_ajout.date_embauche, {'attr': {'class': 'form-control'}}) }}
                      {{ form_errors(form_ajout.date_embauche) }}
                    </div>
                  </div>
                </div>
                <div class="mt-3">
                  <button type="submit" class="btn btn-primary">Ajouter</button>
                  <a href="{{ path('RH_Home') }}" class="btn btn-secondary ms-2">Annuler</a>
                </div>
                {{ form_end(form_ajout) }}
              </div>
            </div>
          </div>
          {% endif %}

        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}