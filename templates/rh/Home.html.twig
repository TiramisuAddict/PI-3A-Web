{% extends 'base.html.twig' %}

{% block title %}Gestion des employés{% endblock %}

{% block body %}
  {{ include('components/navbar.html.twig') }}
  <div class="d-flex overflow-hidden" style="height:calc(100vh - 56px);">
    {{ include('components/sidebar.html.twig', {'active_page': 'employes','sidebar_role': role}) }}
    <div class="flex-fill overflow-y-auto p-4" style="background:#F6F7FF; min-width:0;">

      <div class="modal" id="logoutModal" tabindex="-1">
        <div class="modal-dialog modal-sm" role="document">
          <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            <div class="modal-status bg-danger"></div>
            <div class="modal-body text-center py-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon mb-2 text-danger icon-lg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v2m0 4v.01"/><path d="M5 19h14a2 2 0 0 0 1.84-2.75l-7.1-12.25a2 2 0 0 0-3.5 0l-7.1 12.25a2 2 0 0 0 1.75 2.75"/></svg>
              <h3>Déconnexion</h3>
              <div class="text-secondary">Êtes-vous sûr de vouloir vous déconnecter ?</div>
            </div>
            <div class="modal-footer">
              <div class="w-100">
                <div class="row">
                  <div class="col"><button class="btn w-100" data-bs-dismiss="modal">Annuler</button></div>
                  <div class="col"><a href="{{ path('logout') }}" class="btn btn-danger w-100">Se déconnecter</a></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="mb-0">Gestion des employés</h1>
          <div class="text-muted small mt-1">Consultez et modifiez les informations des employés</div>
        </div>
      </div>
      {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
          <div class="d-flex align-items-center">
            <div class="alert-icon me-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-2"><path d="M5 12l5 5l10 -10"/></svg>
            </div>
            <div>
              <h4 class="alert-heading mb-1">Succès !</h4>
              <div class="alert-description">{{ message }}</div>
            </div>
          </div>
          <a class="btn-close" data-bs-dismiss="alert"></a>
        </div>
      {% endfor %}

      <div class="d-flex justify-content-between mb-3 align-items-center">
  
  {# Filtre automatique sans bouton #}
  <form method="GET" class="d-flex gap-2 flex-fill">
    <input type="text" name="search" class="form-control"
           placeholder="Rechercher par nom..."
           value="{{ search }}">
           
    <select name="role" class="form-select" onchange="this.form.submit()">
      <option value="">Tous les rôles</option>
      <option value="rh" {{ selected_role == 'rh' ? 'selected' }}>RH</option>
      <option value="employé" {{ selected_role == 'employé' ? 'selected' }}>Employé</option>
      <option value="chef projet" {{ selected_role == 'chef projet' ? 'selected' }}>Chef de projet</option>
      <option value="administrateur entreprise" {{ selected_role == 'administrateur entreprise' ? 'selected' }}>Administrateur entreprise</option>
    </select>
  </form>

  {# Bouton ajouter employé #}
  <div class="ms-2">
    <a href="{{ path('employe_ajouter') }}" class="btn text-white" style="background:#4254D6;">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Ajouter un employé
    </a>
  </div>

</div>
      {# Liste + panel #}
      <div class="d-flex gap-3 align-items-start">

        {# Liste employés #}
        <div class="flex-fill" style="min-width:0;">
          {% for emp in employes %}
          <div
            class="employee-card bg-white rounded border mb-2 d-flex align-items-center gap-3 px-4 py-3"
            data-id="{{ emp.getId_employe() }}"
            data-nom="{{ emp.getNom()|lower }}"
            data-prenom="{{ emp.getPrenom()|lower }}"
            data-role="{{ emp.getRole()|lower }}"
            onclick="toggleDetail({{ emp.getId_employe() }})"
            onmouseover="this.style.borderColor='#4254D6'; this.style.cursor='pointer';"
            onmouseout="this.style.borderColor='{% if employe_select is defined and employe_select.getId_employe() == emp.getId_employe() %}#4254D6{% else %}#dee2e6{% endif %}'">
            <span class="avatar avatar-sm bg-blue-lt text-blue fw-bold" style="flex-shrink:0;">
              {{ emp.getPrenom()|first }}{{ emp.getNom()|first }}
            </span>
            <div class="flex-fill" style="min-width:0;">
              <div class="fw-semibold" style="font-size:0.875rem;">{{ emp.getPrenom() }} {{ emp.getNom() }}</div>
              <div class="text-muted" style="font-size:0.78rem;">{{ emp.getPoste() }}</div>
            </div>
            <span class="badge bg-blue-lt">{{ emp.getRole() }}</span>
          </div>
          {% else %}
          <div class="empty bg-white rounded py-5">
            <p class="empty-title">Aucun employé trouvé</p>
          </div>
          {% endfor %}
        </div>

        {# Panel détail #}
        <div id="detailPanel"
          class="overflow-hidden border-start bg-white"
          style="width:{% if employe_select is defined %}360px{% else %}0{% endif %};
                 flex-shrink:0;
                 transition:width 0.3s ease;
                 position:fixed;
                 right:0;
                 top:56px;
                 height:calc(100vh - 56px);
                 z-index:100;">
          <div class="d-flex flex-column h-100" style="width:360px;">
            {% if employe_select is defined %}
            <div class="d-flex flex-column h-100">
              <div class="d-flex align-items-center justify-content-between py-3 px-3 ">
                <h3 class="mb-0" style="font-size:0.95rem; font-weight:600;">
                  {{ employe_select.getPrenom() }} {{ employe_select.getNom() }}
                </h3>
                <button type="button" class="btn-close" onclick="closeDetail()"></button>
              </div>
              <div class="flex-fill overflow-y-auto p-3">

                {% if employe_select.getRole() == 'administrateur entreprise' %}
                  <div class="alert alert-warning" role="alert">
                    <div class="d-flex gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon alert-icon icon-2"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636-2.87l-8.106-13.536a1.914 1.914 0 0 0-3.274 0z"/><path d="M12 16h.01"/></svg>
                      <div>
                        <h4 class="alert-heading">Modification impossible</h4>
                        <div class="alert-description">Le profil administrateur ne peut pas être modifié.</div>
                      </div>
                    </div>
                  </div>
                  <div class="mb-2"><div class="form-label small mb-1">Nom</div><div class="form-control form-control-sm bg-light">{{ employe_select.getNom() }}</div></div>
                  <div class="mb-2"><div class="form-label small mb-1">Prénom</div><div class="form-control form-control-sm bg-light">{{ employe_select.getPrenom() }}</div></div>
                  <div class="mb-2"><div class="form-label small mb-1">Email</div><div class="form-control form-control-sm bg-light">{{ employe_select.getEmail() }}</div></div>
                  <div class="mb-2"><div class="form-label small mb-1">Téléphone</div><div class="form-control form-control-sm bg-light">{{ employe_select.getTelephone() }}</div></div>
                  <div class="mb-2"><div class="form-label small mb-1">Poste</div><div class="form-control form-control-sm bg-light">{{ employe_select.getPoste() }}</div></div>
                  <div class="mb-2"><div class="form-label small mb-1">Rôle</div><div class="form-control form-control-sm bg-light">{{ employe_select.getRole() }}</div></div>

                {% else %}
                  {{ form_start(form, {action: path('employe_details', {id: employe_select.getId_employe()}), method: 'POST'}) }}
                  <div class="mb-2">
                    {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.nom, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <div class="mb-2">
                    {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.prenom, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <div class="mb-2">
                    {{ form_label(form.e_mail, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.e_mail, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <div class="mb-2">
                    {{ form_label(form.telephone, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <div class="mb-2">
                    {{ form_label(form.poste, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.poste, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <div class="mb-2">
                    {{ form_label(form.role, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.role, {'attr': {'class': 'form-select form-select'}}) }}
                  </div>
                  <div class="mb-3">
                    {{ form_label(form.date_embauche, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
                    {{ form_widget(form.date_embauche, {'attr': {'class': 'form-control form-control'}}) }}
                  </div>
                  <button type="submit" class="btn btn-sm w-100 text-white p-2" style="background:#4254D6;">Enregistrer</button>
                  {{ form_end(form) }}
                {% endif %}
                    <form method="POST" action="{{ path('employe_supprimer', {id: employe_select.getId_employe()}) }}" 
                        onsubmit="return confirm('Supprimer cet employé ?');">
                    <button type="submit" class="btn btn-sm w-100 text-white bg-red mt-2 p-2">
                        Supprimer
                    </button>
                    </form>
              </div>
            </div>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>

  {{ include('rh/ajoutEmploye.html.twig', {'form': form_ajout, 'show_ajout': show_ajout is defined ? show_ajout : false}) }}
<script>
function toggleDetail(id) {
    // Redirige vers la route qui affiche le détail de l'employé
    window.location.href = "{{ path('employe_details', {'id': 'ID'}) }}".replace('ID', id);
}

function closeDetail() {
    // Redirige vers la page home sans employé sélectionné
    window.location.href = "{{ path('RH_Home') }}";
}
</script>

{% endblock %}