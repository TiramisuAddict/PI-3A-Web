{% extends 'base.html.twig' %}

{% block title %}Nouvelle Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
.field-error {
    color: #dc2626;
    font-size: .85rem;
    margin-top: .4rem;
    font-weight: 600;
}
.is-invalid-custom {
    border-color: #dc2626 !important;
    box-shadow: 0 0 0 .2rem rgba(220, 38, 38, 0.12) !important;
}
.is-valid-custom {
    border-color: #16a34a !important;
}
.section-note {
    font-size: .88rem;
    color: #64748b;
}
.form-label.required::after {
    content: " *";
    color: #dc2626;
}
</style>
{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <div class="page-pretitle">Demandes</div>
        <h2 class="page-title">
            <i class="ti ti-file-plus me-2"></i>Nouvelle Demande
        </h2>
    </div>
</div>

{% if form.vars.submitted %}
    {% include 'demande/_form_errors.html.twig' with {'form': form, 'detailErrors': detailErrors} %}
{% endif %}

{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'demandeForm'}}) }}
<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-info-circle me-2"></i>Informations generales
                </h3>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        {{ form_label(form.employe, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.employe, {'attr': {'class': 'form-select' ~ (form.employe.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select' ~ (form.categorie.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        {{ form_label(form.typeDemande, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.typeDemande, {'attr': {'class': 'form-select' ~ (form.typeDemande.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                        <small class="section-note" id="typeInfo"></small>
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.priorite, {'attr': {'class': 'form-select' ~ (form.priorite.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label required'}}) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid-custom' : ''), 'placeholder': 'Titre de votre demande'}}) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Description detaillee (optionnel)'}}) }}
                </div>
            </div>
        </div>

        <div class="card mb-4" id="dynamicFieldsCard" style="{{ submittedType ? 'display:block;' : 'display:none;' }}">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-forms me-2"></i>Informations specifiques
                </h3>
            </div>
            <div class="card-body">
                <div class="row g-3" id="dynamicFields"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="ti ti-send me-2"></i>Actions
                </h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="form-label">Statut</div>
                    <span class="badge bg-blue">Nouvelle</span>
                </div>
                <hr>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        <i class="ti ti-check me-1"></i>Creer la demande
                    </button>
                    <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </div>
        </div>
    </div>
</div>
{{ form_end(form) }}

<div class="modal modal-blur fade" id="mapModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ti ti-map-pin me-2"></i>Selectionner une localisation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="input-group">
                        <input type="text" id="mapSearch" class="form-control" placeholder="Rechercher une adresse...">
                        <button class="btn btn-primary" type="button" id="searchBtn">Rechercher</button>
                    </div>
                </div>
                <div id="map" style="height: 400px; border-radius: 8px;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="confirmLocation">Confirmer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function() {
    "use strict";

    var CATEGORIES = {{ categories|json_encode|raw }};
    var SUBMITTED_DETAILS = {{ submittedDetails|json_encode|raw }};
    var SUBMITTED_TYPE = {{ submittedType|json_encode|raw }};
    var DETAIL_ERRORS = {{ detailErrors|json_encode|raw }};

    var currentLocationField = null;
    var map = null;
    var marker = null;
    var selectedLocation = null;
    var mapModal = null;

    var categorieSelect;
    var typeSelect;
    var typeInfo;
    var dynamicFieldsCard;
    var dynamicFieldsContainer;

    document.addEventListener("DOMContentLoaded", init);

    function init() {
        categorieSelect = document.getElementById("demande_categorie");
        typeSelect = document.getElementById("demande_typeDemande");
        typeInfo = document.getElementById("typeInfo");
        dynamicFieldsCard = document.getElementById("dynamicFieldsCard");
        dynamicFieldsContainer = document.getElementById("dynamicFields");

        if (!categorieSelect || !typeSelect) {
            console.error("Form elements not found");
            return;
        }

        categorieSelect.addEventListener("change", onCategoryChange);
        typeSelect.addEventListener("change", onTypeChange);

        if (SUBMITTED_TYPE) {
            loadDynamicFields(SUBMITTED_TYPE, SUBMITTED_DETAILS);
        }

        var mapModalEl = document.getElementById("mapModal");
        if (mapModalEl) {
            mapModal = new bootstrap.Modal(mapModalEl);
            mapModalEl.addEventListener("shown.bs.modal", initMap);
        }

        var confirmBtn = document.getElementById("confirmLocation");
        if (confirmBtn) {
            confirmBtn.addEventListener("click", confirmLocationSelection);
        }

        var searchBtn = document.getElementById("searchBtn");
        if (searchBtn) {
            searchBtn.addEventListener("click", function() {
                searchLocation(document.getElementById("mapSearch").value);
            });
        }

        var mapSearchInput = document.getElementById("mapSearch");
        if (mapSearchInput) {
            mapSearchInput.addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    searchLocation(this.value);
                }
            });
        }
    }

    function onCategoryChange() {
        var category = categorieSelect.value;
        
        typeSelect.innerHTML = '<option value="">-- Choisir un type --</option>';
        dynamicFieldsCard.style.display = "none";
        dynamicFieldsContainer.innerHTML = "";

        if (category && CATEGORIES[category]) {
            var types = CATEGORIES[category];
            for (var i = 0; i < types.length; i++) {
                var opt = document.createElement("option");
                opt.value = types[i];
                opt.textContent = types[i];
                typeSelect.appendChild(opt);
            }
            typeInfo.textContent = types.length + " types disponibles";
            typeInfo.style.color = "green";
        } else {
            typeInfo.textContent = "";
        }
    }

    function onTypeChange() {
        var type = typeSelect.value;
        if (!type) {
            dynamicFieldsCard.style.display = "none";
            dynamicFieldsContainer.innerHTML = "";
            return;
        }
        loadDynamicFields(type, {});
    }

    function loadDynamicFields(type, existingValues) {
        fetch("/demande/api/fields/" + encodeURIComponent(type))
            .then(function(response) {
                if (!response.ok) throw new Error("HTTP error " + response.status);
                return response.json();
            })
            .then(function(fields) {
                if (fields && fields.length > 0) {
                    renderDynamicFields(fields, existingValues);
                    dynamicFieldsCard.style.display = "block";
                } else {
                    dynamicFieldsCard.style.display = "none";
                    dynamicFieldsContainer.innerHTML = "";
                }
            })
            .catch(function(error) {
                console.error("Error loading fields:", error);
            });
    }

    function hasFieldError(fieldKey) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === fieldKey) {
                return true;
            }
        }
        return false;
    }

    function renderDynamicFields(fields, existingValues) {
        dynamicFieldsContainer.innerHTML = "";

        for (var i = 0; i < fields.length; i++) {
            var field = fields[i];
            var col = document.createElement("div");
            col.className = field.type === "textarea" ? "col-12" : "col-md-6";

            var label = document.createElement("label");
            label.className = "form-label" + (field.required ? " required" : "");
            label.textContent = field.label;
            col.appendChild(label);

            var input;
            var existingValue = existingValues[field.key] || "";
            var fieldHasError = hasFieldError(field.key);
            var errorClass = fieldHasError ? " is-invalid-custom" : "";

            switch (field.type) {
                case "text":
                    input = document.createElement("input");
                    input.type = "text";
                    input.className = "form-control" + errorClass;
                    input.name = "details[" + field.key + "]";
                    input.value = existingValue;
                    col.appendChild(input);
                    break;

                case "number":
                    input = document.createElement("input");
                    input.type = "number";
                    input.className = "form-control" + errorClass;
                    input.name = "details[" + field.key + "]";
                    input.value = existingValue;
                    input.min = "0";
                    col.appendChild(input);
                    break;

                case "date":
                    input = document.createElement("input");
                    input.type = "date";
                    input.className = "form-control" + errorClass;
                    input.name = "details[" + field.key + "]";
                    input.value = existingValue;
                    col.appendChild(input);
                    break;

                case "textarea":
                    input = document.createElement("textarea");
                    input.className = "form-control" + errorClass;
                    input.rows = 3;
                    input.name = "details[" + field.key + "]";
                    input.value = existingValue;
                    col.appendChild(input);
                    break;

                case "select":
                    input = document.createElement("select");
                    input.className = "form-select" + errorClass;
                    input.name = "details[" + field.key + "]";

                    var defOpt = document.createElement("option");
                    defOpt.value = "";
                    defOpt.textContent = "-- Selectionnez --";
                    input.appendChild(defOpt);

                    if (field.options) {
                        for (var j = 0; j < field.options.length; j++) {
                            var opt = document.createElement("option");
                            opt.value = field.options[j];
                            opt.textContent = field.options[j];
                            if (existingValue === field.options[j]) {
                                opt.selected = true;
                            }
                            input.appendChild(opt);
                        }
                    }
                    col.appendChild(input);
                    break;

                case "location":
                    var inputGroup = document.createElement("div");
                    inputGroup.className = "input-group";

                    var locInput = document.createElement("input");
                    locInput.type = "text";
                    locInput.className = "form-control" + errorClass;
                    locInput.name = "details[" + field.key + "]";
                    locInput.id = "location-" + field.key;
                    locInput.readOnly = true;
                    locInput.value = existingValue;

                    var mapBtn = document.createElement("button");
                    mapBtn.type = "button";
                    mapBtn.className = "btn btn-primary";
                    mapBtn.innerHTML = '<i class="ti ti-map-pin"></i>';

                    (function(li, fk) {
                        mapBtn.addEventListener("click", function() {
                            openMapPicker(li, fk);
                        });
                    })(locInput, field.key);

                    inputGroup.appendChild(locInput);
                    inputGroup.appendChild(mapBtn);
                    col.appendChild(inputGroup);

                    var latInput = document.createElement("input");
                    latInput.type = "hidden";
                    latInput.name = "details[" + field.key + "Lat]";
                    latInput.id = "lat-" + field.key;
                    latInput.value = existingValues[field.key + "Lat"] || "";
                    col.appendChild(latInput);

                    var lonInput = document.createElement("input");
                    lonInput.type = "hidden";
                    lonInput.name = "details[" + field.key + "Lon]";
                    lonInput.id = "lon-" + field.key;
                    lonInput.value = existingValues[field.key + "Lon"] || "";
                    col.appendChild(lonInput);
                    break;
            }

            dynamicFieldsContainer.appendChild(col);
        }
    }

    function openMapPicker(inputField, fieldKey) {
        currentLocationField = { input: inputField, key: fieldKey };
        selectedLocation = null;
        if (mapModal) {
            mapModal.show();
        }
    }

    function initMap() {
        var mapContainer = document.getElementById("map");
        if (!mapContainer) return;

        setTimeout(function() {
            if (!map) {
                map = L.map("map").setView([36.8065, 10.1815], 8);
                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                    attribution: "OpenStreetMap"
                }).addTo(map);
                map.on("click", onMapClick);
            } else {
                map.invalidateSize();
            }

            if (marker) {
                map.removeLayer(marker);
                marker = null;
            }
        }, 300);
    }

    function onMapClick(e) {
        if (marker) map.removeLayer(marker);
        marker = L.marker(e.latlng).addTo(map);

        selectedLocation = {
            lat: e.latlng.lat,
            lon: e.latlng.lng,
            name: e.latlng.lat.toFixed(4) + ", " + e.latlng.lng.toFixed(4)
        };

        fetch("https://nominatim.openstreetmap.org/reverse?format=json&lat=" + e.latlng.lat + "&lon=" + e.latlng.lng)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.display_name) {
                    selectedLocation.name = data.display_name;
                    marker.bindPopup(data.display_name).openPopup();
                }
            });
    }

    function searchLocation(query) {
        if (!query) return;

        fetch("https://nominatim.openstreetmap.org/search?format=json&q=" + encodeURIComponent(query))
            .then(function(r) { return r.json(); })
            .then(function(results) {
                if (results.length > 0) {
                    var result = results[0];
                    var latlng = L.latLng(parseFloat(result.lat), parseFloat(result.lon));
                    map.setView(latlng, 14);

                    if (marker) map.removeLayer(marker);
                    marker = L.marker(latlng).addTo(map);
                    marker.bindPopup(result.display_name).openPopup();

                    selectedLocation = {
                        lat: parseFloat(result.lat),
                        lon: parseFloat(result.lon),
                        name: result.display_name
                    };
                }
            });
    }

    function confirmLocationSelection() {
        if (selectedLocation && currentLocationField) {
            currentLocationField.input.value = selectedLocation.name;

            var latInput = document.getElementById("lat-" + currentLocationField.key);
            var lonInput = document.getElementById("lon-" + currentLocationField.key);

            if (latInput) latInput.value = selectedLocation.lat;
            if (lonInput) lonInput.value = selectedLocation.lon;
        }

        if (mapModal) {
            mapModal.hide();
        }
    }
})();
</script>
{% endblock %}