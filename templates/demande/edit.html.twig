{% extends 'base.html.twig' %}

{% block title %}Modifier Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
.badge { color: #ffffff !important; background: #206bc4 !important; }
.badge.bg-blue { color: #ffffff !important; background: #206bc4 !important; }
.badge.bg-green { color: #ffffff !important; background: #2fb344 !important; }
.badge.bg-red { color: #ffffff !important; background: #d63939 !important; }
.badge.bg-yellow { color: #1e293b !important; background: #f59f00 !important; }
.badge.bg-orange { color: #ffffff !important; background: #f76707 !important; }
.badge.bg-secondary { color: #ffffff !important; background: #6c757d !important; }
.badge.bg-primary { color: #ffffff !important; background: #206bc4 !important; }
.badge.bg-success { color: #ffffff !important; background: #2fb344 !important; }
.badge.bg-danger { color: #ffffff !important; background: #d63939 !important; }
.badge.bg-warning { color: #1e293b !important; background: #f59f00 !important; }
.badge.bg-info { color: #ffffff !important; background: #4299e1 !important; }
.field-error { color: #dc2626; font-size: .85rem; margin-top: .4rem; font-weight: 600; }
.is-invalid-custom { border-color: #dc2626 !important; box-shadow: 0 0 0 .2rem rgba(220,38,38,0.12) !important; }
.section-note { font-size: .88rem; color: #64748b; }
.form-label.required::after { content: " *"; color: #dc2626; }
.map-wrapper { position: relative; }
.map-zoom-controls { position: absolute; top: 10px; left: 10px; z-index: 1000; display: flex; flex-direction: column; gap: 4px; }
.map-zoom-controls button { width: 32px; height: 32px; background: white; border: 1px solid #ddd; border-radius: 4px; font-size: 18px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
.map-zoom-controls button:hover { background: #f0f0f0; }
.map-info-bar { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); z-index: 1000; background: white; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: bold; color: #444; box-shadow: 0 2px 8px rgba(0,0,0,0.2); white-space: nowrap; max-width: 60%; overflow: hidden; text-overflow: ellipsis; }
.map-search-bar { display: flex; gap: 8px; margin-bottom: 10px; }
.map-search-bar input { flex: 1; padding: 8px 15px; border: 1px solid #ddd; border-radius: 20px; font-size: 14px; }
.map-search-bar button { padding: 8px 20px; background: #4A5DEF; color: white; border: none; border-radius: 20px; cursor: pointer; font-size: 14px; }
.map-search-bar button:hover { background: #3a4ddf; }
.map-selected-info { font-size: .9rem; color: #475569; background: #f0f5ff; border: 1px solid #c0d0ff; padding: .65rem .85rem; border-radius: .5rem; margin-top: 8px; display: none; }
.map-selected-info.visible { display: block; }
.map-card-header { background: #f0f5ff; padding: 12px 16px; border-bottom: 1px solid #c0d0ff; display: flex; align-items: center; gap: 8px; font-weight: 600; color: #4A5DEF; }
.map-card-body { padding: 16px; }
.map-confirm-bar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 12px; }
.btn-confirm-location { background: #4A5DEF; color: white; border: none; padding: 10px 24px; border-radius: 25px; font-weight: 600; font-size: 14px; cursor: pointer; }
.btn-confirm-location:disabled { background: #aaa; cursor: not-allowed; }
.btn-confirm-location:not(:disabled):hover { background: #3a4ddf; }
.btn-clear-location { background: #888; color: white; border: none; padding: 10px 20px; border-radius: 25px; font-size: 14px; cursor: pointer; }
.btn-clear-location:hover { background: #666; }
.inline-map-section { margin-top: 8px; border: 2px solid #4A5DEF; border-radius: 12px; overflow: hidden; }
</style>
{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <div class="page-pretitle">Demandes</div>
        <h2 class="page-title"><i class="ti ti-edit me-2"></i>Modifier la demande</h2>
    </div>
</div>

{% if form.vars.submitted %}
    {% include 'demande/_form_errors.html.twig' with {'form': form, 'detailErrors': detailErrors} %}
{% endif %}

{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'demandeForm'}}) }}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations generales</h3>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select' ~ (form.categorie.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.typeDemande, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.typeDemande, {'attr': {'class': 'form-select' ~ (form.typeDemande.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                        <small class="section-note" id="typeInfo"></small>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.priorite, {'attr': {'class': 'form-select' ~ (form.priorite.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_label(form.status, null, {'label_attr': {'class': 'form-label required'}}) }}
                        {{ form_widget(form.status, {'attr': {'class': 'form-select' ~ (form.status.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                    </div>
                </div>
                <div class="mb-3">
                    {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label required'}}) }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid-custom' : '')}}) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                </div>
            </div>
        </div>

        <div class="card mb-4" id="dynamicFieldsCard" style="display:block;">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations specifiques</h3>
            </div>
            <div class="card-body">
                <div class="row g-3" id="dynamicFields"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-send me-2"></i>Actions</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    {{ form_label(form.commentaire, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.commentaire, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Ajoutez un commentaire (optionnel)'}}) }}
                </div>
                <hr>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary"><i class="ti ti-check me-1"></i>Enregistrer</button>
                    <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </div>
        </div>
    </div>
</div>

{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    "use strict";

    var CATEGORIES = {{ categories|json_encode|raw }};
    var CURRENT_TYPE = {{ submittedType|json_encode|raw }};
    var EXISTING_DETAILS = {{ existingDetails|json_encode|raw }};
    var DETAIL_ERRORS = {{ detailErrors|json_encode|raw }};

    var maps = {};
    var markers = {};
    var selectedLocations = {};

    document.addEventListener("DOMContentLoaded", function () {
        var categorieSelect = document.getElementById("demande_categorie");
        var typeSelect = document.getElementById("demande_typeDemande");
        var typeInfo = document.getElementById("typeInfo");
        var dynamicFieldsCard = document.getElementById("dynamicFieldsCard");
        var dynamicFieldsContainer = document.getElementById("dynamicFields");

        if (CURRENT_TYPE) {
            loadFields(CURRENT_TYPE, EXISTING_DETAILS, dynamicFieldsContainer, dynamicFieldsCard);
        }

        categorieSelect.addEventListener("change", function () {
            var cat = this.value;
            typeSelect.innerHTML = '<option value="">-- Choisir un type --</option>';
            dynamicFieldsCard.style.display = "none";
            dynamicFieldsContainer.innerHTML = "";
            maps = {}; markers = {}; selectedLocations = {};

            if (cat && CATEGORIES[cat]) {
                var types = CATEGORIES[cat];
                for (var i = 0; i < types.length; i++) {
                    var o = document.createElement("option");
                    o.value = types[i];
                    o.textContent = types[i];
                    typeSelect.appendChild(o);
                }
                typeInfo.textContent = types.length + " types disponibles";
                typeInfo.style.color = "green";
            } else {
                typeInfo.textContent = "";
            }
        });

        typeSelect.addEventListener("change", function () {
            maps = {}; markers = {}; selectedLocations = {};
            if (this.value) {
                loadFields(this.value, {}, dynamicFieldsContainer, dynamicFieldsCard);
            } else {
                dynamicFieldsCard.style.display = "none";
                dynamicFieldsContainer.innerHTML = "";
            }
        });

        function loadFields(type, values, container, card) {
            fetch("{{ path('demande_api_fields', {type: '__TYPE__'}) }}".replace("__TYPE__", encodeURIComponent(type)))
                .then(function (r) { return r.json(); })
                .then(function (fields) {
                    if (fields && fields.length > 0) {
                        renderFields(fields, values, container);
                        card.style.display = "block";
                    } else {
                        card.style.display = "none";
                        container.innerHTML = "";
                    }
                })
                .catch(function (e) { console.error(e); });
        }
    });

    function hasError(key) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === key) return true;
        }
        return false;
    }

    function renderFields(fields, values, container) {
        container.innerHTML = "";
        maps = {}; markers = {}; selectedLocations = {};

        for (var i = 0; i < fields.length; i++) {
            var f = fields[i];
            var val = values[f.key] || "";
            var err = hasError(f.key) ? " is-invalid-custom" : "";

            if (f.type === "location") {
                var fullCol = document.createElement("div");
                fullCol.className = "col-12";
                fullCol.appendChild(buildLocationField(f, val, values));
                container.appendChild(fullCol);
            } else {
                var col = document.createElement("div");
                col.className = f.type === "textarea" ? "col-12" : "col-md-6";
                col.appendChild(buildLabel(f));
                col.appendChild(buildInput(f, val, err));
                container.appendChild(col);
            }
        }
    }

    function buildLabel(f) {
        var lbl = document.createElement("label");
        lbl.className = "form-label" + (f.required ? " required" : "");
        lbl.textContent = f.label;
        return lbl;
    }

    function buildInput(f, val, err) {
        var inp;
        switch (f.type) {
            case "text":
                inp = document.createElement("input");
                inp.type = "text"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
            case "number":
                inp = document.createElement("input");
                inp.type = "number"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val; inp.min = "0";
                return inp;
            case "date":
                inp = document.createElement("input");
                inp.type = "date"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
            case "textarea":
                inp = document.createElement("textarea");
                inp.className = "form-control" + err; inp.rows = 3;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
            case "select":
                inp = document.createElement("select");
                inp.className = "form-select" + err;
                inp.name = "details[" + f.key + "]";
                var d = document.createElement("option");
                d.value = ""; d.textContent = "-- Selectionnez --";
                inp.appendChild(d);
                if (f.options) {
                    for (var j = 0; j < f.options.length; j++) {
                        var o = document.createElement("option");
                        o.value = f.options[j]; o.textContent = f.options[j];
                        if (val === f.options[j]) o.selected = true;
                        inp.appendChild(o);
                    }
                }
                return inp;
            default:
                inp = document.createElement("input");
                inp.type = "text"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
        }
    }

    function buildLocationField(f, val, values) {
        var wrapper = document.createElement("div");
        var err = hasError(f.key) ? " is-invalid-custom" : "";
        var existingLat = values[f.key + "Lat"] || "";
        var existingLon = values[f.key + "Lon"] || "";

        wrapper.appendChild(buildLabel(f));

        var readonlyInput = document.createElement("input");
        readonlyInput.type = "text";
        readonlyInput.className = "form-control mb-2" + err;
        readonlyInput.readOnly = true;
        readonlyInput.name = "details[" + f.key + "]";
        readonlyInput.id = "locval-" + f.key;
        readonlyInput.placeholder = "Cliquez sur la carte ci-dessous pour choisir un lieu";
        readonlyInput.value = val;
        wrapper.appendChild(readonlyInput);

        var latInp = document.createElement("input");
        latInp.type = "hidden"; latInp.name = "details[" + f.key + "Lat]";
        latInp.id = "lat-" + f.key; latInp.value = existingLat;
        wrapper.appendChild(latInp);

        var lonInp = document.createElement("input");
        lonInp.type = "hidden"; lonInp.name = "details[" + f.key + "Lon]";
        lonInp.id = "lon-" + f.key; lonInp.value = existingLon;
        wrapper.appendChild(lonInp);

        var mapSection = document.createElement("div");
        mapSection.className = "inline-map-section";
        mapSection.id = "mapsection-" + f.key;

        var header = document.createElement("div");
        header.className = "map-card-header";
        header.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right:6px"><path d="M8 0C5.24 0 3 2.24 3 5c0 3.75 5 11 5 11s5-7.25 5-11c0-2.76-2.24-5-5-5zm0 7.5C6.62 7.5 5.5 6.38 5.5 5S6.62 2.5 8 2.5 10.5 3.62 10.5 5 9.38 7.5 8 7.5z"/></svg>' + f.label + ' - Choisir sur la carte';
        mapSection.appendChild(header);

        var body = document.createElement("div");
        body.className = "map-card-body";

        var searchBar = document.createElement("div");
        searchBar.className = "map-search-bar";
        var searchInput = document.createElement("input");
        searchInput.type = "text";
        searchInput.placeholder = "Rechercher une ville ou adresse...";
        searchInput.id = "mapsearch-" + f.key;
        var searchBtn = document.createElement("button");
        searchBtn.type = "button";
        searchBtn.textContent = "Rechercher";
        searchBtn.onclick = (function (k) {
            return function () { searchOnMap(k, document.getElementById("mapsearch-" + k).value); };
        })(f.key);
        searchInput.addEventListener("keypress", (function (k) {
            return function (e) {
                if (e.key === "Enter") { e.preventDefault(); searchOnMap(k, document.getElementById("mapsearch-" + k).value); }
            };
        })(f.key));
        searchBar.appendChild(searchInput);
        searchBar.appendChild(searchBtn);
        body.appendChild(searchBar);

        var mapWrapper = document.createElement("div");
        mapWrapper.className = "map-wrapper";

        var infoBar = document.createElement("div");
        infoBar.className = "map-info-bar";
        infoBar.id = "mapinfo-" + f.key;
        infoBar.textContent = "Cliquez sur la carte pour choisir un lieu";
        mapWrapper.appendChild(infoBar);

        var zoomBox = document.createElement("div");
        zoomBox.className = "map-zoom-controls";
        var zIn = document.createElement("button"); zIn.type = "button"; zIn.textContent = "+";
        zIn.onclick = (function (k) { return function () { if (maps[k]) maps[k].zoomIn(); }; })(f.key);
        var zOut = document.createElement("button"); zOut.type = "button"; zOut.textContent = "−";
        zOut.onclick = (function (k) { return function () { if (maps[k]) maps[k].zoomOut(); }; })(f.key);
        zoomBox.appendChild(zIn); zoomBox.appendChild(zOut);
        mapWrapper.appendChild(zoomBox);

        var mapDiv = document.createElement("div");
        mapDiv.id = "map-" + f.key;
        mapDiv.style.height = "450px";
        mapDiv.style.width = "100%";
        mapDiv.style.background = "#aad3df";
        mapWrapper.appendChild(mapDiv);
        body.appendChild(mapWrapper);

        var infoSelected = document.createElement("div");
        infoSelected.className = "map-selected-info";
        infoSelected.id = "mapselected-" + f.key;
        body.appendChild(infoSelected);

        var confirmBar = document.createElement("div");
        confirmBar.className = "map-confirm-bar";
        var clearBtn = document.createElement("button");
        clearBtn.type = "button"; clearBtn.className = "btn-clear-location"; clearBtn.textContent = "Effacer";
        clearBtn.onclick = (function (k) { return function () { clearLocation(k); }; })(f.key);
        var confirmBtn = document.createElement("button");
        confirmBtn.type = "button"; confirmBtn.className = "btn-confirm-location";
        confirmBtn.id = "mapconfirm-" + f.key; confirmBtn.textContent = "Confirmer cette destination";
        confirmBtn.disabled = true;
        confirmBtn.onclick = (function (k) { return function () { confirmLocation(k); }; })(f.key);
        confirmBar.appendChild(clearBtn);
        confirmBar.appendChild(confirmBtn);
        body.appendChild(confirmBar);
        mapSection.appendChild(body);
        wrapper.appendChild(mapSection);

        setTimeout(function () { initInlineMap(f.key, existingLat, existingLon, val); }, 300);

        return wrapper;
    }

    function initInlineMap(key, existingLat, existingLon, existingValue) {
        var mapDiv = document.getElementById("map-" + key);
        if (!mapDiv) return;

        var m = L.map("map-" + key, { zoomControl: false }).setView([36.8065, 10.1815], 6);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: "&copy; OpenStreetMap contributors", maxZoom: 18
        }).addTo(m);

        maps[key] = m;
        markers[key] = null;
        selectedLocations[key] = null;

        if (existingLat && existingLon) {
            var lat = parseFloat(existingLat);
            var lon = parseFloat(existingLon);
            if (!isNaN(lat) && !isNaN(lon)) {
                m.setView([lat, lon], 13);
                markers[key] = L.marker([lat, lon]).addTo(m);
                selectedLocations[key] = { lat: lat, lon: lon, name: existingValue || (lat.toFixed(5) + ", " + lon.toFixed(5)) };
                updateMapInfo(key, selectedLocations[key].name);
                showSelectedInfo(key, selectedLocations[key]);
                document.getElementById("mapconfirm-" + key).disabled = false;
            }
        }

        m.on("click", (function (k) {
            return function (e) { pickLocationOnMap(k, e.latlng.lat, e.latlng.lng); };
        })(key));
    }

    function pickLocationOnMap(key, lat, lon) {
        var m = maps[key];
        if (!m) return;
        if (markers[key]) m.removeLayer(markers[key]);
        markers[key] = L.marker([lat, lon]).addTo(m);
        var tempName = lat.toFixed(5) + ", " + lon.toFixed(5);
        selectedLocations[key] = { lat: lat, lon: lon, name: tempName };
        updateMapInfo(key, "Recherche en cours...");
        document.getElementById("mapconfirm-" + key).disabled = true;
        showSelectedInfo(key, { lat: lat, lon: lon, name: "Geocodage en cours..." });

        fetch("https://nominatim.openstreetmap.org/reverse?format=json&lat=" + lat + "&lon=" + lon + "&accept-language=fr")
            .then(function (r) { return r.json(); })
            .then(function (data) {
                var name = data.display_name || tempName;
                selectedLocations[key] = { lat: lat, lon: lon, name: name };
                updateMapInfo(key, name);
                showSelectedInfo(key, selectedLocations[key]);
                if (markers[key]) markers[key].bindPopup(name).openPopup();
                document.getElementById("mapconfirm-" + key).disabled = false;
            })
            .catch(function () {
                selectedLocations[key] = { lat: lat, lon: lon, name: tempName };
                updateMapInfo(key, tempName);
                showSelectedInfo(key, selectedLocations[key]);
                document.getElementById("mapconfirm-" + key).disabled = false;
            });
    }

    function searchOnMap(key, query) {
        if (!query || !query.trim()) return;
        updateMapInfo(key, "Recherche: " + query + "...");
        fetch("https://nominatim.openstreetmap.org/search?format=json&q=" + encodeURIComponent(query.trim()) + "&limit=1&accept-language=fr")
            .then(function (r) { return r.json(); })
            .then(function (results) {
                if (results && results.length > 0) {
                    var r = results[0];
                    var lat = parseFloat(r.lat);
                    var lon = parseFloat(r.lon);
                    var m = maps[key];
                    if (m) { m.setView([lat, lon], 13); pickLocationOnMap(key, lat, lon); }
                } else {
                    updateMapInfo(key, "Aucun resultat trouve");
                }
            })
            .catch(function () { updateMapInfo(key, "Erreur de recherche"); });
    }

    function updateMapInfo(key, text) {
        var el = document.getElementById("mapinfo-" + key);
        if (el) el.textContent = text.length > 60 ? text.substring(0, 57) + "..." : text;
    }

    function showSelectedInfo(key, loc) {
        var el = document.getElementById("mapselected-" + key);
        if (!el) return;
        el.className = "map-selected-info visible";
        el.innerHTML = "<strong>Lieu selectionne:</strong> " + loc.name +
            "<br><small style='color:#888'>Lat: " + loc.lat.toFixed(6) + " | Lon: " + loc.lon.toFixed(6) + "</small>";
    }

    function confirmLocation(key) {
        var loc = selectedLocations[key];
        if (!loc) return;
        var valInp = document.getElementById("locval-" + key);
        var latInp = document.getElementById("lat-" + key);
        var lonInp = document.getElementById("lon-" + key);
        if (valInp) valInp.value = loc.name;
        if (latInp) latInp.value = loc.lat;
        if (lonInp) lonInp.value = loc.lon;
        var infoEl = document.getElementById("mapselected-" + key);
        if (infoEl) {
            infoEl.innerHTML = "<strong style='color:#16a34a'>Destination confirmee:</strong> " + loc.name +
                "<br><small style='color:#888'>Lat: " + loc.lat.toFixed(6) + " | Lon: " + loc.lon.toFixed(6) + "</small>";
        }
        var btn = document.getElementById("mapconfirm-" + key);
        if (btn) { btn.textContent = "Confirme"; btn.style.background = "#16a34a"; }
    }

    function clearLocation(key) {
        var m = maps[key];
        if (m && markers[key]) { m.removeLayer(markers[key]); markers[key] = null; }
        selectedLocations[key] = null;
        var valInp = document.getElementById("locval-" + key);
        var latInp = document.getElementById("lat-" + key);
        var lonInp = document.getElementById("lon-" + key);
        if (valInp) valInp.value = "";
        if (latInp) latInp.value = "";
        if (lonInp) lonInp.value = "";
        updateMapInfo(key, "Cliquez sur la carte pour choisir un lieu");
        var infoEl = document.getElementById("mapselected-" + key);
        if (infoEl) { infoEl.className = "map-selected-info"; infoEl.innerHTML = ""; }
        var btn = document.getElementById("mapconfirm-" + key);
        if (btn) { btn.disabled = true; btn.textContent = "Confirmer cette destination"; btn.style.background = ""; }
    }

})();
</script>
{% endblock %}