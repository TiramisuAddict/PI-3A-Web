{% extends 'base.html.twig' %}

{% block title %}Modifier Demande #{{ demande.id }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_show', {id: demande.id}) }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <div class="page-pretitle">Demande #{{ demande.id }}</div>
        <h2 class="page-title">
            <i class="ti ti-edit me-2"></i>Modifier la demande
        </h2>
    </div>
</div>

<form id="demandeForm">
    <input type="hidden" id="demandeId" value="{{ demande.id }}">
    
    <div class="row">
        <div class="col-lg-8">
            <div class="surface-card mb-4">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="ti ti-info-circle me-2"></i>Informations generales
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label required">Categorie</label>
                            <select class="form-select" id="categorie" name="categorie" required>
                                <option value="">-- Choisir une categorie --</option>
                                <option value="Ressources Humaines" {{ demande.categorie == 'Ressources Humaines' ? 'selected' : '' }}>Ressources Humaines</option>
                                <option value="Administrative" {{ demande.categorie == 'Administrative' ? 'selected' : '' }}>Administrative</option>
                                <option value="Informatique" {{ demande.categorie == 'Informatique' ? 'selected' : '' }}>Informatique</option>
                                <option value="Formation" {{ demande.categorie == 'Formation' ? 'selected' : '' }}>Formation</option>
                                <option value="Organisation du travail" {{ demande.categorie == 'Organisation du travail' ? 'selected' : '' }}>Organisation du travail</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label required">Type de demande</label>
                            <select class="form-select" id="typeDemande" name="typeDemande" required>
                                <option value="">-- Choisir un type --</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label required">Priorite</label>
                            <select class="form-select" id="priorite" name="priorite" required>
                                <option value="HAUTE" {{ demande.priorite == 'HAUTE' ? 'selected' : '' }}>HAUTE</option>
                                <option value="NORMALE" {{ demande.priorite == 'NORMALE' ? 'selected' : '' }}>NORMALE</option>
                                <option value="BASSE" {{ demande.priorite == 'BASSE' ? 'selected' : '' }}>BASSE</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label required">Statut</label>
                            <select class="form-select" id="status" name="status" required>
                                {% for status in statuses %}
                                    <option value="{{ status }}" {{ demande.status == status ? 'selected' : '' }}>{{ status }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label required">Titre</label>
                        <input type="text" class="form-control" id="titre" name="titre" required value="{{ demande.titre }}">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="4">{{ demande.description }}</textarea>
                    </div>
                </div>
            </div>

            <div class="surface-card mb-4" id="dynamicFieldsCard" style="display: {% if fields|length > 0 %}block{% else %}none{% endif %};">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="ti ti-forms me-2"></i>Informations specifiques
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row g-3" id="dynamicFields">
                        {% for field in fields %}
                        <div class="{{ field.type == 'textarea' ? 'col-12' : 'col-md-6' }}">
                            <label class="form-label{{ field.required ? ' required' : '' }}">{{ field.label }}</label>
                            
                            {% if field.type == 'text' %}
                                <input type="text" class="form-control" name="details[{{ field.key }}]" 
                                       value="{{ existingDetails[field.key] | default('') }}"
                                       {{ field.required ? 'required' : '' }}>
                            
                            {% elseif field.type == 'number' %}
                                <input type="number" class="form-control" name="details[{{ field.key }}]" 
                                       value="{{ existingDetails[field.key] | default('') }}"
                                       {{ field.required ? 'required' : '' }}>
                            
                            {% elseif field.type == 'date' %}
                                <input type="date" class="form-control" name="details[{{ field.key }}]" 
                                       value="{{ existingDetails[field.key] | default('') }}"
                                       {{ field.required ? 'required' : '' }}>
                            
                            {% elseif field.type == 'textarea' %}
                                <textarea class="form-control" name="details[{{ field.key }}]" rows="3" 
                                          {{ field.required ? 'required' : '' }}>{{ existingDetails[field.key] | default('') }}</textarea>
                            
                            {% elseif field.type == 'select' %}
                                <select class="form-select" name="details[{{ field.key }}]" {{ field.required ? 'required' : '' }}>
                                    <option value="">Selectionnez...</option>
                                    {% for opt in field.options %}
                                        <option value="{{ opt }}" {{ existingDetails[field.key] | default('') == opt ? 'selected' : '' }}>{{ opt }}</option>
                                    {% endfor %}
                                </select>
                            
                            {% elseif field.type == 'location' %}
                                <div class="input-group">
                                    <input type="text" class="form-control" 
                                           name="details[{{ field.key }}]" 
                                           id="location-{{ field.key }}"
                                           value="{{ existingDetails[field.key] | default('') }}"
                                           readonly {{ field.required ? 'required' : '' }}>
                                    <button type="button" class="btn btn-primary btn-map" data-field="{{ field.key }}">
                                        <i class="ti ti-map-pin"></i>
                                    </button>
                                </div>
                                <input type="hidden" name="details[{{ field.key }}Lat]" id="lat-{{ field.key }}" value="{{ existingDetails[field.key ~ 'Lat'] | default('') }}">
                                <input type="hidden" name="details[{{ field.key }}Lon]" id="lon-{{ field.key }}" value="{{ existingDetails[field.key ~ 'Lon'] | default('') }}">
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="surface-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="ti ti-send me-2"></i>Actions
                    </h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-label">Date de creation</div>
                        <span class="mini-muted">{{ demande.dateCreation|date('d/m/Y H:i') }}</span>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Commentaire de modification</label>
                        <textarea class="form-control" id="commentaire" name="commentaire" rows="2" placeholder="Commentaire (optionnel)"></textarea>
                    </div>
                    
                    <hr>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary" id="btnSubmit">
                            <i class="ti ti-check me-1"></i>Enregistrer
                        </button>
                        <a href="{{ path('demande_show', {id: demande.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="modal modal-blur fade" id="mapModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ti ti-map-pin me-2"></i>Selectionner une localisation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="input-group">
                        <input type="text" id="mapSearch" class="form-control" placeholder="Rechercher une adresse...">
                        <button class="btn btn-primary" type="button" id="searchBtn">Rechercher</button>
                    </div>
                </div>
                <div id="map" style="height: 400px; border-radius: 8px;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="confirmLocation">Confirmer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function() {
    "use strict";
    
    var DEMANDE_ID = {{ demande.id }};
    var CURRENT_TYPE = "{{ demande.typeDemande }}";
    var CURRENT_CATEGORIE = "{{ demande.categorie }}";
    
    var CATEGORIES = {
        "Ressources Humaines": [
            "Conge",
            "Attestation de travail",
            "Attestation de salaire",
            "Certificat de travail",
            "Mutation",
            "Demission"
        ],
        "Administrative": [
            "Avance sur salaire",
            "Remboursement",
            "Materiel de bureau",
            "Badge acces",
            "Carte de visite"
        ],
        "Informatique": [
            "Materiel informatique",
            "Acces systeme",
            "Logiciel",
            "Probleme technique"
        ],
        "Formation": [
            "Formation interne",
            "Formation externe",
            "Certification"
        ],
        "Organisation du travail": [
            "Teletravail",
            "Changement horaires",
            "Heures supplementaires"
        ]
    };
    
    var currentLocationField = null;
    var map = null;
    var marker = null;
    var selectedLocation = null;
    var mapModal = null;
    
    document.addEventListener("DOMContentLoaded", init);
    
    function init() {
        console.log("Edit form init - Demande ID:", DEMANDE_ID);
        console.log("Current categorie:", CURRENT_CATEGORIE);
        console.log("Current type:", CURRENT_TYPE);
        
        populateTypes(CURRENT_CATEGORIE, CURRENT_TYPE);
        
        document.getElementById("categorie").addEventListener("change", function() {
            populateTypes(this.value, null);
        });
        
        document.getElementById("demandeForm").addEventListener("submit", onFormSubmit);
        
        var mapModalEl = document.getElementById("mapModal");
        if (mapModalEl) {
            mapModal = new bootstrap.Modal(mapModalEl);
            mapModalEl.addEventListener("shown.bs.modal", initMap);
        }
        
        document.querySelectorAll(".btn-map").forEach(function(btn) {
            btn.addEventListener("click", function() {
                var fieldKey = this.getAttribute("data-field");
                var inputField = document.getElementById("location-" + fieldKey);
                openMapPicker(inputField, fieldKey);
            });
        });
        
        var confirmBtn = document.getElementById("confirmLocation");
        if (confirmBtn) {
            confirmBtn.addEventListener("click", confirmLocationSelection);
        }
        
        var searchBtn = document.getElementById("searchBtn");
        if (searchBtn) {
            searchBtn.addEventListener("click", function() {
                searchLocation(document.getElementById("mapSearch").value);
            });
        }
        
        var mapSearchInput = document.getElementById("mapSearch");
        if (mapSearchInput) {
            mapSearchInput.addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    e.preventDefault();
                    searchLocation(this.value);
                }
            });
        }
    }
    
    function populateTypes(category, selectedType) {
        var typeSelect = document.getElementById("typeDemande");
        typeSelect.innerHTML = '<option value="">-- Choisir un type --</option>';
        
        if (category && CATEGORIES[category]) {
            var types = CATEGORIES[category];
            for (var i = 0; i < types.length; i++) {
                var opt = document.createElement("option");
                opt.value = types[i];
                opt.textContent = types[i];
                if (selectedType && types[i] === selectedType) {
                    opt.selected = true;
                }
                typeSelect.appendChild(opt);
            }
        }
    }
    
    function onFormSubmit(e) {
        e.preventDefault();
        e.stopPropagation();
        
        console.log("Form submit triggered");
        
        var form = document.getElementById("demandeForm");
        var formData = new FormData(form);
        
        var data = {
            categorie: formData.get("categorie"),
            typeDemande: formData.get("typeDemande"),
            titre: formData.get("titre"),
            description: formData.get("description") || "",
            priorite: formData.get("priorite"),
            status: formData.get("status"),
            commentaire: formData.get("commentaire") || "",
            details: {}
        };
        
        var entries = formData.entries();
        var entry = entries.next();
        while (!entry.done) {
            var key = entry.value[0];
            var value = entry.value[1];
            
            if (key.indexOf("details[") === 0) {
                var match = key.match(/details\[(.+)\]/);
                if (match && value) {
                    data.details[match[1]] = value;
                }
            }
            entry = entries.next();
        }
        
        console.log("Data to send:", data);
        
        var btnSubmit = document.getElementById("btnSubmit");
        btnSubmit.disabled = true;
        btnSubmit.innerHTML = '<i class="ti ti-loader me-1"></i>Enregistrement...';
        
        fetch("/demande/api/" + DEMANDE_ID + "/update", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
            },
            body: JSON.stringify(data)
        })
        .then(function(response) {
            console.log("Response status:", response.status);
            return response.json();
        })
        .then(function(result) {
            console.log("Result:", result);
            
            if (result.success) {
                alert("Demande mise a jour avec succes!");
                window.location.href = "/demande/" + DEMANDE_ID;
            } else {
                alert("Erreur: " + result.message);
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = '<i class="ti ti-check me-1"></i>Enregistrer';
            }
        })
        .catch(function(error) {
            console.error("Error:", error);
            alert("Erreur de connexion: " + error.message);
            btnSubmit.disabled = false;
            btnSubmit.innerHTML = '<i class="ti ti-check me-1"></i>Enregistrer';
        });
        
        return false;
    }
    
    function openMapPicker(inputField, fieldKey) {
        currentLocationField = { input: inputField, key: fieldKey };
        selectedLocation = null;
        if (mapModal) {
            mapModal.show();
        }
    }
    
    function initMap() {
        var mapContainer = document.getElementById("map");
        if (!mapContainer) return;
        
        if (!map) {
            map = L.map("map").setView([36.8065, 10.1815], 8);
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                attribution: "OpenStreetMap"
            }).addTo(map);
            map.on("click", onMapClick);
        } else {
            map.invalidateSize();
        }
        
        if (marker) {
            map.removeLayer(marker);
            marker = null;
        }
    }
    
    function onMapClick(e) {
        if (marker) {
            map.removeLayer(marker);
        }
        
        marker = L.marker(e.latlng).addTo(map);
        selectedLocation = {
            lat: e.latlng.lat,
            lon: e.latlng.lng,
            name: e.latlng.lat.toFixed(4) + ", " + e.latlng.lng.toFixed(4)
        };
        
        fetch("https://nominatim.openstreetmap.org/reverse?format=json&lat=" + e.latlng.lat + "&lon=" + e.latlng.lng)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.display_name) {
                    selectedLocation.name = data.display_name;
                    marker.bindPopup(data.display_name).openPopup();
                }
            })
            .catch(function(err) {
                console.error("Geocode error:", err);
            });
    }
    
    function searchLocation(query) {
        if (!query) return;
        
        fetch("https://nominatim.openstreetmap.org/search?format=json&q=" + encodeURIComponent(query))
            .then(function(r) { return r.json(); })
            .then(function(results) {
                if (results.length > 0) {
                    var result = results[0];
                    var latlng = L.latLng(parseFloat(result.lat), parseFloat(result.lon));
                    
                    map.setView(latlng, 14);
                    
                    if (marker) {
                        map.removeLayer(marker);
                    }
                    
                    marker = L.marker(latlng).addTo(map);
                    marker.bindPopup(result.display_name).openPopup();
                    
                    selectedLocation = {
                        lat: parseFloat(result.lat),
                        lon: parseFloat(result.lon),
                        name: result.display_name
                    };
                } else {
                    alert("Aucun resultat trouve");
                }
            })
            .catch(function(err) {
                console.error("Search error:", err);
            });
    }
    
    function confirmLocationSelection() {
        if (selectedLocation && currentLocationField) {
            currentLocationField.input.value = selectedLocation.name;
            
            var latInput = document.getElementById("lat-" + currentLocationField.key);
            var lonInput = document.getElementById("lon-" + currentLocationField.key);
            
            if (latInput) latInput.value = selectedLocation.lat;
            if (lonInput) lonInput.value = selectedLocation.lon;
        }
        
        if (mapModal) {
            mapModal.hide();
        }
    }
    
})();
</script>
{% endblock %}