    function loadDynamicFields(type, existingValues, container, card) {
        fetch("{{ path('demande_api_fields', {type: '__TYPE__'}) }}".replace("__TYPE__", encodeURIComponent(type)))
            .then(function (r) {
                if (!r.ok) throw new Error("HTTP " + r.status);
                return r.json();
            })
            .then(function (fields) {
                if (fields && fields.length > 0) {
                    var finalFields = fields;
                    if (isAutreType(type)) {
                        finalFields = composeAutreFields(fields);
                    }

                    renderDynamicFields(finalFields, existingValues, container);
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                    container.innerHTML = "";
                }
            })
            .catch(function (e) { console.error(e); });
    }

