{% extends 'base.html.twig' %}

{% block title %}Nouvelle Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
    .form-label.required::after { content: " *"; color: #dc2626; }
    .field-error { color: #dc2626; font-size: 0.875rem; margin-top: 6px; display: block; }
    .map-wrapper { position: relative; }
    .map-zoom-controls { position: absolute; top: 10px; left: 10px; z-index: 1000; display: flex; flex-direction: column; gap: 4px; }
    .map-zoom-controls button { width: 32px; height: 32px; background: white; border: 1px solid #ddd; border-radius: 4px; font-size: 18px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
    .map-zoom-controls button:hover { background: #f0f0f0; }
    .map-info-bar { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); z-index: 1000; background: white; padding: 6px 16px; border-radius: 6px; font-size: 12px; font-weight: bold; color: #444; box-shadow: 0 2px 8px rgba(0,0,0,0.15); white-space: nowrap; max-width: 60%; overflow: hidden; text-overflow: ellipsis; }
    .map-search-bar { display: flex; gap: 8px; margin-bottom: 10px; }
    .map-search-bar input { flex: 1; padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .map-search-bar button { padding: 8px 16px; background: #4a5def; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; transition: all 0.2s ease; }
    .map-search-bar button:hover { background: #3a4ddf; }
    .map-selected-info { font-size: .9rem; color: #475569; background: #f0f5ff; border: 1px solid #c0d0ff; padding: .65rem .85rem; border-radius: 6px; margin-top: 8px; display: none; }
    .map-selected-info.visible { display: block; }
    .map-card-header { background: #f0f5ff; padding: 12px 16px; border-bottom: 1px solid #c0d0ff; display: flex; align-items: center; gap: 8px; font-weight: 600; color: #4a5def; border-radius: 6px 6px 0 0; }
    .map-card-body { padding: 16px; border: 1px solid #c0d0ff; border-top: none; border-radius: 0 0 6px 6px; }
    .card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 10px;
        background: #fff;
        box-shadow: 0 4px 16px rgba(74, 93, 239, 0.08);
    }
    .card-header {
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        background: #f5f7fb;
        border-radius: 10px 10px 0 0;
        padding: 16px 20px;
        font-weight: 600;
        color: #4a5def;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .card-body {
        padding: 20px;
        border-radius: 0 0 10px 10px;
    }
    .map-confirm-bar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 12px; }
    .btn-confirm-location { background: #4a5def; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-confirm-location:disabled { background: #aaa; cursor: not-allowed; }
    .btn-confirm-location:not(:disabled):hover { background: #3a4ddf; }
    .btn-clear-location { background: #6b7280; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-clear-location:hover { background: #4b5563; }
    .inline-map-section { margin-top: 8px; border: 1px solid #c0d0ff; border-radius: 6px; overflow: hidden; background: white; }
    #map { height: 400px; width: 100%; background: #aad3df; border-radius: 4px; }
    .location-input-group input { background: #f8fafc !important; }
    .autre-ai-box { border: 1px dashed #4a5def; border-radius: 8px; padding: 14px; background: #f8faff; }
    .ai-status { font-size: .88rem; color: #475569; }
    .ai-status.success { color: #166534; }
    .ai-status.error { color: #b91c1c; }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="min-height:calc(100vh - 56px);">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes','sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="page-header d-print-none mb-3">
        <div class="container-xl">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Nouvelle demande</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'demandeForm'}}) }}
            <input type="hidden" name="ai_generated" id="aiGeneratedInput" value="{{ aiGenerated ? '1' : '0' }}">
            <input type="hidden" name="ai_confirmed" id="aiConfirmedInput" value="0">
            <input type="hidden" name="ai_field_plan" id="aiFieldPlanInput" value="{{ submittedAiFieldPlan|default({'add': [], 'remove': [], 'replaceBase': false})|json_encode|e('html_attr') }}">

            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations générales</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.employe, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.employe, {'attr': {'class': 'form-select' ~ (form.employe.vars.errors|length > 0 ? ' is-invalid' : ''), 'onmousedown': 'return false;', 'onkeydown': 'return false;'}}) }}
                                        {% if form.employe.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.employe.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select' ~ (form.categorie.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.categorie.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.categorie.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.typeDemande, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.typeDemande, {'attr': {'class': 'form-select' ~ (form.typeDemande.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.typeDemande.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.typeDemande.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.priorite, {'attr': {'class': 'form-select' ~ (form.priorite.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.priorite.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.priorite.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label required'}}) }}
                                {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Titre de votre demande'}}) }}
                                {% if form.titre.vars.errors %}
                                    <div class="field-error">
                                        {% for error in form.titre.vars.errors %}{{ error.message }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="mb-0">
                                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                            </div>
                        </div>
                    </div>

                    <div class="card mb-3" id="dynamicFieldsCard" style="{{ submittedType ? 'display:block;' : 'display:none;' }}">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations spécifiques</h3>
                        </div>
                        <div class="card-body">
                            <div id="autreAiBox" class="autre-ai-box mb-3" style="display:none;">
                                <label for="autreAiDescription" class="form-label required">Description initiale pour assistant IA</label>
                                <textarea
                                    id="autreAiDescription"
                                    name="autre_ai_description"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Decrivez ce dont vous avez besoin. L IA proposera une description plus claire et remplira les champs specifiques."
                                >{{ submittedAiDescription|default('') }}</textarea>
                                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                    <button type="button" class="btn btn-outline-primary" id="generateWithAiBtn">
                                        <i class="ti ti-sparkles me-1"></i>Generer avec IA
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="regenerateWithAiBtn" style="display:none;">
                                        <i class="ti ti-refresh me-1"></i>Regenerer
                                    </button>
                                    <span id="aiStatusText" class="ai-status"></span>
                                </div>
                            </div>
                            <div class="row g-3" id="dynamicFields"></div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-send me-2"></i>Actions</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary" id="submitBtn">
                                    <i class="ti ti-check me-1"></i>Créer la demande
                                </button>
                                <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">Annuler</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-lightbulb me-2"></i>Conseils</h3>
                        </div>
                        <div class="card-body">
                            <div style="font-size: 0.95rem; line-height: 1.6; color: #555;">
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Titre clair :</strong> Utilisez un titre court et descriptif pour votre demande.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Priorité :</strong> Sélectionnez le niveau de priorité approprié à votre besoin.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Description :</strong> Fournissez des détails pertinents pour faciliter le traitement.</span>
                                </div>
                                <div style="display: flex;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Champs spécifiques :</strong> Remplissez tous les champs dynamiques requis selon le type choisi.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
</div>

<div class="modal" id="aiConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            <div class="modal-status bg-primary"></div>
            <div class="modal-body py-4">
                <h3 class="mb-2">Confirmer cette demande generee avec IA ?</h3>
                <p class="text-secondary mb-3">Verifiez les informations ci-dessous avant enregistrement. Si ce n est pas exact, vous pouvez modifier ou regenerer.</p>
                <div id="aiConfirmPreview" class="border rounded p-3" style="background:#f8fafc;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn" data-bs-dismiss="modal" id="aiModalRejectBtn">Non, je modifie</button>
                <button type="button" class="btn btn-outline-secondary" id="aiModalRegenerateBtn">M aider a regenerer</button>
                <button type="button" class="btn btn-primary" id="aiModalConfirmBtn">
                        <i class="ti ti-check me-1"></i>Oui, enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

{{ include('demande/_logout_modal.html.twig') }}
