    function canonicalAutreFieldSignature(field) {
        if (!field || typeof field !== "object") return "";

        var key = normalizeUiLabel(String(field.key || ""));
        var label = normalizeUiLabel(String(field.label || ""));
        var type = normalizeUiLabel(String(field.type || "text"));

        var canonical = key;
        if (canonical.indexOf("ai ") === 0) {
            canonical = canonical.slice(3);
        }

        if (canonical.indexOf("date souhaitee") !== -1 || canonical.indexOf("datesouhaitee") !== -1) {
            canonical = "date_souhaitee";
        } else if (canonical.indexOf("nom formation") !== -1 || canonical.indexOf("nom de la formation") !== -1) {
            canonical = "nom_formation";
        } else if (canonical.indexOf("type formation") !== -1) {
            canonical = "type_formation";
        } else if (canonical.indexOf("lieu depart") !== -1) {
            canonical = "lieu_depart";
        } else if (canonical.indexOf("lieu souhaite") !== -1 || canonical.indexOf("destination") !== -1) {
            canonical = "lieu_destination";
        } else if (canonical.indexOf("type transport") !== -1) {
            canonical = "type_transport";
        }

        if (!canonical) {
            canonical = label;
        }

        return canonical + "|" + type;
    }

    function scoreAutreFieldForDedup(field) {
        if (!field || typeof field !== "object") return 0;

        var score = 0;
        var key = String(field.key || "");
        var type = String(field.type || "");

        if (key && key.indexOf("ai_") !== 0) score += 4;
        if (!!field.required) score += 2;
        if (type !== "hidden") score += 1;

        return score;
    }

    function dedupeAutreComposedFields(fields) {
        if (!Array.isArray(fields) || fields.length <= 1) {
            return Array.isArray(fields) ? fields : [];
        }

        var bySignature = {};
        var ordered = [];

        for (var i = 0; i < fields.length; i++) {
            var candidate = fields[i];
            if (!candidate || typeof candidate !== "object") continue;

            var signature = canonicalAutreFieldSignature(candidate);
            if (!signature) {
                ordered.push(candidate);
                continue;
            }

            if (!bySignature[signature]) {
                bySignature[signature] = {
                    field: candidate,
                    score: scoreAutreFieldForDedup(candidate)
                };
                ordered.push(candidate);
                continue;
            }

            var current = bySignature[signature];
            var incomingScore = scoreAutreFieldForDedup(candidate);
            if (incomingScore > current.score) {
                var idx = ordered.indexOf(current.field);
                if (idx >= 0) {
                    ordered[idx] = candidate;
                }
                bySignature[signature] = {
                    field: candidate,
                    score: incomingScore
                };
            }
        }

        return ordered;
    }

