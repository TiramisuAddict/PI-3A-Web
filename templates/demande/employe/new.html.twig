    function applyClassificationSuggestion(suggestion, categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard) {
        if (!suggestion || typeof suggestion !== "object") return;

        var correctedText = String(suggestion.correctedText || "").trim();
        var categorie = resolveCategoryLabel(String(suggestion.categorie || "").trim());
        var typeDemande = String(suggestion.typeDemande || "").trim();
        var priorite = String(suggestion.priorite || "").trim().toUpperCase();
        var titre = String(suggestion.titre || "").trim();
        var description = String(suggestion.description || "").trim();
        var suggestedDetails = suggestion.suggestedDetails && typeof suggestion.suggestedDetails === "object"
            ? suggestion.suggestedDetails
            : {};
        setAutoFilledDetailKeys(Object.keys(suggestedDetails));

        if (correctedText) {
            var promptInput = document.getElementById("classificationAiPrompt");
            if (promptInput) promptInput.value = correctedText;
        }

        if (categorie && CATEGORIES[categorie]) {
            categorieSelect.value = categorie;
            rebuildTypeOptionsForCategory(typeSelect, categorie);
            updateTypeInfo(typeInfo, categorie);
        }

        if (typeDemande) {
            typeDemande = resolveTypeOptionValue(typeSelect, typeDemande);
            var canApplyType = false;
            for (var i = 0; i < typeSelect.options.length; i++) {
                if (String(typeSelect.options[i].value || "") === typeDemande) {
                    canApplyType = true;
                    break;
                }
            }

            if (canApplyType) {
                typeSelect.value = typeDemande;
            }
        }

        var prioriteInput = document.getElementById("demande_priorite");
        if (prioriteInput && priorite) {
            prioriteInput.value = priorite;
        }

        var titreInput = document.getElementById("demande_titre");
        if (titreInput && titre) {
            var existingTitle = String(titreInput.value || "").trim();
            if (!existingTitle) {
                titreInput.value = titre;
            }
        }

        var descriptionInput = document.getElementById("demande_description");
        if (descriptionInput && description) {
            descriptionInput.value = description;
        }

        var aiGeneratedInput = document.getElementById("aiGeneratedInput");
        var aiConfirmedInput = document.getElementById("aiConfirmedInput");
        var aiTrustedLearningInput = document.getElementById("aiTrustedLearningInput");
        if (aiGeneratedInput) aiGeneratedInput.value = "1";
        if (aiConfirmedInput) aiConfirmedInput.value = "0";
        if (aiTrustedLearningInput) aiTrustedLearningInput.value = "0";
        resetAiFieldPlan();
        setAiStatus("", "");
        updateAutreAiControls(typeDemande);

        if (typeDemande) {
            loadDynamicFields(typeDemande, suggestedDetails, dynamicFieldsContainer, dynamicFieldsCard);
        } else {
            dynamicFieldsCard.style.display = "none";
            dynamicFieldsContainer.innerHTML = "";
        }
    }

    function requestClassificationSuggestion(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard) {
        var button = document.getElementById("suggestClassificationBtn");
        var promptInput = document.getElementById("classificationAiPrompt");
        var aiGeneratedInput = document.getElementById("aiGeneratedInput");
        var aiConfirmedInput = document.getElementById("aiConfirmedInput");
        var aiTrustedLearningInput = document.getElementById("aiTrustedLearningInput");
        var originalText = button ? button.innerHTML : "";
        var rawText = promptInput ? String(promptInput.value || "").trim() : "";

        if (!rawText) {
            setClassificationStatus("Ajoutez une description avant de lancer la suggestion.", "error");
            if (promptInput) promptInput.focus();
            updateClassificationSummary(null);
            return;
        }

        if (button) {
            button.disabled = true;
            button.innerHTML = "<span class='spinner-border spinner-border-sm me-1'></span>Analyse...";
        }

        setClassificationStatus("Correction et classement en cours...", "info");

        fetch(CLASSIFICATION_AI_ENDPOINT, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({ text: rawText })
        })
            .then(function (response) {
                return response.json().then(function (json) {
                    if (!response.ok || !json.success) {
                        throw new Error(json.message || "Suggestion IA impossible.");
                    }
                    return json;
                });
            })
            .then(function (json) {
                var suggestion = json.suggestion || {};
                applyClassificationSuggestion(suggestion, categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard);
                updateClassificationSummary(suggestion);
                if (aiGeneratedInput) aiGeneratedInput.value = "1";
                if (aiConfirmedInput) aiConfirmedInput.value = "0";
                if (aiTrustedLearningInput) aiTrustedLearningInput.value = "0";
                setClassificationStatus("Texte corrige et demande classee automatiquement.", "success");
            })
            .catch(function (error) {
                console.error(error);
                setAutoFilledDetailKeys([]);
                updateClassificationSummary(null);
                setClassificationStatus(error.message || "Suggestion IA impossible.", "error");
            })
            .finally(function () {
                if (button) {
                    button.disabled = false;
                    button.innerHTML = originalText;
                }
            });
    }

    function requestDescriptionGeneration(options) {
        var opts = options || {};
        var trigger = opts.trigger === "auto" ? "auto" : "manual";
        var forceApply = true === opts.forceApply;
        var button = document.getElementById("generateDescriptionBtn");
        var titleInput = document.getElementById("demande_titre");
        var descriptionInput = document.getElementById("demande_description");
        var categorieInput = document.getElementById("demande_categorie");
        var typeInput = document.getElementById("demande_typeDemande");
        var autoToggle = document.getElementById("autoGenerateDescriptionToggle");
        var sendToSuggestionToggle = document.getElementById("sendDescriptionToSuggestionToggle");
        var aiGeneratedInput = document.getElementById("aiGeneratedInput");
        var aiConfirmedInput = document.getElementById("aiConfirmedInput");
        var originalText = button ? button.innerHTML : "";
        var title = titleInput ? String(titleInput.value || "").trim() : "";

        if ("auto" === trigger) {
            if (!autoToggle || !autoToggle.checked) {
                return;
            }

            if (!title || title.length < 4 || title === lastAutoGeneratedTitle) {
                return;
            }

            if (
                descriptionInput &&
                descriptionManuallyEdited &&
                String(descriptionInput.value || "").trim() !== "" &&
                !forceApply
            ) {
                return;
            }
        }

        if (isDescriptionRequestInFlight) {
            if ("manual" === trigger) {
                setDescriptionAiStatus("Une generation est deja en cours...", "info");
            }
            return;
        }

        if (!title) {
            if ("manual" === trigger) {
                setDescriptionAiStatus("Ajoutez un titre avant de lancer l IA.", "error");
                if (titleInput) titleInput.focus();
            }
            return;
        }

        if ("manual" === trigger && button) {
            button.disabled = true;
            button.innerHTML = "<span class='spinner-border spinner-border-sm me-1'></span>Generation...";
        }

        isDescriptionRequestInFlight = true;

        if ("manual" === trigger) {
            setDescriptionAiStatus("Generation de la description en cours...", "info");
        }

        fetch(DESCRIPTION_AI_ENDPOINT, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({
                title: title,
                categorie: (categorieInput || {}).value || "",
                typeDemande: (typeInput || {}).value || ""
            })
        })
            .then(function (response) {
                return response.json().then(function (json) {
                    if (!response.ok || !json.success) {
                        throw new Error(json.message || "Generation IA impossible.");
                    }
                    return json;
                });
            })
            .then(function (json) {
                var generatedDescription = String(json.description || "").trim();
                if ("" === generatedDescription) {
                    return;
                }

                var shouldApply = true;
                if (
                    "auto" === trigger &&
                    descriptionInput &&
                    String(descriptionInput.value || "").trim() !== "" &&
                    descriptionManuallyEdited &&
                    !forceApply
                ) {
                    shouldApply = false;
                }

                if (descriptionInput && shouldApply) {
                    setDescriptionValueFromAi(descriptionInput, generatedDescription);
                    lastAutoGeneratedTitle = title;
                }

                if (aiGeneratedInput) aiGeneratedInput.value = "1";
                if (aiConfirmedInput) aiConfirmedInput.value = "0";
                if (aiTrustedLearningInput) aiTrustedLearningInput.value = "0";

                if (sendToSuggestionToggle && sendToSuggestionToggle.checked) {
                    setSuggestionPromptFromGeneratedDescription(generatedDescription);
                }

                if ("manual" === trigger) {
                    if (sendToSuggestionToggle && sendToSuggestionToggle.checked) {
                        setDescriptionAiStatus("Description proposee par IA et envoyee vers Suggestion IA.", "success");
                    } else {
                        setDescriptionAiStatus("Description proposee par IA. Vous pouvez la modifier librement.", "success");
                    }
                    return;
                }

                if (shouldApply) {
                    setDescriptionAiStatus("Description suggeree automatiquement depuis le titre.", "success");
                }
            })
            .catch(function (error) {
                console.error(error);
                if ("manual" === trigger) {
                    setDescriptionAiStatus(error.message || "Generation IA impossible.", "error");
                }
            })
            .finally(function () {
                isDescriptionRequestInFlight = false;
                if (button) {
                    button.disabled = false;
                    button.innerHTML = originalText;
                }
            });
    }

    function applyCategoryAndAutreType(categorieSelect, typeSelect, typeInfo, detectedCategory, silent, sourceText, suggestedType) {
        if (!detectedCategory || !CATEGORIES[detectedCategory]) return false;

        var changed = false;
        var isSilent = true === silent;

        if (categorieSelect.value !== detectedCategory) {
            categorieSelect.value = detectedCategory;
            if (isSilent) {
                rebuildTypeOptionsForCategory(typeSelect, detectedCategory);
                if (typeInfo) {
                    typeInfo.textContent = CATEGORIES[detectedCategory].length + " types disponibles";
                    typeInfo.style.color = "green";
                }
            } else {
                categorieSelect.dispatchEvent(new Event("change"));
            }
            changed = true;
        }

        var targetType = resolveTypeOptionValue(typeSelect, String(suggestedType || "").trim());
        var canApplyTargetType = false;
        if (targetType) {
            for (var i = 0; i < typeSelect.options.length; i++) {
                if (String(typeSelect.options[i].value || "") === targetType) {
                    canApplyTargetType = true;
                    break;
                }
            }
        }

        if (!canApplyTargetType) {
            targetType = inferTypeForCategoryFromText(detectedCategory, sourceText || "");
            canApplyTargetType = !!targetType;
        }

        if (!canApplyTargetType) {
            var hasAutreType = !!typeSelect.querySelector('option[value="Autre"]');
            targetType = hasAutreType ? "Autre" : "";
            canApplyTargetType = !!targetType;
        }

        if (canApplyTargetType && typeSelect.value !== targetType) {
            typeSelect.value = targetType;
            if (!isSilent) {
                typeSelect.dispatchEvent(new Event("change"));
            }
            changed = true;
        }

        return changed;
    }

    function autoAdjustCategoryForAutreFlow(categorieSelect, typeSelect, typeInfo, sourceTextOverride) {
        if (!categorieSelect || !typeSelect) return false;
        if (!isAutreType(typeSelect.value)) return false;

        var sourceText = String(sourceTextOverride || "").trim();
        if (!sourceText) {
            sourceText = [
                (document.getElementById("autreAiDescription") || {}).value || "",
                (document.getElementById("demande_description") || {}).value || "",
                (document.getElementById("demande_titre") || {}).value || ""
            ].join(" ");
        }

        var detectedCategory = inferCategoryFromDescriptionText(sourceText);
        if (!detectedCategory) return false;

        var changed = applyCategoryAndAutreType(categorieSelect, typeSelect, typeInfo, detectedCategory, true, sourceText, "");
        if (changed) {
            setAiStatus("Categorie ajustee automatiquement: " + detectedCategory + ".", "");
        }

        return changed;
    }

    function applyAiSuggestedCategory(suggestedGeneral, categorieSelect, typeSelect, typeInfo) {
        if (!suggestedGeneral || typeof suggestedGeneral !== "object") return false;
        var suggestedCategory = resolveCategoryLabel(String(suggestedGeneral.categorie || "").trim());

        var sourceText = [
            String(suggestedGeneral.description || "").trim(),
            String(suggestedGeneral.titre || "").trim(),
            (document.getElementById("autreAiDescription") || {}).value || "",
            (document.getElementById("demande_description") || {}).value || "",
            (document.getElementById("demande_titre") || {}).value || ""
        ].join(" ");
        var suggestedType = String(suggestedGeneral.typeDemande || "").trim();

        if (!suggestedCategory || !CATEGORIES[suggestedCategory]) {
            suggestedCategory = inferCategoryFromDescriptionText(sourceText);
        }
        if (!suggestedCategory || !CATEGORIES[suggestedCategory]) return false;

        var changed = applyCategoryAndAutreType(categorieSelect, typeSelect, typeInfo, suggestedCategory, true, sourceText, suggestedType);
        if (changed) {
            setAiStatus("Categorie ajustee par IA: " + suggestedCategory + ".", "");
        }

        return changed;
    }

    function escapeHtml(text) {
        var value = String(text || "");
        return value
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function buildConfirmationPreview(container) {
        var general = collectGeneralContext();
        var details = collectCurrentDetails(container);
        var detailsRows = "";

        Object.keys(details).forEach(function (key) {
            var value = String(details[key] || "").trim();
            if (!value) return;
            detailsRows += "<tr><td style='width:35%;font-weight:600;'>" + escapeHtml(key) + "</td><td>" + escapeHtml(value) + "</td></tr>";
        });

        if (!detailsRows) {
            detailsRows = "<tr><td colspan='2' class='text-secondary'>Aucun detail specifique rempli.</td></tr>";
        }

        return ""
            + "<div class='mb-3'><h4 style='font-size:1rem;'>Informations generales</h4>"
            + "<p class='mb-1'><strong>Categorie:</strong> " + escapeHtml(general.categorie) + "</p>"
            + "<p class='mb-1'><strong>Type:</strong> " + escapeHtml(general.typeDemande) + "</p>"
            + "<p class='mb-1'><strong>Titre:</strong> " + escapeHtml(general.titre) + "</p>"
            + "<p class='mb-1'><strong>Priorite:</strong> " + escapeHtml(general.priorite) + "</p>"
            + "<p class='mb-0'><strong>Description:</strong> " + escapeHtml(general.description) + "</p></div>"
            + "<div><h4 style='font-size:1rem;'>Informations specifiques</h4>"
            + "<div class='table-responsive'><table class='table table-sm mb-0'><tbody>" + detailsRows + "</tbody></table></div></div>";
    }

    function closeAiModal(modalInstance, modalEl) {
        if (modalInstance) {
            modalInstance.hide();
            return;
        }

        if (modalEl) {
            modalEl.classList.remove("show");
            modalEl.style.display = "none";
        }

        // Manual fallback cleanup when Bootstrap modal JS API is not available.
        document.body.classList.remove("modal-open");
        document.body.style.removeProperty("padding-right");

        var backdrops = document.querySelectorAll(".modal-backdrop");
        for (var i = 0; i < backdrops.length; i++) {
            backdrops[i].remove();
        }
    }

    function markFormSubmitting(submitBtn, aiModalConfirmBtn) {
        isSubmittingForm = true;
        if (submitBtn) {
            submitBtn.disabled = true;
        }
        if (aiModalConfirmBtn) {
            aiModalConfirmBtn.disabled = true;
        }
    }

    function shouldRequireAiConfirmation(typeSelect, aiGeneratedInput, regenerateWithAiBtn, aiTrustedLearningInput) {
        if (MANUAL_AUTRE_FIELD_MODE) {
            return !!(typeSelect && isAutreType(typeSelect.value) && AI_DYNAMIC_FIELDS.length > 0);
        }

        if (aiGeneratedInput && aiGeneratedInput.value === "1") {
            return true;
        }

        if (!typeSelect || !isAutreType(typeSelect.value)) {
            return false;
        }

        return !!(regenerateWithAiBtn && regenerateWithAiBtn.style.display !== "none");
    }

    function buildAutreConfidenceMessage(confidence) {
        if (!confidence || typeof confidence !== "object") {
            return { text: "", tone: "" };
        }

        var score = Number(confidence.score || 0);
        var label = String(confidence.label || "").trim();
        var message = String(confidence.message || "").trim();
        var tone = String(confidence.tone || "info").trim().toLowerCase();
        if (tone === "warning") {
            tone = "info";
        }
        if (tone !== "success" && tone !== "info" && tone !== "error") {
            tone = "info";
        }

        if (!label && !message) {
            return { text: "", tone: "" };
        }

        var parts = [];
        if (label) {
            parts.push("Confiance du plan: " + label + (score > 0 ? " (" + score + "%)" : ""));
        }
        if (message) {
            parts.push(message);
        }

        return {
            text: parts.join(". "),
            tone: tone || "info"
        };
    }

    function requestAutreAiGeneration(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard, options) {
        options = options || {};
        var mode = String(options.mode || "generate").toLowerCase();
        var forceFresh = true === options.forceFresh;
        var generateBtn = document.getElementById("generateWithAiBtn");
        var regenerateBtn = document.getElementById("regenerateWithAiBtn");
        var autrePromptInput = document.getElementById("autreAiDescription");
        var aiGeneratedInput = document.getElementById("aiGeneratedInput");
        var aiConfirmedInput = document.getElementById("aiConfirmedInput");
        var aiTrustedLearningInput = document.getElementById("aiTrustedLearningInput");
        var originalText = generateBtn ? generateBtn.innerHTML : "";
        var requestId = ++autreGenerationRequestId;
        var promptValue = String((autrePromptInput || {}).value || "").trim();
        syncAutreRawPromptFromVisible(false);

        var general = collectGeneralContext();
        general.aiDescriptionPrompt = promptValue;

        if (!promptValue) {
            setAiStatus("Ajoutez une description initiale avant de lancer l IA.", "error");
            var promptInput = document.getElementById("autreAiDescription");
            if (promptInput) promptInput.focus();
            return;
        }

        if (!isAutreType(typeSelect.value)) {
            setAiStatus("La generation IA est disponible uniquement pour le type Autre.", "error");
            return;
        }

        general = collectGeneralContext();
        general.aiDescriptionPrompt = promptValue;
        general.manualFieldMode = MANUAL_AUTRE_FIELD_MODE;
        var promptNormalized = normalizeUiLabel(promptValue);
        var requestPromptNormalized = promptNormalized;
        var promptChanged = !!lastAutrePromptNormalized && promptNormalized !== lastAutrePromptNormalized;

        if (promptChanged) {
            autreRegenerateCount = 0;
        } else if (mode === "regenerate") {
            autreRegenerateCount += 1;
        } else {
            autreRegenerateCount = 0;
        }

        general.regenerateMode = mode;
        general.regenerateCount = autreRegenerateCount;

        var shouldClearExistingAutreState = !MANUAL_AUTRE_FIELD_MODE && (promptChanged || forceFresh || mode === "regenerate");
        var details = MANUAL_AUTRE_FIELD_MODE ? collectCurrentDetails(dynamicFieldsContainer) : {};
        if (shouldClearExistingAutreState) {
            resetAiFieldPlan();
            setAutoFilledDetailKeys([]);
            clearDynamicFieldState(dynamicFieldsContainer);
            general.manualFieldMode = MANUAL_AUTRE_FIELD_MODE;
        }

        if (generateBtn) {
            generateBtn.disabled = true;
            generateBtn.innerHTML = "<span class='spinner-border spinner-border-sm me-1'></span>Generation...";
        }
        if (regenerateBtn) regenerateBtn.disabled = true;
        if (aiTrustedLearningInput) aiTrustedLearningInput.value = "0";
        setAiStatus("Generation IA en cours...", "");
        clearAutreConfidenceBadge();

        var requestPayload = {
            general: general,
            details: details,
            userPromptAutre: promptValue,
            manualFieldMode: MANUAL_AUTRE_FIELD_MODE,
            fieldPlan: (function () {
                var planInput = document.getElementById("aiFieldPlanInput");
                if (!planInput) {
                    return { add: [], remove: [], replaceBase: false };
                }

                try {
                    var parsedPlan = JSON.parse(String(planInput.value || "{}"));
                    return parsedPlan && typeof parsedPlan === "object" ? parsedPlan : { add: [], remove: [], replaceBase: false };
                } catch (error) {
                    return { add: [], remove: [], replaceBase: false };
                }
            })()
        };

        fetch(AUTRE_AI_ENDPOINT, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify(requestPayload)
        })
            .then(function (response) {
                return response.json().then(function (json) {
                    if (!response.ok || !json.success) {
                        throw new Error(json.message || "Generation IA impossible.");
                    }
                    return json;
                });
            })
            .then(function (json) {
                if (requestId < autreGenerationRequestId || requestId < latestAppliedAutreGenerationRequestId) {
                    return;
                }
                latestAppliedAutreGenerationRequestId = requestId;

                var currentPromptNormalized = normalizeUiLabel(String((autrePromptInput || {}).value || ""));
                if (currentPromptNormalized && currentPromptNormalized !== requestPromptNormalized) {
                    setAiStatus("La description initiale a change. Relancez la generation pour utiliser le texte courant.", "info");
                    clearAutreConfidenceBadge();
                    return;
                }
                lastAutrePromptNormalized = requestPromptNormalized;

                var previousDynamicKeys = {};
                for (var p = 0; p < AI_DYNAMIC_FIELDS.length; p++) {
                    var previousField = AI_DYNAMIC_FIELDS[p];
                    if (!previousField || !previousField.key) continue;
                    previousDynamicKeys[String(previousField.key)] = true;
                }

                var fieldPlan;
                if (MANUAL_AUTRE_FIELD_MODE) {
                    fieldPlan = normalizeAiFieldPlan({
                        add: AI_DYNAMIC_FIELDS,
                        remove: AI_REMOVED_BASE_FIELDS,
                        replaceBase: true,
                        manualMode: true
                    });
                } else {
                    fieldPlan = normalizeAiFieldPlan(json.dynamicFieldPlan || { add: [], remove: [], replaceBase: false });
                    fieldPlan.manualMode = String(json.model || "").indexOf("manual-fields:") === 0;
                }
                setAiFieldPlan(fieldPlan);

                var shouldReplaceBase = shouldClearExistingAutreState || true === fieldPlan.replaceBase;
                var merged = shouldReplaceBase
                    ? resetAutreReplaceBaseState(dynamicFieldsContainer)
                    : {};
                if (!shouldReplaceBase) {
                    var currentKeys = Object.keys(details);
                    for (var i = 0; i < currentKeys.length; i++) {
                        var currentKey = currentKeys[i];
                        if (previousDynamicKeys[currentKey] && !isAutreBaseRequiredKey(currentKey)) {
                            continue;
                        }
                        merged[currentKey] = details[currentKey];
                    }
                }

                var suggestedDetails = json.suggestedDetails && typeof json.suggestedDetails === "object"
                    ? json.suggestedDetails
                    : {};
                if (fieldPlan.manualMode) {
                    var allowedSuggestionKeys = {};
                    for (var rk = 0; rk < AUTRE_BASE_REQUIRED_KEYS.length; rk++) {
                        allowedSuggestionKeys[AUTRE_BASE_REQUIRED_KEYS[rk]] = true;
                    }
                    for (var ak = 0; ak < fieldPlan.add.length; ak++) {
                        var allowedField = fieldPlan.add[ak];
                        if (!allowedField || !allowedField.key) continue;
                        allowedSuggestionKeys[String(allowedField.key)] = true;
                    }

                    var filteredSuggestedDetails = {};
                    var suggestedKeys = Object.keys(suggestedDetails);
                    for (var sk = 0; sk < suggestedKeys.length; sk++) {
                        var suggestedKey = suggestedKeys[sk];
                        if (!allowedSuggestionKeys[suggestedKey]) continue;
                        filteredSuggestedDetails[suggestedKey] = suggestedDetails[suggestedKey];
                    }
                    suggestedDetails = filteredSuggestedDetails;
                }

                if (fieldPlan.manualMode) {
                    resetAiGenerationSnapshot();
                } else {
                    saveAiGenerationSnapshot(suggestedDetails, fieldPlan, json.model || "");
                }

                var suggestionKeys = Object.keys(suggestedDetails);
                for (var j = 0; j < suggestionKeys.length; j++) {
                    merged[suggestionKeys[j]] = suggestedDetails[suggestionKeys[j]];
                }

                var autoFilledKeys = suggestionKeys.slice();
                for (var af = 0; af < fieldPlan.add.length; af++) {
                    var autoField = fieldPlan.add[af];
                    if (autoField && autoField.key) {
                        autoFilledKeys.push(autoField.key);
                    }
                }
                setAutoFilledDetailKeys(autoFilledKeys);

                for (var r = 0; r < fieldPlan.remove.length; r++) {
                    delete merged[fieldPlan.remove[r]];
                }

                for (var a = 0; a < fieldPlan.add.length; a++) {
                    var customField = fieldPlan.add[a];
                    if (!customField || !customField.key) continue;
                    if (shouldReplaceBase || typeof merged[customField.key] === "undefined" || merged[customField.key] === "") {
                        merged[customField.key] = customField.value || "";
                    }
                }

                var generatedDescription = String(json.generatedDescription || "").trim();
                var suggestedGeneralTitle = String((json.suggestedGeneral || {}).titre || "").trim();
                var suggestedGeneralDescription = String((json.suggestedGeneral || {}).description || "").trim();
                var aiGeneratedDescription = generatedDescription || suggestedGeneralDescription;

                if (shouldReplaceBase) {
                    if (generatedDescription) {
                        merged.descriptionBesoin = generatedDescription;
                    }

                    if (!String(merged.besoinPersonnalise || "").trim() && suggestedGeneralTitle) {
                        merged.besoinPersonnalise = suggestedGeneralTitle;
                    }

                    if (!String(merged.descriptionBesoin || "").trim() && aiGeneratedDescription) {
                        merged.descriptionBesoin = aiGeneratedDescription;
                    }
                } else {
                    if (json.generatedDescription && !merged.descriptionBesoin) {
                        merged.descriptionBesoin = json.generatedDescription;
                    }

                    if (!String(merged.descriptionBesoin || "").trim() && aiGeneratedDescription) {
                        merged.descriptionBesoin = aiGeneratedDescription;
                    }

                    if (!String(merged.besoinPersonnalise || "").trim() && suggestedGeneralTitle) {
                        merged.besoinPersonnalise = suggestedGeneralTitle;
                    }
                }

                // Keep the ML response authoritative for the general section.
                applySuggestedGeneralFields(json.suggestedGeneral || {});

                var currentType = String((typeSelect || {}).value || "");
                var isStillAutre = isAutreType(currentType);
                updateAutreAiControls(currentType);

                if (isStillAutre) {
                    if (shouldReplaceBase) {
                        dynamicFieldsContainer.innerHTML = "";
                    }
                    loadDynamicFields(currentType, merged, dynamicFieldsContainer, dynamicFieldsCard);
                } else {
                    setAutoFilledDetailKeys([]);
                    loadDynamicFields(currentType, {}, dynamicFieldsContainer, dynamicFieldsCard);
                }

                if (fieldPlan.manualMode) {
                    if (aiGeneratedInput) aiGeneratedInput.value = "0";
                    if (aiConfirmedInput) aiConfirmedInput.value = "1";
                } else {
                    if (aiGeneratedInput) aiGeneratedInput.value = "1";
                    if (aiConfirmedInput) aiConfirmedInput.value = "0";
                }
                if (aiTrustedLearningInput) {
                    aiTrustedLearningInput.value = json.skipConfirmationRestriction ? "1" : "0";
                }

                if (isStillAutre && regenerateBtn) regenerateBtn.style.display = fieldPlan.manualMode ? "none" : "inline-block";
                if (isStillAutre) {
                    var confidenceStatus = buildAutreConfidenceMessage(json.dynamicFieldConfidence || null);
                    var baseMessage = "Champs Autre pre-remplis par IA.";
                    var finalMessage = confidenceStatus.text
                        ? baseMessage + " " + confidenceStatus.text
                        : baseMessage + " Verifiez puis confirmez la creation.";
                    setAiStatus(finalMessage, confidenceStatus.tone || "success");
                    setAutreConfidenceBadge(confidenceStatus);

                    if (aiConfirmPreview) {
                        aiConfirmPreview.innerHTML = buildConfirmationPreview(dynamicFieldsContainer);
                    }
                } else {
                    setAiStatus("Type ajuste automatiquement vers " + currentType + ". Le bloc IA Autre est masque.", "info");
                    clearAutreConfidenceBadge();
                }
            })
            .catch(function (error) {
                setAiStatus(error.message || "Une erreur est survenue pendant la generation IA.", "error");
                clearAutreConfidenceBadge();
            })
            .finally(function () {
                if (generateBtn) {
                    generateBtn.disabled = false;
                    generateBtn.innerHTML = originalText;
                }
                if (regenerateBtn) regenerateBtn.disabled = false;
            });
    }

    function hasFieldError(key) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === key) return true;
        }
        return false;
    }

    function getFieldErrorMessage(key) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === key) return DETAIL_ERRORS[i].message;
        }
        return "";
    }

    function renderDynamicFields(fields, existingValues, container) {
        container.innerHTML = "";
        maps = {};
        markers = {};
        selectedLocations = {};

        for (var i = 0; i < fields.length; i++) {
            var field = fields[i];
            var existingValue = existingValues[field.key] || "";
            var errClass = hasFieldError(field.key) ? " is-invalid-custom" : "";

            if (field.type === "hidden") {
                container.appendChild(buildInput(field, existingValue, ""));
                continue;
            }

            if (field.type === "location") {
                var fullCol = document.createElement("div");
                fullCol.className = "col-12";
                fullCol.appendChild(buildLocationField(field, existingValue, existingValues));
                container.appendChild(fullCol);
            } else {
                var col = document.createElement("div");
                col.className = field.type === "textarea" ? "col-12" : "col-md-6";
                col.appendChild(buildLabel(field));
                col.appendChild(buildInput(field, existingValue, errClass));
                appendFieldError(col, field.key);
                container.appendChild(col);
            }
        }

        syncAutreMirroredFields();

        setTimeout(function () {
            autoFillNombreJours();
        }, 100);
    }

    function appendFieldError(container, key) {
        var message = getFieldErrorMessage(key);
        if (!message) return;
        var error = document.createElement("div");
        error.className = "field-error";
        error.textContent = message;
        container.appendChild(error);
    }

    function applyInputConstraints(inputEl, field) {
        if (!inputEl || !field) return;

        var isRequired = !!field.required && field.type !== "hidden";
        if (isRequired) {
            inputEl.required = true;
            inputEl.setAttribute("data-required", "1");
        }

        inputEl.setAttribute("data-field-key", String(field.key || ""));
        inputEl.setAttribute("data-field-label", String(field.label || field.key || ""));
    }

    function getInputLabelText(inputEl) {
        if (!inputEl) return "ce champ";

        var directLabel = String(inputEl.getAttribute("data-field-label") || "").trim();
        if (directLabel) {
            return directLabel;
        }

        var id = String(inputEl.id || "").trim();
        if (id) {
            var labelEl = document.querySelector('label[for="' + id.replace(/"/g, '\\"') + '"]');
            if (labelEl) {
                return String(labelEl.textContent || "").replace(/\*/g, "").trim() || "ce champ";
            }
        }

        var name = String(inputEl.getAttribute("name") || "").trim();
        if (name) {
            return name
                .replace(/^details\[/, "")
                .replace(/^demande\[/, "")
                .replace(/\]$/, "")
                .replace(/_/g, " ") || "ce champ";
        }

        return "ce champ";
    }

    function clearClientFieldErrors(form) {
        if (!form) return;

        var errors = form.querySelectorAll(".client-field-error");
        for (var i = 0; i < errors.length; i++) {
            errors[i].remove();
        }

        var invalidInputs = form.querySelectorAll(".client-invalid");
        for (var j = 0; j < invalidInputs.length; j++) {
            invalidInputs[j].classList.remove("client-invalid");
            invalidInputs[j].classList.remove("is-invalid");
            invalidInputs[j].classList.remove("is-invalid-custom");
            invalidInputs[j].classList.remove("is-valid");
            invalidInputs[j].classList.remove("client-valid");
        }

    }

    function resolveInputLabelElement(inputEl) {
        if (!inputEl) return null;

        var form = inputEl.closest("form") || document;
        var id = String(inputEl.id || "").trim();
        if (id) {
            var byFor = form.querySelector('label[for="' + id.replace(/"/g, '\\"') + '"]');
            if (byFor) return byFor;
        }

        var fieldKey = String(inputEl.getAttribute("data-field-key") || "").trim();
        if (fieldKey) {
            var escaped = fieldKey.replace(/"/g, '\\"');
            var byKey = form.querySelector('label[data-field-key="' + escaped + '"]');
            if (byKey) return byKey;
        }

        var group = inputEl.closest(".mb-3, .col-md-6, .col-12");
        if (group) {
            return group.querySelector("label.form-label");
        }

        return null;
    }

    function setInputLabelValidState(inputEl, isValid) {
        var labelEl = resolveInputLabelElement(inputEl);
        if (!labelEl) return;

        if (isValid) {
            labelEl.classList.add("field-label-valid");
        } else {
            labelEl.classList.remove("field-label-valid");
        }
    }

    function getClientFieldToken(inputEl) {
        if (!inputEl) return "";
        var byName = String(inputEl.getAttribute("name") || "").trim();
        if (byName) return byName;
        return String(inputEl.id || "").trim();
    }

    function clearClientErrorForInput(inputEl) {
        if (!inputEl) return;
        var token = getClientFieldToken(inputEl);
        if (!token) return;

        var form = inputEl.closest("form");
        if (!form) return;

        var escaped = token.replace(/"/g, '\\"');
        var errors = form.querySelectorAll('.client-field-error[data-field="' + escaped + '"]');
        for (var i = 0; i < errors.length; i++) {
            errors[i].remove();
        }
    }

    function updateClientFieldVisualState(inputEl) {
        if (!inputEl || inputEl.disabled) return;

        var inputType = String(inputEl.type || "").toLowerCase();
        if (inputType === "hidden") return;

        var isRequired = inputEl.hasAttribute("required") || inputEl.getAttribute("data-required") === "1";
        if (!isRequired) return;

        var value = String(inputEl.value || "").trim();
        if (value === "") {
            inputEl.classList.remove("is-valid");
            inputEl.classList.remove("client-valid");
            setInputLabelValidState(inputEl, false);
            return;
        }

        clearClientErrorForInput(inputEl);
        inputEl.classList.remove("client-invalid");
        inputEl.classList.remove("is-invalid");
        inputEl.classList.remove("is-invalid-custom");
        inputEl.classList.add("is-valid");
        inputEl.classList.add("client-valid");
        setInputLabelValidState(inputEl, true);
    }

    function setupLiveFieldValidation(form) {
        if (!form || form.__liveValidationBound) return;

        var handler = function (event) {
            var inputEl = event.target;
            if (!inputEl) return;
            var tag = String(inputEl.tagName || "").toUpperCase();
            if (tag !== "INPUT" && tag !== "TEXTAREA" && tag !== "SELECT") return;
            updateClientFieldVisualState(inputEl);
        };

        form.addEventListener("input", handler, true);
        form.addEventListener("change", handler, true);
        form.__liveValidationBound = true;
    }

    function appendClientFieldError(inputEl, message) {
        if (!inputEl || !message) return;

        clearClientErrorForInput(inputEl);

        inputEl.classList.add("client-invalid");
        inputEl.classList.remove("is-valid");
        inputEl.classList.remove("client-valid");
        setInputLabelValidState(inputEl, false);
        if (inputEl.closest("#dynamicFields")) {
            inputEl.classList.add("is-invalid-custom");
        } else {
            inputEl.classList.add("is-invalid");
        }

        var error = document.createElement("div");
        error.className = "field-error client-field-error";
        error.textContent = message;
        error.setAttribute("data-field", getClientFieldToken(inputEl));
        inputEl.insertAdjacentElement("afterend", error);
    }

    function validateDemandeFormBeforeSubmit(form) {
        if (!form) return true;

        syncAutreMirroredFields();

        clearClientFieldErrors(form);

        var hasErrors = false;
        var requiredInputs = form.querySelectorAll("[required], [data-required='1']");

        for (var i = 0; i < requiredInputs.length; i++) {
            var inputEl = requiredInputs[i];
            if (!inputEl || inputEl.disabled) continue;

            var inputType = String(inputEl.type || "").toLowerCase();
            if (inputType === "hidden") continue;

            var value = String(inputEl.value || "").trim();
            if (value !== "") continue;

            hasErrors = true;
            var label = getInputLabelText(inputEl);
            appendClientFieldError(inputEl, 'Il faut remplir le champ "' + label + '".');
        }

        if (!hasErrors) {
            for (var j = 0; j < requiredInputs.length; j++) {
                updateClientFieldVisualState(requiredInputs[j]);
            }
        }

        if (hasErrors) {
            setAiStatus("Veuillez remplir tous les champs obligatoires de la demande.", "error");
            return false;
        }

        return true;
    }

