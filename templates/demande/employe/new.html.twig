    function inferCategoryFromDescriptionText(rawText) {
        var text = normalizeUiLabel(rawText || "");
        if (!text.trim()) return "";

        function hasAny(keywords) {
            for (var i = 0; i < keywords.length; i++) {
                if (text.indexOf(keywords[i]) !== -1) return true;
            }
            return false;
        }

        var hasFinanceContext = hasAny(["finance", "financier", "financiere", "salaire", "remboursement", "budget", "paye", "paie", "montant", "facture", "tnd", "dt"])
            || (text.indexOf("avance sur salaire") !== -1)
            || (text.indexOf("avance") !== -1 && hasAny(["salaire", "paie", "paye"]));
        if (hasFinanceContext) {
            return "Administrative";
        }

        if (hasAny(["conge", "attestation", "certificat", "mutation", "demission", "ressources humaines", "rh"])) {
            return "Ressources Humaines";
        }

        if (hasAny(["ordinateur", "pc", "laptop", "logiciel", "systeme", "reseau", "email", "bug", "informatique", "acces"])) {
            return "Informatique";
        }

        if (hasAny(["formation", "certification", "cours", "training"])) {
            return "Formation";
        }

        if (hasAny(["teletravail", "horaire", "heures supplementaires", "organisation"])) {
            return "Organisation du travail";
        }

        return "";
    }

    function inferTypeForCategoryFromText(category, rawText) {
        if (!category || !CATEGORIES[category]) return "";

        var text = normalizeUiLabel(rawText || "");
        if (!text) return "";

        var options = CATEGORIES[category] || [];
        var bestMatch = "";
        var bestScore = 0;

        for (var i = 0; i < options.length; i++) {
            var option = String(options[i] || "");
            if (!option || isAutreType(option)) continue;

            var normalizedOption = normalizeUiLabel(option);
            if (!normalizedOption) continue;

            if (text.indexOf(normalizedOption) !== -1 && normalizedOption.length > bestScore) {
                bestMatch = option;
                bestScore = normalizedOption.length;
            }
        }

        if (bestMatch) {
            return bestMatch;
        }

        var normalizedCategory = normalizeUiLabel(category);
        if (normalizedCategory === normalizeUiLabel("Ressources Humaines")) {
            if (text.indexOf("conge") !== -1 || text.indexOf("vacance") !== -1 || text.indexOf("absence") !== -1) {
                for (var j = 0; j < options.length; j++) {
                    var optionCandidate = String(options[j] || "");
                    if (normalizeUiLabel(optionCandidate).indexOf("conge") !== -1) {
                        return optionCandidate;
                    }
                }
            }
        }

        return "";
    }

    function normalizeUiLabel(value) {
        var text = String(value || "").toLowerCase().trim();
        if (text.normalize) {
            text = text.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        }
        return text.replace(/\s+/g, " ");
    }

    function resolveCategoryLabel(candidate) {
        var value = String(candidate || "").trim();
        if (!value) return "";
        if (CATEGORIES[value]) return value;

        var normalized = normalizeUiLabel(value);
        var keys = Object.keys(CATEGORIES || {});
        for (var i = 0; i < keys.length; i++) {
            if (normalizeUiLabel(keys[i]) === normalized) {
                return keys[i];
            }
        }

        return value;
    }

    function resolveTypeOptionValue(typeSelect, candidate) {
        var value = String(candidate || "").trim();
        if (!typeSelect || !value) return value;

        for (var i = 0; i < typeSelect.options.length; i++) {
            if (String(typeSelect.options[i].value || "") === value) {
                return value;
            }
        }

        var normalized = normalizeUiLabel(value);
        for (var j = 0; j < typeSelect.options.length; j++) {
            if (normalizeUiLabel(typeSelect.options[j].value || "") === normalized) {
                return String(typeSelect.options[j].value || "");
            }
        }

        return value;
    }

