{% extends 'base.html.twig' %}

{% block title %}Nouvelle Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
    .form-label.required::after { content: " *"; color: #dc2626; }
    .field-error { color: #dc2626; font-size: 0.875rem; margin-top: 6px; display: block; }
    .map-wrapper { position: relative; }
    .map-zoom-controls { position: absolute; top: 10px; left: 10px; z-index: 1000; display: flex; flex-direction: column; gap: 4px; }
    .map-zoom-controls button { width: 32px; height: 32px; background: white; border: 1px solid #ddd; border-radius: 4px; font-size: 18px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
    .map-zoom-controls button:hover { background: #f0f0f0; }
    .map-info-bar { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); z-index: 1000; background: white; padding: 6px 16px; border-radius: 6px; font-size: 12px; font-weight: bold; color: #444; box-shadow: 0 2px 8px rgba(0,0,0,0.15); white-space: nowrap; max-width: 60%; overflow: hidden; text-overflow: ellipsis; }
    .map-search-bar { display: flex; gap: 8px; margin-bottom: 10px; }
    .map-search-bar input { flex: 1; padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .map-search-bar button { padding: 8px 16px; background: #4a5def; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; transition: all 0.2s ease; }
    .map-search-bar button:hover { background: #3a4ddf; }
    .map-selected-info { font-size: .9rem; color: #475569; background: #f0f5ff; border: 1px solid #c0d0ff; padding: .65rem .85rem; border-radius: 6px; margin-top: 8px; display: none; }
    .map-selected-info.visible { display: block; }
    .map-card-header { background: #f0f5ff; padding: 12px 16px; border-bottom: 1px solid #c0d0ff; display: flex; align-items: center; gap: 8px; font-weight: 600; color: #4a5def; border-radius: 6px 6px 0 0; }
    .map-card-body { padding: 16px; border: 1px solid #c0d0ff; border-top: none; border-radius: 0 0 6px 6px; }
    .card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 10px;
        background: #fff;
        box-shadow: 0 4px 16px rgba(74, 93, 239, 0.08);
    }
    .card-header {
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        background: #f5f7fb;
        border-radius: 10px 10px 0 0;
        padding: 16px 20px;
        font-weight: 600;
        color: #4a5def;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .card-body {
        padding: 20px;
        border-radius: 0 0 10px 10px;
    }
    .map-confirm-bar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 12px; }
    .btn-confirm-location { background: #4a5def; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-confirm-location:disabled { background: #aaa; cursor: not-allowed; }
    .btn-confirm-location:not(:disabled):hover { background: #3a4ddf; }
    .btn-clear-location { background: #6b7280; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-clear-location:hover { background: #4b5563; }
    .inline-map-section { margin-top: 8px; border: 1px solid #c0d0ff; border-radius: 6px; overflow: hidden; background: white; }
    #map { height: 400px; width: 100%; background: #aad3df; border-radius: 4px; }
    .location-input-group input { background: #f8fafc !important; }
    .classification-ai-box { border: 1px solid rgba(13, 148, 136, 0.2); border-radius: 10px; padding: 14px; background: linear-gradient(180deg, #f4fffd 0%, #eefcf8 100%); }
    .autre-ai-box { border: 1px dashed #4a5def; border-radius: 8px; padding: 14px; background: #f8faff; }
    .ai-status { font-size: .88rem; color: #475569; }
    .ai-status.success { color: #166534; }
    .ai-status.error { color: #b91c1c; }
    .ai-status.info { color: #0f766e; }
    .suggestion-summary { background: #ecfeff; border: 1px solid #a5f3fc; color: #155e75; padding: 10px 12px; border-radius: 6px; font-size: .92rem; display: none; }
    .type-info { font-size: .82rem; color: #64748b; margin-top: 6px; display: block; }
    .assistant-panel { position: sticky; top: 76px; }
    .assistant-panel .card-header { align-items: flex-start; flex-direction: column; gap: 4px; }
    .assistant-eyebrow { font-size: .78rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: #0f766e; }
    .assistant-title { margin: 0; font-size: 1.1rem; color: #0f172a; }
    .assistant-subtitle { margin: 0; font-size: .9rem; color: #64748b; line-height: 1.45; }
    .classification-ai-box .form-control { min-height: 112px; resize: vertical; border-radius: 8px; }
    .assistant-tips { margin: 14px 0 0; padding: 0; list-style: none; display: grid; gap: 10px; }
    .assistant-tips li { font-size: .93rem; line-height: 1.45; color: #334155; padding-left: 16px; position: relative; }
    .assistant-tips li::before { content: ""; position: absolute; left: 0; top: 9px; width: 6px; height: 6px; border-radius: 999px; background: #4a5def; }
    .col-lg-4 > .card { display: none; }
    .ai-prefill-hint { display: none; margin-bottom: 12px; padding: 10px 12px; border-radius: 8px; background: #effcf6; border: 1px solid #bbf7d0; color: #166534; font-size: .9rem; }
    .ai-prefill-hint.visible { display: block; }
    .ai-prefilled-label { display: flex; align-items: center; gap: 8px; }
    .ai-badge { display: inline-flex; align-items: center; justify-content: center; padding: 2px 7px; border-radius: 999px; font-size: .72rem; font-weight: 700; background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .ai-prefilled-input { border-color: #86efac !important; background: #f6fff9 !important; box-shadow: 0 0 0 0.18rem rgba(34, 197, 94, 0.08); }
    .inline-ai-tools { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-top: 8px; }
    .inline-ai-toggle { display: inline-flex; align-items: center; gap: 6px; margin-left: 2px; }
    .inline-ai-toggle .form-check-input { margin-top: 0; }
    .inline-ai-toggle .form-check-label { font-size: .82rem; color: #64748b; }
    .client-valid {
        border-color: #16a34a !important;
        background: #f0fdf4 !important;
        box-shadow: 0 0 0 0.16rem rgba(34, 197, 94, 0.12);
    }
    .field-label-valid {
        color: #166534 !important;
    }
    .autre-confidence-badge {
        display: none;
        margin-top: 8px;
        padding: 8px 10px;
        border-radius: 8px;
        font-size: .84rem;
        font-weight: 600;
        border: 1px solid transparent;
    }
    .autre-confidence-badge.visible { display: block; }
    .autre-confidence-badge.success { background: #ecfdf3; color: #166534; border-color: #bbf7d0; }
    .autre-confidence-badge.info { background: #ecfeff; color: #0f766e; border-color: #a5f3fc; }
    .autre-confidence-badge.error { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="min-height:calc(100vh - 56px);">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes','sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="page-header d-print-none mb-3">
        <div class="container-xl">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Nouvelle demande</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'demandeForm'}}) }}
            <input type="hidden" name="ai_generated" id="aiGeneratedInput" value="{{ aiGenerated ? '1' : '0' }}">
            <input type="hidden" name="ai_confirmed" id="aiConfirmedInput" value="0">
            <input type="hidden" name="ai_trusted_learning" id="aiTrustedLearningInput" value="{{ aiTrustedFromLearning|default(false) ? '1' : '0' }}">
            <input type="hidden" name="autre_ai_raw_prompt" id="autreAiRawPromptInput" value="{{ submittedAiRawPrompt|default('')|e('html_attr') }}">
            <input type="hidden" name="ai_field_plan" id="aiFieldPlanInput" value="{{ submittedAiFieldPlan|default({'add': [], 'remove': [], 'replaceBase': false})|json_encode|e('html_attr') }}">
            <input type="hidden" name="ai_generation_snapshot" id="aiGenerationSnapshotInput" value="">

            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations générales</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.employe, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.employe, {'attr': {'class': 'form-select' ~ (form.employe.vars.errors|length > 0 ? ' is-invalid' : ''), 'onmousedown': 'return false;', 'onkeydown': 'return false;'}}) }}
                                        {% if form.employe.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.employe.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select' ~ (form.categorie.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.categorie.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.categorie.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.typeDemande, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.typeDemande, {'attr': {'class': 'form-select' ~ (form.typeDemande.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        <span id="typeInfo" class="type-info"></span>
                                        {% if form.typeDemande.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.typeDemande.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.priorite, {'attr': {'class': 'form-select' ~ (form.priorite.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.priorite.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.priorite.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label required'}}) }}
                                {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid' : ''), 'placeholder': 'Titre de votre demande'}}) }}
                                {% if form.titre.vars.errors %}
                                    <div class="field-error">
                                        {% for error in form.titre.vars.errors %}{{ error.message }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="mb-0">
                                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                                <div class="inline-ai-tools">
                                    <button type="button" class="btn btn-outline-primary btn-sm" id="generateDescriptionBtn">
                                        <i class="ti ti-sparkles me-1"></i>Remplir avec IA
                                    </button>
                                    <div class="form-check form-switch inline-ai-toggle">
                                        <input class="form-check-input" type="checkbox" id="autoGenerateDescriptionToggle">
                                        <label class="form-check-label" for="autoGenerateDescriptionToggle">Auto depuis titre</label>
                                    </div>
                                    <div class="form-check form-switch inline-ai-toggle">
                                        <input class="form-check-input" type="checkbox" id="sendDescriptionToSuggestionToggle">
                                        <label class="form-check-label" for="sendDescriptionToSuggestionToggle">Vers Suggestion IA</label>
                                    </div>
                                    <span id="descriptionAiStatusText" class="ai-status"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-3" id="dynamicFieldsCard" style="{{ submittedType ? 'display:block;' : 'display:none;' }}">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations spécifiques</h3>
                        </div>
                        <div class="card-body">
                            <div id="autreAiBox" class="autre-ai-box mb-3" style="display:none;">
                                <label for="autreAiDescription" class="form-label required">Description initiale pour assistant IA</label>
                                <textarea
                                    id="autreAiDescription"
                                    name="autre_ai_description"
                                    class="form-control"
                                    rows="4"
                                    placeholder="Decrivez ce dont vous avez besoin. L IA proposera une description plus claire et remplira les champs specifiques."
                                >{{ submittedAiDescription|default('') }}</textarea>
                                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                    <button type="button" class="btn btn-outline-primary" id="generateWithAiBtn">
                                        <i class="ti ti-sparkles me-1"></i>Generer avec IA
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="regenerateWithAiBtn" style="display:none;">
                                        <i class="ti ti-refresh me-1"></i>Regenerer
                                    </button>
                                    <span id="aiStatusText" class="ai-status"></span>
                                </div>
                                <div id="autreConfidenceBadge" class="autre-confidence-badge"></div>
                                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" id="openManualAutreFieldsBtn" data-bs-toggle="modal" data-bs-target="#manualAutreFieldsModal">
                                        <i class="ti ti-layout-grid-add me-1"></i>Configurer les champs
                                    </button>
                                    <span class="text-secondary small">Definissez vos propres champs, puis modifiez les valeurs avant confirmation.</span>
                                </div>
                            </div>
                            <div id="aiPrefillHint" class="ai-prefill-hint"></div>
                            <div class="row g-3" id="dynamicFields"></div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-send me-2"></i>Actions</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary" id="submitBtn">
                                    <i class="ti ti-check me-1"></i>Créer la demande
                                </button>
                                <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">Annuler</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="assistant-panel">
                        <div class="card">
                            <div class="card-header">
                                <span class="assistant-eyebrow">Assistant IA</span>
                                <h3 class="assistant-title">Classement intelligent</h3>
                                <p class="assistant-subtitle">Ecrivez votre besoin meme avec des fautes. L assistant corrige le texte et propose automatiquement la categorie, le type et la priorite.</p>
                            </div>
                            <div class="card-body">
                                <div class="classification-ai-box">
                                    <label for="classificationAiPrompt" class="form-label">Decrivez votre besoin</label>
                                    <textarea
                                        id="classificationAiPrompt"
                                        class="form-control"
                                        rows="4"
                                        placeholder="Exemple: slt j besoin dacces salesforc pr mn nv poste et c un peu urgent"
                                    ></textarea>
                                    <div class="d-grid gap-2 mt-3">
                                        <button type="button" class="btn btn-primary" id="suggestClassificationBtn">
                                            <i class="ti ti-wand me-1"></i>Suggerer automatiquement
                                        </button>
                                        <span id="classificationStatusText" class="ai-status"></span>
                                    </div>
                                    <div id="classificationSummary" class="suggestion-summary mt-2"></div>
                                </div>

                                <ul class="assistant-tips">
                                    <li><strong>Titre clair :</strong> gardez un objet simple et descriptif.</li>
                                    <li><strong>Priorite juste :</strong> reservez le niveau haute aux cas vraiment bloquants.</li>
                                    <li><strong>Champs specifiques :</strong> apres la suggestion, completez uniquement les informations utiles.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-lightbulb me-2"></i>Conseils</h3>
                        </div>
                        <div class="card-body">
                            <div style="font-size: 0.95rem; line-height: 1.6; color: #555;">
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Titre clair :</strong> Utilisez un titre court et descriptif pour votre demande.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Priorité :</strong> Sélectionnez le niveau de priorité approprié à votre besoin.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Description :</strong> Fournissez des détails pertinents pour faciliter le traitement.</span>
                                </div>
                                <div style="display: flex;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Champs spécifiques :</strong> Remplissez tous les champs dynamiques requis selon le type choisi.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
</div>

<div class="modal" id="manualAutreFieldsModal" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            <div class="modal-status bg-primary"></div>
            <div class="modal-body py-4">
                <h3 class="mb-2">Definir les champs specifiques</h3>
                <p class="text-secondary mb-3">Choisissez combien de champs vous voulez, nommez-les puis appliquez-les. Vous pourrez ensuite modifier chaque valeur dans la demande.</p>
                <div class="row g-3 align-items-end mb-3">
                    <div class="col-sm-4">
                        <label for="manualAutreFieldCount" class="form-label">Nombre de champs</label>
                        <input type="number" min="1" max="6" step="1" value="1" class="form-control" id="manualAutreFieldCount">
                    </div>
                    <div class="col-sm-8 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-secondary" id="buildManualAutreFieldsBtn">Generer les champs</button>
                        <button type="button" class="btn btn-primary" id="applyManualAutreFieldsBtn">Appliquer au formulaire</button>
                    </div>
                </div>
                <div class="text-secondary small mb-2">Saisissez les noms des champs puis leurs valeurs par defaut si besoin.</div>
                <div id="manualAutreFieldEditor" class="row g-2"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<div class="modal" id="aiConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            <div class="modal-status bg-primary"></div>
            <div class="modal-body py-4">
                <h3 class="mb-2" id="aiConfirmTitle">Confirmer cette demande generee avec IA ?</h3>
                <p class="text-secondary mb-3" id="aiConfirmDescription">Verifiez les informations ci-dessous avant enregistrement. Si ce n est pas exact, vous pouvez modifier ou regenerer.</p>
                <div id="aiConfirmPreview" class="border rounded p-3" style="background:#f8fafc;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn" data-bs-dismiss="modal" id="aiModalRejectBtn">Non, je modifie</button>
                <button type="button" class="btn btn-outline-secondary" id="aiModalRegenerateBtn">M aider a regenerer</button>
                <button type="button" class="btn btn-primary" id="aiModalConfirmBtn">
                        <i class="ti ti-check me-1"></i>Oui, enregistrer
                </button>
            </div>
        </div>
    </div>
</div>

{{ include('demande/_logout_modal.html.twig') }}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    "use strict";

    var CATEGORIES = {{ categories|json_encode|raw }};
    var SUBMITTED_DETAILS = {{ submittedDetails|json_encode|raw }};
    var SUBMITTED_TYPE = {{ submittedType|json_encode|raw }};
    var DETAIL_ERRORS = {{ detailErrors|json_encode|raw }};
    var SUBMITTED_AI_DESCRIPTION = {{ submittedAiDescription|default('')|json_encode|raw }};
    var SUBMITTED_AI_RAW_PROMPT = {{ submittedAiRawPrompt|default('')|json_encode|raw }};
    var SUBMITTED_AI_FIELD_PLAN = {{ submittedAiFieldPlan|default({'add': [], 'remove': [], 'replaceBase': false})|json_encode|raw }};
    var CLASSIFICATION_AI_ENDPOINT = "{{ path('demande_api_suggest_classification') }}";
    var AUTOCORRECT_AI_ENDPOINT = "{{ path('demande_api_autocorrect') }}";
    var DESCRIPTION_AI_ENDPOINT = "{{ path('demande_api_generate_description') }}";
    var AUTRE_AI_ENDPOINT = "{{ path('demande_api_autre_generate') }}";

    var AUTRE_BASE_REQUIRED_KEYS = ["besoinPersonnalise", "descriptionBesoin", "niveauUrgenceAutre"];
    var AUTRE_HIDDEN_DUPLICATE_KEYS = ["besoinPersonnalise", "descriptionBesoin", "niveauUrgenceAutre", "pieceOuContexte"];
    var AI_DYNAMIC_FIELDS = [];
    var aiModal = null;
    var aiModalEl = null;
    var AI_REMOVED_BASE_FIELDS = [];
    var AI_REPLACE_BASE_FIELDS = false;
    var MANUAL_AUTRE_FIELD_MODE = false;
    var AUTO_FILLED_DETAIL_KEYS = {};
    var maps = {};
    var markers = {};
    var selectedLocations = {};
