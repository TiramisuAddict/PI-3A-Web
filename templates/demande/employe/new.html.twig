    function buildInput(field, value, errClass) {
        var inp;
        switch (field.type) {
            case "hidden":
                inp = document.createElement("input");
                inp.type = "hidden";
                inp.name = "details[" + field.key + "]";
                var hiddenValue = String(value || "").trim();
                if (hiddenValue === "") {
                    hiddenValue = getMirroredAutreValue(field.key);
                }
                inp.value = hiddenValue;
                applyInputConstraints(inp, field);
                return inp;
            case "text":
                inp = document.createElement("input");
                inp.type = "text";
                inp.className = "form-control" + errClass;
                inp.name = "details[" + field.key + "]";
                inp.value = value;
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
            case "number":
                inp = document.createElement("input");
                inp.type = "number";
                inp.className = "form-control" + errClass;
                inp.name = "details[" + field.key + "]";
                inp.value = value;
                inp.min = "0";
                inp.addEventListener("input", function () {
                    autoFillNombreJours();
                });
                inp.addEventListener("change", function () {
                    autoFillNombreJours();
                });
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
            case "date":
                inp = document.createElement("input");
                inp.type = "date";
                inp.className = "form-control" + errClass;
                inp.name = "details[" + field.key + "]";
                inp.value = value;
                inp.addEventListener("change", function () {
                    autoFillNombreJours();
                });
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
            case "textarea":
                inp = document.createElement("textarea");
                inp.className = "form-control" + errClass;
                inp.rows = 3;
                inp.name = "details[" + field.key + "]";
                inp.value = value;
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
            case "select":
                inp = document.createElement("select");
                inp.className = "form-select" + errClass;
                inp.name = "details[" + field.key + "]";
                var def = document.createElement("option");
                def.value = "";
                def.textContent = "-- Selectionnez --";
                inp.appendChild(def);
                if (field.options) {
                    for (var j = 0; j < field.options.length; j++) {
                        var o = document.createElement("option");
                        o.value = field.options[j];
                        o.textContent = field.options[j];
                        if (value === field.options[j]) o.selected = true;
                        inp.appendChild(o);
                    }
                }
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
            default:
                inp = document.createElement("input");
                inp.type = "text";
                inp.className = "form-control" + errClass;
                inp.name = "details[" + field.key + "]";
                inp.value = value;
                applyInputConstraints(inp, field);
                applyAiPrefillState(inp, field);
                return inp;
        }
    }

    function applyAiPrefillState(inputEl, field) {
        if (!inputEl || !field || !isAutoFilledDetailKey(field.key) || field.type === "hidden") return;

        var badgeId = "ai-badge-" + String(field.key || "").replace(/[^a-zA-Z0-9_-]+/g, "_");
        inputEl.classList.add("ai-prefilled-input");
        inputEl.setAttribute("data-ai-label-id", badgeId);

        var eventName = inputEl.tagName === "SELECT" ? "change" : "input";
        inputEl.addEventListener(eventName, function handleReview() {
            markFieldAsReviewed(inputEl);
            inputEl.removeEventListener(eventName, handleReview);
        });
    }

    function autoFillNombreJours() {
        var container = document.getElementById("dynamicFields");
        if (!container) return;

        var startKeys = [
            "dateDebut", "dateDebutConge", "dateDebutTeletravail",
            "dateDebutFormation", "dateDebutHoraires", "dateDebutMission"
        ];
        var endKeys = [
            "dateFin", "dateFinConge", "dateFinTeletravail",
            "dateFinFormation", "dateFinHoraires", "dateFinMission"
        ];
        var joursKeys = [
            "nombreJours", "nombreJoursConge", "nombreJoursTeletravail",
            "nombreJoursFormation", "duree", "nombreJoursMission"
        ];

        var startInput = null;
        var endInput   = null;
        var joursInput = null;

        for (var i = 0; i < startKeys.length; i++) {
            var el = container.querySelector('[name="details[' + startKeys[i] + ']"]');
            if (el) { startInput = el; break; }
        }
        for (var j = 0; j < endKeys.length; j++) {
            var el2 = container.querySelector('[name="details[' + endKeys[j] + ']"]');
            if (el2) { endInput = el2; break; }
        }
        for (var k = 0; k < joursKeys.length; k++) {
            var el3 = container.querySelector('[name="details[' + joursKeys[k] + ']"]');
            if (el3) { joursInput = el3; break; }
        }

        if (!startInput || !endInput || !joursInput) return;

        var startVal = startInput.value;
        var endVal   = endInput.value;
        var joursVal = String(joursInput.value || "").trim();

        var startDate = parseIsoDate(startVal);
        var endDate   = parseIsoDate(endVal);
        var activeEl = document.activeElement;
        var joursCount = parseInt(joursVal, 10);

        if (startDate && endDate && endDate >= startDate && (activeEl === endInput || !joursVal)) {
            joursInput.value = diffInclusiveDays(startDate, endDate);
            return;
        }

        if (startDate && !isNaN(joursCount) && joursCount > 0) {
            var computedEndDate = addDaysInclusive(startDate, joursCount);
            var computedEndValue = formatIsoDate(computedEndDate);
            if (!endVal || activeEl === joursInput || activeEl === startInput) {
                endInput.value = computedEndValue;
                return;
            }
        }

        if (startDate && endDate && endDate >= startDate) {
            joursInput.value = diffInclusiveDays(startDate, endDate);
        }
    }

    function parseIsoDate(value) {
        var text = String(value || "").trim();
        if (!/^\d{4}-\d{2}-\d{2}$/.test(text)) return null;

        var parts = text.split("-");
        var year = parseInt(parts[0], 10);
        var month = parseInt(parts[1], 10) - 1;
        var day = parseInt(parts[2], 10);
        var date = new Date(year, month, day);
        if (
            isNaN(date.getTime()) ||
            date.getFullYear() !== year ||
            date.getMonth() !== month ||
            date.getDate() !== day
        ) {
            return null;
        }

        return date;
    }

    function formatIsoDate(date) {
        if (!date || isNaN(date.getTime())) return "";
        var year = String(date.getFullYear());
        var month = String(date.getMonth() + 1).padStart(2, "0");
        var day = String(date.getDate()).padStart(2, "0");
        return year + "-" + month + "-" + day;
    }

    function addDaysInclusive(startDate, numberOfDays) {
        var date = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
        date.setDate(date.getDate() + Math.max(0, numberOfDays - 1));
        return date;
    }

    function diffInclusiveDays(startDate, endDate) {
        var start = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
        var end = new Date(endDate.getFullYear(), endDate.getMonth(), endDate.getDate());
        var diffMs = end.getTime() - start.getTime();
        return Math.round(diffMs / (1000 * 60 * 60 * 24)) + 1;
    }

