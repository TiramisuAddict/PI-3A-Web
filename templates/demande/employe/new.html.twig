                    classificationAutocorrectApplied = false;
                }

                if (classificationAutocorrectTimer) {
                    window.clearTimeout(classificationAutocorrectTimer);
                }

                var current = String(classificationAiPrompt.value || "").trim();
                if (!current) {
                    return;
                }

                classificationAutocorrectTimer = window.setTimeout(function () {
                    requestLiveClassificationAutocorrect();
                }, 1200);
            });
        }

        if (autreAiDescription) {
            autreAiDescription.addEventListener("input", function () {
                if (aiTrustedLearningInput) {
                    aiTrustedLearningInput.value = "0";
                }

                var current = String(autreAiDescription.value || "").trim();
                if (!current) {
                    syncAutreRawPromptFromVisible(true);
                    return;
                }

                syncAutreRawPromptFromVisible(true);
            });
        }

        if (descriptionInput) {
            descriptionManuallyEdited = String(descriptionInput.value || "").trim() !== "";
            descriptionInput.addEventListener("input", function () {
                if (isUpdatingDescriptionFromAi) {
                    return;
                }

                descriptionManuallyEdited = String(descriptionInput.value || "").trim() !== "";
                if (!descriptionManuallyEdited) {
                    lastAutoGeneratedTitle = "";
                }
            });
        }

        if (autoGenerateDescriptionToggle) {
            try {
                autoGenerateDescriptionToggle.checked = window.localStorage.getItem(AUTO_DESCRIPTION_PREF_KEY) === "1";
            } catch (error) {
                console.warn("Cannot read localStorage for auto description toggle", error);
            }

            autoGenerateDescriptionToggle.addEventListener("change", function () {
                try {
                    window.localStorage.setItem(AUTO_DESCRIPTION_PREF_KEY, this.checked ? "1" : "0");
                } catch (error) {
                    console.warn("Cannot persist auto description toggle", error);
                }

                if (this.checked) {
                    requestDescriptionGeneration({ trigger: "auto" });
                }
            });
        }

        if (sendDescriptionToSuggestionToggle) {
            try {
                sendDescriptionToSuggestionToggle.checked = window.localStorage.getItem(DESCRIPTION_TO_SUGGESTION_PREF_KEY) === "1";
            } catch (error) {
                console.warn("Cannot read localStorage for description to suggestion toggle", error);
            }

            sendDescriptionToSuggestionToggle.addEventListener("change", function () {
                try {
                    window.localStorage.setItem(DESCRIPTION_TO_SUGGESTION_PREF_KEY, this.checked ? "1" : "0");
                } catch (error) {
                    console.warn("Cannot persist description to suggestion toggle", error);
                }
            });
        }

        if (titleInput) {
            titleInput.addEventListener("input", function () {
                if (descriptionAutoTimer) {
                    window.clearTimeout(descriptionAutoTimer);
                }

                syncAutreMirroredFields();

                if (!autoGenerateDescriptionToggle || !autoGenerateDescriptionToggle.checked) {
                    return;
                }

                descriptionAutoTimer = window.setTimeout(function () {
                    requestDescriptionGeneration({ trigger: "auto" });
                }, 900);
            });
        }

        if (prioriteInput) {
            prioriteInput.addEventListener("change", function () {
                syncAutreMirroredFields();
            });
        }

        if (suggestClassificationBtn) {
            suggestClassificationBtn.addEventListener("click", function (event) {
                event.preventDefault();
                requestClassificationSuggestion(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard);
            });
        }

        if (generateDescriptionBtn) {
            generateDescriptionBtn.addEventListener("click", function (event) {
                event.preventDefault();
                requestDescriptionGeneration({ trigger: "manual", forceApply: true });
            });
        }

        if (generateWithAiBtn) {
            generateWithAiBtn.addEventListener("click", function (event) {
                event.preventDefault();
                requestAutreAiGeneration(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard, {
                    mode: "generate",
                    forceFresh: false
                });
            });
        }

        if (regenerateWithAiBtn) {
            regenerateWithAiBtn.addEventListener("click", function (event) {
                event.preventDefault();
                requestAutreAiGeneration(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard, {
                    mode: "regenerate",
                    forceFresh: true
                });
            });
        }

        if (buildManualAutreFieldsBtn) {
            buildManualAutreFieldsBtn.addEventListener("click", function (event) {
                event.preventDefault();
                renderManualAutreFieldBuilder();
            });
        }

        if (applyManualAutreFieldsBtn) {
            applyManualAutreFieldsBtn.addEventListener("click", function (event) {
                event.preventDefault();
                applyManualAutreFieldPlan(categorieSelect, typeSelect, dynamicFieldsContainer, dynamicFieldsCard);
                if (manualAutreFieldsModal) {
                    manualAutreFieldsModal.hide();
                }
            });
        }

        if (openManualAutreFieldsBtn) {
            openManualAutreFieldsBtn.addEventListener("click", function (event) {
                event.preventDefault();
                renderManualAutreFieldBuilder();
                if (manualAutreFieldsModal) {
                    manualAutreFieldsModal.show();
                }
            });
        }

        renderManualAutreFieldBuilder();

        function handleFormSubmitIntent() {
            if (isSubmittingForm) {
                return;
            }

            syncAutreRawPromptFromVisible(false);

            if (!validateDemandeFormBeforeSubmit(form)) {
                return;
            }

            if (shouldRequireAiConfirmation(typeSelect, aiGeneratedInput, regenerateWithAiBtn, aiTrustedLearningInput)) {
                var manualConfirmation = !!MANUAL_AUTRE_FIELD_MODE;
                var confirmTitle = document.getElementById("aiConfirmTitle");
                var confirmDescription = document.getElementById("aiConfirmDescription");
                if (confirmTitle) {
                    confirmTitle.textContent = manualConfirmation
                        ? "Confirmer cette demande avec vos champs manuels ?"
                        : "Confirmer cette demande generee avec IA ?";
                }
                if (confirmDescription) {
                    confirmDescription.textContent = manualConfirmation
                        ? "Verifiez les champs que vous avez configures et leurs valeurs. Apres confirmation, cette structure sera apprise pour les prompts similaires."
                        : "Verifiez les informations ci-dessous avant enregistrement. Si ce n est pas exact, vous pouvez modifier ou regenerer.";
                }
                if (aiModalRegenerateBtn) {
                    aiModalRegenerateBtn.style.display = manualConfirmation ? "none" : "inline-block";
                }
                if (aiGeneratedInput) aiGeneratedInput.value = manualConfirmation ? "0" : "1";
                if (aiConfirmedInput) aiConfirmedInput.value = "0";
                if (aiConfirmPreview) {
                    aiConfirmPreview.innerHTML = buildConfirmationPreview(dynamicFieldsContainer);
                }

                if (aiModal) {
                    aiModal.show();
                } else if (aiModalEl) {
                    aiModalEl.classList.add("show");
                    aiModalEl.style.display = "block";
                }

                return;
            }

            markFormSubmitting(submitBtn, aiModalConfirmBtn);
            form.submit();
        }

        if (submitBtn && form) {
            submitBtn.addEventListener("click", function () {
                handleFormSubmitIntent();
            });
        }

        if (form) {
            form.addEventListener("submit", function (event) {
                if (isSubmittingForm) {
                    return;
                }

                event.preventDefault();
                handleFormSubmitIntent();
            });
        }

        if (aiModalConfirmBtn && form) {
            aiModalConfirmBtn.addEventListener("click", function () {
                if (isSubmittingForm) {
                    return;
                }

                if (!validateDemandeFormBeforeSubmit(form)) {
                    return;
                }

                syncAutreRawPromptFromVisible(false);
                if (aiConfirmedInput) aiConfirmedInput.value = "1";
                closeAiModal(aiModal, aiModalEl);
                markFormSubmitting(submitBtn, aiModalConfirmBtn);
                if (typeof form.requestSubmit === "function") {
                    form.requestSubmit();
                } else {
                    form.submit();
                }
            });
        }

        if (aiModalRegenerateBtn) {
            aiModalRegenerateBtn.addEventListener("click", function () {
                closeAiModal(aiModal, aiModalEl);
                requestAutreAiGeneration(categorieSelect, typeSelect, typeInfo, dynamicFieldsContainer, dynamicFieldsCard, {
                    mode: "regenerate",
                    forceFresh: true
                });
            });
        }

        if (aiModalRejectBtn) {
            aiModalRejectBtn.addEventListener("click", function () {
                closeAiModal(aiModal, aiModalEl);
            });
        }

        categorieSelect.addEventListener("change", function () {
            var category = this.value;
            typeSelect.innerHTML = '<option value="">-- Choisir un type --</option>';
            dynamicFieldsCard.style.display = "none";
            dynamicFieldsContainer.innerHTML = "";
            maps = {}; markers = {}; selectedLocations = {};
            if (aiGeneratedInput && aiGeneratedInput.value === "1" && aiConfirmedInput) {
                aiConfirmedInput.value = "0";
            }
            resetAutreAiGeneratedState();
            resetAiFieldPlan();
            setAutoFilledDetailKeys([]);
            clearAutreConfidenceBadge();
            updateAutreAiControls("");

            if (category && CATEGORIES[category]) {
                var types = CATEGORIES[category];
                for (var i = 0; i < types.length; i++) {
                    var opt = document.createElement("option");
                    opt.value = types[i]; opt.textContent = types[i];
                    typeSelect.appendChild(opt);
                }
                updateTypeInfo(typeInfo, category);
            } else {
                updateTypeInfo(typeInfo, "");
            }
        });

        typeSelect.addEventListener("change", function () {
            var type = this.value;
            maps = {}; markers = {}; selectedLocations = {};
            updateTypeInfo(typeInfo, categorieSelect.value || "");
            if (!type) {
                dynamicFieldsCard.style.display = "none";
                dynamicFieldsContainer.innerHTML = "";
                updateAutreAiControls("");
                return;
            }

            if (aiGeneratedInput && aiGeneratedInput.value === "1" && aiConfirmedInput) {
                aiConfirmedInput.value = "0";
            }
            resetAutreAiGeneratedState();
            resetAiFieldPlan();
            setAutoFilledDetailKeys([]);
            setAiStatus("", "");
            clearAutreConfidenceBadge();
            updateAutreAiControls(type);
            loadDynamicFields(type, {}, dynamicFieldsContainer, dynamicFieldsCard);
        });
    });

})();
</script>
{% endblock %}
