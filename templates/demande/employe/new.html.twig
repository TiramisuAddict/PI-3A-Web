    function requestLiveClassificationAutocorrect() {
        var promptInput = document.getElementById("classificationAiPrompt");
        if (!promptInput) return;

        if (classificationAutocorrectApplied) {
            return;
        }

        var rawText = String(promptInput.value || "").trim();
        if (rawText.length < 6) return;

        var requestId = ++classificationAutocorrectRequestId;

        fetch(AUTOCORRECT_AI_ENDPOINT, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Requested-With": "XMLHttpRequest"
            },
            body: JSON.stringify({ text: rawText })
        })
            .then(function (response) {
                return response.json().then(function (json) {
                    if (!response.ok || !json.success) {
                        throw new Error(json.message || "Correction IA indisponible.");
                    }
                    return json;
                });
            })
            .then(function (json) {
                if (requestId < latestAppliedClassificationAutocorrectRequestId) {
                    return;
                }

                var correctedText = String(json.correctedText || "").trim();
                if (!correctedText) {
                    return;
                }

                var currentText = String(promptInput.value || "").trim();
                if (normalizeUiLabel(currentText) === normalizeUiLabel(correctedText)) {
                    return;
                }

                latestAppliedClassificationAutocorrectRequestId = requestId;
                isApplyingClassificationAutocorrect = true;
                promptInput.value = correctedText;
                if (typeof promptInput.setSelectionRange === "function") {
                    var caret = correctedText.length;
                    promptInput.setSelectionRange(caret, caret);
                }
                isApplyingClassificationAutocorrect = false;
                classificationAutocorrectApplied = true;
                setClassificationStatus("Texte corrige automatiquement pendant la saisie.", "info");
            })
            .catch(function () {
                // Keep typing smooth: ignore transient live-correction errors.
            });
    }

