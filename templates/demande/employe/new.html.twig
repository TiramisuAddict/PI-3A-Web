    function manualAutreDuplicateValueKey(field) {
        if (!field || typeof field !== "object") return "";
        var raw = String(field.value || "").trim();
        if (!raw) return "";

        var normalized = normalizeUiLabel(raw);
        if (normalized.length < 3 && !/^\d{4}-\d{2}-\d{2}$/.test(raw)) {
            return "";
        }

        if (/^(oui|non|autre|a definir|n\/a)$/.test(normalized)) {
            return "";
        }

        return normalized;
    }

    function manualAutreDuplicateKeepScore(field) {
        if (!field || typeof field !== "object") return 0;
        var haystack = normalizeUiLabel(String(field.key || "") + " " + String(field.label || ""));
        var score = 0;
        if (!!field.required) score += 20;
        if (String(field.source || "").toLowerCase() === "manual") score += 10;
        if (String(field.type || "").toLowerCase() === "textarea") score -= 10;
        if (/\b(type|nature|materiel|equipement|systeme|logiciel|montant|date|lieu|destination|attestation|formation|conge|horaire|shift|zone|salle)\b/.test(haystack)) {
            score += 20;
        }
        if (/\b(extra|infos?|information|description|details?|commentaire|justification|motif|custom|champ)\b/.test(haystack)) {
            score -= 20;
        }
        return score;
    }

    function dedupeManualAutreFieldsByValue(fields) {
        if (!Array.isArray(fields) || fields.length <= 1) {
            return Array.isArray(fields) ? fields : [];
        }

        var kept = [];
        var byValue = {};
        for (var i = 0; i < fields.length; i++) {
            var field = fields[i];
            if (!field || typeof field !== "object") continue;

            var valueKey = manualAutreDuplicateValueKey(field);
            if (!valueKey) {
                kept.push(field);
                continue;
            }

            var score = manualAutreDuplicateKeepScore(field);
            if (typeof byValue[valueKey] === "undefined") {
                byValue[valueKey] = { index: kept.length, score: score };
                kept.push(field);
                continue;
            }

            var previous = byValue[valueKey];
            if (score > previous.score) {
                kept[previous.index] = field;
                byValue[valueKey] = { index: previous.index, score: score };
            }
        }

        return kept;
    }

    function shouldHideAutreBaseField(fieldKey) {
        var key = String(fieldKey || "");
        for (var i = 0; i < AUTRE_HIDDEN_DUPLICATE_KEYS.length; i++) {
            if (AUTRE_HIDDEN_DUPLICATE_KEYS[i] === key) {
                return true;
            }
        }
        return false;
    }

    function isAutreBaseRequiredKey(fieldKey) {
        var key = String(fieldKey || "");
        for (var i = 0; i < AUTRE_BASE_REQUIRED_KEYS.length; i++) {
            if (AUTRE_BASE_REQUIRED_KEYS[i] === key) {
                return true;
            }
        }
        return false;
    }

    function mapPrioriteToAutreUrgence(priorite) {
        var value = String(priorite || "").trim().toUpperCase();
        if (value === "HAUTE") return "Urgente";
        if (value === "BASSE") return "Faible";
        return "Normale";
    }

    function getMirroredAutreValue(fieldKey) {
        var key = String(fieldKey || "");
        if (key === "besoinPersonnalise") {
            var titreInput = document.getElementById("demande_titre");
            return String((titreInput || {}).value || "").trim();
        }

        if (key === "descriptionBesoin") {
            var descriptionInput = document.getElementById("demande_description");
            var descriptionValue = String((descriptionInput || {}).value || "").trim();
            if (descriptionValue) {
                return descriptionValue;
            }

            var autrePromptInput = document.getElementById("autreAiDescription");
            return String((autrePromptInput || {}).value || "").trim();
        }

        if (key === "niveauUrgenceAutre") {
            var prioriteInput = document.getElementById("demande_priorite");
            return mapPrioriteToAutreUrgence(String((prioriteInput || {}).value || ""));
        }

        return "";
    }

    function syncAutreMirroredFields() {
        var typeSelect = document.getElementById("demande_typeDemande");
        if (!typeSelect || !isAutreType(typeSelect.value)) return;

        for (var i = 0; i < AUTRE_HIDDEN_DUPLICATE_KEYS.length; i++) {
            var key = AUTRE_HIDDEN_DUPLICATE_KEYS[i];
            var input = document.querySelector('[name="details[' + key + ']"]');
            if (!input) continue;

            var mirroredValue = getMirroredAutreValue(key);
            if (mirroredValue !== "") {
                input.value = mirroredValue;
            }
        }
    }

    function composeAutreFields(baseFields) {
        var removeMap = {};
        for (var i = 0; i < AI_REMOVED_BASE_FIELDS.length; i++) {
            removeMap[AI_REMOVED_BASE_FIELDS[i]] = true;
        }

        var baseByKey = {};
        var usedKeys = {};
        var finalFields = [];

        for (var x = 0; x < baseFields.length; x++) {
            baseByKey[String(baseFields[x].key || "")] = baseFields[x];
        }

        if (AI_REPLACE_BASE_FIELDS && AI_DYNAMIC_FIELDS.length > 0) {
            for (var d = 0; d < AI_DYNAMIC_FIELDS.length; d++) {
                var dynamicField = AI_DYNAMIC_FIELDS[d];
                if (!dynamicField || usedKeys[dynamicField.key]) continue;
                finalFields.push(dynamicField);
                usedKeys[dynamicField.key] = true;
            }

            for (var h = 0; h < AUTRE_BASE_REQUIRED_KEYS.length; h++) {
                var requiredKey = AUTRE_BASE_REQUIRED_KEYS[h];
                if (usedKeys[requiredKey]) continue;

                var baseField = baseByKey[requiredKey] || {
                    key: requiredKey,
                    label: requiredKey,
                    required: true,
                    type: "text"
                };

                finalFields.push({
                    key: requiredKey,
                    label: baseField.label || requiredKey,
                    required: true,
                    type: "hidden"
                });
                usedKeys[requiredKey] = true;
            }

            return dedupeAutreComposedFields(finalFields);
        }

        for (var j = 0; j < baseFields.length; j++) {
            var field = baseFields[j];
            var key = String(field.key || "");
            var isRequired = !!field.required;

            if (removeMap[key] && !isRequired) {
                continue;
            }

            if (shouldHideAutreBaseField(key) && field.type !== "hidden") {
                finalFields.push({
                    key: key,
                    label: field.label || key,
                    required: true,
                    type: "hidden"
                });
            } else {
                finalFields.push(field);
            }
            usedKeys[key] = true;
        }

        for (var k = 0; k < AI_DYNAMIC_FIELDS.length; k++) {
            var customField = AI_DYNAMIC_FIELDS[k];
            if (!customField || usedKeys[customField.key]) continue;
            finalFields.push(customField);
            usedKeys[customField.key] = true;
        }

        return dedupeAutreComposedFields(finalFields);
    }

    function slugifyManualAutreFieldKey(label, fallbackIndex) {
        var key = normalizeUiLabel(String(label || "")).toLowerCase();
        key = key.replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "");
        if (!key) {
            key = "custom_" + String(fallbackIndex || 1);
        }

        if (key.indexOf("ai_") !== 0) {
            key = "ai_" + key;
        }

        return key;
    }

    function renderManualAutreFieldBuilder() {
        if (!manualAutreFieldEditor || !manualAutreFieldCountInput) {
            return;
        }

        var count = parseInt(manualAutreFieldCountInput.value, 10);
        if (!count || count < 1) {
            count = 1;
        }
        if (count > 6) {
            count = 6;
        }

        manualAutreFieldEditor.innerHTML = "";

        for (var i = 0; i < count; i++) {
            var col = document.createElement("div");
            col.className = "col-12 col-md-6";

            var card = document.createElement("div");
            card.className = "border rounded p-2 h-100";

            var label = document.createElement("label");
            label.className = "form-label small mb-1";
            label.textContent = "Champ " + (i + 1);

            var labelInput = document.createElement("input");
            labelInput.type = "text";
            labelInput.className = "form-control form-control-sm mb-2 manual-autre-field-label";
            labelInput.placeholder = "Nom du champ";
            labelInput.setAttribute("data-manual-autre-index", String(i));

            var typeInput = document.createElement("select");
            typeInput.className = "form-select form-select-sm mb-2 manual-autre-field-type";
            typeInput.setAttribute("data-manual-autre-index", String(i));
            ["text", "textarea", "number", "date", "select"].forEach(function (optionValue) {
                var option = document.createElement("option");
                option.value = optionValue;
                option.textContent = optionValue === "textarea" ? "Zone de texte" : optionValue.charAt(0).toUpperCase() + optionValue.slice(1);
                typeInput.appendChild(option);
            });

            var valueInput = document.createElement("input");
            valueInput.type = "text";
            valueInput.className = "form-control form-control-sm manual-autre-field-value";
            valueInput.placeholder = "Valeur initiale";
            valueInput.setAttribute("data-manual-autre-index", String(i));

            var optionsInput = document.createElement("input");
            optionsInput.type = "text";
            optionsInput.className = "form-control form-control-sm mt-2 manual-autre-field-options";
            optionsInput.placeholder = "Options separees par des virgules";
            optionsInput.style.display = "none";
            optionsInput.setAttribute("data-manual-autre-index", String(i));

            var keyPreview = document.createElement("div");
            keyPreview.className = "text-secondary small mt-2 manual-autre-field-key-preview";
            keyPreview.setAttribute("data-manual-autre-index", String(i));
            keyPreview.textContent = "Cle: " + slugifyManualAutreFieldKey("custom " + (i + 1), i + 1);

            labelInput.addEventListener("input", function () {
                var index = this.getAttribute("data-manual-autre-index");
                var preview = manualAutreFieldEditor.querySelector('.manual-autre-field-key-preview[data-manual-autre-index="' + index + '"]');
                if (preview) {
                    preview.textContent = "Cle: " + slugifyManualAutreFieldKey(this.value, parseInt(index, 10) + 1);
                }
            });

            typeInput.addEventListener("change", function () {
                var index = this.getAttribute("data-manual-autre-index");
                var input = manualAutreFieldEditor.querySelector('.manual-autre-field-options[data-manual-autre-index="' + index + '"]');
                if (!input) return;
                input.style.display = this.value === "select" ? "block" : "none";
            });

            card.appendChild(label);
            card.appendChild(labelInput);
            card.appendChild(typeInput);
            card.appendChild(valueInput);
            card.appendChild(optionsInput);
            card.appendChild(keyPreview);
            col.appendChild(card);
            manualAutreFieldEditor.appendChild(col);
        }
    }

    function applyManualAutreFieldPlan(categorieSelect, typeSelect, dynamicFieldsContainer, dynamicFieldsCard) {
        if (!manualAutreFieldEditor || !typeSelect) {
            return;
        }

        var labelInputs = manualAutreFieldEditor.querySelectorAll(".manual-autre-field-label");
        var fields = [];

        for (var i = 0; i < labelInputs.length; i++) {
            var labelInput = labelInputs[i];
            var index = parseInt(labelInput.getAttribute("data-manual-autre-index") || String(i), 10);
            var typeInput = manualAutreFieldEditor.querySelector('.manual-autre-field-type[data-manual-autre-index="' + index + '"]');
            var valueInput = manualAutreFieldEditor.querySelector('.manual-autre-field-value[data-manual-autre-index="' + index + '"]');
            var optionsInput = manualAutreFieldEditor.querySelector('.manual-autre-field-options[data-manual-autre-index="' + index + '"]');
            var label = String(labelInput.value || "").trim();
            if (!label) {
                label = "Champ " + (index + 1);
            }

