    function setAutoFilledDetailKeys(keys) {
        AUTO_FILLED_DETAIL_KEYS = {};
        if (!Array.isArray(keys)) {
            updateAiPrefillHint();
            return;
        }

        for (var i = 0; i < keys.length; i++) {
            var key = String(keys[i] || "").trim();
            if (!key) continue;
            AUTO_FILLED_DETAIL_KEYS[key] = true;
        }

        updateAiPrefillHint();
    }

    function isAutoFilledDetailKey(key) {
        return !!AUTO_FILLED_DETAIL_KEYS[String(key || "")];
    }

    function updateAiPrefillHint() {
        var hint = document.getElementById("aiPrefillHint");
        if (!hint) return;

        var count = Object.keys(AUTO_FILLED_DETAIL_KEYS).length;
        if (count <= 0) {
            hint.classList.remove("visible");
            hint.textContent = "";
            return;
        }

        hint.classList.add("visible");
        hint.textContent = count === 1
            ? "1 champ specifique a ete pre-rempli par l IA. Vous pouvez le modifier."
            : count + " champs specifiques ont ete pre-remplis par l IA. Vous pouvez les modifier.";
    }

    function markFieldAsReviewed(inputEl) {
        if (!inputEl) return;
        inputEl.classList.remove("ai-prefilled-input");

        var key = String(inputEl.getAttribute("data-field-key") || "").trim();
        if (key && AUTO_FILLED_DETAIL_KEYS[key]) {
            delete AUTO_FILLED_DETAIL_KEYS[key];
            updateAiPrefillHint();
