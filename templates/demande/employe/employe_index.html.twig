{% extends 'base.html.twig' %}

{% block title %}Mes Demandes{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
    .stats-row {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .stat-card {
        flex: 1;
        min-width: 140px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 10px;
        background: #fff;
        transition: border-color .2s ease, box-shadow .2s ease;
        cursor: pointer;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 4px 16px rgba(74, 93, 239, 0.08);
    }
    .stat-card:hover {
        border-color: rgba(74, 93, 239, 0.35);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        transform: translateY(-2px);
    }
    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        background: #f5f7fb;
        flex-shrink: 0;
    }
    .stat-content {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
    }
    .stat-label {
        font-size: 0.75rem;
        color: #64748b;
        margin-top: 4px;
        font-weight: 500;
        white-space: nowrap;
    }
    .badge {
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 4px;
        display: inline-block;
        color: #fff !important;
    }
    .badge.bg-danger { background-color: #dc3545 !important; }
    .badge.bg-warning { background-color: #ffc107 !important; }
    .badge.bg-success { background-color: #28a745 !important; }
    .badge.bg-info { background-color: #17a2b8 !important; }
    .badge.bg-orange { background-color: #fd7e14 !important; }
    .badge.bg-secondary { background-color: #6c757d !important; }
    .titre-link {
        color: #1f2937;
        font-weight: 600;
        text-decoration: none;
    }
    .titre-link:hover {
        color: #4a5def;
    }
    .category-tag {
        background: rgba(74, 93, 239, 0.1);
        color: #4a5def;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .date-text {
        color: #64748b;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .quick-filter-btn {
        padding: 6px 14px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }
    .quick-filter-btn:hover {
        border-color: #4a5def;
        color: #4a5def;
        background: rgba(74, 93, 239, 0.05);
    }
    .quick-filter-btn.active {
        background: #4a5def;
        color: white;
        border-color: #4a5def;
    }
    .btn-list {
        display: flex !important;
        gap: 4px;
        align-items: center;
    }
    .page-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 56px);
        overflow: hidden;
    }
    .page-body {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .page-body > .container-xl {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .card.table-card {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-height: 0;
    }
    .card.table-card .table-responsive {
        flex: 1;
        overflow: hidden;
    }
    .card.table-card .table-responsive table {
        margin-bottom: 0;
    }
    .card.table-card .card-footer {
        flex-shrink: 0;
    }
    .card.table-card .card-footer nav,
    .card.table-card .card-footer .pagination {
        margin: 0;
    }
    #demande-table tbody tr.demande-row {
        min-height: 68px;
    }
    #demande-table tbody tr.demande-row > td {
        height: 68px;
    }
    #demande-table tbody td {
        vertical-align: middle;
    }
    #demande-table tbody tr.demande-row > td:nth-child(2),
    #demande-table tbody tr.demande-row > td:nth-child(3) {
        white-space: nowrap;
    }
    #demande-table .category-tag {
        white-space: nowrap;
    }
    .search-filter-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }
    .search-filter-bar .search-input-wrap {
        flex: 1;
        min-width: 200px;
        position: relative;
    }
    .search-filter-bar .search-input-wrap input {
        padding-left: 36px;
    }
    .search-filter-bar .search-input-wrap .search-icon {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }
    .search-filter-bar .search-input-wrap .clear-btn {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 2px;
        display: none;
        line-height: 1;
    }
    .search-filter-bar .search-input-wrap .clear-btn.visible {
        display: block;
    }
    .search-filter-bar .search-input-wrap .clear-btn:hover {
        color: #dc3545;
    }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="height:calc(100vh - 56px);overflow:hidden;">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes', 'sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none mb-3">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Mes demandes</h2>
                    <div class="text-secondary">Visualisez et suivez vos demandes.</div>
                </div>
                <div class="col-auto">
                    <div class="btn-list">
                        <a href="{{ path('demande_new') }}" class="btn btn-primary">
                            <i class="ti ti-plus me-2"></i>Nouvelle Demande
                        </a>
                        <a href="{{ path('demande_statistics') }}" class="btn btn-outline-primary">
                            <i class="ti ti-chart-bar me-2"></i>Statistiques
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">
            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible mb-3" role="alert">
                    <div class="d-flex">
                        <div class="alert-icon me-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon icon-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M12 9v4"/>
                                <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636-2.87l-8.106-13.536a1.914 1.914 0 0 0-3.274 0z"/>
                                <path d="M12 16h.01"/>
                            </svg>
                        </div>
                        <div>{{ message }}</div>
                    </div>
                    <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                </div>
            {% endfor %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible mb-3" role="alert">
                    <div class="d-flex">
                        <div class="alert-icon me-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon icon-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M5 12l5 5l10 -10"/>
                            </svg>
                        </div>
                        <div>{{ message }}</div>
                    </div>
                    <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                </div>
            {% endfor %}

            <div class="stats-row">
                <div class="stat-card" onclick="filterByStatus('')" data-stat-card="total">
                    <div class="stat-icon bg-primary-lt text-primary"><i class="ti ti-files"></i></div>
                    <div class="stat-content">
                        <div class="stat-value text-primary" data-stat-value="total">{{ stats.total }}</div>
                        <div class="stat-label">Total</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('Nouvelle')" data-stat-card="Nouvelle">
                    <div class="stat-icon bg-blue-lt text-blue"><i class="ti ti-clock"></i></div>
                    <div class="stat-content">
                        <div class="stat-value text-blue" data-stat-value="Nouvelle">{{ stats.byStatus['Nouvelle'] | default(0) }}</div>
                        <div class="stat-label">Nouvelles</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('En cours')" data-stat-card="En cours">
                    <div class="stat-icon bg-yellow-lt text-yellow"><i class="ti ti-loader"></i></div>
                    <div class="stat-content">
                        <div class="stat-value text-yellow" data-stat-value="En cours">{{ stats.byStatus['En cours'] | default(0) }}</div>
                        <div class="stat-label">En cours</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('Resolue')" data-stat-card="Resolue">
                    <div class="stat-icon bg-green-lt text-green"><i class="ti ti-check"></i></div>
                    <div class="stat-content">
                        <div class="stat-value text-green" data-stat-value="Resolue">{{ stats.byStatus['Resolue'] | default(0) }}</div>
                        <div class="stat-label">Resolues</div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-body py-2 px-3">
                    <div class="search-filter-bar">
                        <div class="search-input-wrap">
                            <i class="ti ti-search search-icon"></i>
                            <input type="text" id="demande-search-input" class="form-control"
                                   placeholder="Rechercher par titre, categorie, type ou statut..."
                                   autocomplete="off"
                                   value="{{ filters.search|default('') }}">
                            <button type="button" class="clear-btn {{ filters.search|default('') != '' ? 'visible' : '' }}" id="search-clear-btn" title="Effacer">
                                <i class="ti ti-x"></i>
                            </button>
                        </div>
                        <a href="{{ path('demande_index', {'categorie': filters.categorie|default(''), 'limit': limit|default(10), 'page': 1}) }}"
                           class="quick-filter-btn {{ (filters.priorite|default('') == '' and filters.status|default('') == '' and filters.search|default('') == '') ? 'active' : '' }}">
                            <i class="ti ti-list"></i>Tous
                        </a>
                        <a href="{{ path('demande_index', {'categorie': filters.categorie|default(''), 'priorite': 'HAUTE', 'limit': limit|default(10), 'page': 1}) }}"
                           class="quick-filter-btn {{ filters.priorite|default('') == 'HAUTE' ? 'active' : '' }}">
                            <i class="ti ti-alert-circle"></i>Haute
                        </a>
                        <a href="{{ path('demande_index', {'categorie': filters.categorie|default(''), 'status': 'Nouvelle', 'limit': limit|default(10), 'page': 1}) }}"
                           class="quick-filter-btn {{ filters.status|default('') == 'Nouvelle' ? 'active' : '' }}">
                            <i class="ti ti-sparkles"></i>Nouvelles
                        </a>
                        <a href="{{ path('demande_index', {'categorie': filters.categorie|default(''), 'status': 'En cours', 'limit': limit|default(10), 'page': 1}) }}"
                           class="quick-filter-btn {{ filters.status|default('') == 'En cours' ? 'active' : '' }}">
                            <i class="ti ti-progress"></i>En cours
                        </a>
                    </div>
                </div>
            </div>

            <div class="card table-card">
                <div class="table-responsive">
                    <table class="table table-vcenter table-hover card-table" id="demande-table">
                        <thead>
                            <tr>
                                <th style="width: 30%">Titre</th>
                                <th>Categorie</th>
                                <th>Type</th>
                                <th>Priorite</th>
                                <th>Statut</th>
                                <th>Date creation</th>
                                <th class="text-end" style="width: 70px;">Voir</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for demande in demandes %}
                                <tr class="demande-row"
                                    data-titre="{{ demande.titre|lower }}"
                                    data-categorie="{{ demande.categorie|lower }}"
                                    data-type="{{ demande.typeDemande|lower }}"
                                    data-priorite="{{ demande.priorite }}"
                                    data-status="{{ demande.status }}">
                                    <td>
                                        <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="titre-link">
                                            {{ demande.titre }}
                                        </a>
                                    </td>
                                    <td>
                                        <span class="category-tag">
                                            <i class="ti ti-folder"></i>{{ demande.categorie }}
                                        </span>
                                    </td>
                                    <td>{{ demande.typeDemande }}</td>
                                    <td>
                                        {% if demande.priorite == 'HAUTE' %}
                                            <span class="badge bg-danger"><i class="ti ti-alert-triangle me-1"></i>{{ demande.priorite }}</span>
                                        {% elseif demande.priorite == 'NORMALE' %}
                                            <span class="badge bg-info"><i class="ti ti-minus me-1"></i>{{ demande.priorite }}</span>
                                        {% else %}
                                            <span class="badge bg-success"><i class="ti ti-arrow-down me-1"></i>{{ demande.priorite }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if demande.status == 'Nouvelle' %}
                                            <span class="badge bg-info"><i class="ti ti-sparkles me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En cours' %}
                                            <span class="badge bg-warning"><i class="ti ti-loader me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En attente' %}
                                            <span class="badge bg-orange"><i class="ti ti-clock me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Resolue' %}
                                            <span class="badge bg-success"><i class="ti ti-check me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Rejetee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Reconsideration' %}
                                            <span class="badge bg-primary"><i class="ti ti-lock-open me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Annulee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary"><i class="ti ti-lock me-1"></i>{{ demande.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="date-text">
                                            <i class="ti ti-calendar"></i>{{ demande.dateCreation|date('d/m/Y') }}
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="action-btn" title="Afficher">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                        </a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7">
                                        <div style="padding:60px 20px;text-align:center;">
                                            <i class="ti ti-file-off" style="font-size:3rem;color:#cbd5e1;display:block;margin-bottom:16px;"></i>
                                            <h3>Aucune demande trouvee</h3>
                                            <p class="text-muted">Vous n'avez aucune demande pour le moment.</p>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if demandes.getTotalItemCount > 0 %}
                    <div class="card-footer d-flex justify-content-center">
                        {{ knp_pagination_render(demandes) }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/demande-sync.js') }}"></script>
<script>
(function () {
    "use strict";

    var DEFAULT_ROW_HEIGHT = 54;
    var BOTTOM_SAFE_GAP = 18;
    var currentLimit = {{ limit|default(10) }};
    var resizeTimer = null;
    var searchTimer = null;
    var currentStatusFilter = "";
    var searchInput = null;
    var currentSearchTerm = "";
    var fetchSequence = 0;

    function getMeasuredRowHeight(tableCard) {
        if (!tableCard) return DEFAULT_ROW_HEIGHT;

        var sampleRow = tableCard.querySelector('#demande-table tbody tr.demande-row');
        if (sampleRow) {
            var measured = sampleRow.getBoundingClientRect().height;
            if (measured > 0) {
                return measured;
            }
        }

        return DEFAULT_ROW_HEIGHT;
    }

    function calculateOptimalLimit() {
        var tableCard = document.querySelector('.card.table-card');
        if (!tableCard) return currentLimit;

        var rowHeight = getMeasuredRowHeight(tableCard);
        var cardRect = tableCard.getBoundingClientRect();
        var thead = tableCard.querySelector('thead');
        var footer = tableCard.querySelector('.card-footer');
        var tableViewport = tableCard.querySelector('.table-responsive');
        var theadHeight = thead ? thead.offsetHeight : 42;
        var footerHeight = footer ? footer.offsetHeight : 52;
        var availableHeight = 0;

        if (tableViewport && tableViewport.clientHeight > 0) {
            availableHeight = tableViewport.clientHeight - theadHeight - BOTTOM_SAFE_GAP;
        }

        if (availableHeight <= 0) {
            var viewportBottom = window.innerHeight;
            availableHeight = viewportBottom - cardRect.top - theadHeight - footerHeight - BOTTOM_SAFE_GAP;
        }

        if (availableHeight < rowHeight) availableHeight = rowHeight;
        var rows = Math.floor(availableHeight / rowHeight);
        if (rows < 1) rows = 1;
        if (rows > 100) rows = 100;
        return rows;
    }

    function buildUrl(overrides) {
        var url = new URL(window.location.href);
        if (overrides) {
            for (var key in overrides) {
                if (overrides[key] === null || overrides[key] === '') {
                    url.searchParams.delete(key);
                } else {
                    url.searchParams.set(key, overrides[key]);
                }
            }
        }
        return url.toString();
    }

    function getUpdatedUrl(newLimit) {
        var url = new URL(window.location.href);
        var oldLimit = parseInt(url.searchParams.get('limit')) || 10;
        var oldPage = parseInt(url.searchParams.get('page')) || 1;
        var firstItemIndex = (oldPage - 1) * oldLimit;
        var newPage = Math.floor(firstItemIndex / newLimit) + 1;
        if (newPage < 1) newPage = 1;
        url.searchParams.set('limit', newLimit.toString());
        url.searchParams.set('page', newPage.toString());
        return url.toString();
    }

    function applyDynamicLimit() {
        var optimalLimit = calculateOptimalLimit();
        if (optimalLimit !== currentLimit) {
            currentLimit = optimalLimit;
            window.location.assign(getUpdatedUrl(optimalLimit));
        }
    }

    function updateQuickFilterLinks(limit) {
        document.querySelectorAll('.quick-filter-btn').forEach(function (link) {
            try {
                var href = new URL(link.href);
                href.searchParams.set('limit', limit.toString());
                link.href = href.toString();
            } catch (e) {}
        });
    }

    function updateStatCardValues(responseDoc) {
        ["total", "Nouvelle", "En cours", "Resolue"].forEach(function (key) {
            var source = responseDoc.querySelector('[data-stat-value="' + key + '"]');
            var target = document.querySelector('[data-stat-value="' + key + '"]');
            if (source && target) {
                target.textContent = source.textContent;
            }
        });
    }

    function syncTableFromResponse(responseDoc) {
        var currentBody = document.querySelector('#demande-table tbody');
        var nextBody = responseDoc.querySelector('#demande-table tbody');
        if (currentBody && nextBody) {
            currentBody.innerHTML = nextBody.innerHTML;
        }
    }

    function syncPaginationFromResponse(responseDoc) {
        var tableCard = document.querySelector('.card.table-card');
        if (!tableCard) return;

        var currentFooter = tableCard.querySelector('.card-footer');
        var nextFooter = responseDoc.querySelector('.card.table-card .card-footer');

        if (nextFooter) {
            if (!currentFooter) {
                currentFooter = nextFooter.cloneNode(true);
                tableCard.appendChild(currentFooter);
            } else {
                currentFooter.innerHTML = nextFooter.innerHTML;
            }
        } else if (currentFooter) {
            currentFooter.remove();
        }

        bindPaginationLinks();
    }

    function buildRequestUrl(page) {
        var url = new URL(window.location.href);
        url.searchParams.set('limit', currentLimit.toString());
        url.searchParams.set('page', String(page || 1));

        if (currentSearchTerm) {
            url.searchParams.set('search', currentSearchTerm);
        } else {
            url.searchParams.delete('search');
        }

        if (currentStatusFilter) {
            url.searchParams.set('status', currentStatusFilter);
            url.searchParams.delete('priorite');
        }

        if (!currentStatusFilter) {
            url.searchParams.delete('status');
        }

        return url;
    }

    function fetchAndRender(page) {
        var sequence = ++fetchSequence;
        var requestUrl = buildRequestUrl(page);
        window.history.replaceState({}, '', requestUrl.toString());

        fetch(requestUrl.toString(), {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
            .then(function (response) {
                return response.text();
            })
            .then(function (html) {
                if (sequence !== fetchSequence) return;
                var responseDoc = new DOMParser().parseFromString(html, 'text/html');
                updateStatCardValues(responseDoc);
                syncTableFromResponse(responseDoc);
                syncPaginationFromResponse(responseDoc);
            })
            .catch(function () {
                window.location.assign(requestUrl.toString());
            });
    }

    function debounce(func, wait) {
        return function () {
            var args = arguments;
            if (searchTimer) clearTimeout(searchTimer);
            searchTimer = setTimeout(function () {
                func.apply(null, args);
            }, wait);
        };
    }

    function bindPaginationLinks() {
        document.querySelectorAll('.card.table-card .card-footer a').forEach(function (link) {
            link.addEventListener('click', function (event) {
                event.preventDefault();
                try {
                    var href = new URL(link.href);
                    var nextPage = parseInt(href.searchParams.get('page')) || 1;
                    currentSearchTerm = href.searchParams.get('search') || currentSearchTerm;
                    currentStatusFilter = href.searchParams.get('status') || currentStatusFilter;
                    if (searchInput) {
                        searchInput.value = currentSearchTerm;
                    }
                    fetchAndRender(nextPage);
                } catch (e) {
                    window.location.assign(link.href);
                }
            });
        });
    }

    function filterByStatus(status) {
        currentStatusFilter = status || "";
        fetchAndRender(1);
    }

    function clearSearch() {
        if (!searchInput) return;
        searchInput.value = "";
        currentSearchTerm = "";
        fetchAndRender(1);
    }

    document.addEventListener("DOMContentLoaded", function () {
        var optimalLimit = calculateOptimalLimit();
        var urlLimit = parseInt(new URLSearchParams(window.location.search).get('limit')) || 0;
        var queryParams = new URLSearchParams(window.location.search);

        currentSearchTerm = queryParams.get('search') || "";
        currentStatusFilter = queryParams.get('status') || "";

        updateQuickFilterLinks(optimalLimit);

        if (urlLimit === 0 || Math.abs(urlLimit - optimalLimit) >= 1) {
            window.location.assign(getUpdatedUrl(optimalLimit));
            return;
        }

        currentLimit = optimalLimit;

        searchInput = document.getElementById("demande-search-input");
        var clearBtn = document.getElementById("search-clear-btn");

        if (searchInput) {
            searchInput.addEventListener("input", debounce(function () {
                currentSearchTerm = searchInput.value.trim();
                if (clearBtn) {
                    clearBtn.classList.toggle('visible', searchInput.value.trim().length > 0);
                }
                fetchAndRender(1);
            }, 150));

            searchInput.addEventListener("keyup", function (event) {
                if (event.key === "Escape") {
                    if (clearBtn) clearBtn.classList.remove('visible');
                    clearSearch();
                }
            });

            // Focus the input and place cursor at end
            searchInput.focus();
            var len = searchInput.value.length;
            searchInput.setSelectionRange(len, len);
        }

        if (clearBtn) {
            clearBtn.addEventListener("click", function () {
                clearBtn.classList.remove('visible');
                clearSearch();
            });
        }

        bindPaginationLinks();

        // Handle window resize
        window.addEventListener('resize', function () {
            if (resizeTimer) clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function () {
                applyDynamicLimit();
            }, 300);
        });

        if (window.DemandeSyncManager) {
            window.DemandeSyncManager.onStatusUpdate(function (data) {
                if (data.type === "status-update") {
                    window.location.reload();
                }
            });
        }

    });

    window.filterByStatus = filterByStatus;
}());
</script>
{% endblock %}