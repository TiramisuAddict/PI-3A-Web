{% extends 'base.html.twig' %}

{% block title %}Modifier Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
    .form-label.required::after { content: " *"; color: #dc2626; }
    .field-error { color: #dc2626; font-size: 0.875rem; margin-top: 6px; display: block; }
    .map-wrapper { position: relative; }
    .map-zoom-controls { position: absolute; top: 10px; left: 10px; z-index: 1000; display: flex; flex-direction: column; gap: 4px; }
    .map-zoom-controls button { width: 32px; height: 32px; background: white; border: 1px solid #ddd; border-radius: 4px; font-size: 18px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(0,0,0,0.2); }
    .map-zoom-controls button:hover { background: #f0f0f0; }
    .map-info-bar { position: absolute; top: 10px; left: 50%; transform: translateX(-50%); z-index: 1000; background: white; padding: 6px 16px; border-radius: 6px; font-size: 12px; font-weight: bold; color: #444; box-shadow: 0 2px 8px rgba(0,0,0,0.15); white-space: nowrap; max-width: 60%; overflow: hidden; text-overflow: ellipsis; }
    .map-search-bar { display: flex; gap: 8px; margin-bottom: 10px; }
    .map-search-bar input { flex: 1; padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; }
    .map-search-bar button { padding: 8px 16px; background: #4a5def; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; transition: all 0.2s ease; }
    .map-search-bar button:hover { background: #3a4ddf; }
    .map-selected-info { font-size: .9rem; color: #475569; background: #f0f5ff; border: 1px solid #c0d0ff; padding: .65rem .85rem; border-radius: 6px; margin-top: 8px; display: none; }
    .map-selected-info.visible { display: block; }
    .map-card-header { background: #f0f5ff; padding: 12px 16px; border-bottom: 1px solid #c0d0ff; display: flex; align-items: center; gap: 8px; font-weight: 600; color: #4a5def; border-radius: 6px 6px 0 0; }
    .map-card-body { padding: 16px; border: 1px solid #c0d0ff; border-top: none; border-radius: 0 0 6px 6px; }
    .map-confirm-bar { display: flex; justify-content: flex-end; gap: 10px; margin-top: 12px; }
    .btn-confirm-location { background: #4a5def; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-weight: 600; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-confirm-location:disabled { background: #aaa; cursor: not-allowed; }
    .btn-confirm-location:not(:disabled):hover { background: #3a4ddf; }
    .btn-clear-location { background: #6b7280; color: white; border: none; padding: 8px 18px; border-radius: 6px; font-size: 13px; cursor: pointer; transition: all 0.2s ease; }
    .btn-clear-location:hover { background: #4b5563; }
    .inline-map-section { margin-top: 8px; border: 1px solid #c0d0ff; border-radius: 6px; overflow: hidden; background: white; }
    #map { height: 400px; width: 100%; background: #aad3df; border-radius: 4px; }
    .location-input-group input { background: #f8fafc !important; }
    .resolved-info-bar {
        background: linear-gradient(135deg,#f0fff4 0%,#d4edda 100%);
        border: 1.5px solid #c3e6cb;
        border-radius: 8px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        font-size: 0.9rem;
        color: #155724;
    }
    .resolved-info-bar i { font-size: 1.2rem; }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="min-height:calc(100vh - 56px);">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes','sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="page-header d-print-none mb-3">
        <div class="container-xl">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Modifier la Demande</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            {% if demande.status == 'Resolue' %}
            <div class="resolved-info-bar">
                <i class="ti ti-lock"></i>
                <span>
                    <strong>Demande resolue :</strong> le statut ne peut plus etre modifie, mais vous pouvez
                    modifier les autres informations (titre, description, priorite, champs specifiques).
                </span>
            </div>
            {% endif %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'demandeForm'}}) }}

            <div class="row">
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations générales</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.categorie, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.categorie, {'attr': {'class': 'form-select' ~ (form.categorie.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.categorie.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.categorie.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.typeDemande, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.typeDemande, {'attr': {'class': 'form-select' ~ (form.typeDemande.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.typeDemande.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.typeDemande.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_label(form.priorite, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {{ form_widget(form.priorite, {'attr': {'class': 'form-select' ~ (form.priorite.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% if form.priorite.vars.errors %}
                                            <div class="field-error">
                                                {% for error in form.priorite.vars.errors %}{{ error.message }}{% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_label(form.status, null, {'label_attr': {'class': 'form-label required'}}) }}
                                        {% if demande.status == 'Resolue' %}
                                            <input type="hidden" name="{{ form.status.vars.full_name }}" value="{{ demande.status }}">
                                            <select class="form-select" disabled>
                                                <option selected>{{ demande.status }}</option>
                                            </select>
                                            <small class="text-muted">
                                                <i class="ti ti-lock" style="font-size:0.75rem;"></i>
                                                Le statut d'une demande resolue est definitif.
                                            </small>
                                        {% elseif demande.status == 'Annulee' %}
                                            <input type="hidden" name="{{ form.status.vars.full_name }}" value="{{ demande.status }}">
                                            <select class="form-select" disabled>
                                                <option selected>{{ demande.status }}</option>
                                            </select>
                                            <small class="text-muted d-block mt-2">
                                                <i class="ti ti-lock" style="font-size:0.75rem;"></i>
                                                Demande annulee : le statut reste verrouille, mais vous pouvez modifier les autres informations.
                                            </small>
                                        {% elseif demande.status == 'Rejetee' %}
                                            {{ form_widget(form.status, {'attr': {'class': 'form-select' ~ (form.status.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                            <small class="text-muted d-block mt-2">
                                                <i class="ti ti-lock-open" style="font-size:0.75rem;"></i>
                                                Choisissez <strong>Reconsideration</strong> pour rouvrir les changements de statut.
                                            </small>
                                            {% if form.status.vars.errors %}
                                                <div class="field-error">
                                                    {% for error in form.status.vars.errors %}{{ error.message }}{% endfor %}
                                                </div>
                                            {% endif %}
                                        {% else %}
                                            {{ form_widget(form.status, {'attr': {'class': 'form-select' ~ (form.status.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                            {% if form.status.vars.errors %}
                                                <div class="field-error">
                                                    {% for error in form.status.vars.errors %}{{ error.message }}{% endfor %}
                                                </div>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label required'}}) }}
                                {{ form_widget(form.titre, {'attr': {'class': 'form-control' ~ (form.titre.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                {% if form.titre.vars.errors %}
                                    <div class="field-error">
                                        {% for error in form.titre.vars.errors %}{{ error.message }}{% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="mb-0">
                                {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                            </div>
                        </div>
                    </div>

                    <div class="card mb-3" id="dynamicFieldsCard" style="display:block;">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations spécifiques</h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3" id="dynamicFields"></div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-send me-2"></i>Actions</h3>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                {{ form_label(form.commentaire, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.commentaire, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Ajoutez un commentaire (optionnel)'}}) }}
                            </div>
                            <hr>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="ti ti-check me-1"></i>Enregistrer
                                </button>
                                <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="btn btn-outline-secondary">Annuler</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-lightbulb me-2"></i>Conseils</h3>
                        </div>
                        <div class="card-body">
                            <div style="font-size: 0.95rem; line-height: 1.6; color: #555;">
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Mises à jour :</strong> Modifiez les champs selon les besoins actuels.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Statut :</strong> Changez le statut de la demande pour le mettre à jour.</span>
                                </div>
                                <div style="display: flex; margin-bottom: 12px;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Commentaires :</strong> Ajoutez des notes pour justifier vos modifications.</span>
                                </div>
                                <div style="display: flex;">
                                    <span style="color: #4a5def; font-weight: bold; margin-right: 8px;">•</span>
                                    <span><strong>Priorité :</strong> Ajustez la priorité si nécessaire.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
</div>
{{ include('demande/_logout_modal.html.twig') }}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    "use strict";

    var CATEGORIES = {{ categories|json_encode|raw }};
    var CURRENT_TYPE = {{ submittedType|json_encode|raw }};
    var EXISTING_DETAILS = {{ existingDetails|json_encode|raw }};
    var DETAIL_ERRORS = {{ detailErrors|json_encode|raw }};
    var AUTRE_REQUIRED_KEYS = ["besoinPersonnalise", "descriptionBesoin", "niveauUrgenceAutre"];

    var maps = {};
    var markers = {};
    var selectedLocations = {};

    document.addEventListener("DOMContentLoaded", function () {
        var categorieSelect = document.getElementById("demande_categorie");
        var typeSelect = document.getElementById("demande_typeDemande");
        var typeInfo = document.getElementById("typeInfo");
        var dynamicFieldsCard = document.getElementById("dynamicFieldsCard");
        var dynamicFieldsContainer = document.getElementById("dynamicFields");

        if (CURRENT_TYPE) {
            loadFields(CURRENT_TYPE, EXISTING_DETAILS, dynamicFieldsContainer, dynamicFieldsCard);
        }

        categorieSelect.addEventListener("change", function () {
            var cat = this.value;
            typeSelect.innerHTML = '<option value="">-- Choisir un type --</option>';
            dynamicFieldsCard.style.display = "none";
            dynamicFieldsContainer.innerHTML = "";
            maps = {}; markers = {}; selectedLocations = {};

            if (cat && CATEGORIES[cat]) {
                var types = CATEGORIES[cat];
                for (var i = 0; i < types.length; i++) {
                    var o = document.createElement("option");
                    o.value = types[i]; o.textContent = types[i];
                    typeSelect.appendChild(o);
                }
                if (typeInfo) {
                    typeInfo.textContent = types.length + " types disponibles";
                    typeInfo.style.color = "green";
                }
            } else {
                if (typeInfo) typeInfo.textContent = "";
            }
        });

        typeSelect.addEventListener("change", function () {
            maps = {}; markers = {}; selectedLocations = {};
            var currentValues = collectCurrentDetails(dynamicFieldsContainer);
            if (this.value) {
                loadFields(this.value, currentValues, dynamicFieldsContainer, dynamicFieldsCard);
            } else {
                dynamicFieldsCard.style.display = "none";
                dynamicFieldsContainer.innerHTML = "";
            }
        });

        function loadFields(type, values, container, card) {
            fetch("{{ path('demande_api_fields', {type: '__TYPE__'}) }}".replace("__TYPE__", encodeURIComponent(type)))
                .then(function (r) { return r.json(); })
                .then(function (fields) {
                    if (fields && fields.length > 0) {
                        var finalFields = composeAdminFields(type, fields, values);
                        renderFields(finalFields, values, container);
                        card.style.display = "block";
                    } else {
                        card.style.display = "none";
                        container.innerHTML = "";
                    }
                })
                .catch(function (e) { console.error(e); });
        }
    });

    function hasError(key) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === key) return true;
        }
        return false;
    }

    function getFieldErrorMessage(key) {
        for (var i = 0; i < DETAIL_ERRORS.length; i++) {
            if (DETAIL_ERRORS[i].field === key) return DETAIL_ERRORS[i].message;
        }
        return "";
    }

    function isAutreType(type) {
        return type === "Autre";
    }

    function collectCurrentDetails(container) {
        var map = {};
        if (!container) return map;

        var inputs = container.querySelectorAll("input[name^='details['], textarea[name^='details['], select[name^='details[']");
        for (var i = 0; i < inputs.length; i++) {
            var input = inputs[i];
            if (!input.name) continue;

            var key = input.name.replace(/^details\[/, "").replace(/\]$/, "");
            map[key] = input.value;
        }

        return map;
    }

    function toFieldValue(value) {
        if (typeof value === "undefined" || value === null) return "";
        if (typeof value === "object") {
            try {
                return JSON.stringify(value);
            } catch (_e) {
                return "";
            }
        }

        return String(value);
    }

    function normalizeDateValue(value) {
        var text = String(value || "").trim();
        if (!text) return "";

        if (/^\d{4}-\d{2}-\d{2}$/.test(text)) {
            return text;
        }

        var parts = text.split("/");
        if (parts.length === 3) {
            var d = parts[0].trim();
            var m = parts[1].trim();
            var y = parts[2].trim();
            if (/^\d{1,2}$/.test(d) && /^\d{1,2}$/.test(m) && /^\d{4}$/.test(y)) {
                var dd = d.length === 1 ? "0" + d : d;
                var mm = m.length === 1 ? "0" + m : m;
                return y + "-" + mm + "-" + dd;
            }
        }

        return "";
    }

    function prettifyCustomKey(key) {
        var cleaned = String(key || "")
            .replace(/^ai_/, "")
            .replace(/[_\-]+/g, " ")
            .trim();

        if (!cleaned) return "Champ personnalise";

        var parts = cleaned.split(/\s+/);
        for (var i = 0; i < parts.length; i++) {
            if (!parts[i]) continue;
            parts[i] = parts[i].charAt(0).toUpperCase() + parts[i].slice(1);
        }

        return parts.join(" ");
    }

    function inferCustomFieldType(key, value) {
        var lowerKey = String(key || "").toLowerCase();
        var text = toFieldValue(value).trim();

        if (/^\d{4}-\d{2}-\d{2}$/.test(text) || /^\d{1,2}\/\d{1,2}\/\d{4}$/.test(text) || lowerKey.indexOf("date") !== -1) {
            return "date";
        }

        if (
            lowerKey.indexOf("montant") !== -1 ||
            lowerKey.indexOf("nombre") !== -1 ||
            lowerKey.indexOf("quantite") !== -1 ||
            lowerKey.indexOf("cout") !== -1 ||
            (/^\d+(?:[\.,]\d+)?$/.test(text) && text !== "")
        ) {
            return "number";
        }

        if (typeof value === "object" || text.length > 120 || text.indexOf("\n") !== -1) {
            return "textarea";
        }

        return "text";
    }

    function isIgnoredExtraKey(key, baseFieldMap) {
        if (!key) return true;
        if (baseFieldMap[key]) return true;

        if (key.endsWith("Lat") || key.endsWith("Lon")) {
            var rootKey = key.replace(/(Lat|Lon)$/, "");
            if (baseFieldMap[rootKey]) return true;
            if (baseFieldMap[rootKey + "Lat"] || baseFieldMap[rootKey + "Lon"]) return true;
        }

        return false;
    }

    function composeAdminFields(type, baseFields, values) {
        if (!isAutreType(type)) {
            return baseFields;
        }

        var baseByKey = {};
        var baseFieldMap = {};
        for (var i = 0; i < baseFields.length; i++) {
            var baseKey = String(baseFields[i].key || "");
            baseFieldMap[baseKey] = true;
            baseByKey[baseKey] = baseFields[i];
        }

        var extraFields = [];
        var keys = Object.keys(values || {});
        for (var j = 0; j < keys.length; j++) {
            var key = keys[j];
            if (isIgnoredExtraKey(key, baseFieldMap)) continue;

            var rawValue = values[key];
            extraFields.push({
                key: key,
                label: prettifyCustomKey(key) + " (personnalise)",
                type: inferCustomFieldType(key, rawValue),
                required: false
            });
        }

        extraFields.sort(function (a, b) {
            return a.label.localeCompare(b.label);
        });

        if (extraFields.length > 0) {
            var finalFields = [];
            for (var x = 0; x < extraFields.length; x++) {
                finalFields.push(extraFields[x]);
            }

            for (var y = 0; y < AUTRE_REQUIRED_KEYS.length; y++) {
                var requiredKey = AUTRE_REQUIRED_KEYS[y];
                if (!baseByKey[requiredKey]) continue;

                finalFields.push({
                    key: requiredKey,
                    label: baseByKey[requiredKey].label || requiredKey,
                    type: "hidden",
                    required: true
                });
            }

            return finalFields;
        }

        return baseFields.concat(extraFields);
    }

    function renderFields(fields, values, container) {
        container.innerHTML = "";
        maps = {}; markers = {}; selectedLocations = {};

        for (var i = 0; i < fields.length; i++) {
            var f = fields[i];
            var val = toFieldValue(values[f.key]);
            var err = hasError(f.key) ? " is-invalid-custom" : "";

            if (f.type === "hidden") {
                container.appendChild(buildInput(f, val, ""));
                continue;
            }

            if (f.type === "location") {
                var fullCol = document.createElement("div");
                fullCol.className = "col-12";
                fullCol.appendChild(buildLocationField(f, val, values));
                container.appendChild(fullCol);
            } else {
                var col = document.createElement("div");
                col.className = f.type === "textarea" ? "col-12" : "col-md-6";
                col.appendChild(buildLabel(f));
                col.appendChild(buildInput(f, val, err));
                appendFieldError(col, f.key);
                container.appendChild(col);
            }
        }

        setTimeout(function () {
            autoFillNombreJours();
        }, 100);
    }

    function appendFieldError(container, key) {
        var message = getFieldErrorMessage(key);
        if (!message) return;
        var error = document.createElement("div");
        error.className = "field-error";
        error.textContent = message;
        container.appendChild(error);
    }

    function buildLabel(f) {
        var lbl = document.createElement("label");
        lbl.className = "form-label" + (f.required ? " required" : "");
        lbl.textContent = f.label;
        return lbl;
    }

    function buildInput(f, val, err) {
        var inp;
        switch (f.type) {
            case "hidden":
                inp = document.createElement("input");
                inp.type = "hidden";
                inp.name = "details[" + f.key + "]";
                inp.value = val;
                return inp;
            case "text":
                inp = document.createElement("input");
                inp.type = "text"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
            case "number":
                inp = document.createElement("input");
                inp.type = "number"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val; inp.min = "0";
                return inp;
            case "date":
                inp = document.createElement("input");
                inp.type = "date"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = normalizeDateValue(val);
                inp.addEventListener("change", function () {
                    autoFillNombreJours();
                });
                return inp;
            case "textarea":
                inp = document.createElement("textarea");
                inp.className = "form-control" + err; inp.rows = 3;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
            case "select":
                inp = document.createElement("select");
                inp.className = "form-select" + err;
                inp.name = "details[" + f.key + "]";
                var d = document.createElement("option");
                d.value = ""; d.textContent = "-- Selectionnez --";
                inp.appendChild(d);
                if (f.options) {
                    for (var j = 0; j < f.options.length; j++) {
                        var o = document.createElement("option");
                        o.value = f.options[j]; o.textContent = f.options[j];
                        if (val === f.options[j]) o.selected = true;
                        inp.appendChild(o);
                    }
                }
                return inp;
            default:
                inp = document.createElement("input");
                inp.type = "text"; inp.className = "form-control" + err;
                inp.name = "details[" + f.key + "]"; inp.value = val;
                return inp;
        }
    }

    function autoFillNombreJours() {
        var container = document.getElementById("dynamicFields");
        if (!container) return;

        var startKeys = [
            "dateDebut", "dateDebutConge", "dateDebutTeletravail",
            "dateDebutFormation", "dateDebutHoraires", "dateDebutMission"
        ];
        var endKeys = [
            "dateFin", "dateFinConge", "dateFinTeletravail",
            "dateFinFormation", "dateFinHoraires", "dateFinMission"
        ];
        var joursKeys = [
            "nombreJours", "nombreJoursConge", "nombreJoursTeletravail",
            "nombreJoursFormation", "duree", "nombreJoursMission"
        ];

        var startInput = null;
        var endInput   = null;
        var joursInput = null;

        for (var i = 0; i < startKeys.length; i++) {
            var el = container.querySelector('[name="details[' + startKeys[i] + ']"]');
            if (el) { startInput = el; break; }
        }
        for (var j = 0; j < endKeys.length; j++) {
            var el2 = container.querySelector('[name="details[' + endKeys[j] + ']"]');
            if (el2) { endInput = el2; break; }
        }
        for (var k = 0; k < joursKeys.length; k++) {
            var el3 = container.querySelector('[name="details[' + joursKeys[k] + ']"]');
            if (el3) { joursInput = el3; break; }
        }

        if (!startInput || !endInput || !joursInput) return;

        var startVal = startInput.value;
        var endVal   = endInput.value;

        if (!startVal || !endVal) return;

        var startDate = new Date(startVal);
        var endDate   = new Date(endVal);

        if (isNaN(startDate.getTime()) || isNaN(endDate.getTime())) return;
        if (endDate < startDate) return;

        var diffMs   = endDate.getTime() - startDate.getTime();
        var diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24)) + 1;

        joursInput.value = diffDays;
    }

    function buildLocationField(f, val, values) {
        var wrapper = document.createElement("div");
        var err = hasError(f.key) ? " is-invalid-custom" : "";
        var existingLat = values[f.key + "Lat"] || "";
        var existingLon = values[f.key + "Lon"] || "";

        wrapper.appendChild(buildLabel(f));

        var readonlyInput = document.createElement("input");
        readonlyInput.type = "text";
        readonlyInput.className = "form-control mb-2" + err;
        readonlyInput.readOnly = true;
        readonlyInput.name = "details[" + f.key + "]";
        readonlyInput.id = "locval-" + f.key;
        readonlyInput.placeholder = "Cliquez sur la carte ci-dessous pour choisir un lieu";
        readonlyInput.value = val;
        wrapper.appendChild(readonlyInput);

        var latInp = document.createElement("input");
        latInp.type = "hidden"; latInp.name = "details[" + f.key + "Lat]";
        latInp.id = "lat-" + f.key; latInp.value = existingLat;
        wrapper.appendChild(latInp);

        var lonInp = document.createElement("input");
        lonInp.type = "hidden"; lonInp.name = "details[" + f.key + "Lon]";
        lonInp.id = "lon-" + f.key; lonInp.value = existingLon;
        wrapper.appendChild(lonInp);

        var mapSection = document.createElement("div");
        mapSection.className = "inline-map-section";
        mapSection.id = "mapsection-" + f.key;

        var header = document.createElement("div");
        header.className = "map-card-header";
        header.innerHTML = '<svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="margin-right:6px"><path d="M8 0C5.24 0 3 2.24 3 5c0 3.75 5 11 5 11s5-7.25 5-11c0-2.76-2.24-5-5-5zm0 7.5C6.62 7.5 5.5 6.38 5.5 5S6.62 2.5 8 2.5 10.5 3.62 10.5 5 9.38 7.5 8 7.5z"/></svg>' + f.label + ' - Choisir sur la carte';
        mapSection.appendChild(header);

        var body = document.createElement("div");
        body.className = "map-card-body";

        var searchBar = document.createElement("div");
        searchBar.className = "map-search-bar";
        var searchInput = document.createElement("input");
        searchInput.type = "text";
        searchInput.placeholder = "Rechercher une ville ou adresse...";
        searchInput.id = "mapsearch-" + f.key;
        var searchBtn = document.createElement("button");
        searchBtn.type = "button"; searchBtn.textContent = "Rechercher";
        searchBtn.onclick = (function (k) {
            return function () { searchOnMap(k, document.getElementById("mapsearch-" + k).value); };
        })(f.key);
        searchInput.addEventListener("keypress", (function (k) {
            return function (e) {
                if (e.key === "Enter") { e.preventDefault(); searchOnMap(k, document.getElementById("mapsearch-" + k).value); }
            };
        })(f.key));
        searchBar.appendChild(searchInput);
        searchBar.appendChild(searchBtn);
        body.appendChild(searchBar);

        var mapWrapper = document.createElement("div");
        mapWrapper.className = "map-wrapper";

        var infoBar = document.createElement("div");
        infoBar.className = "map-info-bar";
        infoBar.id = "mapinfo-" + f.key;
        infoBar.textContent = "Cliquez sur la carte pour choisir un lieu";
        mapWrapper.appendChild(infoBar);

        var zoomBox = document.createElement("div");
        zoomBox.className = "map-zoom-controls";
        var zIn = document.createElement("button"); zIn.type = "button"; zIn.textContent = "+";
        zIn.onclick = (function (k) { return function () { if (maps[k]) maps[k].zoomIn(); }; })(f.key);
        var zOut = document.createElement("button"); zOut.type = "button"; zOut.textContent = "−";
        zOut.onclick = (function (k) { return function () { if (maps[k]) maps[k].zoomOut(); }; })(f.key);
        zoomBox.appendChild(zIn); zoomBox.appendChild(zOut);
        mapWrapper.appendChild(zoomBox);

        var mapDiv = document.createElement("div");
        mapDiv.id = "map-" + f.key;
        mapDiv.style.height = "450px";
        mapDiv.style.width = "100%";
        mapDiv.style.background = "#aad3df";
        mapWrapper.appendChild(mapDiv);
        body.appendChild(mapWrapper);

        var infoSelected = document.createElement("div");
        infoSelected.className = "map-selected-info";
        infoSelected.id = "mapselected-" + f.key;
        body.appendChild(infoSelected);

        var confirmBar = document.createElement("div");
        confirmBar.className = "map-confirm-bar";
        var clearBtn = document.createElement("button");
        clearBtn.type = "button"; clearBtn.className = "btn-clear-location"; clearBtn.textContent = "Effacer";
        clearBtn.onclick = (function (k) { return function () { clearLocation(k); }; })(f.key);
        var confirmBtn = document.createElement("button");
        confirmBtn.type = "button"; confirmBtn.className = "btn-confirm-location";
        confirmBtn.id = "mapconfirm-" + f.key; confirmBtn.textContent = "Confirmer cette destination";
        confirmBtn.disabled = true;
        confirmBtn.onclick = (function (k) { return function () { confirmLocation(k); }; })(f.key);
        confirmBar.appendChild(clearBtn);
        confirmBar.appendChild(confirmBtn);
        body.appendChild(confirmBar);
        mapSection.appendChild(body);
        wrapper.appendChild(mapSection);
        appendFieldError(wrapper, f.key);

        setTimeout(function () { initInlineMap(f.key, existingLat, existingLon, val); }, 300);

        return wrapper;
    }

    function initInlineMap(key, existingLat, existingLon, existingValue) {
        var mapDiv = document.getElementById("map-" + key);
        if (!mapDiv) return;

        var m = L.map("map-" + key, { zoomControl: false }).setView([36.8065, 10.1815], 6);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: "&copy; OpenStreetMap contributors", maxZoom: 18
        }).addTo(m);

        maps[key] = m;
        markers[key] = null;
        selectedLocations[key] = null;

        if (existingLat && existingLon) {
            var lat = parseFloat(existingLat);
            var lon = parseFloat(existingLon);
            if (!isNaN(lat) && !isNaN(lon)) {
                m.setView([lat, lon], 13);
                markers[key] = L.marker([lat, lon]).addTo(m);
                selectedLocations[key] = { lat: lat, lon: lon, name: existingValue || (lat.toFixed(5) + ", " + lon.toFixed(5)) };
                updateMapInfo(key, selectedLocations[key].name);
                showSelectedInfo(key, selectedLocations[key]);
                document.getElementById("mapconfirm-" + key).disabled = false;
            }
        }

        m.on("click", (function (k) {
            return function (e) { pickLocationOnMap(k, e.latlng.lat, e.latlng.lng); };
        })(key));
    }

    function pickLocationOnMap(key, lat, lon) {
        var m = maps[key];
        if (!m) return;
        if (markers[key]) m.removeLayer(markers[key]);
        markers[key] = L.marker([lat, lon]).addTo(m);
        var tempName = lat.toFixed(5) + ", " + lon.toFixed(5);
        selectedLocations[key] = { lat: lat, lon: lon, name: tempName };
        updateMapInfo(key, "Recherche en cours...");
        document.getElementById("mapconfirm-" + key).disabled = true;
        showSelectedInfo(key, { lat: lat, lon: lon, name: "Geocodage en cours..." });

        fetch("https://nominatim.openstreetmap.org/reverse?format=json&lat=" + lat + "&lon=" + lon + "&accept-language=fr")
            .then(function (r) { return r.json(); })
            .then(function (data) {
                var name = data.display_name || tempName;
                selectedLocations[key] = { lat: lat, lon: lon, name: name };
                updateMapInfo(key, name);
                showSelectedInfo(key, selectedLocations[key]);
                if (markers[key]) markers[key].bindPopup(name).openPopup();
                document.getElementById("mapconfirm-" + key).disabled = false;
            })
            .catch(function () {
                selectedLocations[key] = { lat: lat, lon: lon, name: tempName };
                updateMapInfo(key, tempName);
                showSelectedInfo(key, selectedLocations[key]);
                document.getElementById("mapconfirm-" + key).disabled = false;
            });
    }

    function searchOnMap(key, query) {
        if (!query || !query.trim()) return;
        updateMapInfo(key, "Recherche: " + query + "...");
        fetch("https://nominatim.openstreetmap.org/search?format=json&q=" + encodeURIComponent(query.trim()) + "&limit=1&accept-language=fr")
            .then(function (r) { return r.json(); })
            .then(function (results) {
                if (results && results.length > 0) {
                    var r = results[0];
                    var lat = parseFloat(r.lat);
                    var lon = parseFloat(r.lon);
                    var m = maps[key];
                    if (m) { m.setView([lat, lon], 13); pickLocationOnMap(key, lat, lon); }
                } else { updateMapInfo(key, "Aucun resultat trouve"); }
            })
            .catch(function () { updateMapInfo(key, "Erreur de recherche"); });
    }

    function updateMapInfo(key, text) {
        var el = document.getElementById("mapinfo-" + key);
        if (el) el.textContent = text.length > 60 ? text.substring(0, 57) + "..." : text;
    }

    function showSelectedInfo(key, loc) {
        var el = document.getElementById("mapselected-" + key);
        if (!el) return;
        el.className = "map-selected-info visible";
        el.innerHTML = "<strong>Lieu selectionne:</strong> " + loc.name +
            "<br><small style='color:#888'>Lat: " + loc.lat.toFixed(6) + " | Lon: " + loc.lon.toFixed(6) + "</small>";
    }

    function confirmLocation(key) {
        var loc = selectedLocations[key];
        if (!loc) return;
        var valInp = document.getElementById("locval-" + key);
        var latInp = document.getElementById("lat-" + key);
        var lonInp = document.getElementById("lon-" + key);
        if (valInp) valInp.value = loc.name;
        if (latInp) latInp.value = loc.lat;
        if (lonInp) lonInp.value = loc.lon;
        var infoEl = document.getElementById("mapselected-" + key);
        if (infoEl) {
            infoEl.innerHTML = "<strong style='color:#16a34a'>Destination confirmee:</strong> " + loc.name +
                "<br><small style='color:#888'>Lat: " + loc.lat.toFixed(6) + " | Lon: " + loc.lon.toFixed(6) + "</small>";
        }
        var btn = document.getElementById("mapconfirm-" + key);
        if (btn) { btn.textContent = "Confirme"; btn.style.background = "#16a34a"; }
    }

    function clearLocation(key) {
        var m = maps[key];
        if (m && markers[key]) { m.removeLayer(markers[key]); markers[key] = null; }
        selectedLocations[key] = null;
        var valInp = document.getElementById("locval-" + key);
        var latInp = document.getElementById("lat-" + key);
        var lonInp = document.getElementById("lon-" + key);
        if (valInp) valInp.value = "";
        if (latInp) latInp.value = "";
        if (lonInp) lonInp.value = "";
        updateMapInfo(key, "Cliquez sur la carte pour choisir un lieu");
        var infoEl = document.getElementById("mapselected-" + key);
        if (infoEl) { infoEl.className = "map-selected-info"; infoEl.innerHTML = ""; }
        var btn = document.getElementById("mapconfirm-" + key);
        if (btn) { btn.disabled = true; btn.textContent = "Confirmer cette destination"; btn.style.background = ""; }
    }

})();
</script>
{% endblock %}