{% extends 'base.html.twig' %}

{% block title %}Demande{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .detail-label {
        font-weight: 600;
        color: #64748b;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 6px;
    }
    .detail-value {
        font-size: .95rem;
        color: #1f2937;
    }
    .timeline-item {
        position: relative;
        padding-left: 24px;
        padding-bottom: 16px;
        border-left: 2px solid #e2e8f0;
    }
    .timeline-item:last-child {
        border-left: 2px solid transparent;
    }
    .timeline-item::before {
        content: "";
        position: absolute;
        left: -8px;
        top: 4px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--tblr-primary);
        border: 2px solid #fff;
        box-shadow: 0 0 0 2px var(--tblr-primary);
    }
    .badge {
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 4px;
        display: inline-block;
        color: #fff !important;
    }
    .badge.bg-danger    { background-color: #dc3545 !important; color: white; }
    .badge.bg-warning   { background-color: #ffc107 !important; color: #fff !important; }
    .badge.bg-success   { background-color: #28a745 !important; color: white; }
    .badge.bg-info      { background-color: #17a2b8 !important; color: white; }
    .badge.bg-orange    { background-color: #fd7e14 !important; color: white; }
    .badge.bg-secondary { background-color: #6c757d !important; color: white; }

    .status-option-btn {
        width: 100%;
        padding: 10px 14px;
        border-radius: 8px;
        border: 2px solid;
        background: transparent;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 8px;
        text-align: left;
    }
    .status-option-btn:last-child { margin-bottom: 0; }
    .status-option-btn.btn-encours {
        color: #e6a817; border-color: #ffc107;
        background: rgba(255,193,7,0.05);
    }
    .status-option-btn.btn-encours:hover { background:#ffc107; color:#333; }
    .status-option-btn.btn-attente {
        color: #fd7e14; border-color: #fd7e14;
        background: rgba(253,126,20,0.05);
    }
    .status-option-btn.btn-attente:hover { background:#fd7e14; color:white; }
    .status-option-btn.btn-resolve {
        color: #28a745; border-color: #28a745;
        background: rgba(40,167,69,0.05);
    }
    .status-option-btn.btn-resolve:hover { background:#28a745; color:white; }
    .status-option-btn.btn-reject {
        color: #dc3545; border-color: #dc3545;
        background: rgba(220,53,69,0.05);
    }
    .status-option-btn.btn-reject:hover { background:#dc3545; color:white; }

    .resolved-banner {
        background: linear-gradient(135deg,#f0fff4 0%,#d4edda 100%);
        border: 1.5px solid #c3e6cb;
        border-radius: 10px;
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
    }
    .resolved-banner .resolved-icon {
        width: 46px; height: 46px; border-radius: 50%;
        background: #28a745;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .resolved-banner h4 { margin:0 0 4px; font-size:1rem; font-weight:700; color:#155724; }
    .resolved-banner p  { margin:0; color:#1e7e34; font-size:.875rem; }

    .cancelled-banner {
        background: linear-gradient(135deg,#fff5f5 0%,#ffe0e0 100%);
        border: 1.5px solid #f5c6cb;
        border-radius: 10px;
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
    }
    .cancelled-banner .cancelled-icon {
        width: 46px; height: 46px; border-radius: 50%;
        background: #dc3545;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .cancelled-banner h4 { margin:0 0 4px; font-size:1rem; font-weight:700; color:#842029; }
    .cancelled-banner p  { margin:0; color:#b02a37; font-size:.875rem; }

    .modal-comment-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        margin-bottom: 6px;
        display: block;
        text-align: left;
    }
    .decision-card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
    }
    .decision-card .card-header {
        background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
    }
    .decision-score {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 54px;
        height: 54px;
        border-radius: 999px;
        font-size: 1rem;
        font-weight: 700;
        color: #1e3a8a;
        background: #dbeafe;
        border: 1px solid #bfdbfe;
    }
    .decision-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
    }
    .decision-pill.resolve { background: #dcfce7; color: #166534; }
    .decision-pill.wait { background: #fef3c7; color: #92400e; }
    .decision-pill.reject { background: #fee2e2; color: #991b1b; }
    .decision-pill.review { background: #dbeafe; color: #1d4ed8; }
    .decision-list {
        margin: 0;
        padding-left: 18px;
        color: #334155;
        font-size: .9rem;
    }
    .decision-list li + li {
        margin-top: 6px;
    }
    .decision-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }
    .decision-meta .meta-chip {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        padding: 6px 10px;
        font-size: .8rem;
        color: #475569;
        font-weight: 600;
    }
    .spam-indicator {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 14px;
    }
    .spam-indicator.success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }
    .spam-indicator.warning {
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
    }
    .spam-indicator.danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }
    .spam-score {
        min-width: 46px;
        height: 46px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: .95rem;
        background: rgba(255,255,255,.7);
        border: 1px solid currentColor;
    }
    .spam-copy strong {
        display: block;
        font-size: .85rem;
        margin-bottom: 3px;
    }
    .spam-copy span {
        display: block;
        font-size: .84rem;
        line-height: 1.4;
    }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="min-height:calc(100vh - 56px);">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes', 'sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="page-header d-print-none mb-3">
        <div class="container-xl">
            <div class="row align-items-center">
                <div class="col">
                    <div class="page-pretitle">
                        <a href="{{ path('demande_index') }}" class="text-secondary text-decoration-none">
                            <i class="ti ti-arrow-left me-1"></i>Retour aux demandes
                        </a>
                    </div>
                    <h2 class="page-title mt-1">{{ demande.titre }}</h2>
                    <div class="text-secondary">Consultez les details et repondez a cette demande.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show mb-3">
                    <i class="ti ti-check me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible fade show mb-3">
                    <i class="ti ti-alert-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('danger') %}
                <div class="alert alert-danger alert-dismissible fade show mb-3">
                    <i class="ti ti-alert-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% if demande.status == 'Annulee' %}
            <div class="cancelled-banner">
                <div class="cancelled-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </div>
                <div>
                    <h4>Demande annulee par l'employe</h4>
                    <p>Cette demande a ete annulee. Elle ne peut plus etre traitee ni changer de statut.</p>
                </div>
            </div>
            {% elseif demande.status == 'Resolue' %}
            <div class="resolved-banner">
                <div class="resolved-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
                         fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                </div>
                <div>
                    <h4>Demande resolue</h4>
                    <p>Cette demande a ete resolue. Le statut est definitif. Vous pouvez toujours modifier ses informations.</p>
                </div>
            </div>
            {% endif %}

            <div class="row">
                {# LEFT COLUMN #}
                <div class="col-lg-8">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations generales</h3>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="detail-label">Employe</div>
                                    <div class="detail-value">
                                        {% if demande.employe %}
                                            {{ demande.employe.nom }} {{ demande.employe.prenom }}
                                        {% else %}N/A{% endif %}
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Categorie</div>
                                    <div class="detail-value">{{ demande.categorie }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Type de demande</div>
                                    <div class="detail-value">{{ demande.typeDemande }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Priorite</div>
                                    <div class="detail-value">
                                        {% if demande.priorite == 'HAUTE' %}
                                            <span class="badge bg-danger"><i class="ti ti-alert-triangle me-1"></i>{{ demande.priorite }}</span>
                                        {% elseif demande.priorite == 'NORMALE' %}
                                            <span class="badge bg-info"><i class="ti ti-minus me-1"></i>{{ demande.priorite }}</span>
                                        {% else %}
                                            <span class="badge bg-success"><i class="ti ti-arrow-down me-1"></i>{{ demande.priorite }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Statut</div>
                                    <div class="detail-value">
                                        {% if demande.status == 'Nouvelle' %}
                                            <span class="badge bg-info"><i class="ti ti-sparkles me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En cours' %}
                                            <span class="badge bg-warning"><i class="ti ti-loader me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En attente' %}
                                            <span class="badge bg-orange"><i class="ti ti-clock me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Resolue' %}
                                            <span class="badge bg-success"><i class="ti ti-check me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Rejetee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Reconsideration' %}
                                            <span class="badge bg-primary"><i class="ti ti-lock-open me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Annulee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary"><i class="ti ti-lock me-1"></i>{{ demande.status }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Date de creation</div>
                                    <div class="detail-value">
                                        {{ demande.dateCreation ? demande.dateCreation|date('d/m/Y H:i') : 'N/A' }}
                                    </div>
                                </div>
                                {% if demande.description %}
                                    <div class="col-12">
                                        <div class="detail-label">Description</div>
                                        <div class="detail-value">{{ demande.description }}</div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {% if detailsData|length > 0 %}
                        <div class="card mb-3">
                            <div class="card-header">
                                <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations specifiques</h3>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    {% for key, value in detailsData %}
                                        {% if not (key ends with 'Lat' or key ends with 'Lon') %}
                                            <div class="col-md-6">
                                                <div class="detail-label">{{ fieldLabels[key] ?? key }}</div>
                                                <div class="detail-value">{{ value }}</div>
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    {% if demande.historiqueDemandes|length > 0 %}
                        <div class="card mb-3">
                            <div class="card-header">
                                <h3 class="card-title"><i class="ti ti-history me-2"></i>Historique des modifications</h3>
                            </div>
                            <div class="card-body">
                                {% for historique in demande.historiqueDemandes|reverse %}
                                    <div class="timeline-item">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                {% if historique.ancienStatut %}
                                                    <span class="badge bg-secondary">{{ historique.ancienStatut }}</span>
                                                    <i class="ti ti-arrow-right mx-2"></i>
                                                {% endif %}
                                                <span class="badge bg-info">{{ historique.nouveauStatut }}</span>
                                                {% if historique.commentaire %}
                                                    <div class="text-muted mt-2" style="font-size:.85rem;">
                                                        {{ historique.commentaire }}
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <div class="text-end text-muted" style="font-size:.8rem;">
                                                <div>{{ historique.acteur }}</div>
                                                <div>{{ historique.dateAction|date('d/m/Y H:i') }}</div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>{# end col-lg-8 #}

                {# RIGHT COLUMN #}
                <div class="col-lg-4">

                    {% if decisionAdvice %}
                        {% set recommendationClass = decisionAdvice.recommendedStatus == 'Resolue' ? 'resolve' : (decisionAdvice.recommendedStatus == 'En attente' ? 'wait' : (decisionAdvice.recommendedStatus == 'Rejetee' ? 'reject' : 'review')) %}
                        <div class="decision-card card mb-3">
                            <div class="card-header">
                                <h3 class="card-title"><i class="ti ti-brain me-2"></i>Aide a la decision</h3>
                            </div>
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="decision-score">{{ (decisionAdvice.confidence * 100)|round }}%</div>
                                    <div>
                                        <div class="decision-pill {{ recommendationClass }}">
                                            <i class="ti ti-sparkles"></i>{{ decisionAdvice.recommendedStatus }}
                                        </div>
                                        <div class="mt-2 text-secondary" style="font-size:.9rem;">{{ decisionAdvice.summary }}</div>
                                    </div>
                                </div>

                                {% if decisionAdvice.spamLevel is defined %}
                                    <div class="spam-indicator {{ decisionAdvice.spamLevel.tone }}">
                                        <div class="spam-score">{{ decisionAdvice.spamScore }}</div>
                                        <div class="spam-copy">
                                            <strong>Score test/spam: {{ decisionAdvice.spamLevel.label }}</strong>
                                            <span>{{ decisionAdvice.spamLevel.description }}</span>
                                        </div>
                                    </div>
                                {% endif %}

                                {% if decisionAdvice.reasons is not empty %}
                                    <div class="mb-3">
                                        <div class="detail-label">Pourquoi cette recommandation</div>
                                        <ul class="decision-list">
                                            {% for reason in decisionAdvice.reasons %}
                                                <li>{{ reason }}</li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endif %}

                                {% if decisionAdvice.missingRequired is not empty %}
                                    <div class="mb-3">
                                        <div class="detail-label">Informations manquantes</div>
                                        <ul class="decision-list">
                                            {% for missing in decisionAdvice.missingRequired %}
                                                <li>{{ missing }}</li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endif %}

                                {% if decisionAdvice.weakRequired is defined and decisionAdvice.weakRequired is not empty %}
                                    <div class="mb-3">
                                        <div class="detail-label">Contenu peu fiable</div>
                                        <ul class="decision-list">
                                            {% for weak in decisionAdvice.weakRequired %}
                                                <li>{{ weak }}</li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endif %}

                                {% if decisionAdvice.warnings is not empty %}
                                    <div>
                                        <div class="detail-label">Points de vigilance</div>
                                        <ul class="decision-list">
                                            {% for warning in decisionAdvice.warnings %}
                                                <li>{{ warning }}</li>
                                            {% endfor %}
                                        </ul>
                                    </div>
                                {% endif %}

                                <div class="decision-meta">
                                    <span class="meta-chip">Completude: {{ (decisionAdvice.completeness * 100)|round }}%</span>
                                    <span class="meta-chip">Mode: logique tolerante aux donnees sales</span>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    {% if demande.status == 'Annulee' %}
                        <div class="card mb-3">
                            <div class="card-header" style="background:#dc3545;border-color:#dc3545;">
                                <h3 class="card-title text-white">
                                    <i class="ti ti-ban me-2"></i>Demande Annulee
                                </h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-0">
                                    <i class="ti ti-alert-circle me-1 text-danger"></i>
                                    Cette demande a ete annulee par l'employe. Aucune action de modification n'est possible.
                                </p>
                            </div>
                        </div>

                    {% elseif demande.status == 'Rejetee' %}
                        <div class="card mb-3">
                            <div class="card-header" style="background:#dc3545;border-color:#dc3545;">
                                <h3 class="card-title text-white">
                                    <i class="ti ti-x me-2"></i>Demande rejetee
                                </h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-2">
                                    <i class="ti ti-alert-circle me-1 text-danger"></i>
                                    Cette demande est verrouillee pour les changements de statut.
                                </p>
                                <p class="text-muted mb-3">
                                    Cliquez sur <strong>Reconsideration</strong> pour rouvrir les changements de statut.
                                </p>
                                <button type="button"
                                        class="btn btn-primary w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalStatus-reconsideration">
                                        <i class="ti ti-lock-open me-1"></i>Passer en reconsideration
                                </button>
                            </div>
                        </div>

                    {% elseif demande.status == 'Resolue' %}
                        <div class="card mb-3">
                            <div class="card-header" style="background:#28a745;border-color:#28a745;">
                                <h3 class="card-title text-white">
                                    <i class="ti ti-circle-check me-2"></i>Demande Resolue
                                </h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-0">
                                    <i class="ti ti-lock me-1 text-success"></i>
                                    Le statut est definitif et ne peut plus etre modifie.
                                    Vous pouvez toujours modifier les informations via le bouton Modifier.
                                </p>
                            </div>
                        </div>

                    {% else %}
                        <div class="card mb-3">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="ti ti-settings me-2"></i>Changer le statut
                                </h3>
                            </div>
                            <div class="card-body">
                                <label class="form-label text-muted mb-3" style="font-size:0.8rem;">
                                    CHOISIR UN NOUVEAU STATUT
                                </label>

                                {% if demande.status != 'En cours' %}
                                <button type="button"
                                        class="status-option-btn btn-encours"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalStatus-encours">
                                    <i class="ti ti-loader"></i>Passer en cours
                                </button>
                                {% endif %}

                                {% if demande.status != 'En attente' %}
                                <button type="button"
                                        class="status-option-btn btn-attente"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalStatus-attente">
                                    <i class="ti ti-clock"></i>Mettre en attente
                                </button>
                                {% endif %}

                                <button type="button"
                                        class="status-option-btn btn-resolve"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalStatus-resolue">
                                    <i class="ti ti-check"></i>Marquer comme resolue
                                </button>

                                <button type="button"
                                        class="status-option-btn btn-reject"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalStatus-rejetee">
                                    <i class="ti ti-x"></i>Rejeter la demande
                                </button>
                            </div>
                        </div>
                    {% endif %}

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="ti ti-link me-2"></i>Actions rapides</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                {% if demande.status != 'Annulee' %}
                                    <a href="{{ path('demande_edit', {id: demande.idDemande}) }}"
                                       class="btn btn-outline-primary">
                                        <i class="ti ti-edit me-1"></i>Modifier
                                    </a>
                                {% else %}
                                    <button class="btn btn-outline-secondary" disabled>
                                        <i class="ti ti-lock me-1"></i>Modifier (Indisponible)
                                    </button>
                                {% endif %}
                                <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">
                                    <i class="ti ti-arrow-left me-1"></i>Retour a la liste
                                </a>
                            </div>
                        </div>
                    </div>

                </div>{# end col-lg-4 #}
            </div>
        </div>
    </div>
</div>
</div>

