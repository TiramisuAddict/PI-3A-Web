{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/demande-sync.js') }}"></script>
<script>
(function () {
    "use strict";

    var searchInput;
    var noResults;
    var currentFilter = "all";

    document.addEventListener("DOMContentLoaded", function () {
        searchInput = document.getElementById("searchInput");
        noResults   = document.getElementById("noResults");

        if (searchInput) {
            searchInput.addEventListener("input", debounce(performSearch, 300));
            searchInput.addEventListener("keyup", function (e) {
                if (e.key === "Escape") clearSearch();
            });
        }

        document.querySelectorAll(".quick-filter-btn").forEach(function (btn) {
            btn.addEventListener("click", function () {
                document.querySelectorAll(".quick-filter-btn").forEach(function (b) {
                    b.classList.remove("active");
                });
                this.classList.add("active");
                currentFilter = this.getAttribute("data-filter");
                performSearch();
            });
        });

        if (window.DemandeSyncManager) {
            window.DemandeSyncManager.onStatusUpdate(function (data) {
                if (data.type === "status-update") {
                    window.location.reload();
                }
            });
        }
        performSearch();
    });

    function performSearch() {
        var term    = searchInput ? searchInput.value.toLowerCase().trim() : "";
        var rows    = document.querySelectorAll(".demande-row");
        var visible = 0;

        var counts = {
            total      : 0,
            "Nouvelle" : 0,
            "En cours" : 0,
            "Resolue"  : 0
        };

        rows.forEach(function (row) {
            var titre     = row.getAttribute("data-titre")     || "";
            var categorie = row.getAttribute("data-categorie") || "";
            var type      = row.getAttribute("data-type")      || "";
            var priorite  = row.getAttribute("data-priorite")  || "";
            var status    = row.getAttribute("data-status")    || "";
            var normalizedPriorite = normalizeValue(priorite);
            var normalizedStatus   = normalizeValue(status);
            var normalizedFilter   = normalizeValue(currentFilter);

            var matchSearch =
                term === "" ||
                titre.indexOf(term)                  !== -1 ||
                categorie.indexOf(term)              !== -1 ||
                type.indexOf(term)                   !== -1 ||
                normalizedPriorite.indexOf(term)     !== -1 ||
                normalizedStatus.indexOf(term)       !== -1;

            var matchFilter =
                currentFilter === "all" ||
                normalizedPriorite === normalizedFilter ||
                normalizedStatus   === normalizedFilter;

            if (matchSearch && matchFilter) {
                row.classList.remove("hidden");
                visible++;
                counts.total++;
                var trackedStatus = toTrackedStatus(status);
                if (trackedStatus && counts[trackedStatus] !== undefined) {
                    counts[trackedStatus]++;
                }
            } else {
                row.classList.add("hidden");
            }
        });

        animateStat("total",     counts["total"]);
        animateStat("Nouvelle",  counts["Nouvelle"]);
        animateStat("En cours",  counts["En cours"]);
        animateStat("Resolue",   counts["Resolue"]);

        var table = document.querySelector(".table-responsive");
        if (visible === 0 && rows.length > 0) {
            if (noResults) noResults.style.display = "block";
            if (table)     table.style.display     = "none";
        } else {
            if (noResults) noResults.style.display = "none";
            if (table)     table.style.display     = "block";
        }
    }

    function animateStat(key, value) {
        var el = document.querySelector('[data-stat-value="' + key + '"]');
        if (!el) return;
        var current = parseInt(el.textContent) || 0;
        if (current === value) return;
        el.style.transition = "opacity 0.15s ease";
        el.style.opacity    = "0.3";
        setTimeout(function () {
            el.textContent   = value;
            el.style.opacity = "1";
        }, 150);
    }

    function clearSearch() {
        if (searchInput) searchInput.value = "";
        currentFilter = "all";
        document.querySelectorAll(".quick-filter-btn").forEach(function (b) {
            b.classList.remove("active");
        });
        var allBtn = document.querySelector('.quick-filter-btn[data-filter="all"]');
        if (allBtn) allBtn.classList.add("active");
        performSearch();
    }

    function filterByStatus(status) {
        if (searchInput) searchInput.value = "";
        currentFilter = status || "all";
        document.querySelectorAll(".quick-filter-btn").forEach(function (b) {
            b.classList.remove("active");
            if (normalizeValue(b.getAttribute("data-filter") || "") === normalizeValue(currentFilter)) {
                b.classList.add("active");
            }
        });
        performSearch();
    }

    function normalizeValue(value) {
        return (value || "")
            .toString()
            .trim()
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    }

    function toTrackedStatus(status) {
        var normalized = normalizeValue(status);
        if (normalized === "nouvelle") return "Nouvelle";
        if (normalized === "en cours") return "En cours";
        if (normalized === "resolue") return "Resolue";
        return null;
    }

    function debounce(func, wait) {
        var timeout;
        return function () {
            var ctx  = this;
            var args = arguments;
            clearTimeout(timeout);
            timeout = setTimeout(function () { func.apply(ctx, args); }, wait);
        };
    }

    window.filterByStatus = filterByStatus;
    window.clearSearch    = clearSearch;

}());
</script>
{% endblock %}