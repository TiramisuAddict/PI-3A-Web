{% extends 'base.html.twig' %}

{% block title %}Liste des Demandes{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
    .stats-row {
        display: flex;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .stat-card {
        flex: 1;
        min-width: 140px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        background: #fff;
        transition: border-color .2s ease, box-shadow .2s ease, transform .2s ease;
        cursor: pointer;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .stat-card:hover {
        border-color: rgba(31, 111, 235, 0.35);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.08);
        transform: translateY(-2px);
    }
    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
            color: #fff !important;
        flex-shrink: 0;
    }
    .stat-content {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }
    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1;
    }
    .stat-label {
        font-size: 0.75rem;
        color: #64748b;
        margin-top: 4px;
        font-weight: 500;
        white-space: nowrap;
    }
    .demande-row.hidden {
        display: none;
    }
    .stat-card {
        flex: 1;
        min-width: 140px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 10px;
        background: #fff;
        transition: border-color .2s ease, box-shadow .2s ease;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 4px 16px rgba(74, 93, 239, 0.08);
    }
    .stat-card:hover {
        border-color: rgba(74, 93, 239, 0.35);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        transform: translateY(-2px);
    }
    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        background: #f5f7fb;
    }
    .badge {
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 600;
        border-radius: 4px;
        display: inline-block;
        color: #fff !important;
    }
    .titre-link:hover {
        color: var(--tblr-primary);
    }
    .category-tag {
        background: rgba(31, 111, 235, 0.08);
        color: var(--tblr-primary);
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .date-text {
        color: #64748b;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .quick-filter-btn {
        padding: 6px 14px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .quick-filter-btn:hover {
        border-color: var(--tblr-primary);
        color: var(--tblr-primary);
        background: rgba(31, 111, 235, 0.05);
    }
    .quick-filter-btn.active {
        background: var(--tblr-primary);
        color: white;
        border-color: var(--tblr-primary);
    }
    .btn-list {
        display: flex !important;
        gap: 4px;
        align-items: center;
    }
    .action-buttons {
        display: inline-flex;
        gap: 6px;
        align-items: center;
    }
    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        padding: 0;
        border-radius: 6px;
        border: 1px solid;
        background: transparent;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        font-size: 16px;
    }
    .action-btn-view {
        color: var(--tblr-primary);
        border-color: var(--tblr-primary);
        background-color: rgba(31, 111, 235, 0.08);
    }
    .action-btn-view:hover {
        background-color: var(--tblr-primary);
        color: white;
    }
    .action-btn-edit {
        color: #17a2b8;
        border-color: #17a2b8;
        background-color: rgba(23, 162, 184, 0.1);
    }
    .action-btn-edit:hover {
        background-color: #17a2b8;
        color: white;
    }
    .action-btn-delete {
        color: #dc3545;
        border-color: #dc3545;
        background-color: rgba(220, 53, 69, 0.08);
    }
    .action-btn-delete:hover {
        background-color: #dc3545;
        color: white;
    }
    .empty-state {
        padding: 60px 20px;
        text-align: center;
    }
    .empty-state i {
        font-size: 3rem;
        color: #cbd5e1;
        margin-bottom: 16px;
        display: block;
    }
    .empty-state h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 8px;
    }
    .empty-state p {
        color: #64748b;
        margin-bottom: 20px;
    }
    .filter-card {
        padding: 12px 16px;
    }
</style>
{% endblock %}

{% block body %}
{{ include('components/navbar.html.twig') }}
<div class="d-flex" style="min-height:calc(100vh - 56px);">
{{ include('components/sidebar.html.twig', {'active_page': 'demandes', 'sidebar_role': role}) }}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none mb-3">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Gestion des demandes</h2>
                    <div class="text-secondary">Les comptes RH et administrateur entreprise peuvent consulter, modifier et repondre aux demandes.</div>
                </div>
                <div class="col-auto">
                    <div class="btn-list">
                        <a href="{{ path('demande_statistics') }}" class="btn btn-outline-primary">
                            <i class="ti ti-chart-bar me-2"></i>Statistiques
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="page-body">
        <div class="container-xl">

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show mb-3">
                    <i class="ti ti-check me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible fade show mb-3">
                    <i class="ti ti-alert-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('danger') %}
                <div class="alert alert-danger alert-dismissible fade show mb-3">
                    <i class="ti ti-alert-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="stats-row">
                <div class="stat-card" onclick="filterByStatus('')" data-stat-card="total">
                    <div class="stat-icon bg-primary-lt text-primary">
                        <i class="ti ti-files"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value text-primary" data-stat-value="total">{{ stats.total }}</div>
                        <div class="stat-label">Total</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('Nouvelle')" data-stat-card="Nouvelle">
                    <div class="stat-icon bg-blue-lt text-blue">
                        <i class="ti ti-clock"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value text-blue" data-stat-value="Nouvelle">{{ stats.byStatus['Nouvelle'] | default(0) }}</div>
                        <div class="stat-label">Nouvelles</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('En cours')" data-stat-card="En cours">
                    <div class="stat-icon bg-yellow-lt text-yellow">
                        <i class="ti ti-loader"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value text-yellow" data-stat-value="En cours">{{ stats.byStatus['En cours'] | default(0) }}</div>
                        <div class="stat-label">En cours</div>
                    </div>
                </div>
                <div class="stat-card" onclick="filterByStatus('Resolue')" data-stat-card="Resolue">
                    <div class="stat-icon bg-green-lt text-green">
                        <i class="ti ti-check"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-value text-green" data-stat-value="Resolue">{{ stats.byStatus['Resolue'] | default(0) }}</div>
                        <div class="stat-label">Resolues</div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-body filter-card">
                    <div class="row align-items-center g-2">
                        <div class="col-12 col-md-6">
                            <input type="text" id="searchInput" class="form-control"
                                   placeholder="Rechercher par titre, categorie, type ou statut"
                                   autocomplete="off">
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                <button type="button" class="quick-filter-btn active" data-filter="all">
                                    <i class="ti ti-list"></i>Tous
                                </button>
                                <button type="button" class="quick-filter-btn" data-filter="HAUTE">
                                    <i class="ti ti-alert-circle"></i>Haute
                                </button>
                                <button type="button" class="quick-filter-btn" data-filter="Nouvelle">
                                    <i class="ti ti-sparkles"></i>Nouvelles
                                </button>
                                <button type="button" class="quick-filter-btn" data-filter="En cours">
                                    <i class="ti ti-progress"></i>En cours
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="table-responsive">
                    <table class="table table-vcenter table-hover card-table">
                        <thead>
                            <tr>
                                <th style="width: 28%">Titre</th>
                                <th>Categorie</th>
                                <th>Type</th>
                                <th>Priorite</th>
                                <th>Statut</th>
                                <th>Date creation</th>
                                <th class="text-end" style="width: 130px;">Actions</th>
                            </tr>
                        </thead>
                                                <tbody>
                            {% for demande in demandes %}
                                <tr class="demande-row"
                                    data-titre="{{ demande.titre|lower }}"
                                    data-categorie="{{ demande.categorie|lower }}"
                                    data-type="{{ demande.typeDemande|lower }}"
                                    data-priorite="{{ demande.priorite }}"
                                    data-status="{{ demande.status }}">
                                    <td>
                                        <a href="{{ path('demande_show', {id: demande.idDemande}) }}" class="titre-link">
                                            {{ demande.titre }}
                                        </a>
                                    </td>
                                    <td>
                                        <span class="category-tag">
                                            <i class="ti ti-folder"></i>{{ demande.categorie }}
                                        </span>
                                    </td>
                                    <td>{{ demande.typeDemande }}</td>
                                    <td>
                                        {% if demande.priorite == 'HAUTE' %}
                                            <span class="badge bg-danger"><i class="ti ti-alert-triangle me-1"></i>{{ demande.priorite }}</span>
                                        {% elseif demande.priorite == 'NORMALE' %}
                                            <span class="badge bg-info"><i class="ti ti-minus me-1"></i>{{ demande.priorite }}</span>
                                        {% else %}
                                            <span class="badge bg-success"><i class="ti ti-arrow-down me-1"></i>{{ demande.priorite }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if demande.status == 'Nouvelle' %}
                                            <span class="badge bg-info"><i class="ti ti-sparkles me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En cours' %}
                                            <span class="badge bg-warning"><i class="ti ti-loader me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'En attente' %}
                                            <span class="badge bg-orange"><i class="ti ti-clock me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Resolue' %}
                                            <span class="badge bg-success"><i class="ti ti-check me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Rejetee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Reconsideration' %}
                                            <span class="badge bg-primary"><i class="ti ti-lock-open me-1"></i>{{ demande.status }}</span>
                                        {% elseif demande.status == 'Annulee' %}
                                            <span class="badge bg-danger"><i class="ti ti-x me-1"></i>{{ demande.status }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary"><i class="ti ti-lock me-1"></i>{{ demande.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <span class="date-text">
                                            <i class="ti ti-calendar"></i>{{ demande.dateCreation|date('d/m/Y') }}
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-buttons">

                                            {# View #}
                                            <a href="{{ path('demande_show', {id: demande.idDemande}) }}"
                                            class="action-btn action-btn-view" title="Afficher">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                    <circle cx="12" cy="12" r="3"></circle>
                                                </svg>
                                            </a>

                                            {# Edit #}
                                            {% if demande.status != 'Annulee' %}
                                                <a href="{{ path('demande_edit', {id: demande.idDemande}) }}"
                                                class="action-btn action-btn-edit" title="Modifier">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </a>
                                            {% else %}
                                                <span class="action-btn action-btn-edit"
                                                    style="opacity:0.35;cursor:not-allowed;"
                                                    title="Modification impossible">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                                    </svg>
                                                </span>
                                            {% endif %}

                                            {# Delete #}
                                            <button type="button"
                                                    class="action-btn action-btn-delete"
                                                    title="Supprimer"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteDemandeModal-{{ demande.idDemande }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                                    <path d="M10 11v6"></path>
                                                    <path d="M14 11v6"></path>
                                                    <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                                </svg>
                                            </button>

                                        </div>
                                    </td>
                                </tr>
                                <div class="modal" id="deleteDemandeModal-{{ demande.idDemande }}" tabindex="-1">
                                <div class="modal-dialog modal-sm" role="document">
                                    <div class="modal-content">
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                                    <div class="modal-status bg-danger"></div>
                                    <div class="modal-body text-center py-4">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                            class="icon mb-2 text-danger icon-lg"
                                            width="24" height="24" viewBox="0 0 24 24"
                                            stroke-width="2" stroke="currentColor" fill="none"
                                            stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <path d="M10 11v6"></path>
                                        <path d="M14 11v6"></path>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                        </svg>
                                        <h3>Supprimer la demande ?</h3>
                                        <div class="text-secondary">
                                        Vous allez supprimer :<br>
                                        <strong class="text-dark">{{ demande.titre }}</strong><br><br>
                                        Cette action est <strong>irreversible</strong>.
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <div class="w-100">
                                        <div class="row">
                                            <div class="col">
                                            <button type="button" class="btn w-100" data-bs-dismiss="modal">
                                                Annuler
                                            </button>
                                            </div>
                                            <div class="col">
                                            <form method="post"
                                                    action="{{ path('demande_delete', {id: demande.idDemande}) }}"
                                                    style="margin:0;">
                                                <button type="submit" class="btn btn-danger w-100">
                                                <i class="ti ti-trash me-1"></i>Supprimer
                                                </button>
                                            </form>
                                            </div>
                                        </div>
                                        </div>
                                    </div>
                                    </div>
                                </div>
                                </div>

                            {% else %}
                                <tr>
                                    <td colspan="7">
                                        <div class="empty-state">
                                            <i class="ti ti-file-off"></i>
                                            <h3>Aucune demande trouvee</h3>
                                            <p class="text-muted">Aucune demande ne correspond aux filtres actuels.</p>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="empty-state" id="noResults" style="display: none;">
                <i class="ti ti-search-off"></i>
                <h3>Aucun resultat</h3>
                <p class="text-muted">Aucune demande ne correspond a votre recherche.</p>
                <button type="button" class="btn btn-outline-primary btn-sm mt-3" onclick="clearSearch()">
                    <i class="ti ti-refresh me-1"></i>Reinitialiser
                </button>
            </div>

        </div>
    </div>
</div>
</div>

{{ include('demande/_logout_modal.html.twig') }}

