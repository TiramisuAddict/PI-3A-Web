{% extends 'base.html.twig' %}

{% block title %}Demande #{{ demande.idDemande }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.detail-label { font-weight: 600; color: #64748b; font-size: .85rem; text-transform: uppercase; letter-spacing: .5px; }
.detail-value { font-size: .95rem; }
.timeline-item { position: relative; padding-left: 2rem; padding-bottom: 1.5rem; border-left: 2px solid #e2e8f0; }
.timeline-item:last-child { border-left: 2px solid transparent; }
.timeline-item::before { content: ''; position: absolute; left: -6px; top: 4px; width: 10px; height: 10px; border-radius: 50%; background: #3b82f6; border: 2px solid #fff; }
</style>
{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <div class="page-pretitle">Demande #{{ demande.idDemande }}</div>
        <h2 class="page-title">{{ demande.titre }}</h2>
    </div>
    <div class="col-auto">
        <a href="{{ path('demande_edit', {id: demande.idDemande}) }}" class="btn btn-primary me-2">
            <i class="ti ti-edit me-1"></i>Modifier
        </a>
        <button class="btn btn-danger" onclick="document.getElementById('deleteModal').classList.add('show'); document.getElementById('deleteModal').style.display='block';">
            <i class="ti ti-trash me-1"></i>Supprimer
        </button>
    </div>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="ti ti-check me-2"></i>{{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-info-circle me-2"></i>Informations generales</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="detail-label">Categorie</div>
                        <div class="detail-value">{{ demande.categorie }}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Type de demande</div>
                        <div class="detail-value">{{ demande.typeDemande }}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Priorite</div>
                        <div class="detail-value">
                            {% if demande.priorite == 'HAUTE' %}
                                <span class="badge bg-danger">{{ demande.priorite }}</span>
                            {% elseif demande.priorite == 'NORMALE' %}
                                <span class="badge bg-warning">{{ demande.priorite }}</span>
                            {% else %}
                                <span class="badge bg-secondary">{{ demande.priorite }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Statut</div>
                        <div class="detail-value"><span class="badge bg-blue">{{ demande.status }}</span></div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Employe</div>
                        <div class="detail-value">
                            {% if demande.employe %}
                                {{ demande.employe.nom }} {{ demande.employe.prenom }}
                            {% else %}
                                N/A
                            {% endif %}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Date de creation</div>
                        <div class="detail-value">{{ demande.dateCreation ? demande.dateCreation|date('d/m/Y') : 'N/A' }}</div>
                    </div>
                    {% if demande.description %}
                    <div class="col-12">
                        <div class="detail-label">Description</div>
                        <div class="detail-value">{{ demande.description }}</div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if detailsData|length > 0 %}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-forms me-2"></i>Informations specifiques</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for key, value in detailsData %}
                        {% if not (key ends with 'Lat' or key ends with 'Lon') %}
                        <div class="col-md-6">
                            <div class="detail-label">{{ fieldLabels[key] ?? key }}</div>
                            <div class="detail-value">{{ value }}</div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

        {% if demande.historiqueDemandes|length > 0 %}
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-history me-2"></i>Historique</h3>
            </div>
            <div class="card-body">
                {% for historique in demande.historiqueDemandes|reverse %}
                <div class="timeline-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            {% if historique.ancienStatut %}
                                <span class="badge bg-secondary">{{ historique.ancienStatut }}</span>
                                <i class="ti ti-arrow-right mx-1"></i>
                            {% endif %}
                            <span class="badge bg-blue">{{ historique.nouveauStatut }}</span>
                            {% if historique.commentaire %}
                                <div class="text-muted mt-1" style="font-size:.85rem;">{{ historique.commentaire }}</div>
                            {% endif %}
                        </div>
                        <div class="text-end text-muted" style="font-size:.8rem;">
                            <div>{{ historique.acteur }}</div>
                            <div>{{ historique.dateAction|date('d/m/Y H:i') }}</div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-settings me-2"></i>Changer le statut</h3>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Nouveau statut</label>
                    <select class="form-select" id="newStatus">
                        {% for status in statuses %}
                            <option value="{{ status }}" {{ demande.status == status ? 'selected' : '' }}>{{ status }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Commentaire</label>
                    <textarea class="form-control" id="statusComment" rows="3" placeholder="Commentaire (optionnel)"></textarea>
                </div>
                <button class="btn btn-primary w-100" id="updateStatusBtn">
                    <i class="ti ti-check me-1"></i>Mettre a jour
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="ti ti-link me-2"></i>Actions rapides</h3>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('demande_edit', {id: demande.idDemande}) }}" class="btn btn-outline-primary">
                        <i class="ti ti-edit me-1"></i>Modifier
                    </a>
                    <button class="btn btn-outline-danger" onclick="document.getElementById('deleteModal').classList.add('show'); document.getElementById('deleteModal').style.display='block';">
                        <i class="ti ti-trash me-1"></i>Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" style="display:none;">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmer la suppression</h5>
                <button type="button" class="btn-close" onclick="document.getElementById('deleteModal').classList.remove('show'); document.getElementById('deleteModal').style.display='none';"></button>
            </div>
            <div class="modal-body">
                <p>Etes-vous sur de vouloir supprimer cette demande ?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('deleteModal').classList.remove('show'); document.getElementById('deleteModal').style.display='none';">Annuler</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Supprimer</button>
            </div>
        </div>
    </div>
</div>
<div class="modal-backdrop fade" id="modalBackdrop" style="display:none;"></div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    "use strict";

    var DELETE_URL = "{{ path('demande_delete', {id: demande.idDemande}) }}";
    var STATUS_URL = "{{ path('demande_update_status', {id: demande.idDemande}) }}";
    var INDEX_URL = "{{ path('demande_index') }}";

    document.addEventListener("DOMContentLoaded", function() {

        document.getElementById("confirmDeleteBtn").addEventListener("click", function() {
            var btn = this;
            btn.disabled = true;
            btn.textContent = "Suppression...";

            var xhr = new XMLHttpRequest();
            xhr.open("POST", DELETE_URL, true);
            xhr.setRequestHeader("Content-Type", "application/json");
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    if (xhr.status === 200) {
                        try {
                            var result = JSON.parse(xhr.responseText);
                            if (result.success) {
                                window.location.href = INDEX_URL;
                            } else {
                                alert(result.message);
                                btn.disabled = false;
                                btn.textContent = "Supprimer";
                            }
                        } catch (e) {
                            alert("Erreur lors du traitement de la reponse");
                            btn.disabled = false;
                            btn.textContent = "Supprimer";
                        }
                    } else {
                        alert("Erreur serveur (code " + xhr.status + ")");
                        btn.disabled = false;
                        btn.textContent = "Supprimer";
                    }
                }
            };
            xhr.onerror = function() {
                alert("Erreur de connexion au serveur");
                btn.disabled = false;
                btn.textContent = "Supprimer";
            };
            xhr.send(JSON.stringify({}));
        });

        document.getElementById("updateStatusBtn").addEventListener("click", function() {
            var btn = this;
            var newStatus = document.getElementById("newStatus").value;
            var comment = document.getElementById("statusComment").value;

            btn.disabled = true;
            btn.innerHTML = '<i class="ti ti-loader me-1"></i>Mise a jour...';

            var xhr = new XMLHttpRequest();
            xhr.open("POST", STATUS_URL, true);
            xhr.setRequestHeader("Content-Type", "application/json");
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    if (xhr.status === 200) {
                        try {
                            var result = JSON.parse(xhr.responseText);
                            if (result.success) {
                                window.location.reload();
                            } else {
                                alert(result.message);
                                btn.disabled = false;
                                btn.innerHTML = '<i class="ti ti-check me-1"></i>Mettre a jour';
                            }
                        } catch (e) {
                            alert("Erreur lors du traitement");
                            btn.disabled = false;
                            btn.innerHTML = '<i class="ti ti-check me-1"></i>Mettre a jour';
                        }
                    } else {
                        alert("Erreur serveur (code " + xhr.status + ")");
                        btn.disabled = false;
                        btn.innerHTML = '<i class="ti ti-check me-1"></i>Mettre a jour';
                    }
                }
            };
            xhr.onerror = function() {
                alert("Erreur de connexion au serveur");
                btn.disabled = false;
                btn.innerHTML = '<i class="ti ti-check me-1"></i>Mettre a jour';
            };
            xhr.send(JSON.stringify({status: newStatus, commentaire: comment}));
        });
    });
})();
</script>
{% endblock %}