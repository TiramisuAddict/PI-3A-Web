{% extends 'base.html.twig' %}

{% block title %}Statistiques des Demandes{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .big-stat-card {
        background: linear-gradient(135deg, var(--app-accent), #4f46e5);
        color: white;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(13, 110, 253, 0.3);
    }
    .big-stat-card.green {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 10px 40px rgba(16, 185, 129, 0.3);
    }
    .big-stat-card.yellow {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        box-shadow: 0 10px 40px rgba(245, 158, 11, 0.3);
    }
    .big-stat-value {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1;
    }
    .big-stat-label {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-top: 10px;
    }
    .stat-table {
        border-radius: 12px;
        overflow: hidden;
    }
    .stat-table td {
        padding: 16px 20px !important;
        vertical-align: middle;
    }
    .stat-table tr:hover {
        background: var(--app-accent-soft) !important;
    }
    .progress-bar-container {
        height: 10px;
        background: #e5e7eb;
        border-radius: 5px;
        overflow: hidden;
    }
    .progress-bar-fill {
        height: 100%;
        border-radius: 5px;
        transition: width 0.5s ease;
    }
    .stat-count {
        font-size: 1.25rem;
        font-weight: 700;
    }
    .stat-percentage {
        font-size: 0.85rem;
        color: #6b7280;
    }
    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
    }
    .section-title i {
        margin-right: 10px;
        color: var(--app-accent);
    }
</style>
{% endblock %}

{% block body %}
<div class="row mb-4 align-items-center">
    <div class="col-auto">
        <a href="{{ path('demande_index') }}" class="btn btn-outline-secondary">
            <i class="ti ti-arrow-left me-1"></i>Retour
        </a>
    </div>
    <div class="col">
        <h2 class="page-title mb-1">
            <i class="ti ti-chart-bar me-2"></i>Statistiques
        </h2>
        <p class="text-muted mb-0">Vue d'ensemble des demandes</p>
    </div>
</div>

<div class="row row-deck row-cards mb-4">
    <div class="col-md-4">
        <div class="big-stat-card">
            <div class="big-stat-value">{{ stats.total }}</div>
            <div class="big-stat-label">
                <i class="ti ti-files me-1"></i>Total des demandes
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="big-stat-card green">
            <div class="big-stat-value">{{ stats.byStatus['Resolue'] | default(0) }}</div>
            <div class="big-stat-label">
                <i class="ti ti-check me-1"></i>Demandes resolues
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="big-stat-card yellow">
            <div class="big-stat-value">{{ stats.byStatus['En cours'] | default(0) }}</div>
            <div class="big-stat-label">
                <i class="ti ti-loader me-1"></i>Demandes en cours
            </div>
        </div>
    </div>
</div>

<div class="row row-deck row-cards">
    <div class="col-lg-6 mb-4">
        <div class="surface-card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="ti ti-flag me-2 text-primary"></i>Repartition par Statut
                </h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-vcenter stat-table mb-0">
                    <tbody>
                        {% set statusColors = {
                            'Nouvelle': '#3b82f6',
                            'En cours': '#f59e0b', 
                            'En attente': '#f97316',
                            'Resolue': '#10b981',
                            'Fermee': '#6b7280',
                            'Annulee': '#ef4444'
                        } %}
                        {% for status, count in stats.byStatus %}
                        {% set percentage = stats.total > 0 ? (count / stats.total * 100)|round(1) : 0 %}
                        <tr>
                            <td style="width: 140px;">
                                <span class="badge" style="background: {{ statusColors[status] | default('#6b7280') }}; padding: 8px 14px; font-size: 0.85rem;">
                                    {{ status }}
                                </span>
                            </td>
                            <td>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: {{ percentage }}%; background: {{ statusColors[status] | default('#6b7280') }};"></div>
                                </div>
                            </td>
                            <td class="text-end" style="width: 100px;">
                                <span class="stat-count">{{ count }}</span>
                                <span class="stat-percentage d-block">{{ percentage }}%</span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="surface-card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="ti ti-alert-triangle me-2 text-warning"></i>Repartition par Priorite
                </h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-vcenter stat-table mb-0">
                    <tbody>
                        {% set priorityColors = {'HAUTE': '#ef4444', 'NORMALE': '#3b82f6', 'BASSE': '#10b981'} %}
                        {% for priorite, count in stats.byPriorite %}
                        {% set percentage = stats.total > 0 ? (count / stats.total * 100)|round(1) : 0 %}
                        <tr>
                            <td style="width: 140px;">
                                <span class="badge" style="background: {{ priorityColors[priorite] | default('#6b7280') }}; padding: 8px 14px; font-size: 0.85rem;">
                                    {% if priorite == 'HAUTE' %}
                                        <i class="ti ti-alert-triangle me-1"></i>
                                    {% elseif priorite == 'NORMALE' %}
                                        <i class="ti ti-minus me-1"></i>
                                    {% else %}
                                        <i class="ti ti-arrow-down me-1"></i>
                                    {% endif %}
                                    {{ priorite }}
                                </span>
                            </td>
                            <td>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: {{ percentage }}%; background: {{ priorityColors[priorite] | default('#6b7280') }};"></div>
                                </div>
                            </td>
                            <td class="text-end" style="width: 100px;">
                                <span class="stat-count">{{ count }}</span>
                                <span class="stat-percentage d-block">{{ percentage }}%</span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="surface-card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="ti ti-folder me-2 text-info"></i>Repartition par Categorie
                </h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-vcenter stat-table mb-0">
                    <tbody>
                        {% for categorie, count in stats.byCategorie %}
                        {% set percentage = stats.total > 0 ? (count / stats.total * 100)|round(1) : 0 %}
                        <tr>
                            <td>
                                <span class="category-tag" style="background: var(--app-accent-soft); color: var(--app-accent); padding: 8px 14px; border-radius: 20px; font-size: 0.85rem; font-weight: 500;">
                                    <i class="ti ti-folder me-1"></i>{{ categorie }}
                                </span>
                            </td>
                            <td>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: {{ percentage }}%; background: var(--app-accent);"></div>
                                </div>
                            </td>
                            <td class="text-end" style="width: 100px;">
                                <span class="stat-count">{{ count }}</span>
                                <span class="stat-percentage d-block">{{ percentage }}%</span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="surface-card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="ti ti-tag me-2 text-purple"></i>Repartition par Type
                </h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-vcenter stat-table mb-0">
                    <tbody>
                        {% for type, count in stats.byType %}
                        {% set percentage = stats.total > 0 ? (count / stats.total * 100)|round(1) : 0 %}
                        <tr>
                            <td>
                                <span style="font-weight: 500; color: #374151;">{{ type }}</span>
                            </td>
                            <td>
                                <div class="progress-bar-container">
                                    <div class="progress-bar-fill" style="width: {{ percentage }}%; background: #8b5cf6;"></div>
                                </div>
                            </td>
                            <td class="text-end" style="width: 100px;">
                                <span class="stat-count">{{ count }}</span>
                                <span class="stat-percentage d-block">{{ percentage }}%</span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}