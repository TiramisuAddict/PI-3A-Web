{% set hasError = false %}
{% set hasBlank = false %}
{% set formatErrors = [] %}

{% for field in form %}
    {% if field.vars.errors is defined and field.vars.errors|length > 0 %}
        {% set hasError = true %}
        {% for error in field.vars.errors %}
            {% if 'obligatoire' not in error.message and 'required' not in error.message %}
                {% set formatErrors = formatErrors|merge([error.message]) %}
            {% else %}
                {% set hasBlank = true %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}

{% if detailErrors is defined and detailErrors|length > 0 %}
    {% set hasError = true %}
    {% for error in detailErrors %}
        {% if error.type == 'blank' %}
            {% set hasBlank = true %}
        {% else %}
            {% set formatErrors = formatErrors|merge([error.message]) %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if hasError %}
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <div class="d-flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="icon alert-icon flex-shrink-0 mt-1">
                <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"/>
                <path d="M12 8v4"/>
                <path d="M12 16h.01"/>
            </svg>
            <div style="font-size: 0.9rem;">
                {% if hasBlank %}
                    <div class="mb-2"><strong>Veuillez remplir tous les champs obligatoires.</strong></div>
                {% endif %}
                {% if formatErrors|length > 0 %}
                    <div>
                        {% for errorMsg in formatErrors %}
                            <div class="mb-1">{{ errorMsg }}</div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
{% endif %}