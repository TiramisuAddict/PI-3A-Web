{% extends 'base.html.twig' %}

{% block title %}Inscription Entreprise{% endblock %}

{% block body %}
<div style="height:100vh; display:flex; overflow:hidden;">

    {# ── Colonne gauche : image + dégradé ── #}
    <div style="flex:1; position:relative; display:flex; flex-direction:column; justify-content:flex-end; padding:2rem; overflow:hidden;">

      <img src="/images/building3.jpeg"
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0;">

      <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(66,84,214,0.88) 0%, rgba(100,130,255,0.88) 100%); z-index:1;"></div>

    
      <div style="position:relative; z-index:3;" class="text-white">
        <h2 class="h5 fw-bold mb-2">Rejoignez <strong>Momentum</strong></h2>
        <p style="color:rgba(255,255,255,0.6); font-size:0.8rem; margin:0;">
          Créez votre espace entreprise et commencez à gérer vos équipes dès aujourd'hui.
        </p>
      </div>

    </div>

    {# ── Colonne droite : formulaire ── #}
    <div style="flex:1; background:#fff; display:flex; align-items:center; justify-content:center; padding:1rem; overflow-y:auto;">
      <div style="width:100%; max-width:500px; padding:1rem 0;">

        <h1 class="h1 fw-bold mb-1">Créer un compte entreprise</h1>
        <p class="text-muted mb-3" style="font-size:0.78rem;">Remplissez les informations ci-dessous</p>

        {{ include('components/controleSaisieAlert.html.twig') }}  
           

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

          <div class="row g-2">

            <div class="col-12">
              {{ form_label(form.nom_entreprise, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.nom_entreprise, {'attr': {'class': 'form-control ', 'placeholder': "Nom de l'entreprise"}}) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.pays, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.pays, {'attr': {'class': 'form-control ', 'placeholder': 'Pays'}}) }}
            </div>
            <div class="col-md-6">
              {{ form_label(form.ville, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.ville, {'attr': {'class': 'form-control ', 'placeholder': 'Ville'}}) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.nom, {'attr': {'class': 'form-control ', 'placeholder': 'Nom'}}) }}
            </div>
            <div class="col-md-6">
              {{ form_label(form.prenom, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.prenom, {'attr': {'class': 'form-control ', 'placeholder': 'Prénom'}}) }}
            </div>

            <div class="col-12">
              {{ form_label(form.matricule_fiscale, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.matricule_fiscale, {'attr': {'class': 'form-control ', 'placeholder': 'Matricule fiscale'}}) }}
            </div>

            <div class="col-md-6">
              {{ form_label(form.telephone, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.telephone, {'attr': {'class': 'form-control ', 'placeholder': 'Téléphone'}}) }}
            </div>
            <div class="col-md-6">
              {{ form_label(form.e_mail, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.e_mail, {'attr': {'class': 'form-control ', 'placeholder': 'Email'}}) }}
            </div>

            <div class="col-12">
              {{ form_label(form.site_web, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
              {{ form_widget(form.site_web, {'attr': {'class': 'form-control ', 'placeholder': 'https://votresite.com'}}) }}
            </div>
<div class="col-12">
  {{ form_label(form.logo, null, {'label_attr': {'class': 'form-label small mb-1'}}) }}
  {% set logoInputId = form.logo.vars.id %}

  {# INPUT FILE caché #}
  {{ form_widget(form.logo, {
    'attr': {
      'accept': 'image/*',
      'style': 'display:none;'
    }
  }) }}

  {# BOUTON qui ouvre l'explorateur #}
  <label for="{{ logoInputId }}" class="btn btn-sm btn-outline-secondary">
    Choisir une image
  </label>

  <div class="form-text mt-1" id="logo-file-name">
    Aucun fichier sélectionné
  </div>
</div>
          </div>

          <div class="mt-3">
            {{ form_widget(form.Soumettre, {
              'attr': {
                'class': 'btn w-100 fw-bold text-white ',
                'style': 'background:#4254D6; border:none; letter-spacing:1px;'
              }
            }) }}
          </div>

          <div class="text-center small text-muted mt-2">
            Vous avez déjà un compte ?
            <a href="{{ path('login') }}" class="fw-bold ms-1" style="color:#4254D6;">
              Se connecter
            </a>
          </div>

        {{ form_end(form) }}
      </div>
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var logoInput = document.getElementById('{{ logoInputId }}');
  var logoFileName = document.getElementById('logo-file-name');

  if (!logoInput || !logoFileName) {
    return;
  }

  logoInput.addEventListener('change', function () {
    if (logoInput.files && logoInput.files[0]) {
      logoFileName.textContent = logoInput.files[0].name;
    } else {
      logoFileName.textContent = 'Aucun fichier sélectionné';
    }
  });
});
</script>

{% endblock %}