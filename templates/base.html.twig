<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
        {% block stylesheets %}
            <style>
                :root {
                    --app-bg: #f4f7fb;
                    --app-bg-2: #eef4ff;
                    --app-border: #e4e9f2;
                    --app-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
                    --app-shadow-soft: 0 8px 24px rgba(15, 23, 42, 0.05);
                    --app-accent: #0d6efd;
                    --app-accent-soft: rgba(13, 110, 253, 0.10);
                }

                body {
                    min-height: 100vh;
                    background:
                        radial-gradient(circle at top left, rgba(13, 110, 253, 0.10), transparent 28%),
                        radial-gradient(circle at top right, rgba(255, 193, 7, 0.10), transparent 22%),
                        linear-gradient(180deg, var(--app-bg-2) 0%, var(--app-bg) 26%, #ffffff 100%);
                    color: #1f2a37;
                }

                .navbar-brand-title {
                    letter-spacing: 0.2px;
                }

                .page {
                    position: relative;
                    min-height: 100vh;
                }

                .navbar {
                    position: sticky;
                    top: 0;
                    z-index: 1030;
                    backdrop-filter: blur(14px);
                    background: rgba(255, 255, 255, 0.84);
                    border-bottom: 1px solid rgba(228, 233, 242, 0.9);
                    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.7);
                }

                .navbar-brand-title {
                    font-weight: 800;
                    color: #12263f;
                }

                .app-topbar-chip {
                    display: inline-flex;
                    align-items: center;
                    gap: .4rem;
                    padding: .4rem .7rem;
                    border-radius: 999px;
                    background: var(--app-accent-soft);
                    color: var(--app-accent);
                    font-weight: 700;
                    font-size: .88rem;
                }

                .app-shell {
                    padding-top: 1.25rem;
                    padding-bottom: 2.5rem;
                }

                .app-hero {
                    border: 1px solid var(--app-border);
                    border-radius: 22px;
                    background: linear-gradient(135deg, rgba(255,255,255,.95), rgba(248,250,255,.92));
                    box-shadow: var(--app-shadow);
                    overflow: hidden;
                }

                .app-hero::before {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: linear-gradient(135deg, rgba(13,110,253,.06), transparent 42%);
                    pointer-events: none;
                }

                .surface-card {
                    border: 1px solid var(--app-border);
                    border-radius: 18px;
                    box-shadow: var(--app-shadow-soft);
                    overflow: hidden;
                    background: rgba(255,255,255,.95);
                }

                .surface-card .card-header {
                    background: rgba(248, 250, 255, 0.92);
                    border-bottom: 1px solid var(--app-border);
                }

                .stat-card {
                    border: 1px solid var(--app-border);
                    border-radius: 18px;
                    background: rgba(255,255,255,.95);
                    box-shadow: var(--app-shadow-soft);
                }

                .soft-pill {
                    display: inline-flex;
                    align-items: center;
                    gap: .35rem;
                    border-radius: 999px;
                    padding: .4rem .75rem;
                    background: rgba(15, 23, 42, 0.05);
                    color: #334155;
                    font-size: .85rem;
                }

                .btn-icon-only {
                    width: 2.25rem;
                    height: 2.25rem;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0;
                    border-radius: 999px;
                }

                .btn-icon-only .badge {
                    font-size: .7rem;
                    line-height: 1;
                }

                .table > :not(caption) > * > * {
                    padding-top: .95rem;
                    padding-bottom: .95rem;
                }

                .table tbody tr:hover {
                    background: rgba(13, 110, 253, 0.035);
                }

                .mini-muted {
                    color: #6b7280;
                    font-size: .92rem;
                }
            </style>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="layout-fluid">
        <div class="page">
            <header class="navbar navbar-expand-md d-print-none">
                <div class="container-xl">
                    <h1 class="navbar-brand navbar-brand-autodark pe-0 pe-md-3 m-0">
                        <span class="navbar-brand-title">PI-3A Gestion Formation</span>
                    </h1>
                    {% set currentEmployeeName = app.session is defined and app.session.get('employee_name') ? app.session.get('employee_name') : '' %}
                    {% set currentEmployeeRole = app.session is defined and app.session.get('employee_role') ? app.session.get('employee_role')|lower : '' %}
                    <div class="navbar-text d-none d-md-block ms-3">
                        {% if currentEmployeeName %}
                            <span class="app-topbar-chip me-2"><i class="ti ti-user-circle"></i>{{ currentEmployeeName }}</span>
                            <span class="soft-pill">{{ currentEmployeeRole|upper }}</span>
                        {% endif %}
                    </div>
                    <div class="navbar-nav flex-row order-md-last align-items-center gap-2">
                        <a class="nav-link fw-semibold" href="{{ path('app_formation_rh') }}">
                            <span class="nav-link-title">Formation RH</span>
                        </a>
                        <a class="nav-link fw-semibold" href="{{ path('app_inscription_employe') }}">
                            <span class="nav-link-title">Inscription Employe</span>
                        </a>
                    </div>
                </div>
            </header>

            <div class="page-wrapper">
                <div class="page-body">
                    <div class="container-xl app-shell">
                        {% block body %}{% endblock %}
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>
