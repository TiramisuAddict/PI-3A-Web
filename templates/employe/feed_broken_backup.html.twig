            gap: 0.85rem;
            padding: 1rem;
            border: 1px solid rgba(148, 163, 184, 0.14);
            border-radius: 1.1rem;
            background: #fff;
            box-shadow: 0 14px 32px rgba(15, 23, 42, 0.04);
        }
        .feed-comment-avatar,
        .feed-composer-avatar {
            width: 2.4rem;
            height: 2.4rem;
            flex-shrink: 0;
            background: linear-gradient(135deg, rgba(83, 96, 245, 0.14), rgba(16, 185, 129, 0.12));
            color: #334155;
        }
        .feed-comment-main,
        .feed-composer-main {
            flex: 1;
            min-width: 0;
        }
        .feed-comment-head {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.45rem;
        }
        .feed-comment-meta {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
            color: #64748b;
            font-size: 0.84rem;
        }
        .feed-comment-author {
            font-weight: 700;
            font-size: 0.92rem;
            color: #0f172a;
        }
        .feed-comment-edited {
            padding: 0.2rem 0.45rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.06);
            color: #475569;
            font-size: 0.73rem;
            font-weight: 700;
        }
        .feed-comment-tools {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.35rem;
        }
        .feed-comment-tool {
            border: 0;
            background: transparent;
            color: #5360f5;
            font-size: 0.82rem;
            font-weight: 700;
            padding: 0.2rem 0.3rem;
        }
        .feed-comment-tool.danger {
            color: #dc2626;
        }
        .feed-comment-content {
            color: #334155;
            line-height: 1.65;
            word-break: break-word;
        }
        .feed-comment-replies {
            margin-left: 3.1rem;
            margin-top: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }
        .feed-comment-composer,
        .feed-reply-shell {
            display: flex;
            gap: 0.85rem;
            padding: 1rem;
            border-radius: 1.1rem;
            border: 1px solid rgba(148, 163, 184, 0.16);
            background: rgba(255, 255, 255, 0.96);
        }
        .feed-edit-form,
        .feed-reply-form {
            margin-top: 0.8rem;
        }
        .feed-comment-textarea {
            border-radius: 0.95rem;
            border-color: rgba(148, 163, 184, 0.32);
            resize: vertical;
        }
        .feed-comment-form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 0.55rem;
            margin-top: 0.7rem;
        }
        .feed-empty-state {
            padding: 3rem 1.5rem;
            text-align: center;
            background: rgba(255, 255, 255, 0.82);
            border: 1px dashed rgba(148, 163, 184, 0.28);
            border-radius: 1.6rem;
            color: #64748b;
        }
        .feed-empty-state i {
            font-size: 2.4rem;
            color: #5360f5;
        }
        .feed-empty-state h3 {
            margin: 1rem 0 0.45rem;
            color: #0f172a;
        }
        @media (max-width: 768px) {
            .feed-page-head {
                align-items: stretch;
                flex-direction: column;
            }
            .feed-post-head,
            .feed-comment-head {
                flex-direction: column;
            }
            .feed-comments-section,
            .feed-post-head,
            .feed-post-body,
            .feed-stats-row,
            .feed-actions-row {
                padding-left: 1rem;
                padding-right: 1rem;
            }
            .feed-comment-replies {
                margin-left: 1rem;
            }
            .feed-comment-shell,
            .feed-comment-composer,
            .feed-reply-shell {
                padding: 0.85rem;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var feedRoot = document.getElementById('feed-root');
            if (!feedRoot) return;

            function buildUrl(template, value) {
                return template.replace('__POST__', value).replace('__COMMENT__', value);
            }

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function nl2br(value) {
                return escapeHtml(value).replace(/\n/g, '<br>');
            }

            function formatDate(iso) {
                if (!iso) return '';
                var date = new Date(iso);
                if (isNaN(date.getTime())) return '';
                return date.toLocaleString('fr-FR', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            }

            async function sendAction(url, data) {
                var body = new URLSearchParams();
                Object.keys(data || {}).forEach(function (key) {
                    if (data[key] !== undefined && data[key] !== null) {
                        body.append(key, data[key]);
                    }
                });

                var response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: body.toString(),
                    credentials: 'same-origin'
                });

                var payload;
                try {
                    payload = await response.json();
                } catch (error) {
                    payload = { success: false, message: 'Reponse serveur invalide.' };
                }

                if (!response.ok && payload.success === undefined) {
                    payload.success = false;
                }

                return payload;
            }

            function updateLikeSummary(postId, count) {
                var stats = document.getElementById('like-count-' + postId);
                if (stats) {
                    stats.innerHTML = '<i class="ti ti-heart-filled"></i><span>' + count + ' j\\'aime</span>';
                }
            }

            function updateCommentSummary(postId, count) {
                var stats = document.getElementById('com-count-' + postId);
                if (stats) {
                    var plural = count > 1 ? 's' : '';
                    stats.innerHTML = '<i class="ti ti-message-circle"></i><span>' + count + ' commentaire' + plural + '</span>';
                }
            }

            function updateParticipationSummary(postId, count) {
                var stats = document.getElementById('part-count-' + postId);
                if (stats) {
                    var plural = count > 1 ? 's' : '';
                    stats.innerHTML = '<i class="ti ti-user-check"></i><span>' + count + ' participant' + plural + '</span>';
                }
            }

            function updateRemainingPlaces(postId, remainingPlaces) {
                var badge = document.getElementById('places-restantes-' + postId);
                if (badge && remainingPlaces !== null && remainingPlaces !== undefined) {
                    badge.textContent = remainingPlaces + ' places restantes';
                }
            }

            function ensureCommentsList(postId) {
                var list = document.getElementById('comments-list-' + postId);
                if (!list) return null;

                var empty = document.getElementById('comments-empty-' + postId);
                if (empty) {
                    empty.remove();
                }

                return list;
            }

            function ensureRepliesContainer(card) {
                var replies = null;
                Array.prototype.forEach.call(card.children, function (child) {
                    if (!replies && child.classList && child.classList.contains('feed-comment-replies')) {
                        replies = child;
                    }
                });
                if (!replies) {
                    replies = document.createElement('div');
                    replies.className = 'feed-comment-replies';
                    card.appendChild(replies);
                }
                replies.removeAttribute('data-empty-replies');
                return replies;
            }

            function setButtonLoading(button, isLoading) {
                if (!button) return;
                button.disabled = isLoading;
                button.style.opacity = isLoading ? '0.7' : '1';
            }

            function createCommentElement(comment) {
                var wrapper = document.createElement('div');
                var editUrl = buildUrl(feedRoot.dataset.commentEditUrlTemplate, comment.id_commentaire);
                var deleteUrl = buildUrl(feedRoot.dataset.commentDeleteUrlTemplate, comment.id_commentaire);
                var editedBadge = comment.edited_at ? '<span class="feed-comment-edited">Modifie</span>' : '';
                var ownerTools = comment.owned_by_current_user
                    ? '<button type="button" class="feed-comment-tool" data-action="edit-toggle">Modifier</button><button type="button" class="feed-comment-tool danger" data-action="delete-comment">Supprimer</button>'
                    : '';

                wrapper.innerHTML = '' +
                    '<article class="feed-comment-card" id="comment-' + comment.id_commentaire + '" data-comment-id="' + comment.id_commentaire + '" data-post-id="' + comment.post_id + '" data-parent-id="' + (comment.parent_id || '') + '" data-edit-url="' + editUrl + '" data-delete-url="' + deleteUrl + '" data-edit-token="' + escapeHtml(comment.edit_token || '') + '" data-delete-token="' + escapeHtml(comment.delete_token || '') + '">' +
                        '<div class="feed-comment-shell">' +
                            '<div class="feed-comment-avatar">' + escapeHtml(comment.author_name.split(' ').map(function (part) { return part.charAt(0); }).join('').slice(0, 2).toUpperCase()) + '</div>' +
                            '<div class="feed-comment-main">' +
                                '<div class="feed-comment-head">' +
                                    '<div class="feed-comment-meta">' +
                                        '<span class="feed-comment-author">' + escapeHtml(comment.author_name) + '</span>' +
                                        '<span class="feed-comment-date" data-comment-date="' + escapeHtml(comment.date_commentaire) + '">' + escapeHtml(formatDate(comment.date_commentaire)) + '</span>' +
                                        editedBadge +
                                    '</div>' +
                                    '<div class="feed-comment-tools">' +
                                        '<button type="button" class="feed-comment-tool" data-action="reply-toggle">Repondre</button>' +
                                        ownerTools +
                                    '</div>' +
                                '</div>' +
                                '<div class="feed-comment-content" data-comment-content>' + nl2br(comment.contenu) + '</div>' +
                                '<form class="feed-edit-form" data-comment-id="' + comment.id_commentaire + '" style="display:none;">' +
                                    '<input type="hidden" name="_token" value="' + escapeHtml(comment.edit_token || '') + '">' +
                                    '<textarea class="form-control feed-comment-textarea" name="contenu" rows="3" maxlength="2000" required>' + escapeHtml(comment.contenu) + '</textarea>' +
                                    '<div class="feed-comment-form-actions">' +
                                        '<button type="submit" class="btn btn-primary btn-sm">Enregistrer</button>' +
                                        '<button type="button" class="btn btn-ghost-secondary btn-sm" data-action="edit-cancel">Annuler</button>' +
                                    '</div>' +
                                '</form>' +
                                '<form class="feed-reply-form" data-post-id="' + comment.post_id + '" data-parent-id="' + comment.id_commentaire + '" style="display:none;">' +
                                    '<input type="hidden" name="_token" value="' + escapeHtml(document.querySelector('.feed-comment-form[data-post-id="' + comment.post_id + '"] [name="_token"]') ? document.querySelector('.feed-comment-form[data-post-id="' + comment.post_id + '"] [name="_token"]').value : '') + '">' +
                                    '<input type="hidden" name="parent_id" value="' + comment.id_commentaire + '">' +
                                    '<div class="feed-reply-shell">' +
                                        '<textarea class="form-control feed-comment-textarea" name="contenu" rows="2" maxlength="2000" placeholder="Ecrire une reponse..." required></textarea>' +
                                        '<div class="feed-comment-form-actions">' +
                                            '<button type="submit" class="btn btn-primary btn-sm">Repondre</button>' +
                                            '<button type="button" class="btn btn-ghost-secondary btn-sm" data-action="reply-cancel">Annuler</button>' +
                                        '</div>' +
                                    '</div>' +
                                '</form>' +
                            '</div>' +
                        '</div>' +
                        '<div class="feed-comment-replies" data-empty-replies="true"></div>' +
                    '</article>';

                return wrapper.firstElementChild;
            }

            function addCommentToUi(comment) {
                var element = createCommentElement(comment);

                if (comment.parent_id) {
                    var parent = document.getElementById('comment-' + comment.parent_id);
                    if (parent) {
                        ensureRepliesContainer(parent).appendChild(element);
                    }
                } else {
                    var list = ensureCommentsList(comment.post_id);
                    if (list) {
                        list.prepend(element);
                    }
                }
            }

            function removeCommentFromUi(commentId) {
                var card = document.getElementById('comment-' + commentId);
                if (!card) return;

                var repliesContainer = card.parentElement;
                card.remove();

                if (repliesContainer && repliesContainer.classList.contains('feed-comment-replies') && repliesContainer.children.length === 0) {
                    repliesContainer.setAttribute('data-empty-replies', 'true');
                }
            }

            function ensureEmptyState(postId) {
                var list = document.getElementById('comments-list-' + postId);
                if (!list) return;

                if (list.children.length === 0) {
                    var empty = document.createElement('div');
                    empty.className = 'feed-empty-comments';
                    empty.id = 'comments-empty-' + postId;
                    empty.textContent = "Aucun commentaire pour l'instant. Lancez la conversation.";
                    list.appendChild(empty);
                }
            }

            feedRoot.addEventListener('click', async function (event) {
                var actionButton = event.target.closest('[data-action]');
                if (!actionButton) return;

                var action = actionButton.getAttribute('data-action');

                if (action === 'comment' && actionButton.classList.contains('feed-action-button')) {
                    var postId = actionButton.getAttribute('data-post-id');
                    var section = document.getElementById('comments-section-' + postId);
                    if (!section) return;

                    var isHidden = section.style.display === 'none';
                    section.style.display = isHidden ? 'block' : 'none';

                    if (isHidden) {
                        var input = section.querySelector('.feed-comment-input');
                        if (input) input.focus();
                    }
                    return;
                }

                if (action === 'like' && actionButton.classList.contains('feed-action-button')) {
                    var likePostId = actionButton.getAttribute('data-post-id');
                    var likeIcon = actionButton.querySelector('.feed-action-icon i');

                    setButtonLoading(actionButton, true);
                    try {
                        var likeData = await sendAction('/employe/like/' + likePostId, {
                            _token: actionButton.getAttribute('data-csrf')
                        });

                        if (likeData.success) {
                            actionButton.classList.toggle('is-active', !!likeData.liked);
                            if (likeIcon) {
                                likeIcon.className = 'ti ' + (likeData.liked ? 'ti-heart-filled' : 'ti-heart');
                            }
                            updateLikeSummary(likePostId, likeData.count);
                        } else {
                            alert(likeData.message || 'Erreur lors de la mise a jour du like');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la mise a jour du like');
                    } finally {
                        setButtonLoading(actionButton, false);
                    }
                    return;
                }

                if (action === 'participate' && actionButton.classList.contains('feed-action-button')) {
                    var participatePostId = actionButton.getAttribute('data-post-id');
                    var participateIcon = actionButton.querySelector('.feed-action-icon i');
                    var participateText = actionButton.querySelector('.feed-action-text');

                    setButtonLoading(actionButton, true);
                    try {
                        var participateData = await sendAction('/employe/participate/' + participatePostId, {
                            _token: actionButton.getAttribute('data-csrf')
                        });

                        if (participateData.success) {
                            actionButton.classList.toggle('is-active', !!participateData.participating);
                            if (participateIcon) {
                                participateIcon.className = 'ti ' + (participateData.participating ? 'ti-circle-check-filled' : 'ti-circle-check');
                            }
                            if (participateText) {
                                participateText.textContent = participateData.participating ? 'Annuler' : 'Participer';
                            }
                            updateParticipationSummary(participatePostId, participateData.count);
                            updateRemainingPlaces(participatePostId, participateData.remaining_places);
                        } else {
                            alert(participateData.message || 'Erreur lors de la mise a jour de la participation');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la mise a jour de la participation');
                    } finally {
                        setButtonLoading(actionButton, false);
                    }
                    return;
                }

                var card = actionButton.closest('.feed-comment-card');
                if (!card) return;

                var replyForm = card.querySelector('.feed-reply-form');
                var editForm = card.querySelector('.feed-edit-form');
                var contentNode = card.querySelector('[data-comment-content]');

                if (action === 'reply-toggle' && replyForm) {
                    var replyVisible = replyForm.style.display === 'block';
                    replyForm.style.display = replyVisible ? 'none' : 'block';
                    if (!replyVisible) {
                        var replyTextarea = replyForm.querySelector('textarea');
                        if (replyTextarea) replyTextarea.focus();
                    }
                    return;
                }

                if (action === 'reply-cancel' && replyForm) {
                    replyForm.style.display = 'none';
                    replyForm.reset();
                    return;
                }

                if (action === 'edit-toggle' && editForm && contentNode) {
                    var editVisible = editForm.style.display === 'block';
                    editForm.style.display = editVisible ? 'none' : 'block';
                    contentNode.style.display = editVisible ? 'block' : 'none';
                    if (!editVisible) {
                        var editTextarea = editForm.querySelector('textarea');
                        if (editTextarea) editTextarea.focus();
                    }
                    return;
                }

                if (action === 'edit-cancel' && editForm && contentNode) {
                    editForm.style.display = 'none';
                    contentNode.style.display = 'block';
                    return;
                }

                if (action === 'delete-comment') {
                    if (!window.confirm('Supprimer ce commentaire et ses reponses ?')) {
                        return;
                    }

                    setButtonLoading(actionButton, true);
                    try {
                        var deleteData = await sendAction(card.dataset.deleteUrl, {
                            _token: card.dataset.deleteToken
                        });

                        if (deleteData.success) {
                            removeCommentFromUi(deleteData.deleted_comment_id);
                            updateCommentSummary(deleteData.post_id, deleteData.count);
                            ensureEmptyState(deleteData.post_id);
                        } else {
                            alert(deleteData.message || 'Erreur lors de la suppression du commentaire');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la suppression du commentaire');
                    } finally {
                        setButtonLoading(actionButton, false);
                    }
                }
            });

            feedRoot.addEventListener('submit', async function (event) {
                var form = event.target;
                if (!form.matches('.feed-comment-form, .feed-reply-form, .feed-edit-form')) {
                    return;
                }

                event.preventDefault();

                if (form.matches('.feed-comment-form')) {
                    var postId = form.getAttribute('data-post-id');
                    var textarea = form.querySelector('.feed-comment-input');
                    var submitButton = form.querySelector('button[type="submit"]');
                    var content = textarea ? textarea.value.trim() : '';
                    var token = form.querySelector('[name="_token"]').value;

                    if (!content) return;

                    setButtonLoading(submitButton, true);
                    try {
                        var commentData = await sendAction(buildUrl(feedRoot.dataset.commentUrlTemplate, postId), {
                            _token: token,
                            contenu: content
                        });

                        if (commentData.success) {
                            addCommentToUi(commentData.comment);
                            updateCommentSummary(postId, commentData.count);
                            textarea.value = '';
                            document.getElementById('comments-section-' + postId).style.display = 'block';
                        } else {
                            alert(commentData.message || 'Erreur lors de la publication du commentaire');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la publication du commentaire');
                    } finally {
                        setButtonLoading(submitButton, false);
                    }
                    return;
                }

                if (form.matches('.feed-reply-form')) {
                    var replyPostId = form.getAttribute('data-post-id');
                    var parentId = form.getAttribute('data-parent-id');
                    var replyTextareaField = form.querySelector('textarea');
                    var replySubmitButton = form.querySelector('button[type="submit"]');
                    var replyContent = replyTextareaField ? replyTextareaField.value.trim() : '';
                    var replyToken = form.querySelector('[name="_token"]').value;

                    if (!replyContent) return;

                    setButtonLoading(replySubmitButton, true);
                    try {
                        var replyData = await sendAction(buildUrl(feedRoot.dataset.commentUrlTemplate, replyPostId), {
                            _token: replyToken,
                            contenu: replyContent,
                            parent_id: parentId
                        });

                        if (replyData.success) {
                            addCommentToUi(replyData.comment);
                            updateCommentSummary(replyPostId, replyData.count);
                            form.reset();
                            form.style.display = 'none';
                        } else {
                            alert(replyData.message || 'Erreur lors de la publication de la reponse');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la publication de la reponse');
                    } finally {
                        setButtonLoading(replySubmitButton, false);
                    }
                    return;
                }

                if (form.matches('.feed-edit-form')) {
                    var commentCard = form.closest('.feed-comment-card');
                    var editTextareaField = form.querySelector('textarea');
                    var editSubmitButton = form.querySelector('button[type="submit"]');
                    var editContent = editTextareaField ? editTextareaField.value.trim() : '';
                    var commentContentNode = commentCard ? commentCard.querySelector('[data-comment-content]') : null;

                    if (!commentCard || !editContent) return;

                    setButtonLoading(editSubmitButton, true);
                    try {
                        var editData = await sendAction(commentCard.dataset.editUrl, {
                            _token: commentCard.dataset.editToken,
                            contenu: editContent
                        });

                        if (editData.success) {
                            if (commentContentNode) {
                                commentContentNode.innerHTML = nl2br(editData.comment.contenu);
                                commentContentNode.style.display = 'block';
                            }
                            form.style.display = 'none';

                            var badge = commentCard.querySelector('.feed-comment-edited');
                            if (!badge) {
                                badge = document.createElement('span');
                                badge.className = 'feed-comment-edited';
                                badge.textContent = 'Modifie';
                                var meta = commentCard.querySelector('.feed-comment-meta');
                                if (meta) meta.appendChild(badge);
                            }
                        } else {
                            alert(editData.message || 'Erreur lors de la modification du commentaire');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Erreur lors de la modification du commentaire');
                    } finally {
                        setButtonLoading(editSubmitButton, false);
                    }
                }
            });
        });
    </script>
{% endblock %}
