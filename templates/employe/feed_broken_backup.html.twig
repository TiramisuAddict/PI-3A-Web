{% extends 'base.html.twig' %}
{% import _self as feed %}

{% macro comment_item(comment, postId, currentUserId, feed_route_comment_edit, feed_route_comment_delete) %}
    <article
        class="feed-comment-card"
        id="comment-{{ comment.id_commentaire }}"
        data-comment-id="{{ comment.id_commentaire }}"
        data-post-id="{{ postId }}"
        data-parent-id="{{ comment.parent_id is not null ? comment.parent_id : '' }}"
        data-edit-url="{{ path(feed_route_comment_edit, {id_commentaire: comment.id_commentaire}) }}"
        data-delete-url="{{ path(feed_route_comment_delete, {id_commentaire: comment.id_commentaire}) }}"
        data-edit-token="{{ csrf_token('feed_comment_edit_' ~ comment.id_commentaire) }}"
        data-delete-token="{{ csrf_token('feed_comment_delete_' ~ comment.id_commentaire) }}"
    >
        <div class="feed-comment-shell">
            <div class="feed-comment-avatar">
                {{ comment.author_name|slice(0, 2)|upper }}
            </div>
            <div class="feed-comment-main">
                <div class="feed-comment-head">
                    <div class="feed-comment-meta">
                        <span class="feed-comment-author">{{ comment.author_name }}</span>
                        <span class="feed-comment-date" data-comment-date="{{ comment.date_commentaire }}">{{ comment.date_commentaire|date('d/m/Y H:i') }}</span>
                        {% if comment.edited_at %}
                            <span class="feed-comment-edited">Modifie</span>
                        {% endif %}
                    </div>
                    <div class="feed-comment-tools">
                        {% if currentUserId is not null %}
                            <button type="button" class="feed-comment-tool" data-action="reply-toggle">Repondre</button>
                        {% endif %}
                        {% if currentUserId is not null and comment.owned_by_current_user %}
                            <button type="button" class="feed-comment-tool" data-action="edit-toggle">Modifier</button>
                            <button type="button" class="feed-comment-tool danger" data-action="delete-comment">Supprimer</button>
                        {% endif %}
                    </div>
                </div>

                <div class="feed-comment-content" data-comment-content>{{ comment.contenu|nl2br }}</div>

                <form class="feed-edit-form" data-comment-id="{{ comment.id_commentaire }}" style="display:none;">
                    <input type="hidden" name="_token" value="{{ csrf_token('feed_comment_edit_' ~ comment.id_commentaire) }}">
                    <textarea class="form-control feed-comment-textarea" name="contenu" rows="3" maxlength="2000" required>{{ comment.contenu }}</textarea>
                    <div class="feed-comment-form-actions">
                        <button type="submit" class="btn btn-primary btn-sm">Enregistrer</button>
                        <button type="button" class="btn btn-ghost-secondary btn-sm" data-action="edit-cancel">Annuler</button>
                    </div>
                </form>

                {% if currentUserId is not null %}
                    <form class="feed-reply-form" data-post-id="{{ postId }}" data-parent-id="{{ comment.id_commentaire }}" style="display:none;">
                        <input type="hidden" name="_token" value="{{ csrf_token('feed_comment_' ~ postId) }}">
                        <input type="hidden" name="parent_id" value="{{ comment.id_commentaire }}">
                        <div class="feed-reply-shell">
                            <textarea class="form-control feed-comment-textarea" name="contenu" rows="2" maxlength="2000" placeholder="Ecrire une reponse..." required></textarea>
                            <div class="feed-comment-form-actions">
                                <button type="submit" class="btn btn-primary btn-sm">Repondre</button>
                                <button type="button" class="btn btn-ghost-secondary btn-sm" data-action="reply-cancel">Annuler</button>
                            </div>
                        </div>
                    </form>
                {% endif %}
            </div>
        </div>

        {% if comment.replies is not empty %}
            <div class="feed-comment-replies">
                {% for reply in comment.replies %}
                    {{ _self.comment_item(reply, postId, currentUserId, feed_route_comment_edit, feed_route_comment_delete) }}
                {% endfor %}
            </div>
        {% else %}
            <div class="feed-comment-replies" data-empty-replies="true"></div>
        {% endif %}
    </article>
{% endmacro %}

{% block title %}Fil d'actualite - Espace Employe{% endblock %}

{% block body %}
{% set TYPE_ANNONCE = post_type_annonce|default(1) %}
{% set TYPE_EVENEMENT = post_type_evenement|default(2) %}
{% set current_user_initials = current_user_label|default('Employe')|slice(0, 2)|upper %}

{{ include('components/navbar.html.twig') }}

<div
    id="feed-root"
    class="d-flex overflow-hidden"
    style="height:calc(100vh - 56px);"
    data-comment-url-template="{{ path(feed_route_comment, {id_post: '__POST__'}) }}"
    data-comment-edit-url-template="{{ path(feed_route_comment_edit, {id_commentaire: '__COMMENT__'}) }}"
    data-comment-delete-url-template="{{ path(feed_route_comment_delete, {id_commentaire: '__COMMENT__'}) }}"
>
    {{ include('components/sidebar.html.twig', {'active_page': 'accueil', 'sidebar_role': role}) }}

    <div class="flex-fill overflow-y-auto p-4 feed-page-shell">
        <div class="feed-container">
            <div class="feed-page-head">
                <div>
                    <p class="feed-kicker">Espace collaborateur</p>
                    <h1 class="feed-title">Le fil d'actualite de l'entreprise</h1>
                    <p class="feed-subtitle">Annonces, evenements et conversations utiles, reunis dans une experience plus claire et plus vivante.</p>
                </div>
                <div class="dropdown">
                    <button type="button" class="btn btn-light feed-filter-btn" id="filterDropdownBtn" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">
                        <i class="ti ti-adjustments-horizontal"></i>
                        <span>Filtrer</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end" aria-labelledby="filterDropdownBtn">
                        <a class="dropdown-item{% if filter|default('all') == 'all' %} active{% endif %}" href="{{ path('app_employe_feed') }}">Toutes les publications</a>
                        <a class="dropdown-item{% if filter|default('all') == 'annonce' %} active{% endif %}" href="{{ path('app_employe_feed', {filter: 'annonce'}) }}">Annonces uniquement</a>
                        <a class="dropdown-item{% if filter|default('all') == 'evenement' %} active{% endif %}" href="{{ path('app_employe_feed', {filter: 'evenement'}) }}">Evenements uniquement</a>
                    </div>
                </div>
            </div>

            {% for post in posts %}
                {% if post.active %}
                    {% set is_event = post.typePost == TYPE_EVENEMENT %}
                    {% set is_annonce = post.typePost == TYPE_ANNONCE %}
                    {% set pid = post.idPost %}
                    {% set like_n = likes_count[pid]|default(0) %}
                    {% set com_n = comments_count[pid]|default(0) %}
                    {% set part_n = participants_count[pid]|default(0) %}
                    {% set restantes = places_restantes[pid]|default(null) %}
                    {% set comments = comments_by_post[pid]|default([]) %}
                    {% set liked = pid in user_liked_post_ids|default([]) %}
                    {% set participating = pid in user_participates_post_ids|default([]) %}
                    {% set author = author_labels[post.utilisateurId]|default('Employe') %}
                    {% set initials = author|slice(0, 2)|upper %}

                    <article class="feed-post-card" data-post-id="{{ pid }}" data-capacite-max="{{ post.capaciteMax is not null ? post.capaciteMax : '' }}">
                        <div class="feed-post-head">
                            <div class="feed-author-block">
                                <div class="feed-avatar {% if is_event %}event{% else %}announcement{% endif %}">{{ initials }}</div>
                                <div>
                                    <div class="feed-author-name">{{ author }}</div>
                                    <div class="feed-post-meta">
                                        <span>{{ post.dateCreation ? post.dateCreation|date('d/m/Y H:i') : '' }}</span>
                                    </div>
                                </div>
                            </div>
                            <span class="feed-post-tag {% if is_event %}event{% else %}announcement{% endif %}">
                                {% if is_event %}Evenement{% elseif is_annonce %}Annonce{% else %}Publication{% endif %}
                            </span>
                        </div>

                        <div class="feed-post-body">
                            <h2 class="feed-post-title">{{ post.titre }}</h2>
                            <p class="feed-post-content">{{ post.contenu }}</p>

                            {% if is_event %}
                                <div class="feed-event-panel">
                                    {% if post.dateEvenement %}
                                        <div class="feed-event-item">
                                            <i class="ti ti-calendar-event"></i>
                                            <div>
                                                <span class="feed-event-label">Date debut</span>
                                                <strong>{{ post.dateEvenement|date('d/m/Y') }}</strong>
                                            </div>
                                        </div>
                                    {% endif %}
                                    {% if post.dateFinEvenement %}
                                        <div class="feed-event-item">
                                            <i class="ti ti-calendar-time"></i>
                                            <div>
                                                <span class="feed-event-label">Date fin</span>
                                                <strong>{{ post.dateFinEvenement|date('d/m/Y') }}</strong>
                                            </div>
                                        </div>
                                    {% endif %}
                                    {% if post.lieu %}
                                        <div class="feed-event-item">
                                            <i class="ti ti-map-pin"></i>
                                            <div>
                                                <span class="feed-event-label">Lieu</span>
                                                <strong>{{ post.lieu }}</strong>
                                            </div>
                                        </div>
                                    {% endif %}
                                    {% if post.capaciteMax is not null %}
                                        <div class="feed-event-item">
                                            <i class="ti ti-users"></i>
                                            <div>
                                                <span class="feed-event-label">Capacite</span>
                                                <strong>{{ post.capaciteMax }} places</strong>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>

                                {% if post.lieu %}
                                    <div class="feed-map-link-wrap">
                                        <a class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener noreferrer" href="https://www.google.com/maps/search/?api=1&query={{ post.lieu|url_encode }}">
                                            <i class="ti ti-map-pin me-1"></i> Voir sur Google Maps
                                        </a>
                                    </div>
                                {% endif %}
                            {% endif %}

                            {% if is_event and post.eventImages|length > 0 %}
                                <div class="row g-2 mt-1">
                                    {% for img in post.eventImages %}
                                        {% set src = img.imagePath starts with 'http' ? img.imagePath : asset(img.imagePath) %}
                                        <div class="col-6 col-sm-4">
                                            <img src="{{ src }}" alt="" class="img-fluid rounded-4 border" loading="lazy" style="aspect-ratio: 4/3; object-fit: cover;">
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="feed-stats-row">
                            <span class="feed-stat" id="like-count-{{ pid }}">
                                <i class="ti ti-heart-filled"></i>
                                <span>{{ like_n }} j'aime</span>
                            </span>
                            <span class="feed-stat" id="com-count-{{ pid }}">
                                <i class="ti ti-message-circle"></i>
                                <span>{{ com_n }} commentaire{{ com_n > 1 ? 's' : '' }}</span>
                            </span>
                            {% if is_event %}
                                <span class="feed-stat" id="part-count-{{ pid }}">
                                    <i class="ti ti-user-check"></i>
                                    <span>{{ part_n }} participant{{ part_n > 1 ? 's' : '' }}</span>
                                </span>
                                {% if restantes is not null %}
                                    <span class="feed-places-badge" id="places-restantes-{{ pid }}">{{ restantes }} places restantes</span>
                                {% endif %}
                            {% endif %}
                        </div>

                        <div class="feed-actions-row">
                            <button
                                type="button"
                                class="feed-action-button feed-like-button {% if liked %}is-active{% endif %}"
                                data-post-id="{{ pid }}"
                                data-action="like"
                                data-csrf="{{ csrf_token('feed_like_' ~ pid) }}"
                            >
                                <span class="feed-action-icon">
                                    <i class="ti {% if liked %}ti-heart-filled{% else %}ti-heart{% endif %}"></i>
                                </span>
                                <span class="feed-action-label">J'aime</span>
                            </button>

                            <button
                                type="button"
                                class="feed-action-button"
                                data-post-id="{{ pid }}"
                                data-action="comment"
                            >
                                <span class="feed-action-icon">
                                    <i class="ti ti-message-circle"></i>
                                </span>
                                <span class="feed-action-label">Commentaires</span>
                            </button>

                            {% if is_event %}
                                <button
                                    type="button"
                                    class="feed-action-button feed-participation-button {% if participating %}is-active{% endif %}"
                                    data-post-id="{{ pid }}"
                                    data-action="participate"
                                    data-csrf="{{ csrf_token('feed_participate_' ~ pid) }}"
                                >
                                    <span class="feed-action-icon">
                                        <i class="ti {% if participating %}ti-circle-check-filled{% else %}ti-circle-check{% endif %}"></i>
                                    </span>
                                    <span class="feed-action-label feed-action-text">{% if participating %}Annuler{% else %}Participer{% endif %}</span>
                                </button>
                            {% endif %}
                        </div>

                        <section class="feed-comments-section" id="comments-section-{{ pid }}" style="display:none;">
                            <div class="feed-comments-list" id="comments-list-{{ pid }}">
                                {% if comments is not empty %}
                                    {% for comment in comments %}
                                        {{ feed.comment_item(comment, pid, current_user_id, feed_route_comment_edit, feed_route_comment_delete) }}
                                    {% endfor %}
                                {% else %}
                                    <div class="feed-empty-comments" id="comments-empty-{{ pid }}">Aucun commentaire pour l'instant. Lancez la conversation.</div>
                                {% endif %}
                            </div>

                            {% if current_user_id is not null %}
                                <form class="feed-comment-composer feed-comment-form" data-post-id="{{ pid }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('feed_comment_' ~ pid) }}">
                                    <div class="feed-composer-avatar">{{ current_user_initials }}</div>
                                    <div class="feed-composer-main">
                                        <textarea class="form-control feed-comment-textarea feed-comment-input" name="contenu" rows="2" maxlength="2000" placeholder="Ajouter un commentaire..." required></textarea>
                                        <div class="feed-comment-form-actions">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="ti ti-send me-1"></i> Publier
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            {% endif %}
                        </section>
                    </article>
                {% endif %}
            {% else %}
                <div class="feed-empty-state">
                    <i class="ti ti-inbox"></i>
                    <h3>Aucune publication pour le moment</h3>
                    <p>Les nouvelles annonces et evenements apparaitront ici des qu'ils seront publies.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

