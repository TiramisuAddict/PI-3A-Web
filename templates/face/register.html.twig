{% extends 'base.html.twig' %}

{% block title %}Enregistrement Face ID{% endblock %}

{% block body %}
<div class="container py-5" style="max-width: 880px;">
    <h1 class="h3 mb-3">Enregistrer Face ID</h1>
    <p class="text-muted mb-4">Faites un mouvement leger du visage devant la camera, puis enregistrez votre empreinte.</p>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <video id="video" autoplay playsinline muted style="width:100%;max-height:420px;border-radius:12px;background:#111"></video>

            <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                <button id="registerBtn" class="btn btn-primary" disabled>Enregistrer mon Face ID</button>
                <span id="status" class="text-muted">Initialisation camera...</span>
            </div>

            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" id="consent">
                <label class="form-check-label" for="consent">
                    J'accepte le stockage de mon empreinte faciale pour l'authentification.
                </label>
            </div>

            <div id="result" class="mt-3"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
(async function () {
    const video = document.getElementById('video');
    const registerBtn = document.getElementById('registerBtn');
    const statusEl = document.getElementById('status');
    const resultEl = document.getElementById('result');
    const consentEl = document.getElementById('consent');

    let latestDescriptor = null;
    let isLive = false;
    let movedEnough = false;
    let baseX = null;

    function setStatus(msg) { statusEl.textContent = msg; }
    function setResult(msg, ok = false) {
        resultEl.innerHTML = `<div class="alert ${ok ? 'alert-success' : 'alert-danger'}" role="alert">${msg}</div>`;
    }

    try {
        await Promise.all([
            faceapi.nets.tinyFaceDetector.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models'),
            faceapi.nets.faceLandmark68Net.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models'),
            faceapi.nets.faceRecognitionNet.loadFromUri('https://justadudewhohacks.github.io/face-api.js/models')
        ]);

        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
        video.srcObject = stream;

        setStatus('Regardez la camera et bougez legerement la tete.');

        const interval = setInterval(async () => {
            if (video.readyState < 2) return;

            const detection = await faceapi
                .detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
                .withFaceLandmarks()
                .withFaceDescriptor();

            if (!detection) {
                setStatus('Aucun visage detecte...');
                registerBtn.disabled = true;
                return;
            }

            latestDescriptor = Array.from(detection.descriptor);

            const currentX = detection.detection.box.x;
            if (baseX === null) {
                baseX = currentX;
            }
            if (Math.abs(currentX - baseX) > 20) {
                movedEnough = true;
                isLive = true;
            }

            registerBtn.disabled = !(latestDescriptor && isLive);
            setStatus(isLive
                ? 'Vivacite OK. Vous pouvez enregistrer.'
                : 'Faites un leger mouvement gauche/droite pour valider la vivacite.');
        }, 700);

        registerBtn.addEventListener('click', async () => {
            if (!latestDescriptor) {
                setResult('Empreinte non disponible.');
                return;
            }

            if (!consentEl.checked) {
                setResult('Vous devez accepter le consentement.');
                return;
            }

            const response = await fetch('{{ path('face_register') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    embedding: latestDescriptor,
                    consent: consentEl.checked,
                    isLive: isLive && movedEnough
                })
            });

            const data = await response.json();
            setResult(data.message || 'Erreur.', !!data.success);

            if (data.success) {
                clearInterval(interval);
            }
        });
    } catch (e) {
        setStatus('Erreur camera ou chargement des modeles.');
        setResult(e.message || 'Impossible de demarrer Face ID.');
    }
})();
</script>
{% endblock %}
