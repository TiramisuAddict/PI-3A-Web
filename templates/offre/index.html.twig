{% extends 'base.html.twig' %}

{% block title %}Offres d'emploi | Momentum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .offres-page {
            background: #f5f7fb;
            min-height: 100vh;
            padding-bottom: 2rem;
        }

        .offres-carousel {
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: #ffffff;
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
        }

        .offres-carousel .carousel-item {
            min-height: 380px;
        }

        .offres-carousel .carousel-panel {
            min-height: 380px;
            position: relative;
            overflow: hidden;
            color: #fff;
            padding: 2rem;
            background-size: cover;
            background-position: center;
            isolation: isolate;
        }

        .offres-carousel .carousel-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(110deg, rgba(19, 26, 56, 0.86) 20%, rgba(15, 107, 183, 0.45) 100%);
            z-index: -2;
        }

        .offres-carousel .carousel-panel::after {
            content: "";
            position: absolute;
            width: 380px;
            height: 380px;
            right: -120px;
            top: -140px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.28), transparent 70%);
            z-index: -1;
        }

        .offres-kicker {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.35);
            background: rgba(255, 255, 255, 0.12);
            padding: .35rem .8rem;
            font-size: .75rem;
            letter-spacing: .04em;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: .9rem;
        }

        .offres-carousel-title {
            font-size: clamp(1.7rem, 2.7vw, 2.4rem);
            margin-bottom: .8rem;
            line-height: 1.2;
            max-width: 640px;
        }

        .offres-carousel-subtitle {
            max-width: 620px;
            margin-bottom: 1.15rem;
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.02rem;
        }

        .offres-carousel-badges {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .offres-carousel-badges .badge {
            border: 1px solid rgba(255, 255, 255, 0.4);
            background: rgba(255, 255, 255, 0.14);
            color: #fff;
            font-weight: 600;
            padding: .45rem .65rem;
            backdrop-filter: blur(2px);
        }

        .offres-carousel .carousel-caption {
            position: absolute;
            right: auto;
            left: 2rem;
            bottom: 2.4rem;
            text-align: left;
            padding: 0;
            width: min(92%, 800px);
        }

        .offres-carousel .carousel-indicators {
            margin-bottom: 1rem;
        }

        .offres-carousel .carousel-indicators [data-bs-target] {
            width: 26px;
            height: 5px;
            border-radius: 999px;
        }

        .offres-carousel .carousel-control-prev,
        .offres-carousel .carousel-control-next {
            width: 52px;
            opacity: 1;
        }

        .offres-carousel .carousel-control-prev-icon,
        .offres-carousel .carousel-control-next-icon {
            width: 2.5rem;
            height: 2.5rem;
            background-color: rgba(15, 23, 42, 0.38);
            border-radius: 999px;
            background-size: 1.2rem;
            backdrop-filter: blur(2px);
        }

        .offres-filter-bar {
            border-radius: 10px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: #fff;
        }

        .offres-filter-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            margin-bottom: 1rem;
            padding-bottom: .85rem;
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        }

        .offres-filter-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #1f2937;
        }

        .offres-filter-subtitle {
            margin: .2rem 0 0;
            color: #6b7280;
            font-size: .84rem;
        }

        .offres-filter-layout {
            row-gap: .75rem;
        }

        .offres-filter-label {
            font-size: .78rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: .04em;
            font-weight: 700;
            margin-bottom: .4rem;
        }

        .offres-filter-actions {
            display: flex;
            justify-content: flex-end;
            align-items: flex-end;
            gap: .5rem;
        }

        @media (max-width: 991.98px) {
            .offres-filter-actions {
                justify-content: stretch;
            }

            .offres-filter-actions .btn {
                flex: 1;
            }
        }

        .offre-card {
            border-radius: 10px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            background: #fff;
            transition: border-color .2s ease, box-shadow .2s ease;
        }

        .offre-card:hover {
            border-color: rgba(31, 111, 235, 0.35);
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        }

        .offre-card .card-body {
            padding: 1rem;
        }

        .offre-title {
            font-size: 1.05rem;
            line-height: 1.35;
            margin: 0;
            color: #1f2937;
        }

        .offre-category {
            font-size: .72rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .04em;
            font-weight: 700;
            margin-bottom: .35rem;
        }

        .offre-info {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .5rem;
            margin-top: .9rem;
        }

        .offre-info-item {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 8px;
            background: #f8fafc;
            padding: .55rem .65rem;
        }

        .offre-info-label {
            display: block;
            font-size: .72rem;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: .04em;
            font-weight: 700;
            margin-bottom: .1rem;
        }

        .offre-info-value {
            display: block;
            font-weight: 600;
            color: #182433;
            font-size: .9rem;
        }

        @media (max-width: 575.98px) {
            .offre-info {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 767.98px) {
            .offres-carousel .carousel-item,
            .offres-carousel .carousel-panel {
                min-height: 430px;
            }

            .offres-carousel .carousel-caption {
                left: 1.1rem;
                bottom: 2.8rem;
                width: calc(100% - 2.2rem);
            }

            .offres-carousel-title {
                font-size: 1.45rem;
            }

            .offres-carousel-subtitle {
                font-size: .95rem;
                margin-bottom: .9rem;
            }
        }
    </style>
{% endblock %}

{# clear form when modal is closed #}
{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.modal[id^="postulerModal-"]').forEach(function (modal) {
                modal.addEventListener('hidden.bs.modal', function () {
                    modal.querySelectorAll('form').forEach(function (form) {
                        form.reset();
                        form.querySelectorAll('.is-valid, .is-invalid').forEach(function (field) {
                            field.classList.remove('is-valid', 'is-invalid');
                        });
                    });
                });
            });
        });
    </script>
{% endblock %}

{% block body %}
{# filter parameters #}

{% set queryName = app.request.query.get('q')|default('') %}
{% set queryCategory = app.request.query.get('category')|default('') %}
{% set queryContract = app.request.query.get('contract')|default('') %}

{% set categories = [
    'Informatique',
    'Marketing',
    'Vente',
    'Finance',
    'Ressources Humaines',
    'Sante',
    'Education',
    'Art et Design',
    'Autre'
] %}

{# check flashes #}


{# navbar #}
<div class="offres-page">
    {% include 'offre/_home_page_navbar.html.twig' with { active_nav: 'offres', logged_user: true } %}

    <section class="container-xl mt-3">
        <div id="offresCarousel" class="carousel slide carousel-fade offres-carousel" data-bs-ride="carousel" data-bs-interval="5200">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#offresCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#offresCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#offresCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
            </div>

            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="carousel-panel" style="background-image: url('https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1600&q=80');">
                        <div class="carousel-caption">
                            <div class="offres-kicker"><i class="ti ti-sparkles"></i> Decouverte intelligente</div>
                            <h2 class="offres-carousel-title">Trouvez l'offre qui vous correspond vraiment</h2>
                            <p class="offres-carousel-subtitle">Un moteur de recherche clair, des filtres utiles et une lecture rapide des postes les plus pertinents pour votre profil.</p>
                            <div class="offres-carousel-badges">
                                <span class="badge">Filtres rapides</span>
                                <span class="badge">UI claire</span>
                                <span class="badge">Postuler en quelques clics</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="carousel-panel" style="background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1600&q=80');">
                        <div class="carousel-caption">
                            <div class="offres-kicker"><i class="ti ti-users-group"></i> Focus RH</div>
                            <h2 class="offres-carousel-title">Un recrutement plus rapide pour les equipes RH</h2>
                            <p class="offres-carousel-subtitle">Passez de la publication d'offre au suivi candidat avec une experience unifiee et des composants Tabler coherents.</p>
                            <div class="offres-carousel-badges">
                                <span class="badge">Pipeline organise</span>
                                <span class="badge">Score IA</span>
                                <span class="badge">Suivi en direct</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="carousel-panel" style="background-image: url('https://images.unsplash.com/photo-1573497491765-dccce02b29df?auto=format&fit=crop&w=1600&q=80');">
                        <div class="carousel-caption">
                            <div class="offres-kicker"><i class="ti ti-briefcase-2"></i> Carriere</div>
                            <h2 class="offres-carousel-title">CDI, CDD, Stage ou CVP: avancez selon vos objectifs</h2>
                            <p class="offres-carousel-subtitle">Comparez les opportunites par categorie, contrat et echeance pour accelerer votre prochaine etape professionnelle.</p>
                            <div class="offres-carousel-badges">
                                <span class="badge">8+ categories</span>
                                <span class="badge">Contrats varies</span>
                                <span class="badge">Descriptions detaillees</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#offresCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Precedent</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#offresCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Suivant</span>
            </button>
        </div>
    </section>

    <section class="container-xl mt-3">
        <div class="card offres-filter-bar">
            <div class="card-body">
                <div class="offres-filter-head">
                    <div>
                        <h3 class="offres-filter-title">Filtrer les offres</h3>
                        <p class="offres-filter-subtitle">Affinez rapidement par poste, categorie et contrat.</p>
                    </div>
                    <a href="{{ path('app_offre_list') }}" class="btn btn-outline-secondary btn-sm">Reinitialiser</a>
                </div>

                <form method="get" action="{{ path('app_offre_list') }}" class="row offres-filter-layout align-items-end">
                    <div class="col-12 col-lg-5">
                        <label class="offres-filter-label" for="q">Poste</label>
                        <input type="text" id="q" name="q" class="form-control" placeholder="Ex: Developpeur Full Stack" value="{{ queryName }}">
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="offres-filter-label" for="category">Categorie</label>
                        <select id="category" name="category" class="form-select">
                            <option value="">Toutes les categories</option>
                            {% for category in categories %}
                                <option value="{{ category }}" {{ queryCategory == category ? 'selected' : '' }}>{{ category }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="offres-filter-label" for="contract">Contrat</label>
                        <select id="contract" name="contract" class="form-select">
                            <option value="">Tous les contrats</option>
                            <option value="CDI" {{ queryContract == 'CDI' ? 'selected' : '' }}>CDI</option>
                            <option value="CDD" {{ queryContract == 'CDD' ? 'selected' : '' }}>CDD</option>
                            <option value="STAGE" {{ queryContract == 'STAGE' ? 'selected' : '' }}>STAGE</option>
                            <option value="CVP" {{ queryContract == 'CVP' ? 'selected' : '' }}>CVP</option>
                        </select>
                    </div>

                    <div class="col-12 col-lg-1 offres-filter-actions">
                        <button type="submit" class="btn btn-primary w-100">Chercher</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <section class="container-xl mt-4">
        {% if offres|length > 0 %}
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h2 mb-0">{{ offres|length }} offres disponibles</h2>
            </div>

            <div class="row g-3">
                {% for offre in offres %}
                    {% set applyModalId = 'postulerModal-' ~ offre.id %}
                    {% set detailsModalId = 'detailsModal-' ~ offre.id %}
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card offre-card h-100">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                    <div>
                                        <div class="offre-category">{{ offre.categorie }}</div>
                                        <h3 class="offre-title">{{ offre.titrePoste }}</h3>
                                    </div>
                                    <span class="badge bg-blue-lt text-blue">{{ offre.typeContrat }}</span>
                                </div>

                                <div class="offre-info">
                                    <div class="offre-info-item">
                                        <span class="offre-info-label">Date limite</span>
                                        <span class="offre-info-value">{{ offre.dateLimite|date('Y-m-d') }}</span>
                                    </div>

                                    <div class="offre-info-item">
                                        <span class="offre-info-label">Candidats</span>
                                        <span class="offre-info-value">{{ offre.candidats|length }} candidat(s)</span>
                                    </div>
                                </div>

                                <div class="mt-3 pt-1 mt-auto row g-2">
                                    <div class="col-6 d-grid">
                                        <button type="button" class="btn btn-primary" data-bs-toggle="modal"
                                            data-bs-target="#{{ applyModalId }}">
                                            Postuler
                                        </button>

                                        <div class="modal fade" id="{{ applyModalId }}" tabindex="-1" aria-labelledby="{{ applyModalId }}Label" aria-hidden="true">
                                            <div class="modal-dialog modal-lg" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="{{ applyModalId }}Label">Postuler - {{ offre.titrePoste }}</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        {{ render(controller('App\\Controller\\CandidatController::postuler', {
                                                            'offreId': offre.id,
                                                            'visiteurId': 8
                                                        })) }}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-6 d-grid">
                                        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                            data-bs-target="#{{ detailsModalId }}">
                                            Details
                                        </button>

                                        <div class="modal fade" id="{{ detailsModalId }}" tabindex="-1" aria-labelledby="{{ detailsModalId }}Label" aria-hidden="true">
                                            <div class="modal-dialog" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="{{ detailsModalId }}Label">Poste {{ offre.titrePoste }}</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                                        aria-label="Fermer"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        {% set safeDescription = (offre.description|default(''))
                                                            |replace({
                                                                ' contenteditable="true"': '',
                                                                ' contenteditable="false"': '',
                                                                ' contenteditable=true': '',
                                                                ' contenteditable=false': '',
                                                                ' contenteditable': '',
                                                                ' designmode="on"': '',
                                                                ' designMode="on"': ''
                                                            })
                                                        %}
                                                        {{ safeDescription|raw }}
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn me-auto"
                                                        data-bs-dismiss="modal">Fermer</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="card">
                <div class="card-body">
                    <div class="empty">
                        <div class="empty-img mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-briefcase" width="48" height="48" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z" />
                                <path d="M8 7l0 -2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2l0 2" />
                                <path d="M12 12l0 .01" />
                                <path d="M3 13a20 20 0 0 0 18 0" />
                            </svg>
                        </div>
                        <p class="empty-title">Aucune offre disponible</p>
                        <p class="empty-subtitle text-secondary">Aucune offre ne correspond pour le moment. Revenez plus tard.</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </section>

    {% include 'components/front_footer.html.twig' %}
</div>
{% endblock %}
