{% set logged_user = logged_user|default(app.session.get('visiteur_logged_in') == true) %}
{% set active_nav = active_nav|default('home') %}
{% set visiteur_nom = visiteur_nom|default(app.session.get('visiteur_nom')) %}
{% set visiteur_prenom = visiteur_prenom|default(app.session.get('visiteur_prenom')) %}
{% set visiteur_email = visiteur_email|default(app.session.get('visiteur_email')) %}

{% set nav_items = nav_items|default([
    { key: 'home', label: 'Accueil', href: path('app_offre_home') },
    { key: 'offres', label: "Offres d'emploi", href: path('app_offre_list') },
    { key: 'candidature', label: 'Suivre candidature', href: path('app_suivre_candidature') },
    { key: 'pricing', label: 'Tarification', href: path('app_pricing') },
    { key: 'download', label: 'Telechargement', href: path('app_download') }
]) %}

<div class="navbar-wrap d-print-none">
    <header class="navbar navbar-expand-lg">
    <div class="container-xl px-2 px-md-3">
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbar-menu"
      aria-controls="navbar-menu"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
    <span class="navbar-toggler-icon"></span>
    </button>

    <!-- BEGIN NAVBAR LOGO -->
    <a href="{{ path('app_offre_home') }}" aria-label="Momentum" class="navbar-brand navbar-brand-autodark me-4 me-xl-5"> <img src="{{ asset('images/momentum_logo.png') }}" class="navbar-brand-image" alt="Momentum logo"> </a>
    <!-- END NAVBAR LOGO -->
    
    <div class="collapse navbar-collapse" id="navbar-menu">

        <ul class="navbar-nav gap-lg-1 pt-2 pb-2">
            {% for item in nav_items %}
            <li class="nav-item {{ active_nav == item.key ? 'active' }}">
                <a class="nav-link" href="{{ item.href }}">
                    <span class="nav-link-title"> {{ item.label }} </span>
                </a>
            </li>
            {% endfor %}
        </ul>

        <div class="navbar-nav flex-row align-items-center order-md-last ms-auto gap-2">
            {% if logged_user %}
            <div class="nav-item dropdown">
                <a
                href="#"
                class="nav-link d-flex lh-1 text-reset"
                data-bs-toggle="dropdown"
                aria-label="Open user menu"
                >
                <div class="d-none d-xl-block ps-2">
                    <div>{{ (visiteur_prenom|default('')) ~ ' ' ~ (visiteur_nom|default('')) }}</div>
                    <div class="mt-1 small text-secondary">{{ visiteur_email|default('Visiteur') }}</div>
                </div>
                </a>
                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                <a href="{{ path('logout') }}" class="dropdown-item">Logout</a>
                </div>
            </div>
            {% else %}
                <a href="{{ path('login') }}"  class="btn btn-primary btn-md">Se connecter</a>
                <a href="{{ path('compte_visiteur') }}" class="btn btn-outline-primary btn-md">Register</a>
            {% endif %}
        </div>
    </div>
  </div>
    </header>
</div>
