{% set currentRoute = app.request.attributes.get('_route') %}
<style>
    .rh-nav-card {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 12px;
        background: #ffffff;
    }

    .rh-nav-title {
        font-size: .95rem;
        font-weight: 600;
        color: #1f2937;
        line-height: 1.2;
    }

    .rh-nav-subtitle {
        font-size: .78rem;
        color: #64748b;
        margin-top: .1rem;
    }

    .rh-nav-track {
        background: #f6f8fc;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 10px;
        padding: .25rem;
        display: inline-flex;
        gap: .25rem;
        flex-wrap: wrap;
    }

    .rh-nav-link {
        min-height: 36px;
        border-radius: 8px;
        border: 0;
        padding: .45rem .85rem;
        font-weight: 600;
        color: #526075;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background-color .2s ease, color .2s ease;
    }

    .rh-nav-link:hover {
        color: #1f2937;
        background: rgba(31, 111, 235, 0.08);
    }

    .rh-nav-link.is-active {
        background: #1f6feb;
        color: #fff;
    }

    @media (max-width: 767.98px) {
        .rh-nav-track {
            width: 100%;
        }

        .rh-nav-link {
            flex: 1 1 calc(50% - .25rem);
            text-align: center;
        }
    }
</style>

<div class="card mb-4 border-0">
    <div class="card-body p-2 p-md-3 rh-nav-card">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-2 ms-1">
                <span class="badge bg-blue-lt text-blue">Espace RH</span>
            </div>

            <div class="rh-nav-track" role="tablist" aria-label="Navigation recrutement">
                <a
                    class="rh-nav-link {{ currentRoute == 'app_offre_dashboard' ? 'is-active' : '' }}"
                    href="{{ path('app_offre_dashboard') }}"
                    {% if currentRoute == 'app_offre_dashboard' %}aria-current="page"{% endif %}
                >
                    Offres
                </a>

                <a
                    class="rh-nav-link {{ currentRoute == 'app_candidat_dashboard' ? 'is-active' : '' }}"
                    href="{{ path('app_candidat_dashboard') }}"
                    {% if currentRoute == 'app_candidat_dashboard' %}aria-current="page"{% endif %}
                >
                    Candidats
                </a>

                <a
                    class="rh-nav-link {{ currentRoute == 'app_recrutement_statistiques' ? 'is-active' : '' }}"
                    href="{{ path('app_recrutement_statistiques') }}"
                    {% if currentRoute == 'app_recrutement_statistiques' %}aria-current="page"{% endif %}
                >
                    Statistiques
                </a>
            </div>
        </div>
    </div>
</div>
