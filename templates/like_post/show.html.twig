{% extends 'base.html.twig' %}

{% block title %}Like #{{ like_post.idLike }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Like #{{ like_post.idLike }}</h1>
    <div class="card border shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">ID</th><td>{{ like_post.idLike }}</td></tr>
                        <tr><th>Utilisateur</th><td>{{ like_post.utilisateurId }}</td></tr>
                        <tr><th>Date like</th><td>{{ like_post.dateLike ? like_post.dateLike|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>Post</th><td>{% if like_post.post %}#{{ like_post.post.idPost }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_like_post_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_like_post_edit', { id_like: like_post.idLike }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('like_post/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
