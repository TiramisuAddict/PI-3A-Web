{% extends 'base.html.twig' %}

{% block title %}Like #{{ like_post.id_like }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Like #{{ like_post.id_like }}</h1>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">id_like</th><td>{{ like_post.id_like }}</td></tr>
                        <tr><th>utilisateur_id</th><td>{{ like_post.utilisateur_id }}</td></tr>
                        <tr><th>date_like</th><td>{{ like_post.date_like ? like_post.date_like|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>post (id_post)</th><td>{% if like_post.post %}{{ like_post.post.id_post }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_like_post_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_like_post_edit', { id_like: like_post.id_like }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('like_post/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
