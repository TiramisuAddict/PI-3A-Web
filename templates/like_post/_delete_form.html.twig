<form class="d-inline" method="post" action="{{ path('app_like_post_delete', {'id_like': like_post.id_like}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ like_post.id_like) }}">
    <button type="submit" class="btn btn-danger"><i class="ti ti-trash me-1"></i>Supprimer</button>
</form>
