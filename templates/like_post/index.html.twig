{% extends 'base.html.twig' %}

{% block title %}Likes{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Likes</h1>
        <p class="text-secondary small mb-0">Données issues du fil d’actualité — pas de création ni modification manuelle.</p>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle table-vcenter">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Utilisateur</th>
                    <th>Date like</th>
                    <th>Post</th>
                </tr>
            </thead>
            <tbody>
            {% for like_post in like_posts %}
                <tr>
                    <td>{{ like_post.idLike }}</td>
                    <td>{{ like_post.utilisateurId }}</td>
                    <td>{{ like_post.dateLike ? like_post.dateLike|date('Y-m-d H:i') : '' }}</td>
                    <td>{% if like_post.post %}#{{ like_post.post.idPost }}{% endif %}</td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
