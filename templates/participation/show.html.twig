{% extends 'base.html.twig' %}

{% block title %}Participation #{{ participation.idParticipation }} - Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Participation #{{ participation.idParticipation }}</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Statut</label>
                            <p class="mb-0"><span class="badge bg-blue-lt text-blue">{{ participation.statut }}</span></p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Date d'action</label>
                            <p class="mb-0">{{ participation.dateAction ? participation.dateAction|date('d/m/Y H:i') : '-' }}</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Post associe</label>
                            <p class="mb-0">
                                {% if participation.post %}
                                    <a href="{{ path('app_post_show', {id_post: participation.post.idPost}) }}" class="btn btn-ghost-primary">{{ participation.post.titre|length > 40 ? participation.post.titre|slice(0, 40) ~ '...' : participation.post.titre }}</a>
                                {% else %}
                                    -
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-primary" href="{{ path('app_participation_index') }}"><i class="ti ti-list me-1"></i>Retour a la liste</a>
                <a class="btn btn-outline-primary" href="{{ path('app_participation_ticket', { id_participation: participation.idParticipation }) }}" target="_blank" rel="noopener noreferrer">
                    <i class="ti ti-qrcode me-1"></i>Voir le QR code
                </a>
                {{ include('participation/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
