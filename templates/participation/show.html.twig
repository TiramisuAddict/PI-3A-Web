{% extends 'base.html.twig' %}

{% block title %}Participation #{{ participation.id_participation }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Participation #{{ participation.id_participation }}</h1>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">id_participation</th><td>{{ participation.id_participation }}</td></tr>
                        <tr><th>utilisateur_id</th><td>{{ participation.utilisateur_id }}</td></tr>
                        <tr><th>statut</th><td>{{ participation.statut }}</td></tr>
                        <tr><th>date_action</th><td>{{ participation.date_action ? participation.date_action|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>post (id_post)</th><td>{% if participation.post %}{{ participation.post.id_post }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_participation_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_participation_edit', { id_participation: participation.id_participation }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('participation/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
