{% extends 'base.html.twig' %}

{% block title %}Participation #{{ participation.idParticipation }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Participation #{{ participation.idParticipation }}</h1>
    <div class="card border shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">ID</th><td>{{ participation.idParticipation }}</td></tr>
                        <tr><th>Utilisateur</th><td>{{ participation.utilisateurId }}</td></tr>
                        <tr><th>Statut</th><td>{{ participation.statut }}</td></tr>
                        <tr><th>Date action</th><td>{{ participation.dateAction ? participation.dateAction|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>Post</th><td>{% if participation.post %}#{{ participation.post.idPost }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_participation_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_participation_edit', { id_participation: participation.idParticipation }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('participation/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
