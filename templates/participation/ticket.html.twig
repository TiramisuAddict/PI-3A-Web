{% extends 'base.html.twig' %}

{% block title %}Ticket participation #{{ ticket.id_participation }}{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-body">
        <div class="container-xl py-4">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-6">
                    <div class="card shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                                <div>
                                    <div class="text-uppercase text-secondary small fw-bold">Ticket evenement</div>
                                    <h1 class="h3 mb-1">{{ ticket.post_titre }}</h1>
                                    <p class="text-secondary mb-0">Participation #{{ ticket.id_participation }}</p>
                                </div>
                                <span class="badge bg-green-lt text-green">{{ ticket.statut }}</span>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <div class="text-secondary small">Employe</div>
                                    <div class="fw-semibold">{{ ticket_holder }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-secondary small">Date de participation</div>
                                    <div class="fw-semibold">{{ ticket.date_action ? ticket.date_action|date('d/m/Y H:i') : '-' }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-secondary small">Debut evenement</div>
                                    <div class="fw-semibold">{{ ticket.date_evenement ? ticket.date_evenement|date('d/m/Y') : '-' }}</div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-secondary small">Lieu</div>
                                    <div class="fw-semibold">{{ ticket.lieu ?: '-' }}</div>
                                </div>
                            </div>

                            <div class="text-center border rounded-4 p-4 bg-light">
                                <img
                                    src="{{ qr_code_data_uri(validation_url) }}"
                                    alt="QR code du ticket"
                                    style="width: 240px; max-width: 100%; height: auto;"
                                >
                                <p class="text-secondary small mt-3 mb-0">
                                    En scannant ce QR code, le ticket s ouvre directement sur mobile afin de pouvoir le consulter et le verifier facilement.
                                </p>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-4">
                                <a href="{{ validation_path|default(validation_url) }}" class="btn btn-outline-primary" target="_blank" rel="noopener noreferrer">
                                    <i class="ti ti-shield-check me-1"></i>Verifier le ticket
                                </a>
                                <button type="button" class="btn btn-primary" onclick="window.print()">
                                    <i class="ti ti-printer me-1"></i>Imprimer
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
