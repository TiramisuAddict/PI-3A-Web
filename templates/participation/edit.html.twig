{% extends 'base.html.twig' %}

{% block title %}Modifier une participation — Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Modifier une participation</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    {{ include('participation/_form.html.twig', {
                        cancel_path: path('app_participation_index'),
                        submit_label: 'Modifier'
                    }) }}
                </div>
            </div>
            <div class="mt-3">
                {{ include('participation/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
