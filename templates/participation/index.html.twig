{% extends 'base.html.twig' %}

{% block title %}Participations{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Participations</h1>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle table-vcenter">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Utilisateur</th>
                    <th>Statut</th>
                    <th>Date action</th>
                    <th>Post</th>
                    <th class="text-end text-nowrap" style="width: 1%;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for participation in participations %}
                <tr>
                    <td>{{ participation.idParticipation }}</td>
                    <td>{{ participation.utilisateurId }}</td>
                    <td>{{ participation.statut }}</td>
                    <td>{{ participation.dateAction ? participation.dateAction|date('Y-m-d H:i') : '' }}</td>
                    <td>{% if participation.post %}#{{ participation.post.idPost }}{% endif %}</td>
                    <td class="text-end text-nowrap">
                        <form class="d-inline" method="post" action="{{ path('app_participation_delete', { id_participation: participation.idParticipation }) }}" onsubmit="return confirm('Supprimer cette participation ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ participation.idParticipation) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Supprimer"><i class="ti ti-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
