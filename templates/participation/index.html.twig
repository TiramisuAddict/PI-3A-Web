{% extends 'base.html.twig' %}

{% block title %}Participations{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Participations</h1>
        <a class="btn btn-primary" href="{{ path('app_participation_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>id_participation</th>
                    <th>utilisateur_id</th>
                    <th>statut</th>
                    <th>date_action</th>
                    <th>post</th>
                    <th class="text-nowrap">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for participation in participations %}
                <tr>
                    <td>{{ participation.id_participation }}</td>
                    <td>{{ participation.utilisateur_id }}</td>
                    <td>{{ participation.statut }}</td>
                    <td>{{ participation.date_action ? participation.date_action|date('Y-m-d H:i') : '' }}</td>
                    <td>{% if participation.post %}#{{ participation.post.id_post }}{% endif %}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-primary" href="{{ path('app_participation_show', { id_participation: participation.id_participation }) }}"><i class="ti ti-eye"></i></a>
                        <a class="btn btn-sm btn-warning" href="{{ path('app_participation_edit', { id_participation: participation.id_participation }) }}"><i class="ti ti-edit"></i></a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
