{% extends 'base.html.twig' %}

{% block title %}Modifier la notification{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Modifier la notification</h1>
    <div class="card shadow-sm">
        <div class="card-body p-4">
            {{ include('notification/_form.html.twig', { cancel_path: path('app_notification_index'), submit_label: 'Mettre à jour' }) }}
        </div>
    </div>
    <div class="mt-3">{{ include('notification/_delete_form.html.twig') }}</div>
</div>
{% endblock %}
