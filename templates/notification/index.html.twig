{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Notifications</h1>
        <a class="btn btn-primary" href="{{ path('app_notification_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle table-vcenter">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Titre</th>
                    <th>Message</th>
                    <th>Création</th>
                    <th>Lu</th>
                    <th>Post</th>
                    <th class="text-end text-nowrap" style="width: 1%;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for notification in notifications %}
                <tr>
                    <td>{{ notification.idNotification }}</td>
                    <td>{{ notification.userId }}</td>
                    <td>{{ notification.titre }}</td>
                    <td>{{ notification.message|length > 50 ? notification.message|slice(0, 50) ~ '…' : notification.message }}</td>
                    <td>{{ notification.dateCreation ? notification.dateCreation|date('Y-m-d H:i') : '' }}</td>
                    <td>{{ notification.isRead ? 'Oui' : 'Non' }}</td>
                    <td>{% if notification.post %}#{{ notification.post.idPost }}{% else %}—{% endif %}</td>
                    <td class="text-end text-nowrap">
                        <div class="d-inline-flex align-items-center justify-content-end gap-1">
                            <a class="btn btn-sm btn-primary btn-icon" href="{{ path('app_notification_show', { id_notification: notification.idNotification }) }}" title="Voir"><i class="ti ti-eye"></i></a>
                            <a class="btn btn-sm btn-warning btn-icon" href="{{ path('app_notification_edit', { id_notification: notification.idNotification }) }}" title="Modifier"><i class="ti ti-edit"></i></a>
                            <form class="d-inline" method="post" action="{{ path('app_notification_delete', { id_notification: notification.idNotification }) }}" onsubmit="return confirm('Supprimer cette notification ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ notification.idNotification) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger btn-icon" title="Supprimer"><i class="ti ti-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
