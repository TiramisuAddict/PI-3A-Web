{% extends 'base.html.twig' %}

{% block title %}Notifications — Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Notifications</h2>
                </div>
                <div class="col-auto">
                    <a class="btn btn-primary" href="{{ path('app_notification_new') }}"><i class="ti ti-plus me-1"></i>Créer une notification</a>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th>Titre</th>
                                <th>Lu</th>
                                <th>Date de création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for notification in notifications %}
                            <tr>
                                <td>{{ notification.titre|length > 40 ? notification.titre|slice(0, 40) ~ '…' : notification.titre }}</td>
                                <td><span class="badge {% if notification.isRead %}bg-green-lt text-green{% else %}bg-secondary-lt text-secondary{% endif %}">{{ notification.isRead ? 'Oui' : 'Non' }}</span></td>
                                <td class="text-secondary small">{{ notification.dateCreation ? notification.dateCreation|date('d/m/Y H:i') : '—' }}</td>
                                <td class="text-end text-nowrap">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <a href="{{ path('app_notification_show', { id_notification: notification.idNotification }) }}" class="btn btn-icon btn-ghost-primary" title="Voir"><i class="ti ti-eye" style="font-size: 1.25rem;"></i></a>
                                        <a href="{{ path('app_notification_edit', { id_notification: notification.idNotification }) }}" class="btn btn-icon btn-ghost-warning" title="Modifier"><i class="ti ti-edit" style="font-size: 1.25rem;"></i></a>
                                        <form class="d-inline" method="post" action="{{ path('app_notification_delete', { id_notification: notification.idNotification }) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette notification ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ notification.idNotification) }}">
                                            <button type="submit" class="btn btn-icon btn-ghost-danger" title="Supprimer"><i class="ti ti-trash" style="font-size: 1.25rem;"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <div class="empty">
                                        <div class="empty-header">404</div>
                                        <div class="empty-title">Aucune notification trouvée</div>
                                        <div class="empty-subtitle text-secondary">Créez une nouvelle notification pour commencer.</div>
                                        <div class="empty-action">
                                            <a href="{{ path('app_notification_new') }}" class="btn btn-primary"><i class="ti ti-plus me-1"></i>Créer une notification</a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
