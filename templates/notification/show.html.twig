{% extends 'base.html.twig' %}

{% block title %}{{ notification.titre }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">{{ notification.titre }}</h1>
    <div class="card border shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">ID</th><td>{{ notification.idNotification }}</td></tr>
                        <tr><th>User ID</th><td>{{ notification.userId }}</td></tr>
                        <tr><th>Titre</th><td>{{ notification.titre }}</td></tr>
                        <tr><th>Message</th><td class="text-break">{{ notification.message }}</td></tr>
                        <tr><th>Date création</th><td>{{ notification.dateCreation ? notification.dateCreation|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>Lu</th><td>{{ notification.isRead ? 'Oui' : 'Non' }}</td></tr>
                        <tr><th>Post</th><td>{% if notification.post %}#{{ notification.post.idPost }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_notification_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_notification_edit', { id_notification: notification.idNotification }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('notification/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
