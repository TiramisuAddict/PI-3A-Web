{% extends 'base.html.twig' %}

{% block title %}{{ notification.titre|truncate(50) }} — Momentum{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">{{ notification.titre }}</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <div class="card">
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label text-secondary small">Titre</label>
                            <p class="mb-0"><strong>{{ notification.titre }}</strong></p>
                        </div>

                        <div class="col-12">
                            <label class="form-label text-secondary small">Message</label>
                            <p class="mb-0 text-break">{{ notification.message }}</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Lu</label>
                            <p class="mb-0"><span class="badge {% if notification.isRead %}bg-green-lt text-green{% else %}bg-secondary-lt text-secondary{% endif %}">{{ notification.isRead ? 'Oui' : 'Non' }}</span></p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Date de création</label>
                            <p class="mb-0">{{ notification.dateCreation ? notification.dateCreation|date('d/m/Y H:i') : '—' }}</p>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Post associé</label>
                            <p class="mb-0">
                                {% if notification.post %}
                                    <a href="{{ path('app_post_show', {id_post: notification.post.idPost}) }}" class="btn btn-ghost-primary">{{ notification.post.titre|length > 40 ? notification.post.titre|slice(0, 40) ~ '…' : notification.post.titre }}</a>
                                {% else %}
                                    —
                                {% endif %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-primary" href="{{ path('app_notification_index') }}"><i class="ti ti-list me-1"></i>Retour à la liste</a>
                <a class="btn btn-warning" href="{{ path('app_notification_edit', { id_notification: notification.idNotification }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
                {{ include('notification/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
