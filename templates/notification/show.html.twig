{% extends 'base.html.twig' %}

{% block title %}{{ notification.titre }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">{{ notification.titre }}</h1>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">id_notification</th><td>{{ notification.id_notification }}</td></tr>
                        <tr><th>user_id</th><td>{{ notification.user_id }}</td></tr>
                        <tr><th>titre</th><td>{{ notification.titre }}</td></tr>
                        <tr><th>message</th><td class="text-break">{{ notification.message }}</td></tr>
                        <tr><th>date_creation</th><td>{{ notification.date_creation ? notification.date_creation|date('Y-m-d H:i:s') : '' }}</td></tr>
                        <tr><th>is_read</th><td>{{ notification.isRead ? 'Oui' : 'Non' }}</td></tr>
                        <tr><th>post (id_post)</th><td>{% if notification.post %}{{ notification.post.id_post }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_notification_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_notification_edit', { id_notification: notification.id_notification }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('notification/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
