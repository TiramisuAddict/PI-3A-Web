{% extends 'base.html.twig' %}

{% block title %}Panneau d'administration{% endblock %}

{% block body %}
<div class="d-flex overflow-hidden" style="height:100vh;">

  {# ── Sidebar ── #}
  <aside class="d-flex flex-column border-end bg-white px-2 py-3" style="width:220px; min-width:220px; overflow-y:auto;">

    <div class="px-3 mb-4 mt-2">
      <img src="/images/WKlogo.svg" height="24" alt="Logo">
    </div>

    <ul class="list-unstyled d-flex flex-column gap-1 mb-0 flex-fill">

      <li>
        <a href="{{ path('admin_dashboard') }}" class="d-flex align-items-center gap-2 px-3 py-2 rounded text-secondary text-decoration-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><polyline points="5 12 3 12 12 3 21 12 19 12"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/></svg>
          <span style="font-size:0.875rem;">Accueil</span>
        </a>
      </li>

      <li>
        <a href="{{ path('admin_dashboard') }}" class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium bg-blue-lt text-blue">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21h-10a2 2 0 0 1-2-2v-14a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z"/></svg>
          <span style="font-size:0.875rem;">Demandes</span>
        </a>
      </li>

    </ul>

    <div class="px-2 pb-2 mt-auto">
      <a href="#" class="d-flex align-items-center gap-2 px-3 py-2 rounded text-secondary text-decoration-none"
        data-bs-toggle="modal" data-bs-target="#logoutModal">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-sm" width="18" height="18" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 8v-2a2 2 0 0 0-2-2h-7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2-2v-2"/><path d="M7 12h14l-3-3m0 6l3-3"/></svg>
        <span style="font-size:0.875rem;">Se déconnecter</span>
      </a>
    </div>

  </aside>

  {# ── Modal déconnexion ── #}
  <div class="modal" id="logoutModal" tabindex="-1">
    <div class="modal-dialog modal-sm" role="document">
      <div class="modal-content">
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        <div class="modal-status bg-danger"></div>
        <div class="modal-body text-center py-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon mb-2 text-danger icon-lg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 9v2m0 4v.01"/><path d="M5 19h14a2 2 0 0 0 1.84-2.75l-7.1-12.25a2 2 0 0 0-3.5 0l-7.1 12.25a2 2 0 0 0 1.75 2.75"/></svg>
          <h3>Déconnexion</h3>
          <div class="text-secondary">Êtes-vous sûr de vouloir vous déconnecter ?</div>
        </div>
        <div class="modal-footer">
          <div class="w-100">
            <div class="row">
              <div class="col"><button class="btn w-100" data-bs-dismiss="modal">Annuler</button></div>
              <div class="col"><a href="{{ path('logout') }}" class="btn btn-danger w-100">Se déconnecter</a></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ── Contenu principal ── #}
  <div class="flex-fill overflow-y-auto p-4" style="background:#F6F7FF; min-width:0;">

    {% for label, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ label == 'error' ? 'danger' : label }}" role="alert">{{ message }}</div>
      {% endfor %}
    {% endfor %}

    <div class="page-header mb-3">
      <div class="row align-items-center">
        <div class="col">
          <h2 class="page-title">Demandes compte entreprise</h2>
          <div class="text-muted mt-1">Gérez et traitez les demandes d'inscription</div>
        </div>
      </div>
    </div>

    {% if entreprises is defined %}

      {% set total   = entreprises|length %}
      {% set accepte = 0 %}
      {% set refuse  = 0 %}
      {% set attente = 0 %}
      {% for e in entreprises %}
        {% if e.statut == 'acceptée'   %}{% set accepte = accepte + 1 %}{% endif %}
        {% if e.statut == 'refusée'    %}{% set refuse  = refuse  + 1 %}{% endif %}
        {% if e.statut == 'en attente' %}{% set attente = attente + 1 %}{% endif %}
      {% endfor %}

      {# Stat cards #}
      <div class="row g-4 mb-4">
        <div class="col-sm-6 col-xl-2">
          <div class="card">
            <div class="card-body">
              <div class="text-muted text-blue">Total demandes</div>
              <div class="h2 mb-1">{{ total }}</div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-2">
          <div class="card">
            <div class="card-body">
              <div class="text-muted text-green">Acceptées</div>
              <div class="h2 mb-1">{{ accepte }}</div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-2">
          <div class="card">
            <div class="card-body">
              <div class="text-muted text-red">Refusées</div>
              <div class="h2 mb-1">{{ refuse }}</div>
            </div>
          </div>
        </div>
        <div class="col-sm-6 col-xl-2">
          <div class="card">
            <div class="card-body">
              <div class="text-muted text-yellow">En attente</div>
              <div class="h2 mb-1">{{ attente }}</div>
            </div>
          </div>
        </div>
      </div>

      {# Filtres #}
      <form method="GET" class="d-flex gap-2 mb-4">
        <input type="text" name="search" class="form-control"
          placeholder="Rechercher par nom d'entreprise..."
          value="{{ app.request.query.get('search') }}">
        <select name="status" class="form-select" onchange="this.form.submit()">
          <option value="">Tous les statuts</option>
          <option value="en attente" {% if app.request.query.get('status') == 'en attente' %}selected{% endif %}>En attente</option>
          <option value="acceptée"   {% if app.request.query.get('status') == 'acceptée'   %}selected{% endif %}>Acceptée</option>
          <option value="refusée"    {% if app.request.query.get('status') == 'refusée'    %}selected{% endif %}>Refusée</option>
        </select>
      </form>

      {# Tableau #}
      <div class="card" id="tableCard">
        <div class="table-responsive" id="tableWrapper">
          <table class="table table-vcenter" id="entrepriseTable">
            <thead>
              <tr>
                <th>Entreprise</th>
                <th>Email</th>
                <th>Pays</th>
                <th>Ville</th>
                <th>Contact</th>
                <th>Statut</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="tableBody">
              {% for entreprise in entreprises %}
              <tr data-nom="{{ entreprise.getNomEntreprise()|lower }}" data-statut="{{ entreprise.statut }}">
                <td class="fw-semibold">{{ entreprise.getNomEntreprise() }}</td>
                <td class="text-secondary">{{ entreprise.getEmail() }}</td>
                <td class="text-secondary">{{ entreprise.pays }}</td>
                <td class="text-secondary">{{ entreprise.ville }}</td>
                <td>{{ entreprise.prenom }} {{ entreprise.nom }}</td>
                <td>
                  {% if entreprise.statut == 'acceptée' %}
                    <span class="badge bg-success-lt">Acceptée</span>
                  {% elseif entreprise.statut == 'refusée' %}
                    <span class="badge bg-danger-lt">Refusée</span>
                  {% else %}
                    <span class="badge bg-warning-lt">En attente</span>
                  {% endif %}
                </td>
                <td class="text-end">
                  {% if entreprise.statut == 'en attente' %}
                    <form method="post" class="d-inline">
                      <input type="hidden" name="id_entreprise" value="{{ entreprise.id_entreprise }}">
                      <button type="submit" name="action" value="accepter" class="btn btn-sm btn-success">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><polyline points="20 6 9 17 4 12"/></svg>
                        Accepter
                      </button>
                    </form>
                    <form method="post" class="d-inline ms-1">
                      <input type="hidden" name="id_entreprise" value="{{ entreprise.id_entreprise }}">
                      <button type="submit" name="action" value="refuser" class="btn btn-sm btn-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        Refuser
                      </button>
                    </form>
                  {% else %}
                    <button class="btn btn-sm btn-success disabled" disabled>Accepter</button>
                    <button class="btn btn-sm btn-danger disabled ms-1" disabled>Refuser</button>
                  {% endif %}
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div id="emptyState" class="empty d-none">
          <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="12" r="9"/><line x1="9" y1="10" x2="9.01" y2="10"/><line x1="15" y1="10" x2="15.01" y2="10"/><path d="M9.5 15.25a3.5 3.5 0 0 1 5 0"/></svg>
          </div>
          <p class="empty-title">Aucun résultat trouvé</p>
          <p class="empty-subtitle text-secondary">Essayez de modifier votre recherche ou filtre.</p>
          <div class="empty-action">
            <a href="{{ path('admin_dashboard') }}" class="btn btn-primary">Réinitialiser</a>
          </div>
        </div>

      </div>

    {% endif %}

  </div>
</div>

{% endblock %}