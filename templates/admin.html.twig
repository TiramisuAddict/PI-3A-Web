{% extends 'base.html.twig' %}

{% block title %}Panneau d'administration{% endblock %}

{% block body %}
<div class="page" style="background-color: azure;">

  <!-- Navbar horizontale -->
  <header class="navbar navbar-expand-lg navbar-light d-print-none sticky-top" style="background-color: #ffffff; border-bottom: 1px solid #e6e7e9;">
  <div class="container-fluid">
    <h1 class="navbar-brand pe-0 pe-md-3 mb-0">
        <a href="#">
          <img src="/images/WKlogo.svg" width="110" height="32" alt="Tabler">
        </a>
      </h1>

      <div class="navbar-nav flex-row order-md-last">
        <div class="nav-item">
          <a href="#" class="nav-link d-flex lh-1 text-reset p-0">
            <span class="avatar avatar-sm"
              style="background-image: url(/static/avatars/002m.jpg)">
            </span>
            <div class="d-none d-xl-block ps-2">
              <div>Paweł Kuna</div>
              <div class="mt-1 small text-secondary">UI Designer</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Layout horizontal -->
  <div class="page-wrapper">
  <div class="container-fluid">
    <div class="row">

      <!-- Sidebar -->
      <aside class="col-md-2 bg-white border-end px-0" style="min-height: calc(100vh - 60px);">
        <ul class="navbar-nav flex-column pt-3 px-3">
          <li class="nav-item">
            <a class="nav-link" href="./">
              <span class="nav-link-title">Acceuil</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#">
              <span class="nav-link-title">Demandes</span>
            </a>
          </li>
   </ul>
      </aside>

      <!-- Contenu principal -->
      <main class="col-md-10 px-4 py-3" style="background-color: azure;">
        <div class="row row-deck row-cards">
            <div class="card">
              <div class="card-body" style="height: 100%">
              <div class="row g-2 align-items-center">
          <div class="col">
            <h2 class="page-title" style="margin-top: 20px;">Les demandes compte entreprise</h2>
          </div>
        </div>
        {% if entreprises is defined and entreprises|length > 0 %}
        {% set total = entreprises|length %}
        {% set accepte = 0 %}
        {% set refuse = 0 %}
        {% set attente = 0 %}
        {% for entreprise in entreprises %}
          {% if entreprise.statut == 'acceptée' %}
            {% set accepte = accepte + 1 %}
          {% endif %}
          {% if entreprise.statut == 'refusée' %}
            {% set refuse = refuse + 1 %}
          {% endif %}
          {% if entreprise.statut == 'en attente' %}
            {% set attente = attente + 1 %}
          {% endif %}
        {% endfor %}
        <div class="row mb-3" style="margin-top: 50px;">
          <div class="col-md-3">
            <div class="card">
              <div class="card-body text-center">
                <h3 data-countup>{{ total }}</h3>
                <p>Total demandes</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card">
              <div class="card-body text-center">
                <h3 data-countup>{{ accepte }}</h3>
                <p>Demandes acceptées</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card">
              <div class="card-body text-center">
                <h3 data-countup>{{ refuse }}</h3>
                <p>Demandes refusées</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card">
              <div class="card-body text-center">
                <h3 data-countup='{"duration":4}'>{{ attente }}</h3>
                <p>Demandes en attente</p>
              </div>
            </div>
          </div>
        </div>
        <div class="row mb-3" style="margin-top: 30px;">
          <form method="get" class="d-flex">
            <div class="col-md-6 me-2">
              <input type="text" name="search" class="form-control" placeholder="Rechercher par nom entreprise..." value="{{ app.request.query.get('search') }}">
            </div>
            <div class="col-md-4 me-2">
              <select name="status" class="form-select">
                <option value="">Tous les statuts</option>
                <option value="en attente" {% if app.request.query.get('status') == 'en attente' %}selected{% endif %}>En attente</option>
                <option value="acceptée" {% if app.request.query.get('status') == 'acceptée' %}selected{% endif %}>Acceptée</option>
                <option value="refusée" {% if app.request.query.get('status') == 'refusée' %}selected{% endif %}>Refusée</option>
              </select>
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary">Filtrer</button>
            </div>
          </form>
        </div>
            <div class="table-responsive" style="margin-top: 50px;">
                <table class="table table-vcenter">
                <thead>
     <tr>
                <th>Nom entreprise</th>
                <th>Email</th>
                <th>Pays</th>
                <th>Ville</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Statut</th>
                <th></th>
            </tr>
    </thead>
    <tbody>
    {% for entreprise in entreprises %}
      <tr>
        <td class="text-secondary">{{ entreprise.nom_entreprise }}</td>
        <td class="text-secondary">{{ entreprise.e_mail }}</td>
        <td class="text-secondary">{{ entreprise.pays }}</td>
        <td class="text-secondary">{{ entreprise.ville }}</td>
        <td class="text-secondary">{{ entreprise.nom }}</td>
        <td class="text-secondary">{{ entreprise.prenom }}</td>
        <td class="text-secondary">{{ entreprise.statut }}</td>

        <td >
          {% if entreprise.statut == 'en attente' %}
                            <form method="post" style="display:inline;">
                                <input type="hidden" name="id_entreprise" value="{{ entreprise.id_entreprise }}">
                                <button type="submit" name="action" value="accepter" class="btn btn-success">Accépter</button>
                            </form>
                            <form method="post" style="display:inline;">
                                <input type="hidden" name="id_entreprise" value="{{ entreprise.id_entreprise }}">
                                <button type="submit" name="action" value="refuser" class="btn btn-danger">Refuser</button>
                            </form>
                        {% else %}
                            <a href="#" class="btn btn-success disabled">Success</a>
                            <a href="#" class="btn btn-danger disabled">Refuser</a>
                           
           {% endif %}
        </td>
      </tr>
      {% endfor %}
      {% endif %}
    </tbody>
  </table>
                </div>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</div>
{% endblock %}