<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{{ actionLabel }}</title>
</head>
<body style="margin:0; padding:0; background:#f2f4f8; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color:#1f2937;">
    {% set isCanceled = event == 'canceled' %}
    {% set headerGradient = isCanceled ? 'linear-gradient(135deg,#e03131,#d94841)' : 'linear-gradient(135deg,#375a7f,#339af0)' %}
    {% set panelBorder = isCanceled ? '#ef4444' : '#3b82f6' %}
    {% set panelBg = isCanceled ? '#fef2f2' : '#eff6ff' %}
    {% set panelText = isCanceled ? '#b91c1c' : '#1d4ed8' %}

    {% set prioriteBg = '#e8f0fe' %}
    {% set prioriteColor = '#2859c5' %}
    {% if (demande.priorite ?: '') in ['HAUTE', 'Haute'] %}
        {% set prioriteBg = '#fdeaea' %}
        {% set prioriteColor = '#c0392b' %}
    {% elseif (demande.priorite ?: '') in ['BASSE', 'Basse'] %}
        {% set prioriteBg = '#eef2f7' %}
        {% set prioriteColor = '#475569' %}
    {% endif %}

    {% set statusBg = '#e8f0fe' %}
    {% set statusColor = '#2859c5' %}
    {% if demande.status in ['Annulee', 'Rejetee'] %}
        {% set statusBg = '#fdeaea' %}
        {% set statusColor = '#c0392b' %}
    {% elseif demande.status in ['En cours', 'Resolue'] %}
        {% set statusBg = '#eaf8ef' %}
        {% set statusColor = '#1f8c4b' %}
    {% endif %}

    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="padding:28px 12px; background:#f2f4f8;">
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" width="640" style="max-width:640px; width:100%; background:#ffffff; border-radius:14px; overflow:hidden; border:1px solid #e5e7eb; box-shadow:0 6px 20px rgba(31,41,55,0.08);">
                    <tr>
                        <td style="padding:24px 28px; background:{{ headerGradient }}; color:#ffffff; text-align:center;">
                            <h1 style="margin:0; font-size:31px; font-weight:700; line-height:1.2;">{{ actionLabel }}</h1>
                            <p style="margin:8px 0 0; opacity:.95; font-size:14px;">Notification automatique</p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:28px;">
                            <div style="padding:14px; background:{{ panelBg }}; border-left:4px solid {{ panelBorder }}; border-radius:10px; margin:0 0 18px;">
                                <strong style="display:block; color:{{ panelText }}; font-size:15px; margin-bottom:6px;">
                                    {{ isCanceled ? 'Information importante' : 'Nouvelle demande soumise' }}
                                </strong>
                                <span style="color:#4b5563; font-size:14px;">
                                    {% if isCanceled %}
                                        Un employe a annule sa demande avant traitement.
                                    {% else %}
                                        Une nouvelle demande a ete soumise par {{ (demande.employe.prenom ?? '') ~ ' ' ~ (demande.employe.nom ?? '')|trim ?: 'un employe' }}.
                                    {% endif %}
                                </span>
                            </div>

                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; background:#ffffff; margin:0 0 16px;">
                                <tr>
                                    <td style="padding:12px 14px; font-size:15px; color:#6b7280; border-bottom:1px solid #eef2f7; width:34%;">Titre</td>
                                    <td style="padding:12px 14px; font-size:15px; color:#111827; border-bottom:1px solid #eef2f7; font-weight:600;">{{ demande.titre ?: 'Non renseigne' }}</td>
                                </tr>
                                <tr>
                                    <td style="padding:12px 14px; font-size:15px; color:#6b7280; border-bottom:1px solid #eef2f7;">Type</td>
                                    <td style="padding:12px 14px; font-size:15px; color:#111827; border-bottom:1px solid #eef2f7;">{{ demande.typeDemande ?: 'Non renseigne' }}</td>
                                </tr>
                                <tr>
                                    <td style="padding:12px 14px; font-size:15px; color:#6b7280; border-bottom:1px solid #eef2f7;">Priorite</td>
                                    <td style="padding:12px 14px; border-bottom:1px solid #eef2f7;">
                                        <span style="display:inline-block; padding:7px 12px; border-radius:999px; font-size:13px; font-weight:700; background:{{ prioriteBg }}; color:{{ prioriteColor }};">{{ demande.priorite ?: 'Non renseignee' }}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:12px 14px; font-size:15px; color:#6b7280; border-bottom:1px solid #eef2f7;">Statut</td>
                                    <td style="padding:12px 14px; border-bottom:1px solid #eef2f7;">
                                        <span style="display:inline-block; padding:7px 12px; border-radius:999px; font-size:13px; font-weight:700; background:{{ statusBg }}; color:{{ statusColor }};">{{ demande.status ?: 'Non renseigne' }}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:12px 14px; font-size:15px; color:#6b7280;">Email employe</td>
                                    <td style="padding:12px 14px; font-size:15px;">
                                        <a href="mailto:{{ ownerEmail }}" style="color:#2563eb; text-decoration:none;">{{ ownerEmail ?: 'Non renseigne' }}</a>
                                    </td>
                                </tr>
                            </table>

                            <div style="padding:14px; text-align:center; background:#f3f6fb; border-radius:10px; color:#4b5563; font-size:14px;">
                                Connectez-vous a l'application pour consulter et traiter cette demande.
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding:16px 22px; text-align:center; background:#f8fafc; color:#9ca3af; font-size:13px; border-top:1px solid #e5e7eb;">
                            Momentum - Systeme RH | {{ 'now'|date('d/m/Y H:i') }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
