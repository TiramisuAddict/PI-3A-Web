<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Certificat de Formation</title>
    <style>
        @page {
            margin: 20mm;
        }

        body {
            font-family: DejaVu Sans, sans-serif;
            color: #1f2937;
            border: 2px solid #0d6efd;
            padding: 28px;
            position: relative;
        }

        .title {
            text-align: center;
            font-size: 36px;
            font-weight: bold;
            color: #0d6efd;
            margin-top: 10px;
            margin-bottom: 12px;
            letter-spacing: 1px;
        }

        .subtitle {
            text-align: center;
            font-size: 18px;
            margin-bottom: 28px;
            color: #334155;
        }

        .content {
            text-align: center;
            font-size: 20px;
            line-height: 1.6;
            margin: 20px 0;
        }

        .name {
            display: block;
            font-size: 34px;
            font-weight: bold;
            color: #111827;
            margin: 18px 0;
        }

        .formation {
            display: block;
            font-size: 28px;
            font-weight: bold;
            color: #0f766e;
            margin: 14px 0;
        }

        .footer {
            margin-top: 48px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            font-size: 14px;
            color: #475569;
        }

        .signature {
            text-align: right;
        }

        .line {
            width: 220px;
            border-top: 1px solid #475569;
            margin-top: 42px;
            margin-left: auto;
            margin-bottom: 6px;
        }
    </style>
</head>
<body>
    <div class="title">CERTIFICAT DE FORMATION</div>
    <div class="subtitle">Attestation officielle de participation et de reussite</div>

    <div class="content">
        Ceci certifie que
        <span class="name">{{ employee_name }}</span>
        a complete avec succes la formation
        <span class="formation">{{ formation.titre }}</span>
        organisee par <strong>{{ formation.organisme }}</strong><br>
        du {{ formation.dateDebut ? formation.dateDebut|date('d/m/Y') : '-' }} au {{ formation.dateFin ? formation.dateFin|date('d/m/Y') : '-' }}.
    </div>

    <div class="footer">
        <div>
            Date de delivrance: {{ issued_at|date('d/m/Y') }}
        </div>
        <div class="signature">
            <div class="line"></div>
            Responsable formation
        </div>
    </div>
</body>
</html>
