{% extends 'base.html.twig' %}

{% block title %}Inscription Employe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dashboard-inscription {
            background: #f5f7fb;
            min-height: 100vh;
            padding: 1.25rem 0 2rem;
        }

        .inscription-shell {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 .75rem;
        }

        .inscription-hero {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 10px;
            background: #fff;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

        .surface-card {
            border: 1px solid rgba(15, 23, 42, 0.08);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
        }

        .surface-card .card-header {
            padding: 1rem 1.25rem;
            background: #fff;
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        }

        .surface-card .card-title {
            margin: 0;
            font-size: 1.02rem;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: .01em;
        }

        .filter-toolbar {
            background: #fff;
            padding: 1rem 1.25rem;
        }

        .filter-toolbar .form-label {
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #64748b;
            margin-bottom: .35rem;
        }

        .rating-pill {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            border-radius: 999px;
            padding: .2rem .55rem;
            font-size: .78rem;
            background: rgba(13, 110, 253, 0.10);
            color: #0d6efd;
            font-weight: 700;
        }

        .rating-pill .ti {
            font-size: .85rem;
        }

        .table-clean thead th {
            background: rgba(248, 250, 255, 0.95);
            color: #64748b;
            font-size: .74rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            border-bottom: 1px solid rgba(228, 233, 242, 0.95);
        }

        .table-clean tbody td {
            vertical-align: middle;
        }

        .table-clean tbody tr:hover {
            background: rgba(13, 110, 253, 0.02);
        }

        .section-spacer {
            padding: 1.25rem 1.25rem 0;
        }

        .employee-table .btn {
            min-width: 6.2rem;
        }

        .status-badge {
            font-weight: 700;
            letter-spacing: .01em;
        }

        .status-badge.pending {
            background: #f59e0b;
            color: #fff;
        }

        .status-badge.accepted {
            background: #16a34a;
            color: #fff;
        }

        .status-badge.refused {
            background: #dc2626;
            color: #fff;
        }

        .review-count-badge {
            min-width: 1.5rem;
        }

        .formation-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1rem;
            padding: 1rem 1.25rem 1.25rem;
        }

        .formation-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .9rem;
        }

        .formation-item {
            border: 1px solid rgba(15, 23, 42, 0.1);
            border-radius: 10px;
            background: #fff;
            padding: .9rem;
            box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
            transition: transform .15s ease, box-shadow .15s ease;
        }

        .formation-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
            border-color: rgba(31, 111, 235, 0.32);
        }

        .formation-item.is-selected {
            border-color: rgba(31, 111, 235, 0.65);
            box-shadow: 0 0 0 1px rgba(31, 111, 235, 0.25);
        }

        .formation-meta {
            font-size: .78rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .formation-score {
            display: flex;
            align-items: center;
            gap: .45rem;
            margin-bottom: .55rem;
        }

        .score-pill {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            border-radius: 999px;
            padding: .2rem .55rem;
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .01em;
        }

        .score-pill.rating {
            color: #0b57d0;
            background: rgba(13, 110, 253, 0.14);
        }

        .score-pill.rating::before {
            content: '★';
            font-size: .82rem;
            line-height: 1;
        }

        .score-pill.reviews {
            color: #0f766e;
            background: rgba(13, 148, 136, 0.13);
        }

        .score-pill.reviews::before {
            content: '👤';
            font-size: .8rem;
            line-height: 1;
        }

        .score-pill.empty {
            color: #64748b;
            background: rgba(148, 163, 184, 0.15);
        }

        .formation-item h4 {
            margin: .2rem 0 .45rem;
            font-size: 1.08rem;
            line-height: 1.25;
            color: #0f172a;
        }

        .formation-item .formation-dates {
            font-size: .86rem;
            color: #475569;
            margin-bottom: .45rem;
        }

        .formation-item .formation-note {
            border-top: 1px dashed #c9d5e7;
            margin-top: .55rem;
            padding-top: .55rem;
        }

        .formation-sidepanel {
            border: 1px solid rgba(15, 23, 42, 0.1);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            height: fit-content;
            position: sticky;
            top: 5.75rem;
        }

        .formation-sidepanel-header {
            padding: .9rem 1rem;
            border-bottom: 1px solid rgba(15, 23, 42, 0.08);
            background: rgba(31, 111, 235, 0.07);
        }

        .formation-sidepanel-body {
            padding: .9rem 1rem;
        }

        .formation-no-results {
            grid-column: 1 / -1;
            margin-bottom: 0;
        }

        @media (max-width: 991.98px) {
            .formation-layout {
                grid-template-columns: 1fr;
            }

            .formation-grid {
                grid-template-columns: 1fr;
            }

            .formation-sidepanel {
                position: static;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-inscription">
     {{ include('components/navbar.html.twig') }}
    <div class="d-flex" style="min-height:calc(100vh - 56px);">
        {{ include('components/sidebar.html.twig', {'active_page': 'formations','sidebar_role': role}) }}
 
    <div class="inscription-shell">
    <div class="inscription-hero">
        <div class="row align-items-center g-4 position-relative">
            <div class="col-lg-8">
                <div class="text-secondary text-uppercase small fw-bold mb-2">Espace Employe</div>
                <h2 class="h2 mb-2">Inscription formation</h2>
                <p class="text-secondary mb-0">Consultez les formations, lisez les avis et envoyez vos demandes dans une interface claire et uniforme.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                {% if employee_logged %}
                    <div class="stat-card p-3 d-inline-flex flex-column align-items-end">
                        <span class="mini-muted">Connecte en tant que</span>
                        <div class="fw-bold">{{ app.session.get('employe_email') }}</div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ message }}</div>
    {% endfor %}

    <div class="surface-card mb-3">
        <div class="card-header">
            <h3 class="card-title">Formations disponibles</h3>
        </div>
        <div class="card-body border-bottom filter-toolbar">
            <form method="get" action="{{ path('app_inscription_employe') }}" class="row g-3 align-items-end" id="formation-filter-form">
                <input type="hidden" name="formation" value="{{ selected_formation ? selected_formation.id : '' }}">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label" for="q">Recherche</label>
                    <div class="input-icon">
                        <span class="input-icon-addon"><i class="ti ti-search"></i></span>
                        <input id="q" name="q" class="form-control" type="text" value="{{ q|default('') }}" placeholder="Titre, organisme, lieu...">
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label" for="sort">Tri</label>
                    <select id="sort" name="sort" class="form-select">
                        <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Plus recentes</option>
                        <option value="rating_desc" {{ sort == 'rating_desc' ? 'selected' : '' }}>Meilleure note</option>
                        <option value="reviews_desc" {{ sort == 'reviews_desc' ? 'selected' : '' }}>Plus d'avis</option>
                        <option value="title_asc" {{ sort == 'title_asc' ? 'selected' : '' }}>Titre A-Z</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="min_rating">Note minimale</label>
                    <select id="min_rating" name="min_rating" class="form-select">
                        <option value="0" {{ min_rating == 0 ? 'selected' : '' }}>Toutes</option>
                        <option value="1" {{ min_rating == 1 ? 'selected' : '' }}>1+</option>
                        <option value="2" {{ min_rating == 2 ? 'selected' : '' }}>2+</option>
                        <option value="3" {{ min_rating == 3 ? 'selected' : '' }}>3+</option>
                        <option value="4" {{ min_rating == 4 ? 'selected' : '' }}>4+</option>
                        <option value="5" {{ min_rating == 5 ? 'selected' : '' }}>5</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-6">
                    <label class="form-label" for="min_reviews">Avis minimum</label>
                    <input id="min_reviews" name="min_reviews" class="form-control" type="number" min="0" value="{{ min_reviews }}">
                </div>
            </form>
        </div>
        <div class="formation-layout">
            <div>
                <div class="formation-grid">
                    {% for formation in formations %}
                        {% set state = inscription_by_formation[formation.id] ?? null %}
                        {% set reviews = review_stats_by_formation[formation.id] ?? {'reviews_count': 0, 'average_note': 0} %}
                        {% set formationQuery = app.request.query.all|merge({'formation': formation.id}) %}
                        <article
                            class="formation-item {{ selected_formation and selected_formation.id == formation.id ? 'is-selected' : '' }}"
                            data-formation-id="{{ formation.id }}"
                            data-title="{{ formation.titre }}"
                            data-organisme="{{ formation.organisme }}"
                            data-lieu="{{ formation.lieu }}"
                            data-date-debut="{{ formation.dateDebut ? formation.dateDebut|date('Y-m-d') : '' }}"
                            data-rating="{{ reviews.average_note|default(0) }}"
                            data-reviews="{{ reviews.reviews_count|default(0) }}"
                        >
                            <div class="formation-score">
                                {% if reviews.reviews_count > 0 %}
                                    <span class="score-pill rating">{{ reviews.average_note }}/5</span>
                                    <span class="score-pill reviews">{{ reviews.reviews_count }} avis</span>
                                {% else %}
                                    <span class="score-pill empty"><i class="ti ti-sparkles"></i>Pas encore d'avis</span>
                                {% endif %}
                            </div>

                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div class="formation-meta">{{ formation.dateDebut ? formation.dateDebut|date('d M Y') : '' }}</div>
                                {% if state and state.statut == 'EN_ATTENTE' %}
                                    <span class="badge status-badge pending">En attente</span>
                                {% elseif state and state.statut == 'ACCEPTEE' %}
                                    <span class="badge status-badge accepted">Acceptee</span>
                                {% elseif state and state.statut == 'REFUSEE' %}
                                    <span class="badge status-badge refused">Refusee</span>
                                {% else %}
                                    <span class="badge bg-azure-lt text-azure">Disponible</span>
                                {% endif %}
                            </div>

                            <h4>{{ formation.titre }}</h4>
                            <div class="mini-muted mb-2">{{ formation.organisme }}</div>
                            <div class="formation-dates">{{ formation.dateDebut ? formation.dateDebut|date('Y-m-d') : '' }} - {{ formation.dateFin ? formation.dateFin|date('Y-m-d') : '' }}</div>

                            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                                <span class="badge bg-secondary-lt text-secondary">{{ formation.lieu }}</span>
                                <span class="badge bg-indigo-lt text-indigo">Capacite {{ formation.capacite }}</span>
                            </div>

                            <div class="formation-note">
                                {% if employee_logged %}
                                    {% if state and state.statut == 'EN_ATTENTE' %}
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_inscription_employe', formationQuery) }}">Modifier raison</a>
                                            <form method="post" action="{{ path('app_inscription_employe') }}">
                                                <input type="hidden" name="action" value="annuler">
                                                <input type="hidden" name="inscription_id" value="{{ state.id }}">
                                                <button class="btn btn-sm btn-outline-danger" type="submit">Annuler</button>
                                            </form>
                                        </div>
                                    {% elseif state and state.statut == 'ACCEPTEE' %}
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            <a class="btn btn-sm btn-outline-primary" href="{{ path('app_inscription_employe', formationQuery) }}">Evaluer</a>
                                            {% set existingEvaluation = evaluation_by_formation[formation.id] ?? null %}
                                            {% if existingEvaluation %}
                                                <span class="mini-muted">Note: {{ existingEvaluation.note }}/5</span>
                                            {% endif %}
                                        </div>
                                    {% elseif state and state.statut == 'REFUSEE' %}
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_inscription_employe', formationQuery) }}">Voir details</a>
                                    {% else %}
                                        <a class="btn btn-sm btn-success" href="{{ path('app_inscription_employe', formationQuery) }}">Inscription</a>
                                    {% endif %}
                                {% else %}
                                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_inscription_employe', formationQuery) }}">Voir avis</a>
                                {% endif %}
                            </div>
                        </article>
                    {% else %}
                        <div class="alert alert-secondary mb-0">Aucune formation disponible.</div>
                    {% endfor %}
                </div>
            </div>

            <aside class="formation-sidepanel">
                <div class="formation-sidepanel-header">
                    <div class="mini-muted">Formation selectionnee</div>
                    <div class="fw-bold">{{ selected_formation ? selected_formation.titre : 'Aucune selection' }}</div>
                </div>
                <div class="formation-sidepanel-body">
                    {% if selected_formation %}
                        <div class="mini-muted mb-2">{{ selected_formation.organisme }}</div>
                        <div class="mb-3">{{ selected_formation.dateDebut ? selected_formation.dateDebut|date('Y-m-d') : '' }} - {{ selected_formation.dateFin ? selected_formation.dateFin|date('Y-m-d') : '' }}</div>

                        {% if formation_reviews is not empty %}
                            <div class="stat-card p-3 mb-3">
                                <div class="mini-muted mb-2">Analyse des avis</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <span class="badge bg-green-lt text-green">Positifs: {{ formation_review_summary.positive|default(0) }}</span>
                                    <span class="badge bg-yellow-lt text-yellow">Mitigés: {{ formation_review_summary.neutral|default(0) }}</span>
                                    <span class="badge bg-red-lt text-red">Negatifs: {{ formation_review_summary.negative|default(0) }}</span>
                                    {% if formation_review_summary.problem|default(0) > 0 %}
                                        <span class="badge bg-orange-lt text-orange">Problemes: {{ formation_review_summary.problem }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                {% for review in formation_reviews|slice(0, 4) %}
                                    <div class="stat-card p-2">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <div class="fw-bold small">{{ review.prenom }} {{ review.nom }}</div>
                                            <span class="badge {{ review.analysis.label == 'positive' ? 'bg-green-lt text-green' : (review.analysis.label == 'negative' ? 'bg-red-lt text-red' : 'bg-yellow-lt text-yellow') }}">{{ review.note }}/5</span>
                                        </div>
                                        <div class="small text-secondary">{{ review.commentaire ?: 'Aucun commentaire.' }}</div>
                                        <div class="mt-1">
                                            <span class="badge {{ review.analysis.label == 'positive' ? 'bg-green-lt text-green' : (review.analysis.label == 'negative' ? 'bg-red-lt text-red' : 'bg-yellow-lt text-yellow') }}">
                                                {{ review.analysis.label == 'positive' ? 'Positif' : (review.analysis.label == 'negative' ? 'Negatif' : 'Mitige') }}
                                            </span>
                                            {% if review.analysis.problems is not empty %}
                                                <span class="badge bg-red-lt text-red ms-1">Probleme detecte</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-secondary">Aucun avis pour cette formation.</div>
                        {% endif %}
                    {% else %}
                        <div class="text-secondary">Choisissez une formation pour afficher ses details.</div>
                    {% endif %}
                </div>
            </aside>
        </div>
    </div>

    <script>
        (function () {
            const filterForm = document.getElementById('formation-filter-form');
            if (!filterForm) {
                return;
            }

            const grid = document.querySelector('.formation-grid');
            const cards = Array.from(document.querySelectorAll('.formation-item'));
            const searchInput = filterForm.querySelector('input[name="q"]');
            const sortSelect = filterForm.querySelector('select[name="sort"]');
            const minRatingSelect = filterForm.querySelector('select[name="min_rating"]');
            const minReviewsInput = filterForm.querySelector('input[name="min_reviews"]');
            let noResults = document.getElementById('formation-no-results');

            if (!noResults && grid) {
                noResults = document.createElement('div');
                noResults.id = 'formation-no-results';
                noResults.className = 'alert alert-secondary formation-no-results d-none';
                noResults.textContent = 'Aucune formation ne correspond a vos filtres.';
                grid.appendChild(noResults);
            }

            const parseDate = (dateValue) => {
                if (!dateValue) {
                    return null;
                }
                const parsed = new Date(dateValue + 'T00:00:00');
                return Number.isNaN(parsed.getTime()) ? null : parsed;
            };

            const applyClientFilters = () => {
                const query = (searchInput ? searchInput.value : '').trim().toLowerCase();
                const sort = sortSelect ? sortSelect.value : 'date_desc';
                const minRating = Math.max(0, parseFloat(minRatingSelect ? minRatingSelect.value : '0') || 0);
                const minReviews = Math.max(0, parseInt(minReviewsInput ? minReviewsInput.value : '0', 10) || 0);

                const visibleCards = [];
                cards.forEach((card) => {
                    const title = (card.dataset.title || '').toLowerCase();
                    const organisme = (card.dataset.organisme || '').toLowerCase();
                    const lieu = (card.dataset.lieu || '').toLowerCase();
                    const rating = parseFloat(card.dataset.rating || '0') || 0;
                    const reviews = parseInt(card.dataset.reviews || '0', 10) || 0;

                    const matchesQuery = query === '' || (title + ' ' + organisme + ' ' + lieu).includes(query);
                    const matchesMinReviews = reviews >= minReviews;
                    const matchesMinRating = minRating <= 0 || (reviews > 0 && rating >= minRating);

                    const isVisible = matchesQuery && matchesMinReviews && matchesMinRating;
                    card.classList.toggle('d-none', !isVisible);
                    if (isVisible) {
                        visibleCards.push(card);
                    }
                });

                visibleCards.sort((a, b) => {
                    const dateA = parseDate(a.dataset.dateDebut || '');
                    const dateB = parseDate(b.dataset.dateDebut || '');
                    const ratingA = parseFloat(a.dataset.rating || '0') || 0;
                    const ratingB = parseFloat(b.dataset.rating || '0') || 0;
                    const reviewsA = parseInt(a.dataset.reviews || '0', 10) || 0;
                    const reviewsB = parseInt(b.dataset.reviews || '0', 10) || 0;
                    const titleA = (a.dataset.title || '').toLowerCase();
                    const titleB = (b.dataset.title || '').toLowerCase();

                    if (sort === 'rating_desc') {
                        if (ratingB !== ratingA) {
                            return ratingB - ratingA;
                        }
                        return reviewsB - reviewsA;
                    }

                    if (sort === 'reviews_desc') {
                        if (reviewsB !== reviewsA) {
                            return reviewsB - reviewsA;
                        }
                        return ratingB - ratingA;
                    }

                    if (sort === 'title_asc') {
                        return titleA.localeCompare(titleB);
                    }

                    return (dateB?.getTime() || 0) - (dateA?.getTime() || 0);
                });

                if (grid) {
                    visibleCards.forEach((card) => grid.appendChild(card));
                    if (noResults) {
                        grid.appendChild(noResults);
                    }
                }

                if (noResults) {
                    noResults.classList.toggle('d-none', visibleCards.length > 0);
                }
            };

            if (searchInput) {
                searchInput.addEventListener('input', applyClientFilters);
                searchInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        applyClientFilters();
                    }
                });
            }

            [sortSelect, minRatingSelect, minReviewsInput].forEach((control) => {
                if (control) {
                    control.addEventListener('input', applyClientFilters);
                    control.addEventListener('change', applyClientFilters);
                }
            });

            const resetLink = filterForm.querySelector('a[title="Reinitialiser filtres"]');
            if (resetLink && searchInput && sortSelect && minRatingSelect && minReviewsInput) {
                resetLink.addEventListener('click', (event) => {
                    event.preventDefault();
                    searchInput.value = '';
                    sortSelect.value = 'date_desc';
                    minRatingSelect.value = '0';
                    minReviewsInput.value = '0';
                    applyClientFilters();
                });
            }

            applyClientFilters();

            // Card selection handler - load reviews via AJAX without page refresh
            if (grid) {
                grid.addEventListener('click', (event) => {
                    const clickInsideButton = event.target.closest('a, button, form, input, select, textarea');
                    if (clickInsideButton) {
                        return;
                    }

                    const card = event.target.closest('.formation-item');
                    if (!card) {
                        return;
                    }

                    const formationId = card.dataset.formationId;
                    if (!formationId) {
                        return;
                    }

                    console.log('Formation card clicked:', card.dataset.title);
                    
                    // Remove selection from all cards
                    document.querySelectorAll('.formation-item').forEach((item) => item.classList.remove('is-selected'));
                    card.classList.add('is-selected');

                    // Update URL without reload
                    const url = new URL(window.location.href);
                    url.searchParams.set('formation', formationId);
                    window.history.replaceState({}, '', url.toString());

                    // Fetch reviews data via AJAX
                    const reviewsUrl = '{{ path("app_inscription_employe_reviews", {id: 0}) }}'.replace('/0', '/' + formationId);
                    
                    fetch(reviewsUrl)
                        .then(response => response.json())
                        .then(data => {
                            const panelHeader = document.querySelector('.formation-sidepanel-header');
                            const panelBody = document.querySelector('.formation-sidepanel-body');

                            if (!panelHeader || !panelBody) return;

                            // Update header
                            panelHeader.innerHTML = '<div class="mini-muted">Formation selectionnee</div><div class="fw-bold">' + (data.formation.titre || 'Aucune selection') + '</div>';

                            // Build reviews HTML
                            let reviewsHTML = '<div class="mini-muted mb-2">' + (data.formation.organisme || '') + '</div>';
                            reviewsHTML += '<div class="mb-3">' + (data.formation.dateDebut || '') + ' - ' + (data.formation.dateFin || '') + '</div>';

                            if (data.reviews && data.reviews.length > 0) {
                                reviewsHTML += '<div class="stat-card p-3 mb-3">';
                                reviewsHTML += '<div class="mini-muted mb-2">Analyse des avis</div>';
                                reviewsHTML += '<div class="d-flex flex-wrap gap-2">';
                                reviewsHTML += '<span class="badge bg-green-lt text-green">Positifs: ' + (data.summary.positive || 0) + '</span>';
                                reviewsHTML += '<span class="badge bg-yellow-lt text-yellow">Mitigés: ' + (data.summary.neutral || 0) + '</span>';
                                reviewsHTML += '<span class="badge bg-red-lt text-red">Negatifs: ' + (data.summary.negative || 0) + '</span>';
                                if ((data.summary.problem || 0) > 0) {
                                    reviewsHTML += '<span class="badge bg-orange-lt text-orange">Problemes: ' + data.summary.problem + '</span>';
                                }
                                reviewsHTML += '</div></div>';

                                reviewsHTML += '<div class="d-flex flex-column gap-2">';
                                data.reviews.slice(0, 4).forEach((review) => {
                                    const labelClass = review.label === 'positive' ? 'bg-green-lt text-green' : (review.label === 'negative' ? 'bg-red-lt text-red' : 'bg-yellow-lt text-yellow');
                                    const labelText = review.label === 'positive' ? 'Positif' : (review.label === 'negative' ? 'Negatif' : 'Mitige');
                                    
                                    reviewsHTML += '<div class="stat-card p-2">';
                                    reviewsHTML += '<div class="d-flex justify-content-between align-items-start mb-1">';
                                    reviewsHTML += '<div class="fw-bold small">' + review.prenom + ' ' + review.nom + '</div>';
                                    reviewsHTML += '<span class="badge ' + labelClass + '">' + review.note + '/5</span>';
                                    reviewsHTML += '</div>';
                                    reviewsHTML += '<div class="small text-secondary">' + (review.commentaire || 'Aucun commentaire.') + '</div>';
                                    reviewsHTML += '<div class="mt-1">';
                                    reviewsHTML += '<span class="badge ' + labelClass + '">' + labelText + '</span>';
                                    if (review.problems && review.problems.length > 0) {
                                        reviewsHTML += '<span class="badge bg-red-lt text-red ms-1">Probleme detecte</span>';
                                    }
                                    reviewsHTML += '</div></div>';
                                });
                                reviewsHTML += '</div>';
                            } else {
                                reviewsHTML += '<div class="text-secondary">Aucun avis pour cette formation.</div>';
                            }

                            panelBody.innerHTML = reviewsHTML;
                        })
                        .catch(error => {
                            console.error('Error loading reviews:', error);
                            const panelBody = document.querySelector('.formation-sidepanel-body');
                            if (panelBody) {
                                panelBody.innerHTML = '<div class="alert alert-danger">Erreur lors du chargement des avis.</div>';
                            }
                        });
                });
            }
        })();
    </script>

    {% if employee_logged and selected_formation %}
        {% set selectedState = inscription_by_formation[selected_formation.id] ?? null %}
        <div class="surface-card">
            <div class="card-header">
                <h3 class="card-title">Demande d'inscription - {{ selected_formation.titre }}</h3>
            </div>
            <div class="card-body">
                {% if selectedState and selectedState.statut == 'EN_ATTENTE' %}
                    <div class="alert alert-warning mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span>Votre demande est en attente. Vous pouvez modifier la raison ou annuler.</span>
                        <form method="post" action="{{ path('app_inscription_employe') }}" class="ms-0 ms-md-3">
                            <input type="hidden" name="action" value="annuler">
                            <input type="hidden" name="inscription_id" value="{{ selectedState.id }}">
                            <button class="btn btn-outline-danger btn-sm" type="submit">Annuler</button>
                        </form>
                    </div>

                    <form method="post" action="{{ path('app_inscription_employe') }}" id="reason-form" data-analyze-url="{{ path('app_inscription_employe_analyze') }}" data-generate-url="{{ path('app_inscription_employe_generate') }}">
                        <input type="hidden" name="action" value="modifier_raison">
                        <input type="hidden" name="inscription_id" value="{{ selectedState.id }}">
                        <input type="hidden" name="formation_id" value="{{ selected_formation.id }}">

                        <div class="mb-3">
                            <label for="raison" class="form-label">Raison</label>
                            <textarea id="raison" name="raison" class="form-control" rows="5" placeholder="Expliquez pourquoi vous voulez suivre cette formation...">{{ selectedState.raison|default('') }}</textarea>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary" type="button" data-action="analyze">
                                <i class="ti ti-scan me-1"></i>
                                Corriger LanguageTool
                            </button>
                            <button class="btn btn-primary" type="button" data-action="generate">
                                <i class="ti ti-sparkles me-1"></i>
                                Generer avec IA
                            </button>
                            <button class="btn btn-success" type="submit">Modifier la demande</button>
                        </div>

                        <div id="assistant-notice" class="alert alert-info mt-3 mb-0 d-none"></div>
                    </form>

                    <div id="analysis-panel" class="d-none">
                        <div class="row g-3 mt-4">
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Langue detectee</div>
                                    <div id="analysis-language" class="h4 mb-0 text-capitalize"></div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Corrections LanguageTool</div>
                                    <div id="analysis-count" class="h4 mb-0"></div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Texte fourni</div>
                                    <div id="analysis-length" class="h4 mb-0"></div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-lg-6">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted mb-2">Version corrigee</div>
                                    <div id="analysis-corrected"></div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted mb-2">Version amelioree par l'IA</div>
                                    <div id="analysis-generated"></div>
                                </div>
                            </div>
                        </div>

                        <div id="analysis-messages" class="stat-card p-3 mt-3 d-none">
                            <div class="mini-muted mb-2">Détails des corrections</div>
                            <ul class="mb-0 ps-3" id="analysis-messages-list"></ul>
                        </div>
                    </div>

                    <script>
                        (function () {
                            const form = document.getElementById('reason-form');
                            if (!form) {
                                return;
                            }

                            const reasonField = document.getElementById('raison');
                            const noticeBox = document.getElementById('assistant-notice');
                            const analysisPanel = document.getElementById('analysis-panel');
                            const analysisLanguage = document.getElementById('analysis-language');
                            const analysisCount = document.getElementById('analysis-count');
                            const analysisLength = document.getElementById('analysis-length');
                            const analysisCorrected = document.getElementById('analysis-corrected');
                            const analysisGenerated = document.getElementById('analysis-generated');
                            const analysisMessages = document.getElementById('analysis-messages');
                            const analysisMessagesList = document.getElementById('analysis-messages-list');
                            const analyzeUrl = form.dataset.analyzeUrl;
                            const generateUrl = form.dataset.generateUrl;

                            const setNotice = (message, variant) => {
                                if (!noticeBox) {
                                    return;
                                }

                                noticeBox.classList.remove('d-none', 'alert-info', 'alert-danger');
                                noticeBox.classList.add(variant === 'error' ? 'alert-danger' : 'alert-info');
                                noticeBox.textContent = message;
                            };

                            const renderAnalysis = (payload, mode) => {
                                const analysis = payload.analysis || {};
                                const text = payload.text || '';

                                if (reasonField && text) {
                                    reasonField.value = text;
                                }

                                if (analysisPanel) {
                                    analysisPanel.classList.remove('d-none');
                                }

                                if (analysisLanguage) {
                                    analysisLanguage.textContent = analysis.language || '';
                                }

                                if (analysisCount) {
                                    analysisCount.textContent = Array.isArray(analysis.grammarMessages) ? String(analysis.grammarMessages.length) : '0';
                                }

                                if (analysisLength) {
                                    analysisLength.textContent = analysis.originalText ? String(analysis.originalText.length) : '0';
                                }

                                if (analysisCorrected) {
                                    analysisCorrected.textContent = analysis.correctedText || (mode === 'analyze' ? 'Aucune correction proposee.' : '');
                                }

                                if (analysisGenerated) {
                                    analysisGenerated.textContent = analysis.generatedText || (mode === 'generate' ? 'Aucune suggestion IA disponible.' : '');
                                }

                                if (analysisMessages && analysisMessagesList) {
                                    analysisMessagesList.innerHTML = '';

                                    if (Array.isArray(analysis.grammarMessages) && analysis.grammarMessages.length > 0) {
                                        analysisMessages.classList.remove('d-none');
                                        analysis.grammarMessages.forEach((message) => {
                                            const item = document.createElement('li');
                                            item.textContent = message;
                                            analysisMessagesList.appendChild(item);
                                        });
                                    } else {
                                        analysisMessages.classList.add('d-none');
                                    }
                                }

                                setNotice(payload.message || (mode === 'analyze' ? 'LanguageTool a propose une version corrigee.' : 'Hugging Face a genere un paragraphe complet.'), 'info');
                            };

                            const postAction = async (url, mode) => {
                                const formData = new FormData();
                                formData.append('formation_id', form.querySelector('input[name="formation_id"]').value || '');
                                formData.append('raison', reasonField ? reasonField.value : '');

                                const response = await fetch(url, {
                                    method: 'POST',
                                    body: formData,
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest',
                                        'Accept': 'application/json',
                                    },
                                });

                                const payload = await response.json().catch(() => null);
                                if (!response.ok || !payload || !payload.ok) {
                                    setNotice(payload && payload.message ? payload.message : 'Une erreur est survenue.', 'error');
                                    return;
                                }

                                renderAnalysis(payload, mode);
                            };

                            form.querySelectorAll('button[data-action]').forEach((button) => {
                                button.addEventListener('click', () => {
                                    const mode = button.dataset.action;
                                    const url = mode === 'analyze' ? analyzeUrl : generateUrl;

                                    if (!reasonField || reasonField.value.trim() === '') {
                                        setNotice('Veuillez saisir une raison avant de lancer l action.', 'error');
                                        if (reasonField) {
                                            reasonField.focus();
                                        }
                                        return;
                                    }

                                    setNotice(mode === 'analyze' ? 'Correction en cours...' : 'Generation en cours...', 'info');
                                    postAction(url, mode).catch(() => {
                                        setNotice('Impossible de contacter le service IA.', 'error');
                                    });
                                });
                            });
                        })();
                    </script>
