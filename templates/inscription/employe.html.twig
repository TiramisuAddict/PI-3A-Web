{% extends 'base.html.twig' %}

{% block title %}Inscription Employe{% endblock %}

{% block body %}
    <div class="app-hero position-relative p-4 p-md-5 mb-4">
        <div class="row align-items-center g-4 position-relative">
            <div class="col-lg-8">
                <div class="soft-pill mb-3"><i class="ti ti-user-share"></i> Espace Employe</div>
                <h2 class="display-6 mb-2">Inscription Formation</h2>
                <p class="mini-muted mb-0">Consultez les formations et envoyez votre raison d'inscription depuis une interface plus fluide.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                {% if employee_logged %}
                    <div class="stat-card p-3 d-inline-flex flex-column align-items-end">
                        <span class="mini-muted">Connecte en tant que</span>
                        <div class="fw-bold">{{ app.session.get('employee_name') }}</div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger" role="alert">{{ message }}</div>
    {% endfor %}

    <div class="surface-card mb-3">
        <div class="card-header">
            <h3 class="card-title">Identification employe</h3>
        </div>
        <div class="card-body">
            {% if not employee_logged %}
                <form method="post" action="{{ path('app_inscription_employe') }}">
                    <input type="hidden" name="action" value="login">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label" for="employee_id">Employe</label>
                            <select class="form-select" id="employee_id" name="employee_id" required>
                                <option value="">Choisir un employe</option>
                                {% for employee in employees %}
                                    <option value="{{ employee.id_employe }}">{{ employee.prenom }} {{ employee.nom }} ({{ employee.role }})</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-primary w-100" type="submit">Entrer</button>
                        </div>
                    </div>
                </form>
            {% else %}
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <span class="badge bg-green-lt">Employe #{{ app.session.get('employee_id') }}</span>
                        <span class="ms-2">{{ app.session.get('employee_name') }}</span>
                    </div>
                    <form method="post" action="{{ path('app_inscription_employe') }}">
                        <input type="hidden" name="action" value="logout">
                        <button class="btn btn-outline-secondary btn-sm" type="submit">Changer ID</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="surface-card mb-3">
        <div class="card-header">
            <h3 class="card-title">Formations disponibles</h3>
        </div>
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                <tr>
                    <th>Titre</th>
                    <th>Organisme</th>
                    <th>Date debut</th>
                    <th>Date fin</th>
                    <th>Lieu</th>
                    <th>Capacite</th>
                    <th class="w-1">Action</th>
                </tr>
                </thead>
                <tbody>
                {% for formation in formations %}
                    <tr>
                        {% set state = inscription_by_formation[formation.id] ?? null %}
                        <td>{{ formation.titre }}</td>
                        <td>{{ formation.organisme }}</td>
                        <td>{{ formation.dateDebut ? formation.dateDebut|date('Y-m-d') : '' }}</td>
                        <td>{{ formation.dateFin ? formation.dateFin|date('Y-m-d') : '' }}</td>
                        <td>{{ formation.lieu }}</td>
                        <td>{{ formation.capacite }}</td>
                        <td>
                            {% if employee_logged %}
                                {% if state and state.statut == 'EN_ATTENTE' %}
                                    <div class="d-flex flex-column gap-1 align-items-start">
                                        <span class="badge bg-orange text-white">En attente</span>
                                        <form method="post" action="{{ path('app_inscription_employe') }}">
                                            <input type="hidden" name="action" value="annuler">
                                            <input type="hidden" name="inscription_id" value="{{ state.id }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Annuler</button>
                                        </form>
                                    </div>
                                {% elseif state and state.statut == 'ACCEPTEE' %}
                                    <span class="badge bg-green text-white">Acceptee</span>
                                {% elseif state and state.statut == 'REFUSEE' %}
                                    <span class="badge bg-red text-white">Refusee</span>
                                {% else %}
                                    <a class="btn btn-sm btn-success" href="{{ path('app_inscription_employe', {'formation': formation.id}) }}">Inscription</a>
                                {% endif %}
                            {% else %}
                                <button class="btn btn-sm" disabled>Inscription</button>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="text-secondary">Aucune formation disponible.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if employee_logged and selected_formation %}
        {% set selectedState = inscription_by_formation[selected_formation.id] ?? null %}
        <div class="surface-card">
            <div class="card-header">
                <h3 class="card-title">Demande d'inscription - {{ selected_formation.titre }}</h3>
            </div>
            <div class="card-body">
                {% if selectedState and selectedState.statut == 'EN_ATTENTE' %}
                    <div class="alert alert-warning mb-0 d-flex justify-content-between align-items-center">
                        <span>Votre demande est en attente. Vous pouvez encore l'annuler.</span>
                        <form method="post" action="{{ path('app_inscription_employe') }}" class="ms-3">
                            <input type="hidden" name="action" value="annuler">
                            <input type="hidden" name="inscription_id" value="{{ selectedState.id }}">
                            <button class="btn btn-outline-danger btn-sm" type="submit">Annuler</button>
                        </form>
                    </div>
                {% elseif selectedState and selectedState.statut == 'ACCEPTEE' %}
                    <div class="alert alert-success mb-0">Cette inscription est acceptee.</div>
                {% elseif selectedState and selectedState.statut == 'REFUSEE' %}
                    <div class="alert alert-danger mb-0">Cette inscription est refusee.</div>
                {% else %}
                    <form method="post" action="{{ path('app_inscription_employe') }}" id="reason-form" data-analyze-url="{{ path('app_inscription_employe_analyze') }}" data-generate-url="{{ path('app_inscription_employe_generate') }}">
                        <input type="hidden" name="formation_id" value="{{ selected_formation.id }}">

                        <div class="mb-3">
                            <label for="raison" class="form-label">Raison</label>
                            <textarea id="raison" name="raison" class="form-control" rows="5" placeholder="Expliquez pourquoi vous voulez suivre cette formation...">{{ typed_reason|default('') }}</textarea>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-outline-primary" type="button" data-action="analyze">
                                <i class="ti ti-scan me-1"></i>
                                Corriger LanguageTool
                            </button>
                            <button class="btn btn-primary" type="button" data-action="generate">
                                <i class="ti ti-sparkles me-1"></i>
                                Generer avec IA
                            </button>
                            <button class="btn btn-success" type="submit" name="action" value="inscrire">
                                Envoyer la demande
                            </button>
                        </div>

                        <div id="assistant-notice" class="alert alert-info mt-3 mb-0 d-none"></div>
                    </form>

                    <div id="analysis-panel" class="d-none">
                        <div class="row g-3 mt-4">
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Langue detectee</div>
                                    <div id="analysis-language" class="h4 mb-0 text-capitalize"></div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Corrections LanguageTool</div>
                                    <div id="analysis-count" class="h4 mb-0"></div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted">Texte fourni</div>
                                    <div id="analysis-length" class="h4 mb-0"></div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mt-3">
                            <div class="col-lg-6">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted mb-2">Version corrigee</div>
                                    <div id="analysis-corrected"></div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="stat-card p-3 h-100">
                                    <div class="mini-muted mb-2">Version amelioree par l'IA</div>
                                    <div id="analysis-generated"></div>
                                </div>
                            </div>
                        </div>

                        <div id="analysis-messages" class="stat-card p-3 mt-3 d-none">
                            <div class="mini-muted mb-2">Détails des corrections</div>
                            <ul class="mb-0 ps-3" id="analysis-messages-list"></ul>
                        </div>
                    </div>

                    <script>
                        (function () {
                            const form = document.getElementById('reason-form');
                            if (!form) {
                                return;
                            }

                            const reasonField = document.getElementById('raison');
                            const noticeBox = document.getElementById('assistant-notice');
                            const analysisPanel = document.getElementById('analysis-panel');
                            const analysisLanguage = document.getElementById('analysis-language');
                            const analysisCount = document.getElementById('analysis-count');
                            const analysisLength = document.getElementById('analysis-length');
                            const analysisCorrected = document.getElementById('analysis-corrected');
                            const analysisGenerated = document.getElementById('analysis-generated');
                            const analysisMessages = document.getElementById('analysis-messages');
                            const analysisMessagesList = document.getElementById('analysis-messages-list');
                            const analyzeUrl = form.dataset.analyzeUrl;
                            const generateUrl = form.dataset.generateUrl;

                            const setNotice = (message, variant) => {
                                if (!noticeBox) {
                                    return;
                                }

                                noticeBox.classList.remove('d-none', 'alert-info', 'alert-danger');
                                noticeBox.classList.add(variant === 'error' ? 'alert-danger' : 'alert-info');
                                noticeBox.textContent = message;
                            };

                            const renderAnalysis = (payload, mode) => {
                                const analysis = payload.analysis || {};
                                const text = payload.text || '';

                                if (reasonField && text) {
                                    reasonField.value = text;
                                }

                                if (analysisPanel) {
                                    analysisPanel.classList.remove('d-none');
                                }

                                if (analysisLanguage) {
                                    analysisLanguage.textContent = analysis.language || '';
                                }

                                if (analysisCount) {
                                    analysisCount.textContent = Array.isArray(analysis.grammarMessages) ? String(analysis.grammarMessages.length) : '0';
                                }

                                if (analysisLength) {
                                    analysisLength.textContent = analysis.originalText ? String(analysis.originalText.length) : '0';
                                }

                                if (analysisCorrected) {
                                    analysisCorrected.textContent = analysis.correctedText || (mode === 'analyze' ? 'Aucune correction proposee.' : '');
                                }

                                if (analysisGenerated) {
                                    analysisGenerated.textContent = analysis.generatedText || (mode === 'generate' ? 'Aucune suggestion IA disponible.' : '');
                                }

                                if (analysisMessages && analysisMessagesList) {
                                    analysisMessagesList.innerHTML = '';

                                    if (Array.isArray(analysis.grammarMessages) && analysis.grammarMessages.length > 0) {
                                        analysisMessages.classList.remove('d-none');
                                        analysis.grammarMessages.forEach((message) => {
                                            const item = document.createElement('li');
                                            item.textContent = message;
                                            analysisMessagesList.appendChild(item);
                                        });
                                    } else {
                                        analysisMessages.classList.add('d-none');
                                    }
                                }

                                setNotice(payload.message || (mode === 'analyze' ? 'LanguageTool a propose une version corrigee.' : 'Hugging Face a genere un paragraphe complet.'), 'info');
                            };

                            const postAction = async (url, mode) => {
                                const formData = new FormData();
                                formData.append('formation_id', form.querySelector('input[name="formation_id"]').value || '');
                                formData.append('raison', reasonField ? reasonField.value : '');

                                const response = await fetch(url, {
                                    method: 'POST',
                                    body: formData,
                                    headers: {
                                        'X-Requested-With': 'XMLHttpRequest',
                                        'Accept': 'application/json',
                                    },
                                });

                                const payload = await response.json().catch(() => null);
                                if (!response.ok || !payload || !payload.ok) {
                                    setNotice(payload && payload.message ? payload.message : 'Une erreur est survenue.', 'error');
                                    return;
                                }

                                renderAnalysis(payload, mode);
                            };

                            form.querySelectorAll('button[data-action]').forEach((button) => {
                                button.addEventListener('click', () => {
                                    const mode = button.dataset.action;
                                    const url = mode === 'analyze' ? analyzeUrl : generateUrl;

                                    if (!reasonField || reasonField.value.trim() === '') {
                                        setNotice('Veuillez saisir une raison avant de lancer l action.', 'error');
                                        if (reasonField) {
                                            reasonField.focus();
                                        }
                                        return;
                                    }

                                    setNotice(mode === 'analyze' ? 'Correction en cours...' : 'Generation en cours...', 'info');
                                    postAction(url, mode).catch(() => {
                                        setNotice('Impossible de contacter le service IA.', 'error');
                                    });
                                });
                            });
                        })();
                    </script>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
