{% extends 'base.html.twig' %}

{% block title %}Tableau de bord admin{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="container-xl">
        <div class="page-header d-print-none">
            <div class="row align-items-center">
                <div class="col">
                    <h2 class="page-title">Tableau de bord</h2>
                    <p class="text-secondary small mb-0">Statistiques et gestion du backend. <a href="{{ path('app_employe_feed') }}">Voir le fil d'actualité</a></p>
                </div>
            </div>
        </div>
    </div>
    <div class="page-body">
        <div class="container-xl">
            <!-- Stats Cards -->
            <div class="row row-cards mb-4">
                <div class="col-sm-6 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-baseline">
                                <div>
                                    <div class="text-secondary small">Posts</div>
                                    <div class="h2 mb-0">{{ stats.posts }}</div>
                                </div>
                                <div class="ms-auto lh-1"><i class="ti ti-file-text text-blue" style="font-size: 2.5rem; opacity: 0.15;"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-baseline">
                                <div>
                                    <div class="text-secondary small">Commentaires</div>
                                    <div class="h2 mb-0">{{ stats.comments }}</div>
                                </div>
                                <div class="ms-auto lh-1"><i class="ti ti-message text-azure" style="font-size: 2.5rem; opacity: 0.15;"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-baseline">
                                <div>
                                    <div class="text-secondary small">Likes</div>
                                    <div class="h2 mb-0">{{ stats.likes }}</div>
                                </div>
                                <div class="ms-auto lh-1"><i class="ti ti-thumb-up text-pink" style="font-size: 2.5rem; opacity: 0.15;"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex align-items-baseline">
                                <div>
                                    <div class="text-secondary small">Participations</div>
                                    <div class="h2 mb-0">{{ stats.participations }}</div>
                                </div>
                                <div class="ms-auto lh-1"><i class="ti ti-users text-teal" style="font-size: 2.5rem; opacity: 0.15;"></i></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts -->
            <div class="row g-4 mb-4">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header pb-0">
                            <h4 class="card-title">Annonces vs Événements</h4>
                        </div>
                        <div class="card-body pt-2">
                            <div style="position: relative; height: 200px;">
                                <canvas id="chartPieTypes" aria-label="Répartition des types de posts"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header pb-0">
                            <h4 class="card-title">Engagement par publication</h4>
                        </div>
                        <div class="card-body pt-2">
                            <div style="position: relative; height: 200px;">
                                <canvas id="chartBarEngagement" aria-label="Engagement par publication"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-header pb-0">
                            <h4 class="card-title">Participations aux événements (par jour)</h4>
                        </div>
                        <div class="card-body pt-2">
                            <div style="position: relative; height: 220px;">
                                <canvas id="chartLineParticipation" aria-label="Participations par date"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Access -->
            <h3 class="my-4">Gestion</h3>
            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_post_index') }}" class="card" style="text-decoration: none; color: inherit;">
                        <div class="card-body">
                            <div class="d-flex align-items-start gap-3">
                                <div class="avatar avatar-lg" style="background-color: #4A5DEF; color: white; flex-shrink: 0;">
                                    <i class="ti ti-file-text"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Publications</h3>
                                    <p class="text-secondary small mb-0">Gestion des posts</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_commentaire_index') }}" class="card" style="text-decoration: none; color: inherit;">
                        <div class="card-body">
                            <div class="d-flex align-items-start gap-3">
                                <div class="avatar avatar-lg" style="background-color: #0e72ba; color: white; flex-shrink: 0;">
                                    <i class="ti ti-message"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Commentaires</h3>
                                    <p class="text-secondary small mb-0">Modération</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_participation_index') }}" class="card" style="text-decoration: none; color: inherit;">
                        <div class="card-body">
                            <div class="d-flex align-items-start gap-3">
                                <div class="avatar avatar-lg" style="background-color: #00a699; color: white; flex-shrink: 0;">
                                    <i class="ti ti-users"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Participations</h3>
                                    <p class="text-secondary small mb-0">Événements</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6 col-xl-3">
                    <a href="{{ path('app_notification_index') }}" class="card" style="text-decoration: none; color: inherit;">
                        <div class="card-body">
                            <div class="d-flex align-items-start gap-3">
                                <div class="avatar avatar-lg" style="background-color: #f59f00; color: white; flex-shrink: 0;">
                                    <i class="ti ti-bell"></i>
                                </div>
                                <div>
                                    <h3 class="card-title">Notifications</h3>
                                    <p class="text-secondary small mb-0">Messages</p>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
    (function () {
        var pieAnnonces = {{ pieAnnonces|default(0) }};
        var pieEvenements = {{ pieEvenements|default(0) }};
        var pieEl = document.getElementById('chartPieTypes');
        if (pieEl && typeof Chart !== 'undefined') {
            new Chart(pieEl, {
                type: 'pie',
                data: {
                    labels: ['Annonces (type 1)', 'Événements (type 2)'],
                    datasets: [{ data: [pieAnnonces, pieEvenements], backgroundColor: ['#206bc4', '#f59f00'], borderWidth: 1 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        }

        var barLabels = [{% for label in chartEngagementLabels|default([]) %}"{{ label|e('js') }}"{% if not loop.last %},{% endif %}{% endfor %}];
        var barValues = [{% for value in chartEngagementValues|default([]) %}{{ value }}{% if not loop.last %},{% endif %}{% endfor %}];
        var barEl = document.getElementById('chartBarEngagement');
        if (barEl && typeof Chart !== 'undefined') {
            new Chart(barEl, {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{ label: 'Likes + commentaires', data: barValues, backgroundColor: 'rgba(32, 107, 196, 0.65)', borderColor: '#206bc4', borderWidth: 1 }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } }, x: { ticks: { maxRotation: 45, minRotation: 0 } } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        var lineLabels = [{% for label in chartParticipationLabels|default([]) %}"{{ label|e('js') }}"{% if not loop.last %},{% endif %}{% endfor %}];
        var lineValues = [{% for value in chartParticipationValues|default([]) %}{{ value }}{% if not loop.last %},{% endif %}{% endfor %}  ];
        var lineEl = document.getElementById('chartLineParticipation');
        if (lineEl && typeof Chart !== 'undefined') {
            new Chart(lineEl, {
                type: 'line',
                data: {
                    labels: lineLabels,
                    datasets: [{
                        label: 'Participations (événements)',
                        data: lineValues,
                        fill: true,
                        tension: 0.25,
                        borderColor: '#2fb344',
                        backgroundColor: 'rgba(47, 179, 68, 0.15)',
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                    plugins: { legend: { display: true } }
                }
            });
        }
    })();
    </script>
{% endblock %}