{% extends 'base.html.twig' %}

{% block title %}Tableau de bord admin{% endblock %}

{% block body %}
<div class="surface-card p-4 mb-4">
    <h1 class="mb-1">Tableau de bord</h1>
    <p class="text-secondary mb-0">Statistiques et accès rapide au back-office. <a href="{{ path('app_employe_feed') }}">Front office — Fil d’actualité</a></p>
</div>

<div class="row row-cards mb-4">
    <div class="col-sm-6 col-lg-4 col-xl-2">
        <div class="card card-sm border shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto"><span class="bg-blue text-white avatar"><i class="ti ti-file-text"></i></span></div>
                    <div class="col">
                        <div class="font-weight-medium">Posts</div>
                        <div class="h2 mb-0">{{ stats.posts }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-2">
        <div class="card card-sm border shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto"><span class="bg-azure text-white avatar"><i class="ti ti-message"></i></span></div>
                    <div class="col">
                        <div class="font-weight-medium">Commentaires</div>
                        <div class="h2 mb-0">{{ stats.comments }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-2">
        <div class="card card-sm border shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto"><span class="bg-pink text-white avatar"><i class="ti ti-thumb-up"></i></span></div>
                    <div class="col">
                        <div class="font-weight-medium">Likes</div>
                        <div class="h2 mb-0">{{ stats.likes }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-2">
        <div class="card card-sm border shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto"><span class="bg-teal text-white avatar"><i class="ti ti-users"></i></span></div>
                    <div class="col">
                        <div class="font-weight-medium">Participations</div>
                        <div class="h2 mb-0">{{ stats.participations }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4 col-xl-2">
        <div class="card card-sm border shadow-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto"><span class="bg-yellow text-white avatar"><i class="ti ti-bell"></i></span></div>
                    <div class="col">
                        <div class="font-weight-medium">Notifications</div>
                        <div class="h2 mb-0">{{ stats.notifications }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card border shadow-sm h-100">
            <div class="card-header"><h3 class="card-title mb-0">Annonces vs événements</h3></div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 260px;">
                <canvas id="chartPieTypes" width="280" height="260" aria-label="Répartition des types de posts"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border shadow-sm h-100">
            <div class="card-header"><h3 class="card-title mb-0">Engagement par post (likes + commentaires)</h3></div>
            <div class="card-body" style="min-height: 280px;">
                <canvas id="chartBarEngagement" height="240" aria-label="Engagement par publication"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card border shadow-sm">
            <div class="card-header"><h3 class="card-title mb-0">Participations aux événements (par jour)</h3></div>
            <div class="card-body" style="min-height: 280px;">
                <canvas id="chartLineParticipation" height="260" aria-label="Participations par date"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_post_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-blue-lt text-blue"><i class="ti ti-file-text fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Gestion des posts</h2><span class="text-secondary small">CRUD publications</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_commentaire_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-azure-lt text-azure"><i class="ti ti-message fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Commentaires</h2><span class="text-secondary small">Modération</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_participation_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-teal-lt text-teal"><i class="ti ti-users fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Participations</h2><span class="text-secondary small">Événements</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_notification_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-yellow-lt text-yellow"><i class="ti ti-bell fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Notifications</h2><span class="text-secondary small">Messages</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_event_image_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-purple-lt text-purple"><i class="ti ti-photo fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Images événement</h2><span class="text-secondary small">Galerie</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="{{ path('app_like_post_index') }}" class="text-decoration-none text-reset d-block h-100">
            <div class="card h-100 border shadow-sm admin-dash-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="avatar avatar-lg bg-pink-lt text-pink"><i class="ti ti-thumb-up fs-2"></i></span>
                        <div><h2 class="h5 mb-0">Likes</h2><span class="text-secondary small">Lecture seule</span></div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script>
    (function () {
        var pieAnnonces = {{ pieAnnonces|default(0) }};
        var pieEvenements = {{ pieEvenements|default(0) }};
        var pieEl = document.getElementById('chartPieTypes');
        if (pieEl && typeof Chart !== 'undefined') {
            new Chart(pieEl, {
                type: 'pie',
                data: {
                    labels: ['Annonces (type 1)', 'Événements (type 2)'],
                    datasets: [{ data: [pieAnnonces, pieEvenements], backgroundColor: ['#206bc4', '#f59f00'], borderWidth: 1 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        }

        var barLabels = {{ chartEngagementLabels|default([])|json_encode|raw }};
        var barValues = {{ chartEngagementValues|default([])|json_encode|raw }};
        var barEl = document.getElementById('chartBarEngagement');
        if (barEl && typeof Chart !== 'undefined') {
            new Chart(barEl, {
                type: 'bar',
                data: {
                    labels: barLabels,
                    datasets: [{ label: 'Likes + commentaires', data: barValues, backgroundColor: 'rgba(32, 107, 196, 0.65)', borderColor: '#206bc4', borderWidth: 1 }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } }, x: { ticks: { maxRotation: 45, minRotation: 0 } } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        var lineLabels = {{ chartParticipationLabels|default([])|json_encode|raw }};
        var lineValues = {{ chartParticipationValues|default([])|json_encode|raw }};
        var lineEl = document.getElementById('chartLineParticipation');
        if (lineEl && typeof Chart !== 'undefined') {
            new Chart(lineEl, {
                type: 'line',
                data: {
                    labels: lineLabels,
                    datasets: [{
                        label: 'Participations (événements)',
                        data: lineValues,
                        fill: true,
                        tension: 0.25,
                        borderColor: '#2fb344',
                        backgroundColor: 'rgba(47, 179, 68, 0.15)',
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                    plugins: { legend: { display: true } }
                }
            });
        }
    })();
    </script>
{% endblock %}
