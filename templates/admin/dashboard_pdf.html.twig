<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport gestion des posts</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            color: #1f2937;
            font-size: 12px;
            line-height: 1.5;
            margin: 24px;
        }
        .header {
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #dbe4ff;
        }
        .title {
            font-size: 24px;
            font-weight: bold;
            color: #243b7a;
            margin: 0 0 6px;
        }
        .subtitle {
            color: #6b7280;
            margin: 0;
        }
        .stats {
            width: 100%;
            border-collapse: collapse;
            margin: 18px 0 24px;
        }
        .stats td {
            width: 25%;
            padding: 12px;
            border: 1px solid #e5e7eb;
            vertical-align: top;
        }
        .stat-label {
            color: #6b7280;
            font-size: 11px;
            margin-bottom: 4px;
        }
        .stat-value {
            font-size: 22px;
            font-weight: bold;
            color: #111827;
        }
        .section {
            margin-bottom: 24px;
            padding: 16px;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
        }
        .section-title {
            font-size: 16px;
            font-weight: bold;
            margin: 0 0 8px;
            color: #1d4ed8;
        }
        .section-text {
            margin: 0 0 14px;
            color: #4b5563;
        }
        .bar-row {
            margin-bottom: 10px;
        }
        .bar-head {
            font-size: 11px;
            margin-bottom: 4px;
        }
        .bar-track {
            width: 100%;
            height: 10px;
            background: #edf2ff;
            border-radius: 999px;
            overflow: hidden;
        }
        .bar-fill {
            height: 10px;
            background: #4a5def;
            border-radius: 999px;
        }
        .bar-fill.alt {
            background: #f59f00;
        }
        .bar-fill.green {
            background: #2fb344;
        }
        table.data-table {
            width: 100%;
            border-collapse: collapse;
        }
        .data-table th,
        .data-table td {
            border: 1px solid #e5e7eb;
            padding: 8px 10px;
            text-align: left;
            font-size: 11px;
        }
        .data-table th {
            background: #f8fafc;
        }
        .muted {
            color: #6b7280;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="title">Rapport PDF - Gestion des posts</h1>
        <p class="subtitle">Genere le {{ generated_at|date('d/m/Y') }} a {{ generated_at|date('H:i') }} a partir du tableau de bord administrateur.</p>
    </div>

    <p class="section-text">{{ descriptions.overview }}</p>

    <table class="stats">
        <tr>
            <td>
                <div class="stat-label">Posts</div>
                <div class="stat-value">{{ stats.posts }}</div>
            </td>
            <td>
                <div class="stat-label">Commentaires</div>
                <div class="stat-value">{{ stats.comments }}</div>
            </td>
            <td>
                <div class="stat-label">Likes</div>
                <div class="stat-value">{{ stats.likes }}</div>
            </td>
            <td>
                <div class="stat-label">Participations</div>
                <div class="stat-value">{{ stats.participations }}</div>
            </td>
        </tr>
    </table>

    {% set pie_total = (pieAnnonces + pieEvenements) > 0 ? (pieAnnonces + pieEvenements) : 1 %}
    {% set annonces_width = ((pieAnnonces / pie_total) * 100)|round(0, 'floor') %}
    {% set evenements_width = ((pieEvenements / pie_total) * 100)|round(0, 'floor') %}

    <div class="section">
        <h2 class="section-title">Repartition des types de posts</h2>
        <p class="section-text">{{ descriptions.pie }}</p>
        <div class="bar-row">
            <div class="bar-head">Annonces: {{ pieAnnonces }}</div>
            <div class="bar-track"><div class="bar-fill" style="width: {{ annonces_width }}%;"></div></div>
        </div>
        <div class="bar-row">
            <div class="bar-head">Evenements: {{ pieEvenements }}</div>
            <div class="bar-track"><div class="bar-fill alt" style="width: {{ evenements_width }}%;"></div></div>
        </div>
    </div>

    <div class="section">
        <h2 class="section-title">Engagement par publication</h2>
        <p class="section-text">{{ descriptions.engagement }}</p>
        {% if engagement_rows is not empty %}
            {% set max_engagement = engagement_rows[0].engagement > 0 ? engagement_rows[0].engagement : 1 %}
            {% for row in engagement_rows|slice(0, 6) %}
                {% set width = ((row.engagement / max_engagement) * 100)|round(0, 'floor') %}
                <div class="bar-row">
                    <div class="bar-head">{{ row.titre }} <span class="muted">({{ row.engagement }} interactions)</span></div>
                    <div class="bar-track"><div class="bar-fill" style="width: {{ width }}%;"></div></div>
                </div>
            {% endfor %}

            <table class="data-table" style="margin-top: 14px;">
                <thead>
                    <tr>
                        <th>Publication</th>
                        <th>Commentaires</th>
                        <th>Likes</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in engagement_rows|slice(0, 8) %}
                        <tr>
                            <td>{{ row.titre }}</td>
                            <td>{{ row.comments }}</td>
                            <td>{{ row.likes }}</td>
                            <td>{{ row.engagement }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p class="muted">Aucune donnee d engagement disponible.</p>
        {% endif %}
    </div>

    <div class="section">
        <h2 class="section-title">Participations aux evenements par jour</h2>
        <p class="section-text">{{ descriptions.participation }}</p>
        {% if participation_rows is not empty %}
            {% set max_participation = 1 %}
            {% for row in participation_rows %}
                {% if row.count > max_participation %}
                    {% set max_participation = row.count %}
                {% endif %}
            {% endfor %}

            {% for row in participation_rows|slice(-10, 10) %}
                {% set width = ((row.count / max_participation) * 100)|round(0, 'floor') %}
                <div class="bar-row">
                    <div class="bar-head">{{ row.day }} <span class="muted">({{ row.count }} participations)</span></div>
                    <div class="bar-track"><div class="bar-fill green" style="width: {{ width }}%;"></div></div>
                </div>
            {% endfor %}
        {% else %}
            <p class="muted">Aucune participation recente a afficher.</p>
        {% endif %}
    </div>
</body>
</html>
