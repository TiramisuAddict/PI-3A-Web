<div id="google-phone-modal" style="display:none; position:fixed; inset:0; background:rgba(17, 24, 39, 0.45); z-index:1200; align-items:center; justify-content:center; padding:1rem;">
    <div style="width:100%; max-width:520px; background:#fff; border-radius:16px; box-shadow:0 25px 60px rgba(15,23,42,0.35); overflow:hidden;">
        <div style="padding:1rem 1.25rem; border-bottom:1px solid #e5e7eb; display:flex; align-items:center; justify-content:space-between; gap:1rem;">
            <div>
                <div style="font-weight:700; color:#111827;">Completer le numero de telephone</div>
                <div style="font-size:0.85rem; color:#6b7280;">Finaliser la connexion Google</div>
            </div>
            <a href="{{ path('login') }}" class="btn btn-sm btn-outline-secondary">Annuler</a>
        </div>

        <div style="padding:1rem 1.25rem 1.25rem 1.25rem;">
            <div class="mb-3 p-2 rounded" style="background:#f5f7ff; color:#4254D6;">
                Compte Google: {{ google_email }}
            </div>

            {{ include('components/controleSaisieAlert.html.twig', { form: google_phone_form }) }}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger" role="alert">{{ message }}</div>
            {% endfor %}

            {{ form_start(google_phone_form, { attr: { novalidate: 'novalidate' } }) }}
                <div class="mb-3">
                    {{ form_widget(google_phone_form.telephone, { attr: { class: 'form-control', placeholder: 'Telephone' } }) }}
                </div>
                <div>
                    {{ form_widget(google_phone_form.save, { attr: { class: 'btn w-100 fw-bold text-white', style: 'background:#4254D6; border:none; letter-spacing:0.5px;' } }) }}
                </div>
            {{ form_end(google_phone_form) }}
        </div>
    </div>
</div>

<script>
(() => {
    const modal = document.getElementById('google-phone-modal');
    if (!modal) {
        return;
    }
    modal.style.display = 'flex';
})();
</script>
