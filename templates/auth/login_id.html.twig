{% extends 'base.html.twig' %}

{% block title %}Connexion employe{% endblock %}

{% block body %}
    <div class="workspace-card p-4" style="max-width: 520px;">
        <div class="mb-3">
            <h2 class="mb-1">Connexion par ID employe</h2>
            <div class="workspace-subtle">Session temporaire pour appliquer les regles de role.</div>
        </div>

        {% if currentEmploye %}
            <div class="alert alert-info" role="alert">
                Session active: <strong>{{ currentEmploye.nom }} {{ currentEmploye.prenom }}</strong> (ID {{ currentEmploye.idEmploye }}, role {{ currentEmploye.role|default('-') }}).
            </div>
        {% endif %}

        {% if errorMessage %}
            <div class="alert alert-danger" role="alert">{{ errorMessage }}</div>
        {% endif %}

        <form method="post" class="workspace-form" novalidate>
            <label for="employee_id" class="form-label">ID employe</label>
            <input type="number" min="1" step="1" class="form-control" id="employee_id" name="employee_id" placeholder="Ex: 12" required>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Se connecter</button>
                <a href="{{ path('app_projet_index') }}" class="btn btn-outline-secondary">Aller aux projets</a>
            </div>
        </form>
    </div>
{% endblock %}
