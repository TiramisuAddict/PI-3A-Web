{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:#f0f0f8;">
  <div style="width:70%; max-width:80vw; min-height:500px; border-radius:18px; overflow:hidden; display:flex; box-shadow:0 8px 40px rgba(0,0,0,0.15);">

    {# ── Colonne gauche : formulaire ── #}
    <div style="flex:1; background:#fff; display:flex; align-items:center; justify-content:center; padding:3rem;">
      <div style="width:100%; max-width:350px;">

        <div class="mb-4 text-center">
          <img src="/images/WKlogo.svg" style="width:350px; max-width:100%; height:auto;" alt="Logo">
        </div>

        <div class="text-muted  mb-4 text-secondary">Accédez à votre espace entreprise</div>

        {# Erreurs flash (uniquement sur login, pas pendant OTP) #}
        {% if two_factor_form is not defined %}
          {% for message in app.flashes('error') %}
            <div class="alert alert-danger" role="alert">
              <div class="d-flex gap-2">
                <div>
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    class="icon alert-icon">
                    <path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"/>
                    <path d="M12 8v4"/>
                    <path d="M12 16h.01"/>
                  </svg>
                </div>
                <div>
                  <h4 class="alert-heading">Erreur d'authentification</h4>
                  <div class="alert-description">{{ message }}</div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

          {# Email #}
          <div class="mb-3">
            {{ form_widget(form.email, {
              'attr': {
                'class': 'form-control ',
                'placeholder': 'Email'
              }
            }) }}
            {{ form_errors(form.email) }}
          </div>

          {# Mot de passe #}
          <div class="mb-3">
            <div class="input-group input-group-flat">
              {{ form_widget(form.password, {
                'attr': {
                  'class': 'form-control ',
                  'placeholder': 'Mot de passe',
                  'id': 'password-input'
                }
              }) }}
            </div>
            {{ form_errors(form.password) }}
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <a href="{{ path('face_verify_page') }}" class="small fw-semibold" style="color:#4254D6;">Se connecter avec Face ID</a>
            <a href="{{ path('forgot_password') }}" class="small" style="color:#4254D6;">Mot de passe oublié ?</a>
          </div>

          {# Bouton connexion #}
          <div class="mb-3">
            {{ form_widget(form.se_connecter, {
              'attr': {
                'class': 'btn w-100  fw-bold text-white',
                'style': 'background:#4254D6; border:none; letter-spacing:1px;'
              }
            }) }}
          </div>

          <div class="d-grid mb-3">
            <a href="{{ path('oauth_google_start') }}" class="btn btn-outline-secondary w-100 d-inline-flex align-items-center justify-content-center gap-2">
              <img src="/images/google.png" alt="Google" width="18" height="18">
              <span>Continuer avec Google</span>
            </a>
          </div>

          {# Lien inscription entreprise #}
          <div class="text-center small text-muted">
            Vous n'avez pas un compte entreprise ?
            <a href="{{ path('compteEntreprise') }}" class="fw-bold ms-1" style="color:#4254D6;">
              Inscrivez-vous
            </a>
          </div>
          <div class="text-center small text-muted mt-1">
          <p>ou</p></div>
          <div class="text-center small text-muted">
            Vous souhaitez postule ?
            <a href="{{ path('compte_visiteur') }}" class="fw-bold ms-1" style="color:#4254D6;">
              Avoir un compte candidat
            </a>
          </div>

        {{ form_end(form) }}
      </div>
    </div>

    {# ── Colonne droite : image + dégradé ── #}
    <div style="flex:1.2; position:relative; overflow:hidden; display:flex; flex-direction:column; justify-content:flex-end; padding:3rem;">

      {# Image de fond #}
      <img src="/images/building1.jpg" alt=""
        style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0;">

      {# Dégradé #}
      <div style="position:absolute; inset:0; background:linear-gradient(135deg, rgba(66,84,214,0.88) 0%, rgba(100,130,255,0.88) 100%); z-index:1;"></div>

      {# Texte #}
      <div style="position:relative; z-index:3;" class="text-white">
        <h2 class="display-6 fw-bold mb-3">Welcome to <strong>Momentum</strong></h2>
        <p style="color:rgba(255,255,255,0.6);">
          Gérez vos équipes, suivez vos projets et collaborez efficacement depuis une seule plateforme.
        </p>
      </div>

    </div>

  </div>
</div>

<script>
function togglePassword() {
  var input = document.getElementById('password-input');
  input.type = input.type === 'password' ? 'text' : 'password';
}
</script>

{% if two_factor_form is defined %}
  {{ include('2FA/two_factor.html.twig', {
    otp_form: two_factor_form,
    destination: two_factor_destination|default(''),
    otp_close_url: otp_close_url|default(path('login', {'cancel_2fa': 1})),
    otp_resend_route: otp_resend_route|default('two_factor_resend'),
    otp_resend_csrf_id: otp_resend_csrf_id|default('two_factor_resend'),
    otp_resend_remaining_seconds: otp_resend_remaining_seconds|default(two_factor_resend_remaining_seconds|default(30))
  }) }}
{% endif %}

{% if forgot_password_form is defined %}
  {{ include('forgot_password/forgot_password_component.html.twig', {
    forgot_password_form: forgot_password_form
  }) }}
{% endif %}

{% if reset_password_form is defined %}
  {{ include('forgot_password/reset_password_component.html.twig', {
    reset_password_form: reset_password_form
  }) }}
{% endif %}

{% endblock %}