<div class="modal fade show" id="resetPasswordModal" tabindex="-1" style="display:block;">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header mt-2">
        <div>
          <h2 class="h2 modal-title">Nouveau mot de passe</h2>
          <small class="text-muted">Saisissez et confirmez votre nouveau mot de passe.</small>
        </div>
        <a href="{{ path('login') }}" class="btn-close" aria-label="Fermer"></a>
      </div>

      <div class="modal-body p-4">
        {% for message in app.flashes('error') %}
          <div class="alert alert-danger" role="alert">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('success') %}
          <div class="alert alert-success" role="alert">{{ message }}</div>
        {% endfor %}

        {{ form_start(reset_password_form, {'action': path('forgot_password_new'), 'attr': {'novalidate': 'novalidate'}}) }}
          <div class="mb-3">
            {{ form_widget(reset_password_form.password, {'attr': {'class': 'form-control', 'placeholder': 'Nouveau mot de passe'}}) }}
            {{ form_errors(reset_password_form.password) }}
          </div>

          <div class="mb-3">
            {{ form_widget(reset_password_form.confirm_password, {'attr': {'class': 'form-control', 'placeholder': 'Confirmer le mot de passe'}}) }}
            {{ form_errors(reset_password_form.confirm_password) }}
          </div>

          <div class="d-grid">
            {{ form_widget(reset_password_form.save, {'attr': {'class': 'btn text-white', 'style': 'background:#4A5DEF; border:none;'}}) }}
          </div>
        {{ form_end(reset_password_form) }}
      </div>
    </div>
  </div>
</div>
<div class="modal-backdrop fade show"></div>
