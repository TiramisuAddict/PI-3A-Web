{% extends 'base.html.twig' %}

{% block title %}Image #{{ event_image.id_image }}{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <h1 class="mb-4">Image événement #{{ event_image.id_image }}</h1>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <tbody>
                        <tr><th class="w-25">id_image</th><td>{{ event_image.id_image }}</td></tr>
                        <tr><th>image_path</th><td class="text-break"><code>{{ event_image.image_path }}</code></td></tr>
                        <tr><th>ordre</th><td>{{ event_image.ordre }}</td></tr>
                        <tr><th>post (id_post)</th><td>{% if event_image.post %}{{ event_image.post.id_post }}{% else %}—{% endif %}</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-4">
        <a class="btn btn-primary" href="{{ path('app_event_image_index') }}"><i class="ti ti-list me-1"></i>Retour</a>
        <a class="btn btn-warning" href="{{ path('app_event_image_edit', { id_image: event_image.id_image }) }}"><i class="ti ti-edit me-1"></i>Modifier</a>
        {{ include('event_image/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
