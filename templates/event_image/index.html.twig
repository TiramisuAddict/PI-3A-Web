{% extends 'base.html.twig' %}

{% block title %}Images événement{% endblock %}

{% block body %}
<div class="surface-card p-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <h1 class="mb-0">Images événement</h1>
        <a class="btn btn-primary" href="{{ path('app_event_image_new') }}"><i class="ti ti-plus me-1"></i>Créer</a>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>id_image</th>
                    <th>image_path</th>
                    <th>ordre</th>
                    <th>post</th>
                    <th class="text-nowrap">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for event_image in event_images %}
                <tr>
                    <td>{{ event_image.id_image }}</td>
                    <td class="text-break"><code>{{ event_image.image_path }}</code></td>
                    <td>{{ event_image.ordre }}</td>
                    <td>{% if event_image.post %}#{{ event_image.post.id_post }}{% endif %}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-primary" href="{{ path('app_event_image_show', { id_image: event_image.id_image }) }}"><i class="ti ti-eye"></i></a>
                        <a class="btn btn-sm btn-warning" href="{{ path('app_event_image_edit', { id_image: event_image.id_image }) }}"><i class="ti ti-edit"></i></a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="5" class="text-center text-secondary py-4">Aucun enregistrement</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
