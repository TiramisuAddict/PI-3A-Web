<div class="surface-card p-4">
    <h1 class="mb-4">Modifier l'image</h1>
    <div class="card shadow-sm">
        <div class="card-body p-4">
            {{ include('event_image/_form.html.twig', { cancel_path: path('app_event_image_index'), submit_label: 'Mettre à jour' }) }}
