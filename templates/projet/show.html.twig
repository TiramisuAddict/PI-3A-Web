{% extends 'base.html.twig' %}

{% block title %}Projet{% endblock %}

{% block body %}
    <h1>Projet</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ projet.idProjet }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ projet.nom }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ projet.description }}</td>
            </tr>
            <tr>
                <th>Date debut</th>
                <td>{{ projet.dateDebut ? projet.dateDebut|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Date fin prevue</th>
                <td>{{ projet.dateFinPrevue ? projet.dateFinPrevue|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Date fin reelle</th>
                <td>{{ projet.dateFinReelle ? projet.dateFinReelle|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ projet.statut }}</td>
            </tr>
            <tr>
                <th>Priorite</th>
                <td>{{ projet.priorite }}</td>
            </tr>
            <tr>
                <th>Responsable</th>
                <td>
                    {% if projet.responsable %}
                        {{ projet.responsable.nom }} {{ projet.responsable.prenom }}
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Membres equipe</th>
                <td>
                    {% for employe in projet.membresEquipe %}
                        {{ employe.nom }} {{ employe.prenom }}{% if not loop.last %}, {% endif %}
                    {% else %}
                        Aucun membre
                    {% endfor %}
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_projet_index') }}">back to list</a>

    <a href="{{ path('app_projet_edit', {'id_projet': projet.idProjet}) }}">edit</a>

    {{ include('projet/_delete_form.html.twig') }}
{% endblock %}
