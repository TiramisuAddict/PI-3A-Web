{% extends 'base.html.twig' %}

{% block title %}Projets{% endblock %}

{% block body %}
    {% set total = projets|length %}
    {% set enCours = 0 %}
    {% set termines = 0 %}
    {% set prioritaires = 0 %}
    {% for projet in projets %}
        {% if projet.statut == 'EN_COURS' %}{% set enCours = enCours + 1 %}{% endif %}
        {% if projet.statut == 'TERMINE' %}{% set termines = termines + 1 %}{% endif %}
        {% if projet.priorite == 'HAUTE' %}{% set prioritaires = prioritaires + 1 %}{% endif %}
    {% endfor %}

    <div class="page-wrapper">
        <div class="page-header d-print-none">
            <div class="container-xl">
                <div class="row g-2 align-items-center">
                    <div class="col">
                        <h2 class="page-title">Projets</h2>
                        <div class="text-secondary mt-1">Suivi des projets, responsables et equipe.</div>
                    </div>
                    <div class="col-auto ms-auto d-print-none">
                        <a href="{{ path('app_projet_new') }}" class="btn btn-primary">
                            <i class="ti ti-plus me-1"></i>
                            Nouveau projet
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="page-body">
            <div class="container-xl">
                <div class="row row-deck row-cards mb-3">
                    <div class="col-sm-6 col-lg-3">
                        <div class="card card-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <span class="bg-primary text-white avatar me-3"><i class="ti ti-folders"></i></span>
                                    <div>
                                        <div class="h1 mb-0">{{ total }}</div>
                                        <div class="text-secondary">Total projets</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card card-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <span class="bg-azure text-white avatar me-3"><i class="ti ti-progress"></i></span>
                                    <div>
                                        <div class="h1 mb-0">{{ enCours }}</div>
                                        <div class="text-secondary">En cours</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card card-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <span class="bg-green text-white avatar me-3"><i class="ti ti-check"></i></span>
                                    <div>
                                        <div class="h1 mb-0">{{ termines }}</div>
                                        <div class="text-secondary">Termines</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card card-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <span class="bg-red text-white avatar me-3"><i class="ti ti-alert-triangle"></i></span>
                                    <div>
                                        <div class="h1 mb-0">{{ prioritaires }}</div>
                                        <div class="text-secondary">Priorite haute</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Projet</th>
                                    <th>Responsable</th>
                                    <th>Statut</th>
                                    <th>Priorite</th>
                                    <th>Debut</th>
                                    <th>Fin prevue</th>
                                    <th class="w-1"></th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for projet in projets %}
                                <tr>
                                    <td>
                                        <div class="fw-semibold">{{ projet.nom }}</div>
                                        <div class="text-secondary text-truncate" style="max-width: 340px;">{{ projet.description }}</div>
                                    </td>
                                    <td>
                                        {% if projet.responsable %}
                                            {{ projet.responsable.nom }} {{ projet.responsable.prenom }}
                                        {% else %}
                                            <span class="text-secondary">Non defini</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% set statutColor = 'secondary' %}
                                        {% if projet.statut == 'EN_COURS' %}{% set statutColor = 'azure' %}{% endif %}
                                        {% if projet.statut == 'TERMINE' %}{% set statutColor = 'green' %}{% endif %}
                                        {% if projet.statut == 'ANNULE' %}{% set statutColor = 'red' %}{% endif %}
                                        <span class="badge bg-{{ statutColor }}-lt">{{ projet.statut }}</span>
                                    </td>
                                    <td>
                                        {% set prioriteColor = 'secondary' %}
                                        {% if projet.priorite == 'HAUTE' %}{% set prioriteColor = 'red' %}{% endif %}
                                        {% if projet.priorite == 'MOYENNE' %}{% set prioriteColor = 'orange' %}{% endif %}
                                        {% if projet.priorite == 'BASSE' %}{% set prioriteColor = 'green' %}{% endif %}
                                        <span class="badge bg-{{ prioriteColor }}-lt">{{ projet.priorite is empty ? 'AUCUNE' : projet.priorite }}</span>
                                    </td>
                                    <td>{{ projet.dateDebut ? projet.dateDebut|date('d/m/Y') : '-' }}</td>
                                    <td>{{ projet.dateFinPrevue ? projet.dateFinPrevue|date('d/m/Y') : '-' }}</td>
                                    <td>
                                        <div class="btn-list flex-nowrap">
                                            <a href="{{ path('app_projet_show', {'id_projet': projet.idProjet}) }}" class="btn btn-sm">Voir</a>
                                            <a href="{{ path('app_projet_edit', {'id_projet': projet.idProjet}) }}" class="btn btn-sm btn-primary-lt">Modifier</a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="7" class="text-center text-secondary py-4">Aucun projet pour le moment.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
